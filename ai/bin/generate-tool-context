#!/usr/bin/env bash
# Regenerates generated files and README sections from source registries and config.
#
# Writes:
#   ai/guidelines/rules/tools.generated.md  — tool context for AI sessions
#   README.md sections                      — scripts table, tasks block, AI installs
#
# Run automatically via pre-push hook and otto-workbench sync.
# Never edit generated content directly — edit the source files instead.
#
# Registry discovery:
#   Uses collect_registries() to auto-discover all */registry.yml and /*/*/registry.yml
#   files, plus brew stacks (brew/*/*.registry.yml) and consumer env files (*.env.yml).
#   Adding a new registry requires only creating the file — no edits here.
#
# Each registry file must contain a `meta` block:
#   meta:
#     section:       "Section Title"   # H2 heading in generated output
#     install_check: false             # if true, omit tools not found in PATH
#     validation:    brewfile          # brewfile | bindir | zsh-comments | none
#     source:        brew/Brewfile     # relative path used by validate-registries
#
# Environment overrides (for tests):
#   REGISTRY_SCAN_DIR    root directory for registry discovery (default: REPO_ROOT)
#   BREW_STACKS_DIR      brew/ directory (scanned for *.registry.yml stacks)
#   TOOL_CONTEXT_OUTPUT  tools.generated.md path
#   README_PATH          README.md path
#   TASKFILE_PATH        Taskfile.global.yml path
#   AI_DIR               ai/ directory

set -euo pipefail

_SELF="$(readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
REPO_ROOT="$(cd "$(dirname "$_SELF")/../.." && pwd)"

# shellcheck source=../lib/ui.sh
. "$REPO_ROOT/lib/ui.sh"
# shellcheck source=../lib/registries.sh
. "$REPO_ROOT/lib/registries.sh"

BREW_STACKS_DIR="${BREW_STACKS_DIR:-"$REPO_ROOT/brew"}"
BREW_REGISTRY="${BREW_REGISTRY:-"$REPO_ROOT/brew/registry.yml"}"
MISE_REGISTRY="${MISE_REGISTRY:-"$REPO_ROOT/mise/registry.yml"}"
BIN_REGISTRY="${BIN_REGISTRY:-"$REPO_ROOT/bin/registry.yml"}"
OUTPUT="${TOOL_CONTEXT_OUTPUT:-"$REPO_ROOT/$TOOLS_GENERATED_RELPATH"}"
WORKFLOW_OUTPUT="${TOOL_WORKFLOW_OUTPUT:-"$REPO_ROOT/$TOOLS_WORKFLOW_GENERATED_RELPATH"}"
ENV_LOCAL_TEMPLATE_PATH="${ENV_LOCAL_TEMPLATE_PATH:-"$REPO_ROOT/zsh/.env.local.template"}"
README_PATH="${README_PATH:-"$REPO_ROOT/README.md"}"
TASKFILE_PATH="${TASKFILE_PATH:-"$REPO_ROOT/Taskfile.global.yml"}"
AI_DIR="${AI_DIR:-"$REPO_ROOT/ai"}"
COMPONENTS_FILE="${COMPONENTS_FILE:-"$REPO_ROOT/install.components"}"
CONTRIBUTING_PATH="${CONTRIBUTING_PATH:-"$REPO_ROOT/CONTRIBUTING.md"}"
DOCS_DIR="${DOCS_DIR:-"$REPO_ROOT/docs"}"
TOOLS_DOC_PATH="${TOOLS_DOC_PATH:-"$DOCS_DIR/tools.md"}"
AI_DOC_PATH="${AI_DOC_PATH:-"$DOCS_DIR/ai-automation.md"}"
COMPONENTS_DOC_PATH="${COMPONENTS_DOC_PATH:-"$DOCS_DIR/components.md"}"

usage() {
  cat <<EOF
Usage: $(basename "$0") [--quiet]

Regenerate tools.generated.md and README sections from source registries.

Options:
  --quiet     Suppress per-file success messages
  -h, --help  Show this help
EOF
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }
QUIET=false
[[ "${1:-}" == "--quiet" ]] && QUIET=true

if ! command -v yq >/dev/null 2>&1; then
  err "yq not found — run: brew install yq"
  exit 1
fi

# ── Helpers ───────────────────────────────────────────────────────────────────

# _join SEP ITEMS... — joins items with SEP
_join() {
  local sep=$1; shift
  local result="" item
  for item in "$@"; do
    [[ -n "$result" ]] && result+="$sep"
    result+="$item"
  done
  printf '%s' "$result"
}

# _splice_readme README MARKER [--shell]
# Reads new section content from stdin and replaces the region between
# <!-- MARKER-START --> and <!-- MARKER-END --> in README. No-ops if absent.
# With --shell, uses shell-comment markers: # --- MARKER-START ---
_splice_readme() {
  local readme="$1" marker="$2" fmt="html"
  shift 2
  [[ "${1:-}" == "--shell" ]] && fmt="shell"
  if [[ ! -f "$readme" ]]; then cat > /dev/null; return 0; fi
  local start_marker end_marker
  if [[ "$fmt" == "shell" ]]; then
    start_marker="# --- ${marker}-START ---"
    end_marker="# --- ${marker}-END ---"
  else
    start_marker="<!-- ${marker}-START -->"
    end_marker="<!-- ${marker}-END -->"
  fi
  local tmp_content tmp_out
  tmp_content=$(mktemp)
  tmp_out=$(mktemp)
  # shellcheck disable=SC2064
  trap "rm -f '$tmp_content' '$tmp_out'" RETURN
  cat > "$tmp_content"
  awk -v tf="$tmp_content" \
      -v s="$start_marker" \
      -v e="$end_marker" '
    $0 == s { print; while ((getline line < tf) > 0) print line; skip=1; next }
    $0 == e { skip=0 }
    !skip   { print }
  ' "$readme" > "$tmp_out" && mv "$tmp_out" "$readme"
}

# _splice_inline FILE MARKER
# Replaces inline content between <!-- MARKER-START -->...<!-- MARKER-END --> on
# the same line. Reads replacement text from stdin (must be a single line).
_splice_inline() {
  local file="$1" marker="$2"
  if [[ ! -f "$file" ]]; then cat > /dev/null; return 0; fi
  local start_marker="<!-- ${marker}-START -->"
  local end_marker="<!-- ${marker}-END -->"
  local replacement
  replacement=$(cat)
  local tmp_out
  tmp_out=$(mktemp)
  # shellcheck disable=SC2064
  trap "rm -f '$tmp_out'" RETURN
  awk -v s="$start_marker" -v e="$end_marker" -v r="$replacement" '
    {
      idx_s = index($0, s)
      if (idx_s > 0) {
        idx_e = index($0, e)
        if (idx_e > 0) {
          printf "%s%s%s%s%s\n", substr($0, 1, idx_s - 1 + length(s)), r, e, substr($0, idx_e + length(e)), ""
          next
        }
      }
      print
    }
  ' "$file" > "$tmp_out" && mv "$tmp_out" "$file"
}

# _iter_tools FILE CALLBACK [FILTER]
# Calls CALLBACK name description when_to_use usage docs for each tool in FILE.
# If FILTER is provided (a function name), skips tools for which FILTER NAME fails.
_iter_tools() {
  local file="$1" cb="$2" filter="${3:-}"
  [[ -f "$file" ]] || return 0
  local count i
  count=$(yq '.tools | length' "$file")
  for (( i=0; i<count; i++ )); do
    local name
    name=$(yq ".tools[$i].name" "$file")
    if [[ -n "$filter" ]] && ! "$filter" "$name"; then continue; fi
    "$cb" \
      "$name" \
      "$(yq ".tools[$i].description"   "$file")" \
      "$(yq ".tools[$i].when_to_use"   "$file")" \
      "$(yq ".tools[$i].usage // \"\""  "$file")" \
      "$(yq ".tools[$i].docs  // \"\""  "$file")"
  done
}

# ── tools.generated.md ────────────────────────────────────────────────────────

_tool_md_entry() {
  local name="$1" description="$2" when_to_use="$3" usage="$4" docs="$5"
  printf '\n### %s\n' "$name"
  printf '%s\n' "$description"
  printf -- '- **When to use**: %s\n' "$when_to_use"
  # shellcheck disable=SC2016  # backticks are markdown literals, not shell substitution
  if [[ -n "$usage" && "$usage" != "null" ]]; then printf -- '- **Usage**: `%s`\n' "$usage"; fi
  if [[ -n "$docs"  && "$docs"  != "null" ]]; then printf -- '- **Docs**: %s\n'   "$docs";  fi
}

# _render_registry FILE
# Reads meta.section and meta.install_check from FILE, then renders all matching
# tools as a markdown section. Skips the section entirely if no tools pass the filter.
_render_registry() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  local count
  count=$(yq '.tools | length' "$file")
  [[ "$count" -gt 0 ]] || return 0

  local section install_check filter=""
  section=$(yq '.meta.section // "Tools"' "$file")
  install_check=$(yq '.meta.install_check // false' "$file")
  [[ "$install_check" == "true" ]] && filter="is_installed"

  # Accumulate tool entries first; skip the section header if nothing renders
  local content
  content=$( _iter_tools "$file" _tool_md_entry "$filter" )
  [[ -n "$content" ]] || return 0

  printf '\n## %s\n' "$section"
  printf '%s\n' "$content"
}

_tool_registries=()
collect_registries _tool_registries "${REGISTRY_SCAN_DIR:-$REPO_ROOT}" "$BREW_STACKS_DIR"

# _is_always_loaded FILE — returns 0 if registry meta.loading is "always".
_is_always_loaded() { [[ "$(yq '.meta.loading // "scoped"' "$1")" == "always" ]]; }

# Split registries into always-loaded (workflow) and path-scoped sets.
_workflow_registries=()
_scoped_registries=()
for _reg in "${_tool_registries[@]}"; do
  if _is_always_loaded "$_reg"; then
    _workflow_registries+=("$_reg")
  else
    _scoped_registries+=("$_reg")
  fi
done

# Always-loaded file — no frontmatter, available in every Claude session.
{
  printf '# Workflow Tools\n'
  printf '<!-- AUTO-GENERATED — do not edit directly -->\n'
  printf '<!-- Regenerate: ai/bin/generate-tool-context -->\n'
  for _reg in "${_workflow_registries[@]}"; do
    _render_registry "$_reg"
  done
} > "$WORKFLOW_OUTPUT"
$QUIET || success "Generated $(basename "$WORKFLOW_OUTPUT")"

# Path-scoped file — loads only when editing Brewfile, registry, bin, Taskfile, or zsh files.
{
  printf -- '---\n'
  printf 'paths:\n'
  printf '  - "**/Brewfile"\n'
  printf '  - "**/Brewfile.*"\n'
  printf '  - "**/registry.yml"\n'
  printf '  - "**/*.registry.yml"\n'
  printf '  - "**/bin/*"\n'
  printf '  - "**/Taskfile*.yml"\n'
  printf '  - "**/zsh/**"\n'
  printf -- '---\n\n'
  printf '# Environment Tools\n'
  printf '<!-- AUTO-GENERATED — do not edit directly -->\n'
  printf '<!-- Regenerate: ai/bin/generate-tool-context -->\n'
  for _reg in "${_scoped_registries[@]}"; do
    _render_registry "$_reg"
  done
} > "$OUTPUT"
$QUIET || success "Generated $(basename "$OUTPUT")"

# ── .env.local.template env section ───────────────────────────────────────────

# _env_entry_plain — callback for iter_registry_env; emits plain-text env template lines.
_env_entry_plain() {
  local var="$1" comment="$2" default_val="$3" setup_url="$4" prefix="$5"

  if [[ -n "$comment" && "$comment" != "null" ]]; then
    local comment_line="# $comment"
    if [[ -n "$setup_url" && "$setup_url" != "null" ]]; then
      comment_line+=" — $setup_url"
    fi
    printf '%s\n' "$comment_line"
  fi

  local export_line="# export ${var}="
  if [[ -n "$prefix" && "$prefix" != "null" ]]; then
    export_line+="${prefix}"
  elif [[ -n "$default_val" && "$default_val" != "null" ]]; then
    export_line+="${default_val}"
  fi
  printf '%s\n\n' "$export_line"
}

# _auth_entry_plain — callback for iter_registry_auth; emits plain-text auth template lines.
_auth_entry_plain() {
  local name="$1" env_var="$2" setup_url="$3" prefix="$4"

  local comment="# ${name}"
  if [[ -n "$setup_url" && "$setup_url" != "null" ]]; then
    comment+=" — create key at ${setup_url}"
  fi

  local export_line="# export ${env_var}="
  if [[ -n "$prefix" && "$prefix" != "null" ]]; then
    export_line+="${prefix}"
  fi

  printf '%s\n%s\n\n' "$comment" "$export_line"
}

# _render_registry_env FILE — renders env + auth entries for a single registry.
# Outputs a section header and entries, or nothing if no entries pass filters.
_render_registry_env() {
  local file="$1"
  [[ -f "$file" ]] || return 0

  registry_passes_install_check "$file" || return 0

  local entries=""
  local env_entries auth_entries
  env_entries=$(iter_registry_env "$file" _env_entry_plain)
  auth_entries=$(iter_registry_auth "$file" _auth_entry_plain)
  [[ -n "$env_entries" ]] && entries+="$env_entries"$'\n'
  [[ -n "$auth_entries" ]] && entries+="$auth_entries"$'\n'
  [[ -n "$entries" ]] || return 0

  local section
  section=$(yq '.meta.section // "Tools"' "$file")
  printf '# ── %s %s\n\n' "$section" "$(printf '─%.0s' $(seq 1 $(( 72 - ${#section} ))))"
  printf '%s' "$entries"
}

_generate_env_section() {
  local output=""

  local -a unique_registries=()
  collect_registries unique_registries "${REGISTRY_SCAN_DIR:-$REPO_ROOT}" "$BREW_STACKS_DIR"

  local section_output first=true
  for registry in "${unique_registries[@]}"; do
    section_output=$(_render_registry_env "$registry")
    if [[ -n "$section_output" ]]; then
      $first || output+=$'\n'
      first=false
      output+="$section_output"$'\n'
    fi
  done

  if [[ -n "$output" ]]; then printf '%s' "$output"; fi
}

if [[ -f "$ENV_LOCAL_TEMPLATE_PATH" ]]; then
  _generate_env_section | _splice_readme "$ENV_LOCAL_TEMPLATE_PATH" "ENV" --shell
  $QUIET || success "Updated .env.local.template env section"
fi

# ── README sections ───────────────────────────────────────────────────────────

# shellcheck disable=SC2016  # backticks are markdown literals, not shell substitution
_tool_readme_row() { printf '| `%s` | %s |\n' "$1" "$2"; }

_readme_scripts() {
  printf '| Script | Description |\n'
  printf '|--------|-------------|\n'
  local -a _script_registries=()
  collect_registries _script_registries "${REGISTRY_SCAN_DIR:-$REPO_ROOT}" "$BREW_STACKS_DIR"
  for _reg in "${_script_registries[@]}"; do
    local _val
    _val=$(yq '.meta.validation // ""' "$_reg")
    if [[ "$_val" == "bindir" ]]; then
      _iter_tools "$_reg" _tool_readme_row
    fi
  done
}

_readme_tasks() {
  local count i key desc
  printf '```bash\n'
  count=$(yq '.tasks | to_entries | length' "$TASKFILE_PATH")
  for (( i=0; i<count; i++ )); do
    key=$(yq ".tasks | to_entries[$i].key" "$TASKFILE_PATH")
    desc=$(yq ".tasks | to_entries[$i].value.desc // \"\"" "$TASKFILE_PATH")
    # Exclude utility/infrastructure tasks; only surface user-facing AI tasks
    [[ "$key" == brew:* || "$key" == "help" ]] && continue
    [[ -z "$desc" || "$desc" == "null" ]] && continue
    printf 'task --global %-20s # %s\n' "$key" "$desc"
  done
  printf '```\n'
}

# _extract_frontmatter_field FILE FIELD — reads a YAML frontmatter field from a markdown file.
_extract_frontmatter_field() {
  local file="$1" field="$2"
  sed -n '/^---$/,/^---$/p' "$file" 2>/dev/null \
    | grep "^${field}:" \
    | sed "s/^${field}:[[:space:]]*//" \
    | sed 's/^"\(.*\)"$/\1/' \
    | head -1
}

_readme_ai_installs() {
  # Derive display paths from constants, replacing $HOME prefix with ~
  local claude_home="~${CLAUDE_DIR#"$HOME"}"
  local claude_rules="~${CLAUDE_RULES_DIR#"$HOME"}"
  # Source dirs within the repo
  local claude_skills_src="$AI_DIR/claude/skills"
  local claude_agents_src="$AI_DIR/claude/agents"
  local claude_mcps_src="$AI_DIR/claude/mcps"

  printf '**Claude Code:**\n'
  # shellcheck disable=SC2016  # backticks are markdown literals, not shell substitution
  printf -- '- `%s/settings.json` — permissions and deny rules (merged, not overwritten)\n' "$claude_home"
  # shellcheck disable=SC2016
  printf -- '- `%s/CLAUDE.md` — coding guidelines\n' "$claude_home"
  # shellcheck disable=SC2016
  printf -- '- `%s/` — language and tool-specific rules (symlinked)\n' "$claude_rules"

  # Skills table with descriptions from SKILL.md frontmatter
  local has_skills=false
  for d in "$claude_skills_src"/*/; do
    [[ -d "$d" ]] || continue
    if [[ "$has_skills" == false ]]; then
      printf '\n**Skills:**\n\n'
      printf '| Skill | Description |\n'
      printf '|-------|-------------|\n'
      has_skills=true
    fi
    local skill_name skill_desc
    skill_name="$(basename "$d")"
    skill_desc="$(_extract_frontmatter_field "$d/SKILL.md" "description")"
    [[ -z "$skill_desc" ]] && skill_desc="—"
    printf '| %s | %s |\n' "$skill_name" "$skill_desc"
  done

  # Agents table with descriptions from agent .md frontmatter
  local has_agents=false
  for f in "$claude_agents_src"/*.md; do
    [[ -f "$f" ]] || continue
    if [[ "$has_agents" == false ]]; then
      printf '\n**Agents:**\n\n'
      printf '| Agent | Description |\n'
      printf '|-------|-------------|\n'
      has_agents=true
    fi
    local agent_name agent_desc
    agent_name="$(basename "${f%.md}")"
    agent_desc="$(_extract_frontmatter_field "$f" "description")"
    [[ -z "$agent_desc" ]] && agent_desc="—"
    printf '| %s | %s |\n' "$agent_name" "$agent_desc"
  done

  # MCPs
  local mcps=()
  for f in "$claude_mcps_src"/*.json; do
    [[ -f "$f" ]] && mcps+=("$(jq -r '.name // ""' "$f")")
  done
  if [[ ${#mcps[@]} -gt 0 ]]; then
    printf '\n**MCP Servers:** %s\n' "$(_join ', ' "${mcps[@]}")"
  fi

}

# _tool_readme_table_row NAME DESCRIPTION WHEN_TO_USE USAGE DOCS
# Renders a single row for the README tools table. Name links to docs if available.
_tool_readme_table_row() {
  local name="$1" description="$2" docs="$5"
  local display_name
  if [[ -n "$docs" && "$docs" != "null" ]]; then
    display_name="[${name}](${docs})"
  else
    display_name="$name"
  fi
  printf '| %s | %s |\n' "$display_name" "$description"
}

# _render_readme_registry FILE — renders a single registry as a tools table section.
# Skips the section if no tools are present. Does NOT filter by install_check
# because the README is reference documentation, not runtime context.
_render_readme_registry() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  local count
  count=$(yq '.tools | length' "$file")
  [[ "$count" -gt 0 ]] || return 0

  local section
  section=$(yq '.meta.section // "Tools"' "$file")

  local content
  content=$(_iter_tools "$file" _tool_readme_table_row)
  [[ -n "$content" ]] || return 0

  printf '\n**%s**\n\n' "$section"
  printf '| Tool | Description |\n'
  printf '|------|-------------|\n'
  printf '%s\n' "$content"
}

_readme_tools_table() {
  # Same registry order as tools.generated.md, but skip bin and zsh (they have their own sections)
  _render_readme_registry "$BREW_REGISTRY"
  _render_readme_registry "$MISE_REGISTRY"
  while IFS= read -r -d '' registry; do
    _render_readme_registry "$registry"
  done < <(find "$BREW_STACKS_DIR" -mindepth 2 -maxdepth 2 -name '*.registry.yml' -print0 | sort -z)
}

# _readme_component_menu — comma-separated list of optional component labels from install.components.
_readme_component_menu() {
  [[ -f "$COMPONENTS_FILE" ]] || return 0
  local labels=() component conf label
  while IFS= read -r component; do
    [[ -z "$component" || "$component" =~ ^# ]] && continue
    conf="$REPO_ROOT/$component/setup.conf"
    [[ -f "$conf" ]] || continue
    label=$(conf_get "$conf" label)
    [[ -n "$label" ]] && labels+=("$label")
  done < "$COMPONENTS_FILE"
  _join ', ' "${labels[@]}"
}

# _readme_after_install — numbered post-install steps from setup.conf post_install fields.
_readme_after_install() {
  [[ -f "$COMPONENTS_FILE" ]] || return 0
  local step_num=1
  # shellcheck disable=SC2016  # backticks are markdown literals, not shell substitution
  printf '%d. **Reload your shell**: `exec zsh`\n' "$step_num"
  step_num=$(( step_num + 1 ))

  local component conf note
  while IFS= read -r component; do
    [[ -z "$component" || "$component" =~ ^# ]] && continue
    conf="$REPO_ROOT/$component/setup.conf"
    [[ -f "$conf" ]] || continue
    note=$(conf_get "$conf" post_install) || true
    [[ -n "$note" ]] || continue
    printf '%d. %s\n' "$step_num" "$note"
    step_num=$(( step_num + 1 ))
  done < "$COMPONENTS_FILE"
}

# _readme_core_components — discovers core components (steps.sh without setup.conf).
_readme_core_components() {
  local names=()
  for steps in "$REPO_ROOT"/*/steps.sh; do
    [[ -f "$steps" ]] || continue
    local dir
    dir=$(dirname "$steps")
    # Core = has steps.sh but no setup.conf (not an optional component)
    [[ -f "$dir/setup.conf" ]] && continue
    names+=("\`$(basename "$dir")\`")
  done
  printf '**Existing core components:** %s\n' "$(_join ', ' "${names[@]}")"
}

# _readme_optional_components — lists optional components from install.components with sync info.
_readme_optional_components() {
  [[ -f "$COMPONENTS_FILE" ]] || return 0
  local entries=() component label sync_note
  while IFS= read -r component; do
    [[ -z "$component" || "$component" =~ ^# ]] && continue
    local conf="$REPO_ROOT/$component/setup.conf"
    [[ -f "$conf" ]] || continue
    label=$(conf_get "$conf" label)
    [[ -n "$label" ]] || label="$component"
    if [[ -f "$REPO_ROOT/$component/steps.sh" ]]; then
      sync_note="has sync"
    else
      sync_note="no sync"
    fi
    entries+=("\`$component\` ($sync_note)")
  done < "$COMPONENTS_FILE"
  printf '**Existing optional components:** %s\n' "$(_join ', ' "${entries[@]}")"
}

# _readme_workbench_commands — renders otto-workbench subcommands table + detail paragraphs
# from the `commands` array on the otto-workbench entry in bin/registry.yml.
_readme_workbench_commands() {
  [[ -f "$BIN_REGISTRY" ]] || return 0
  local count
  count=$(yq '.tools[] | select(.name == "otto-workbench") | .commands | length' "$BIN_REGISTRY" 2>/dev/null)
  [[ "$count" -gt 0 ]] || return 0

  # Command table with optional detail column
  printf '| Command | Scope | Description |\n'
  printf '|---------|-------|-------------|\n'
  local i
  for (( i=0; i<count; i++ )); do
    local cmd scope when detail desc
    cmd=$(yq ".tools[] | select(.name == \"otto-workbench\") | .commands[$i].name" "$BIN_REGISTRY")
    scope=$(yq ".tools[] | select(.name == \"otto-workbench\") | .commands[$i].scope" "$BIN_REGISTRY")
    when=$(yq ".tools[] | select(.name == \"otto-workbench\") | .commands[$i].when" "$BIN_REGISTRY")
    detail=$(yq ".tools[] | select(.name == \"otto-workbench\") | .commands[$i].detail // \"\"" "$BIN_REGISTRY")
    if [[ -n "$detail" && "$detail" != "null" ]]; then
      desc="$detail"
    else
      desc="$when"
    fi
    # shellcheck disable=SC2016  # backticks are markdown literals
    printf '| `otto-workbench %s` | %s | %s |\n' "$cmd" "$scope" "$desc"
  done
}

_gen_success() { $QUIET || success "$*"; }

# README splices (landing page content stays in README)
if [[ -f "$BIN_REGISTRY" ]];    then _readme_workbench_commands | _splice_readme "$README_PATH" "WORKBENCH-COMMANDS"; _gen_success "Updated README workbench commands"; fi
if [[ -f "$COMPONENTS_FILE" ]]; then _readme_component_menu | _splice_inline "$README_PATH" "COMPONENT-MENU";   _gen_success "Updated README component menu";   fi
