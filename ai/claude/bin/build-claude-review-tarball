#!/usr/bin/env bash
# Package claude-review into a self-contained tarball for Homebrew distribution.
#
# Usage: build-claude-review-tarball [VERSION]
#
# If VERSION is omitted, reads from .github/.release-please-manifest.json.
#
# Produces: claude-review-<version>.tar.gz in the current directory.
# The tarball contains a claude-review-<version>/ directory with:
#   bin/          — all executable scripts (dynamically discovered)
#   lib/          — bash modules, Python modules, review-templates/, ui.sh facade
#   agents/       — agent definitions
#   VERSION       — version string
#
# All contents are discovered dynamically via globs — adding a new script,
# module, template, or agent requires no changes to this build script.

set -euo pipefail
shopt -s nullglob

_SELF="$(readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$_SELF")" && pwd)"
WORKBENCH_ROOT="$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel)"
_CLAUDE_DIR="$(dirname "$SCRIPT_DIR")"

# ─── Constants ────────────────────────────────────────────────────────────

MANIFEST_KEY="ai/claude"

# Bash modules from lib/ that claude-review needs at runtime.
# The full ui.sh sources the entire workbench framework; the tarball facade
# sources only these. claude-review does not use constants.sh.
BASH_MODULES=(output.sh prompts.sh)

# Files excluded from bin/ discovery (this script + support files)
BIN_EXCLUDE="build-claude-review-tarball|_version.py"

# Minimum expected file counts — catches silent glob failures
MIN_BIN_SCRIPTS=5
MIN_PYTHON_MODULES=5
MIN_REVIEW_TEMPLATES=4
MIN_AGENTS=1

# ─── Version ─────────────────────────────────────────────────────────────

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  echo "Usage: build-claude-review-tarball [VERSION]"
  echo "Package claude-review into a self-contained tarball."
  echo "If VERSION is omitted, reads from .release-please-manifest.json."
  exit 0
fi

VERSION="${1:-}"
if [[ -z "$VERSION" ]]; then
  MANIFEST="$WORKBENCH_ROOT/.github/.release-please-manifest.json"
  if [[ ! -f "$MANIFEST" ]]; then
    echo "ERROR: No version argument and $MANIFEST not found" >&2
    exit 1
  fi
  VERSION=$(jq -r ".\"${MANIFEST_KEY}\"" "$MANIFEST")
  if [[ -z "$VERSION" || "$VERSION" == "null" ]]; then
    echo "ERROR: Could not read version from $MANIFEST" >&2
    exit 1
  fi
fi

echo "Building claude-review tarball v${VERSION}"

# ─── Staging ──────────────────────────────────────────────────────────────

STAGING="$(mktemp -d)"
trap 'rm -rf "$STAGING"' EXIT

DEST="$STAGING/claude-review-${VERSION}"
mkdir -p "$DEST/bin" "$DEST/lib/review-templates" "$DEST/agents"

# ─── Copy files ───────────────────────────────────────────────────────────

# Binaries — all executable scripts, excluding build tooling and support files
bin_count=0
for bin in "$SCRIPT_DIR"/*; do
  [[ -f "$bin" && -x "$bin" ]] || continue
  name="$(basename "$bin")"
  echo "$name" | grep -qE "^($BIN_EXCLUDE)$" && continue
  cp "$bin" "$DEST/bin/"
  bin_count=$((bin_count + 1))
done
if (( bin_count < MIN_BIN_SCRIPTS )); then
  echo "ERROR: found $bin_count bin scripts, expected >= $MIN_BIN_SCRIPTS" >&2
  exit 1
fi

# Library files — all Python modules
for py in "$_CLAUDE_DIR/lib/"*.py; do
  cp "$py" "$DEST/lib/"
done

# Library files — bash modules required by claude-review
for sh in "${BASH_MODULES[@]}"; do
  cp "$WORKBENCH_ROOT/lib/$sh" "$DEST/lib/"
done

# Templates — all .md files in the templates directory
for tpl in "$_CLAUDE_DIR/lib/review-templates/"*.md; do
  cp "$tpl" "$DEST/lib/review-templates/"
done

# Agents — all .md files in the agents directory
for agent in "$_CLAUDE_DIR/agents/"*.md; do
  cp "$agent" "$DEST/agents/"
done

# Version file
echo "$VERSION" > "$DEST/VERSION"

# ─── Create standalone ui.sh facade ──────────────────────────────────────
# The monorepo's lib/ui.sh sources the full workbench framework. This facade
# sources only the modules copied above.

{
  echo '#!/usr/bin/env bash'
  # Constants that claude-review references (subset of lib/constants.sh)
  # shellcheck disable=SC2016
  echo 'CLAUDE_DIR="$HOME/.claude"'
  # shellcheck disable=SC2016
  echo 'WORKBENCH_STATE_DIR="$HOME/.config/workbench"'
  # shellcheck disable=SC2016
  echo '_ui_lib_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"'
  for sh in "$DEST/lib/"*.sh; do
    name="$(basename "$sh")"
    [[ "$name" == "ui.sh" ]] && continue
    echo ". \"\$_ui_lib_dir/$name\""
  done
  echo 'unset _ui_lib_dir'
} > "$DEST/lib/ui.sh"

# ─── Patch claude-review for standalone layout ────────────────────────────
# Patches are anchored to @tarball-patch sentinel comments in claude-review.
# This is robust against whitespace/expression changes in the source.
#
# In the monorepo, claude-review uses git rev-parse to find the repo root.
# In the standalone tarball there's no git repo, so we use dirname chains
# to resolve paths relative to the script's location.

REVIEW="$DEST/bin/claude-review"

# shellcheck source=/dev/null
source "$WORKBENCH_ROOT/lib/output.sh"

# Patch ui-source: replace git rev-parse with dirname chain
# shellcheck disable=SC2016
sed_i '/@tarball-patch: ui-source/c\
. "$(dirname "$(cd "$(dirname "$_SELF")" && pwd)")/lib/ui.sh"  # @tarball-patch: ui-source' "$REVIEW"

# Patch workbench-root: replace git rev-parse with dirname chain
# shellcheck disable=SC2016
sed_i '/@tarball-patch: workbench-root/c\
_WORKBENCH_ROOT="$(dirname "$(cd "$(dirname "$_SELF")" && pwd)")"  # @tarball-patch: workbench-root' "$REVIEW"

# Patch _generator_version to read VERSION file instead of release-please manifest
# shellcheck disable=SC2016
sed_i '/@tarball-patch-start: generator-version/,/@tarball-patch-end: generator-version/c\
# @tarball-patch-start: generator-version\
_generator_version() {\
  local version\
  version=$(cat "${_WORKBENCH_ROOT}/VERSION" 2>/dev/null || echo "unknown")\
  echo "claude-review ${version}"\
}\
# @tarball-patch-end: generator-version' "$REVIEW"

# ─── Verify patches ──────────────────────────────────────────────────────

bash -n "$REVIEW"
for _sentinel in 'ui-source' 'workbench-root'; do
  if ! grep -q "@tarball-patch: $_sentinel" "$REVIEW"; then
    echo "ERROR: $_sentinel sentinel line missing after patch" >&2
    exit 1
  fi
  if grep "@tarball-patch: $_sentinel" "$REVIEW" | grep -qF 'rev-parse'; then
    echo "ERROR: $_sentinel patch failed — rev-parse still present" >&2
    exit 1
  fi
  if ! grep "@tarball-patch: $_sentinel" "$REVIEW" | grep -qF 'dirname'; then
    echo "ERROR: $_sentinel patch failed — dirname replacement missing" >&2
    exit 1
  fi
done
# generator-version: verify patched body reads VERSION file, not print_version
if sed -n '/@tarball-patch-start: generator-version/,/@tarball-patch-end: generator-version/p' "$REVIEW" \
    | grep -qF 'print_version'; then
  echo "ERROR: generator-version patch failed — old body still present" >&2
  exit 1
fi

# ─── Build tarball ────────────────────────────────────────────────────────

TARBALL="claude-review-${VERSION}.tar.gz"
tar -czf "$TARBALL" -C "$STAGING" "claude-review-${VERSION}"

# ─── Verify tarball ──────────────────────────────────────────────────────

contents=$(tar -tzf "$TARBALL")
failed=false

for entry in "bin/claude-review" "lib/ui.sh" "VERSION"; do
  if ! echo "$contents" | grep -q "$entry"; then
    echo "ERROR: tarball missing $entry" >&2
    failed=true
  fi
done

bin_tarball_count=$(echo "$contents" | grep -c 'bin/' || true)
py_count=$(echo "$contents" | grep -c '\.py$' || true)
agent_count=$(echo "$contents" | grep -c 'agents/.*\.md$' || true)
tpl_count=$(echo "$contents" | grep -c 'review-templates/.*\.md$' || true)

if (( bin_tarball_count < MIN_BIN_SCRIPTS )); then
  echo "ERROR: tarball has $bin_tarball_count bin scripts, expected >= $MIN_BIN_SCRIPTS" >&2
  failed=true
fi
if (( py_count < MIN_PYTHON_MODULES )); then
  echo "ERROR: tarball has $py_count Python modules, expected >= $MIN_PYTHON_MODULES" >&2
  failed=true
fi
if (( agent_count < MIN_AGENTS )); then
  echo "ERROR: tarball has $agent_count agents, expected >= $MIN_AGENTS" >&2
  failed=true
fi
if (( tpl_count < MIN_REVIEW_TEMPLATES )); then
  echo "ERROR: tarball has $tpl_count templates, expected >= $MIN_REVIEW_TEMPLATES" >&2
  failed=true
fi

if $failed; then exit 1; fi

echo "Created $TARBALL"
echo "SHA256: $(shasum -a 256 "$TARBALL" | cut -d' ' -f1)"
