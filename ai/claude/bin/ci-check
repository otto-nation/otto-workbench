#!/usr/bin/env python3
"""Fetch CI run data, classify failures, and output status.

Renders a human-readable dashboard to stderr and structured JSON to stdout.
Manages local state in <worktree>/.workbench/state.json.

Usage:
  ci-check                      # latest run for current branch
  ci-check --branch <name>      # specific branch (works from bare repos)
  ci-check --run <run_id>       # specific run
  ci-check --pr <number_or_url> # discover branch from PR
  ci-check --repo-dir <path>    # specify worktree directory
  ci-check --fix                # diagnose then invoke AI to fix failures
"""

import argparse
import json
import os
import subprocess
import sys
from concurrent.futures import ThreadPoolExecutor
from datetime import datetime, timezone
from pathlib import Path
from string import Template
from typing import TypedDict

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

import ai_backend
import ci_failures as ci
import pr_context
import pr_state
import review_common
import log
from trail import Trail, add_trail_args


# ── Fix phase constants ─────────────────────────────────────────────────────

_SKIP_KINDS = frozenset(("infra", "flaky"))
FIX_MAX_TURNS = 20
FIX_MAX_BUDGET = 3.0
FIX_MODEL = "sonnet"
TEMPLATE_DIR = Path(__file__).resolve().parent.parent / "lib" / "review-templates"


_SKIP_CONCLUSIONS = frozenset(("skipped", "cancelled"))
_FAILURE_CONCLUSIONS = frozenset(("failure", "timed_out", "action_required", "stale", "startup_failure"))


def _fetch_latest_run_ids(repo: str, branch: str) -> list[int]:
    """Fetch workflow run IDs for the latest commit, one per workflow.

    Filters out skipped and cancelled runs before deduplication.
    When a workflow is re-run, both the original and re-run share the same
    SHA.  gh run list returns newest first, so we deduplicate by workflow
    name to keep only the most recent run of each workflow.
    """
    result = subprocess.run(
        ["gh", "run", "list", "--repo", repo, "--branch", branch,
         "--limit", "20", "--json",
         "databaseId,headSha,workflowName,conclusion"],
        capture_output=True, text=True,
    )
    if result.returncode != 0 or not result.stdout.strip():
        return []
    try:
        runs = json.loads(result.stdout)
    except (json.JSONDecodeError, TypeError):
        return []
    if not runs:
        return []
    latest_sha = runs[0]["headSha"]
    seen_workflows: set[str] = set()
    ids: list[int] = []
    for r in runs:
        if r["headSha"] != latest_sha:
            continue
        if r.get("conclusion") in _SKIP_CONCLUSIONS:
            continue
        wf = r.get("workflowName", "")
        if wf in seen_workflows:
            continue
        seen_workflows.add(wf)
        ids.append(r["databaseId"])
    return ids


def _fetch_run_data(repo: str, run_id: int) -> dict | None:
    """Fetch run metadata and job results."""
    result = subprocess.run(
        ["gh", "run", "view", str(run_id), "--repo", repo,
         "--json", "databaseId,number,headSha,status,conclusion,jobs"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return None
    try:
        return json.loads(result.stdout)
    except (json.JSONDecodeError, TypeError):
        return None


def _fetch_annotations(repo: str, job_id: int) -> list[dict]:
    """Fetch annotations for a check run (job)."""
    result = subprocess.run(
        ["gh", "api", f"repos/{repo}/check-runs/{job_id}/annotations",
         "--paginate"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return []
    try:
        return json.loads(result.stdout)
    except (json.JSONDecodeError, TypeError):
        return []


def _fetch_job_logs(repo: str, job_id: int) -> str:
    """Fetch logs for a single job via API. Smaller and faster than per-run."""
    result = subprocess.run(
        ["gh", "api", f"repos/{repo}/actions/jobs/{job_id}/logs"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return ""
    return result.stdout


def _fetch_failed_logs(repo: str, run_id: int) -> str:
    """Fetch logs for failed steps. Returns raw log text."""
    result = subprocess.run(
        ["gh", "run", "view", str(run_id), "--repo", repo, "--log-failed"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return ""
    return result.stdout


def _build_failure_id(annotation: dict, job_name: str) -> str:
    """Build a deterministic failure item ID from annotation data."""
    path = annotation.get("path", "")
    line = annotation.get("start_line", 0)
    title = annotation.get("title", "")
    if path and line:
        slug = title.split(":")[0].strip().lower() if title else "err"
        return f"{slug}-{path}-{line}"
    message = annotation.get("message", "")
    return f"{job_name}-{hash(message) & 0xFFFFFFFF:08x}"


def _annotations_to_items(
    annotations: list[dict], job_name: str, source_run_id: int | None = None,
    context: str | None = None,
) -> list[ci.FailureItem]:
    """Convert raw annotations to FailureItems, skipping notices."""
    items: list[ci.FailureItem] = []
    for ann in annotations:
        if ann.get("annotation_level") == "notice":
            continue
        item_id = _build_failure_id(ann, job_name)
        text = ann.get("message", ann.get("title", ""))
        items.append(ci.FailureItem(
            id=item_id,
            annotation=text,
            file=ann.get("path") or None,
            line=ann.get("start_line") or None,
            diagnosis=None,
            fix_sha=None,
            outcome=None,
            headline=ci.extract_headline(text),
            source_run_id=source_run_id,
            context=context,
        ))
    return items


def _fallback_item(job_name: str, source_run_id: int | None = None) -> ci.FailureItem:
    """Create a placeholder item for a failed job with no annotations."""
    return ci.FailureItem(
        id=f"{job_name}-no-annotation",
        annotation=f"Job '{job_name}' failed with no annotations",
        file=None,
        line=None,
        diagnosis=None,
        fix_sha=None,
        outcome=None,
        source_run_id=source_run_id,
    )


def _annotations_uninformative(annotations: list[dict]) -> bool:
    """True when non-notice annotations exist but carry no actionable file context."""
    non_notices = [a for a in annotations if a.get("annotation_level") != "notice"]
    return bool(non_notices) and all(not a.get("path") for a in non_notices)


def _log_fallback(repo: str, job: dict, run_data: dict, kind: ci.FailureKind) -> tuple[list[dict], list[str], ci.FailureKind]:
    """Fetch job logs and extract failure context as synthetic annotations."""
    job_id = job.get("databaseId", 0)
    log_text = _fetch_job_logs(repo, job_id) if job_id else ""
    if not log_text:
        source_run_id = job.get("_source_run_id", run_data["databaseId"])
        log_text = _fetch_failed_logs(repo, source_run_id)
    if not log_text:
        return [], [], kind
    context = ci.extract_failure_context(log_text, kind)
    if not context:
        return [], [], kind
    annotations = [{"message": context, "path": "", "start_line": 0, "title": ""}]
    return annotations, [context], ci.classify_job(job.get("name", "unknown"), [context])


def _extract_failed_step(job: dict) -> str | None:
    """Return the name of the first failed step in a job, if available."""
    for step in job.get("steps", []):
        if step.get("conclusion") in _FAILURE_CONCLUSIONS:
            return step.get("name")
    return None


class _JobFailure(TypedDict):
    job_name: str
    kind: ci.FailureKind
    items: list[dict]
    failed_step: str | None


def _fetch_job_failure(repo: str, job: dict, run_data: dict) -> _JobFailure | None:
    """Fetch annotations/logs for a single failed job. Thread-safe."""
    job_name = job.get("name", "unknown")
    job_id = job.get("databaseId", 0)
    source_run_id = job.get("_source_run_id") or run_data.get("databaseId")
    failed_step = _extract_failed_step(job)

    annotations = _fetch_annotations(repo, job_id) if job_id else []
    annotation_texts = [a.get("message", "") for a in annotations]
    kind = ci.classify_job(job_name, annotation_texts)
    log_context = None

    if not annotations:
        annotations, annotation_texts, kind = _log_fallback(repo, job, run_data, kind)
    elif kind in (ci.FailureKind.BUILD, ci.FailureKind.TEST) and _annotations_uninformative(annotations):
        result = _log_fallback(repo, job, run_data, kind)
        log_context, kind = (result[1][0], result[2]) if result[0] else (None, kind)

    if annotations:
        items = _annotations_to_items(annotations, job_name, source_run_id, context=log_context)
    else:
        items = [_fallback_item(job_name, source_run_id)]
    if not items:
        return None

    return {"job_name": job_name, "kind": kind, "items": items, "failed_step": failed_step}


def _parse_run(repo: str, run_data: dict) -> ci.RunState:
    """Parse gh run data into a RunState with classified failures."""
    failed_jobs = [j for j in run_data.get("jobs", []) if j.get("conclusion") in _FAILURE_CONCLUSIONS]
    failures: dict[str, ci.FailureGroup] = {}

    with ThreadPoolExecutor(max_workers=5) as pool:
        results = list(pool.map(lambda j: _fetch_job_failure(repo, j, run_data), failed_jobs))

    for r in results:
        if not r:
            continue
        job_key = r["job_name"].lower().replace(" ", "-").replace("/", "-")
        prior_items = failures[job_key].items if job_key in failures else ()
        failures[job_key] = ci.FailureGroup(
            job=r["job_name"], kind=r["kind"], items=prior_items + tuple(r["items"]),
            failed_step=r["failed_step"],
        )

    return ci.RunState(
        run_id=run_data["databaseId"],
        run_number=run_data.get("number", 0),
        head_sha=run_data.get("headSha", ""),
        status=run_data.get("status", ""),
        conclusion=run_data.get("conclusion", ""),
        fetched_at=datetime.now(timezone.utc).isoformat(),
        failures=failures,
    )


def _merge_runs(run_data_list: list[dict]) -> dict | None:
    """Merge multiple workflow run dicts into a single combined run.

    The first run becomes the primary; its conclusion is overridden to
    "failure" if any run has a real failure conclusion.  Jobs from all
    runs are collected into the primary's "jobs" list.
    """
    if not run_data_list:
        return None
    primary = run_data_list[0]
    all_jobs = []
    for rd in run_data_list:
        if rd.get("conclusion") in _FAILURE_CONCLUSIONS:
            primary["conclusion"] = "failure"
        rid = rd.get("_run_id")
        for job in rd.get("jobs", []):
            job["_source_run_id"] = rid
        all_jobs.extend(rd.get("jobs", []))
    primary["jobs"] = all_jobs
    return primary


def _commits_behind_main(repo: str, branch: str) -> int:
    """Count commits on origin/main not reachable from the branch."""
    result = subprocess.run(
        ["gh", "api", f"repos/{repo}/compare/{branch}...main",
         "--jq", ".ahead_by"],
        capture_output=True, text=True,
    )
    val = result.stdout.strip()
    return int(val) if result.returncode == 0 and val.isdigit() else 0


def _run_ci(trail, args, ctx) -> dict:
    repo = ctx.repo
    branch = ctx.branch
    pr_number = ctx.pr_number
    toplevel = ctx.worktree_root

    # Determine run IDs
    if args.run:
        run_ids = [args.run]
    else:
        run_ids = _fetch_latest_run_ids(repo, branch)
        if not run_ids:
            trail.warn("no_runs", "no workflow runs found")
            log.error(f"No workflow runs found for branch '{branch}'")
            sys.exit(1)

    trail.info("fetch_runs", f"fetching {len(run_ids)} run(s)", data={"run_ids": run_ids})

    with ThreadPoolExecutor(max_workers=5) as pool:
        fetched = list(pool.map(lambda rid: (rid, _fetch_run_data(repo, rid)), run_ids))
    run_data_list = []
    for rid, rd in fetched:
        if rd is not None:
            rd["_run_id"] = rid
            run_data_list.append(rd)
            trail.info("fetch_run_data", f"fetched run {rid}", data={"run_id": rid, "conclusion": rd.get("conclusion")})

    primary_run_data = _merge_runs(run_data_list)
    if primary_run_data is None:
        trail.error("fetch_run_data", "failed to fetch run data")
        log.error("Failed to fetch run data")
        sys.exit(1)

    # Parse into typed state
    run_state = _parse_run(repo, primary_run_data)

    # Load unified PR state (or init fresh)
    if toplevel:
        state = pr_state.load_or_init(
            worktree_root=toplevel, repo=repo, branch=branch,
            pr_number=pr_number, head_sha=run_state.head_sha,
        )
        ci_domain = state.ci
    else:
        state = None
        ci_domain = pr_state.CIDomain()

    trail.decision(
        "classify_failures",
        f"classified {len(run_state.failures)} failure groups",
        reason=f"matched job patterns: {list(run_state.failures.keys())}",
        data={"failure_kinds": {k: g.kind.value for k, g in run_state.failures.items()}},
    )

    # Compute progression from prior run in domain
    prior_run = ci_domain.runs.get(str(ci_domain.latest_run_id)) if ci_domain.latest_run_id else None
    prior_failures = prior_run.failures if prior_run else {}
    progression = ci.compute_progression(run_state.failures, prior_failures)

    trail.info(
        "compute_progression",
        f"{len(progression)} items tracked",
        data={"outcomes": {o.value: sum(1 for v in progression.values() if v == o) for o in ci.Outcome}},
    )

    # Sync run into domain
    ci.sync_ci_domain(ci_domain, run_state)

    trail.info("sync_state", f"state synced, {len(ci_domain.runs)} runs retained")

    # Dashboard to stderr
    dashboard = ci.render_dashboard(run_state, progression, run_ids=run_ids)
    print(dashboard, file=sys.stderr)

    # Check how far behind origin/main the branch is — runs on every invocation
    # (not just --fix) because the JSON report includes behind_main for SKILL.md consumers
    behind_main = _commits_behind_main(repo, branch) if branch not in ("main", "master") else 0

    # JSON report to stdout
    report = {
        "repo": repo,
        "branch": branch,
        "pr_number": pr_number,
        "run_id": run_state.run_id,
        "run_ids": run_ids,
        "run_number": run_state.run_number,
        "head_sha": run_state.head_sha,
        "conclusion": run_state.conclusion,
        "behind_main": behind_main,
        "failures": [],
        "progression": {k: v.value for k, v in progression.items()},
        "resolved_since_prior": [],
    }

    for group_key, group in run_state.failures.items():
        for item in group.items:
            report["failures"].append({
                "id": item.id,
                "job": group.job,
                "failed_step": group.failed_step,
                "kind": group.kind.value,
                "annotation": item.annotation,
                "headline": item.headline,
                "file": item.file,
                "line": item.line,
                "diagnosis": item.diagnosis,
                "fix_sha": item.fix_sha,
                "outcome": progression.get(item.id, ci.Outcome.NEW).value,
                "source_run_id": item.source_run_id,
                "context": item.context,
            })

    if prior_run:
        prior_item_ids = ci.collect_item_ids(prior_run.failures)
        current_item_ids = ci.collect_item_ids(run_state.failures)
        report["resolved_since_prior"] = [
            item_id for item_id in prior_item_ids
            if item_id not in current_item_ids
        ]

    # Update summary fields in CIDomain and save unified state
    if state is not None:
        kind_counts: dict[str, int] = {}
        for f in report.get("failures", []):
            k = f.get("kind", "unknown")
            kind_counts[k] = kind_counts.get(k, 0) + 1
        ci_domain.conclusion = run_state.conclusion
        ci_domain.failure_count = len(report.get("failures", []))
        ci_domain.failure_kinds = kind_counts
        ci_domain.last_run_id = run_state.run_id
        ci_domain.last_run_number = run_state.run_number
        ci_domain.updated_at = pr_state.now_iso()
        try:
            pr_state.save_state(toplevel, state)
        except Exception as exc:
            trail.error("state_update", f"state update failed: {exc}")
            log.error(f"ci-check: state update failed: {exc}")

    if report["failures"]:
        json.dump(report, sys.stdout, indent=2)
        print()

    return report


# ── Fix phase ────────────────────────────────────────────────────────────────


def _build_ci_tracking_file(
    tracking_path: Path, failures: list[dict], run_number: int,
) -> int:
    """Build markdown tracking file for fixable CI failures. Returns count."""
    fixable = [f for f in failures if f["kind"] not in _SKIP_KINDS]
    if not fixable:
        return 0

    sections = []
    for f in fixable:
        file_ref = f"{f['file']}:{f['line']}" if f.get("file") and f.get("line") else "—"
        section = f"## <!-- failure:{f['id']} --> {file_ref} — {f['job']}\n\n"
        section += f"**Kind:** {f['kind']}\n"
        if f.get("headline"):
            section += f"**Error:** {f['headline']}\n"
        if f.get("annotation") and f["annotation"] != f.get("headline"):
            section += f"**Details:** {f['annotation']}\n"
        if f.get("context"):
            section += f"**Context:** {f['context']}\n"
        if f.get("outcome") and f["outcome"] != "new":
            section += f"**Progression:** {f['outcome']}\n"
        section += "\n- [ ] Apply fix\n"
        sections.append(section)

    content = f"# CI Fix Tracking — Run #{run_number}\n\n"
    content += "\n".join(sections)
    tracking_path.parent.mkdir(parents=True, exist_ok=True)
    tracking_path.write_text(content)
    return len(fixable)


def _render_ci_fix_template(
    branch: str, repo: str, failures_content: str,
    tracking_file: str, wt_path: str, max_turns: int,
) -> str:
    """Render the fix-ci.md template."""
    tmpl = Template((TEMPLATE_DIR / review_common.TEMPLATE_FIX_CI).read_text())
    return tmpl.safe_substitute(
        branch_name=branch,
        repo=repo,
        failures_content=failures_content,
        tracking_file=tracking_file,
        wt_path=wt_path,
        max_turns=str(max_turns),
    )


def _count_checked(path: Path) -> int:
    if not path.exists():
        return 0
    return sum(1 for line in path.read_text().splitlines()
               if line.strip().startswith("- [x]"))


def _count_unchecked(path: Path) -> int:
    if not path.exists():
        return 0
    return sum(1 for line in path.read_text().splitlines()
               if line.strip().startswith("- [ ]"))


def _commit_and_push(wt_path: Path, fixed: int, skipped: int) -> str | None:
    """Commit and push fixes if there are changes. Returns commit SHA or None."""
    r = subprocess.run(
        ["git", "-C", str(wt_path), "diff", "--quiet"],
        capture_output=True,
    )
    if r.returncode == 0:
        r2 = subprocess.run(
            ["git", "-C", str(wt_path), "diff", "--cached", "--quiet"],
            capture_output=True,
        )
        if r2.returncode == 0:
            log.info("No changes to commit")
            return None

    subprocess.run(
        ["git", "-C", str(wt_path), "add", "-u"],
        check=True,
    )
    msg = "fix: address CI failures"
    if fixed:
        msg += f"\n\n{fixed} fixed, {skipped} skipped"
    subprocess.run(
        ["git", "-C", str(wt_path), "commit", "-m", msg],
        check=True,
    )
    sha = subprocess.run(
        ["git", "-C", str(wt_path), "rev-parse", "HEAD"],
        capture_output=True, text=True, check=True,
    ).stdout.strip()
    log.info(f"Committed fixes ({fixed} fixed, {skipped} skipped)")

    r = subprocess.run(
        ["git", "-C", str(wt_path), "push"],
        capture_output=True, text=True,
    )
    if r.returncode == 0:
        log.info("Pushed fixes")
    else:
        log.warn(f"Push failed: {r.stderr.strip()}")

    return sha


def _rebase_if_behind(trail, report: dict, ctx) -> bool:
    """Rebase onto origin/main if branch is behind. Returns True if rebased and pushed."""
    behind = report.get("behind_main", 0)
    if behind <= 0:
        return False

    trail.decision(
        "rebase_check",
        f"branch is {behind} commit(s) behind main",
        reason="stale branch may cause CI failures",
    )
    log.info(f"Branch is {behind} commit(s) behind main — rebasing first...")

    bin_dir = Path(__file__).resolve().parent
    cmd = [str(bin_dir / "pr-rebase"), "--fix",
           "--repo-dir", str(ctx.worktree_root)]
    if ctx.branch:
        cmd += ["--branch", ctx.branch]
    r = subprocess.run(cmd, capture_output=True, text=True)

    if r.returncode != 0:
        trail.warn("rebase_failed", f"rebase failed (exit {r.returncode})")
        log.warn("Rebase failed — continuing with CI fixes on current base")
        if r.stderr.strip():
            log.dim(r.stderr.strip())
        return False

    trail.info("rebase_done", "rebased and force-pushed")
    log.ok("Rebased onto main and force-pushed — CI will re-run on new HEAD")
    return True


def _run_fix(trail, report: dict, ctx) -> int:
    """Apply AI-driven fixes for CI failures. Returns exit code."""
    toplevel = ctx.worktree_root
    if not toplevel:
        log.error("--fix requires a worktree (use --repo-dir)")
        return 1

    if _rebase_if_behind(trail, report, ctx):
        log.info("Re-run `ci-check --fix` after CI completes on the new HEAD")
        return 0

    failures = report.get("failures", [])
    if not failures:
        log.info("No failures to fix")
        return 0

    tracking_dir = toplevel / "ignore" / "ci-failures"
    tracking_file = tracking_dir / "fix-tracking.md"

    fixable_count = _build_ci_tracking_file(
        tracking_file, failures, report.get("run_number", 0),
    )
    if fixable_count == 0:
        log.info("No fixable failures (all infra/flaky)")
        return 0

    trail.info("fix_start", f"{fixable_count} fixable failure(s)")
    log.info(f"Fixing {fixable_count} CI failure(s)...")

    prompt = _render_ci_fix_template(
        branch=ctx.branch,
        repo=ctx.repo,
        failures_content=tracking_file.read_text(),
        tracking_file=str(tracking_file),
        wt_path=str(toplevel),
        max_turns=FIX_MAX_TURNS,
    )

    rc = ai_backend.invoke_fix(
        prompt,
        add_dirs=[str(toplevel)],
        max_turns=FIX_MAX_TURNS,
        max_budget=FIX_MAX_BUDGET,
        model=FIX_MODEL,
    )

    fixed = _count_checked(tracking_file)
    skipped = _count_unchecked(tracking_file)

    trail.info(
        "fix_result", f"{fixed} fixed, {skipped} skipped",
        data={"fixed": fixed, "skipped": skipped},
    )

    if fixed > 0:
        sha = _commit_and_push(toplevel, fixed, skipped)
        if sha:
            trail.info("fix_committed", f"committed at {sha}")

    if skipped > 0:
        log.info(f"{skipped} failure(s) could not be auto-fixed")

    return 0 if rc == 0 else 1


def main():
    parser = argparse.ArgumentParser(description="CI failure status")
    parser.add_argument("--pr", help="PR number or URL")
    parser.add_argument("--branch", help="Branch name (overrides git detection)")
    parser.add_argument("--run", type=int, help="Specific run ID")
    parser.add_argument("--repo-dir", "--worktree",
                        help="Git worktree directory")
    parser.add_argument("--fix", action="store_true",
                        help="Invoke AI to fix failures after diagnosis")
    add_trail_args(parser)
    args = parser.parse_args()

    ctx = pr_context.resolve(
        pr=args.pr, branch=args.branch, repo_dir=args.repo_dir,
    )
    repo = ctx.repo
    branch = ctx.branch
    pr_number = ctx.pr_number
    toplevel = ctx.worktree_root

    trail = Trail.start(
        script="ci-check",
        artifact_dir=str(toplevel / pr_state.STATE_DIR) if toplevel else os.path.expanduser("~/.config/workbench/logs/ci-check"),
        context={"repo": repo, "pr": pr_number, "branch": branch},
        debug=args.debug,
    )
    try:
        report = _run_ci(trail, args, ctx)
        if args.fix:
            rc = _run_fix(trail, report, ctx)
            sys.exit(rc)
    except Exception as exc:
        trail.error("unexpected_error", str(exc))
        raise
    finally:
        trail.finish()


if __name__ == "__main__":
    main()
