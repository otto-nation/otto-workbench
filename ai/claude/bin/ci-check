#!/usr/bin/env python3
"""Fetch CI run data, classify failures, and output status.

Renders a human-readable dashboard to stderr and structured JSON to stdout.
Manages local state in <worktree>/ignore/ci-failures/state.json.

Usage:
  ci-check                      # latest run for current branch
  ci-check --branch <name>      # specific branch (works from bare repos)
  ci-check --run <run_id>       # specific run
  ci-check --pr <number_or_url> # discover branch from PR
  ci-check --repo-dir <path>    # specify worktree directory
"""

import argparse
import json
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

import ci_failures as ci
import pr_context
import pr_state


def _err(msg: str) -> None:
    print(f"✗ {msg}", file=sys.stderr)


def _fetch_latest_run_ids(repo: str, branch: str) -> list[int]:
    """Fetch workflow run IDs for the latest commit, one per workflow.

    When a workflow is re-run, both the original and re-run share the same
    SHA.  gh run list returns newest first, so we deduplicate by workflow
    name to keep only the most recent run of each workflow.
    """
    result = subprocess.run(
        ["gh", "run", "list", "--repo", repo, "--branch", branch,
         "--limit", "20", "--json", "databaseId,headSha,workflowName"],
        capture_output=True, text=True,
    )
    if result.returncode != 0 or not result.stdout.strip():
        return []
    try:
        runs = json.loads(result.stdout)
    except (json.JSONDecodeError, TypeError):
        return []
    if not runs:
        return []
    latest_sha = runs[0]["headSha"]
    seen_workflows: set[str] = set()
    ids: list[int] = []
    for r in runs:
        if r["headSha"] != latest_sha:
            continue
        wf = r.get("workflowName", "")
        if wf in seen_workflows:
            continue
        seen_workflows.add(wf)
        ids.append(r["databaseId"])
    return ids


def _fetch_run_data(repo: str, run_id: int) -> dict | None:
    """Fetch run metadata and job results."""
    result = subprocess.run(
        ["gh", "run", "view", str(run_id), "--repo", repo,
         "--json", "databaseId,number,headSha,status,conclusion,jobs"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return None
    try:
        return json.loads(result.stdout)
    except (json.JSONDecodeError, TypeError):
        return None


def _fetch_annotations(repo: str, job_id: int) -> list[dict]:
    """Fetch annotations for a check run (job)."""
    result = subprocess.run(
        ["gh", "api", f"repos/{repo}/check-runs/{job_id}/annotations",
         "--paginate"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return []
    try:
        return json.loads(result.stdout)
    except (json.JSONDecodeError, TypeError):
        return []


def _fetch_job_logs(repo: str, job_id: int) -> str:
    """Fetch logs for a single job via API. Smaller and faster than per-run."""
    result = subprocess.run(
        ["gh", "api", f"repos/{repo}/actions/jobs/{job_id}/logs"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return ""
    return result.stdout


def _fetch_failed_logs(repo: str, run_id: int) -> str:
    """Fetch logs for failed steps. Returns raw log text."""
    result = subprocess.run(
        ["gh", "run", "view", str(run_id), "--repo", repo, "--log-failed"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return ""
    return result.stdout


def _build_failure_id(annotation: dict, job_name: str) -> str:
    """Build a deterministic failure item ID from annotation data."""
    path = annotation.get("path", "")
    line = annotation.get("start_line", 0)
    title = annotation.get("title", "")
    if path and line:
        slug = title.split(":")[0].strip().lower() if title else "err"
        return f"{slug}-{path}-{line}"
    message = annotation.get("message", "")
    return f"{job_name}-{hash(message) & 0xFFFFFFFF:08x}"


def _annotations_to_items(annotations: list[dict], job_name: str) -> list[ci.FailureItem]:
    """Convert raw annotations to FailureItems, skipping notices."""
    items: list[ci.FailureItem] = []
    for ann in annotations:
        if ann.get("annotation_level") == "notice":
            continue
        item_id = _build_failure_id(ann, job_name)
        items.append(ci.FailureItem(
            id=item_id,
            annotation=ann.get("message", ann.get("title", "")),
            file=ann.get("path") or None,
            line=ann.get("start_line") or None,
            diagnosis=None,
            fix_sha=None,
            outcome=None,
        ))
    return items


def _fallback_item(job_name: str) -> ci.FailureItem:
    """Create a placeholder item for a failed job with no annotations."""
    return ci.FailureItem(
        id=f"{job_name}-no-annotation",
        annotation=f"Job '{job_name}' failed with no annotations",
        file=None,
        line=None,
        diagnosis=None,
        fix_sha=None,
        outcome=None,
    )


def _log_fallback(repo: str, job: dict, run_data: dict, kind: ci.FailureKind) -> tuple[list[dict], list[str], ci.FailureKind]:
    """Fetch job logs and extract failure context as synthetic annotations."""
    job_id = job.get("databaseId", 0)
    log_text = _fetch_job_logs(repo, job_id) if job_id else ""
    if not log_text:
        source_run_id = job.get("_source_run_id", run_data["databaseId"])
        log_text = _fetch_failed_logs(repo, source_run_id)
    if not log_text:
        return [], [], kind
    context = ci.extract_failure_context(log_text, kind)
    if not context:
        return [], [], kind
    annotations = [{"message": context, "path": "", "start_line": 0, "title": ""}]
    return annotations, [context], ci.classify_job(job.get("name", "unknown"), [context])


def _parse_run(repo: str, run_data: dict) -> ci.RunState:
    """Parse gh run data into a RunState with classified failures."""
    jobs = run_data.get("jobs", [])
    failures: dict[str, ci.FailureGroup] = {}

    for job in jobs:
        conclusion = job.get("conclusion", "")
        if conclusion in ("success", "skipped", "cancelled", "neutral"):
            continue

        job_name = job.get("name", "unknown")
        job_id = job.get("databaseId", 0)

        annotations = _fetch_annotations(repo, job_id) if job_id else []
        annotation_texts = [a.get("message", "") for a in annotations]
        kind = ci.classify_job(job_name, annotation_texts)

        if not annotations:
            annotations, annotation_texts, kind = _log_fallback(repo, job, run_data, kind)

        items = _annotations_to_items(annotations, job_name) if annotations else [_fallback_item(job_name)]

        if items:
            job_key = job_name.lower().replace(" ", "-").replace("/", "-")
            prior_items = failures[job_key].items if job_key in failures else ()
            failures[job_key] = ci.FailureGroup(
                job=job_name, kind=kind, items=prior_items + tuple(items),
            )

    return ci.RunState(
        run_id=run_data["databaseId"],
        run_number=run_data.get("number", 0),
        head_sha=run_data.get("headSha", ""),
        status=run_data.get("status", ""),
        conclusion=run_data.get("conclusion", ""),
        fetched_at=datetime.now(timezone.utc).isoformat(),
        failures=failures,
    )


def _update_pr_state(toplevel, repo, branch, pr_number, run_state, report):
    """Best-effort update of unified PR state."""
    if not toplevel:
        return
    try:
        kind_counts: dict[str, int] = {}
        for f in report.get("failures", []):
            k = f.get("kind", "unknown")
            kind_counts[k] = kind_counts.get(k, 0) + 1
        st = pr_state.load_or_init(
            worktree_root=toplevel, repo=repo, branch=branch,
            pr_number=pr_number, head_sha=run_state.head_sha,
        )
        pr_state.update_ci(st, pr_state.CISummary(
            last_run_id=run_state.run_id,
            last_run_number=run_state.run_number,
            conclusion=run_state.conclusion,
            failure_count=len(report.get("failures", [])),
            failure_kinds=kind_counts,
            updated_at=pr_state.now_iso(),
        ))
        pr_state.save_state(toplevel, st)
    except Exception as exc:
        print(f"ci-check: state update failed: {exc}", file=sys.stderr)


def main():
    parser = argparse.ArgumentParser(description="CI failure status")
    parser.add_argument("--pr", help="PR number or URL")
    parser.add_argument("--branch", help="Branch name (overrides git detection)")
    parser.add_argument("--run", type=int, help="Specific run ID")
    parser.add_argument("--repo-dir", "--worktree",
                        help="Git worktree directory")
    args = parser.parse_args()

    ctx = pr_context.resolve(
        pr=args.pr, branch=args.branch, repo_dir=args.repo_dir,
    )
    repo = ctx.repo
    branch = ctx.branch
    pr_number = ctx.pr_number

    # Determine run IDs
    if args.run:
        run_ids = [args.run]
    else:
        run_ids = _fetch_latest_run_ids(repo, branch)
        if not run_ids:
            _err(f"No workflow runs found for branch '{branch}'")
            sys.exit(1)

    # Fetch all runs and merge their jobs into a single run data
    primary_run_data = None
    all_jobs = []
    for rid in run_ids:
        rd = _fetch_run_data(repo, rid)
        if rd is None:
            continue
        if primary_run_data is None:
            primary_run_data = rd
        if rd.get("conclusion") not in ("success", None):
            primary_run_data["conclusion"] = "failure"
        jobs = rd.get("jobs", [])
        for job in jobs:
            job["_source_run_id"] = rid
        all_jobs.extend(jobs)

    if primary_run_data is None:
        _err("Failed to fetch run data")
        sys.exit(1)

    primary_run_data["jobs"] = all_jobs

    # Parse into typed state
    run_state = _parse_run(repo, primary_run_data)

    # Load and sync state
    toplevel = ctx.worktree_root
    prior_state = ci.load_state(toplevel) if toplevel else None
    if prior_state is None:
        prior_state = ci.empty_state(repo, branch, pr_number)

    prior_run = prior_state.runs.get(prior_state.latest_run_id) if prior_state.latest_run_id else None
    prior_failures = prior_run.failures if prior_run else {}
    progression = ci.compute_progression(run_state.failures, prior_failures)

    state = ci.sync_state(prior_state, run_state)
    if toplevel:
        ci.save_state(toplevel, state)

    # Dashboard to stderr
    dashboard = ci.render_dashboard(run_state, progression)
    print(dashboard, file=sys.stderr)

    # JSON report to stdout
    report = {
        "repo": repo,
        "branch": branch,
        "pr_number": pr_number,
        "run_id": run_state.run_id,
        "run_number": run_state.run_number,
        "head_sha": run_state.head_sha,
        "conclusion": run_state.conclusion,
        "failures": [],
        "progression": {k: v.value for k, v in progression.items()},
        "resolved_since_prior": [],
    }

    for group_key, group in run_state.failures.items():
        for item in group.items:
            report["failures"].append({
                "id": item.id,
                "job": group.job,
                "kind": group.kind.value,
                "annotation": item.annotation,
                "file": item.file,
                "line": item.line,
                "diagnosis": item.diagnosis,
                "fix_sha": item.fix_sha,
                "outcome": progression.get(item.id, ci.Outcome.NEW).value,
            })

    if prior_run:
        prior_item_ids = ci.collect_item_ids(prior_run.failures)
        current_item_ids = ci.collect_item_ids(run_state.failures)
        report["resolved_since_prior"] = [
            item_id for item_id in prior_item_ids
            if item_id not in current_item_ids
        ]

    _update_pr_state(toplevel, repo, branch, pr_number, run_state, report)

    json.dump(report, sys.stdout, indent=2)
    print()


if __name__ == "__main__":
    main()
