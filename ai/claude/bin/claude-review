#!/usr/bin/env bash
# Run Claude's reviewer agent on a PR with local worktree checkout and iterative review support.
#
# Usage: claude-review [options] <pr_url_or_number>
#        claude-review --self [<pr_url_or_number | branch_name>]
#        claude-review <command> [args]
#
# Commands:
#   <pr_url_or_number>   Run headless review, display results, prompt to post
#   gc                   Clean up stale review artifacts
#   post <pr_url_or_number>  Post an existing review file headlessly via poster agent
#
# Options:
#   --no-post                  Skip all interactive prompts; run review and exit
#   --post                     Run review then post automatically (fully headless)
#   --issue <link>             Attach an issue link for reviewer context
#   --self                     Self-review mode: review your own code
#   --fix                      Apply fixes for review findings (requires --self)
#   --skip-user-verification   Skip ownership check in self-review mode
#
# When calling from Claude Code:
#   Run each review in a foreground Bash call (not backgrounded with &).
#   To review multiple PRs in parallel, use the Agent tool to dispatch
#   separate subagents — each runs one `claude-review --no-post <N>` call.

set -Eeo pipefail

_SELF="$(readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
# shellcheck source=/dev/null
. "$(dirname "$_SELF")/../../../lib/ui.sh"

_on_err() {
  local rc=$?
  (( rc == 130 )) && return 0
  err "Unexpected failure at line $1 in ${3}(): $2"
}
trap '_on_err $LINENO "$BASH_COMMAND" "${FUNCNAME[0]:-main}"' ERR

_on_int() {
  echo "" >&2
  info "Interrupted"
  exit 130
}
trap '_on_int' INT

# ─── Constants ───────────────────────────────────────────────────────────────

_WORKBENCH_ROOT="$(cd "$(dirname "$_SELF")/../../.." && pwd)"

_generator_version() {
  print_version "claude-review" | tail -1
}

REVIEWS_DIR="$HOME/.config/workbench/reviews"
LEGACY_REVIEWS_DIR="$HOME/.claude/reviews"

REVIEW_EXT=".md"

FILENAME_PRIOR="prior${REVIEW_EXT}"
FILENAME_SESSION="session.jsonl"
FILENAME_POST_SESSION="post.jsonl"
FILENAME_PIPELINE_STATE="pipeline.json"

ARCHIVE_KEEP_COUNT=3
GC_STALE_DAYS=7
DEFAULT_MAX_PARALLEL=4

ISSUE_PATTERN_JIRA_LINEAR='[A-Z]+-[0-9]+'
ISSUE_PROVIDER_DEFAULT="linear"

PR_URL_PATTERN='/pull/([0-9]+)'
PR_NUMBER_PATTERN='^[0-9]+$'
GITHUB_REPO_PATTERN='github\.com/([^/]+/[^/]+)'

GITHUB_BASE_URL="https://github.com"

WORKTREE_FALLBACK_DIR=".worktrees"

# shellcheck disable=SC2034  # used by commands_usage() via nameref
COMMANDS=(
  "gc"                      "Clean up stale review artifacts"
  "post <pr_url_or_number>" "Post an existing review file via poster agent"
)

ARCHIVE_TIMESTAMP_FMT="%Y%m%d-%H%M%S"

# Severity definitions: parallel arrays map prefix → JSON key.
# Order determines JSON field order in --json-summary output.
SEVERITY_PREFIXES=(M S N I)
SEVERITY_JSON_KEYS=(must_fix should_fix nit idiom)

ORCHESTRATE_BIN="review-orchestrate"

mkdir -p "$REVIEWS_DIR"

# Migrate reviews from legacy location
if [[ -d "$LEGACY_REVIEWS_DIR" ]]; then
  mv "$LEGACY_REVIEWS_DIR"/*.md "$REVIEWS_DIR/" 2>/dev/null || true
  mv "$LEGACY_REVIEWS_DIR"/*.jsonl "$REVIEWS_DIR/" 2>/dev/null || true
fi

# Migrate flat review files to per-review folder layout
_migrate_flat_reviews() {
  local migrated=0
  for flat_review in "$REVIEWS_DIR"/*"${REVIEW_EXT}"; do
    [[ -f "$flat_review" ]] || continue
    local base="${flat_review%"${REVIEW_EXT}"}"
    local dir_name
    dir_name="$(basename "$base")"
    local review_dir="${REVIEWS_DIR}/${dir_name}"

    [[ -d "$review_dir" ]] && continue

    mkdir -p "$review_dir"
    mv "$flat_review" "${review_dir}/review${REVIEW_EXT}"

    # Move associated flat files into the folder
    for suffix in .session.jsonl .meta.json .post.jsonl .pipeline.json .prior.md; do
      local flat_file="${base}${suffix}"
      [[ -f "$flat_file" ]] || continue
      local new_name="${suffix#.}"
      mv "$flat_file" "${review_dir}/${new_name}"
    done

    # Move group/holistic intermediates
    for intermediate in "${base}".group-*.md "${base}".group-*.jsonl "${base}".holistic.md "${base}".holistic.jsonl "${base}".synthesis.jsonl; do
      [[ -f "$intermediate" ]] || continue
      local fname
      fname="$(basename "$intermediate")"
      fname="${fname#"${dir_name}."}"
      mv "$intermediate" "${review_dir}/${fname}"
    done

    # Move timestamped archives
    for archive in "${base}".2*.md "${base}".session.2*.jsonl "${base}".post.2*.jsonl; do
      [[ -f "$archive" ]] || continue
      mkdir -p "${review_dir}/archives"
      local fname
      fname="$(basename "$archive")"
      fname="${fname#"${dir_name}."}"
      mv "$archive" "${review_dir}/archives/${fname}"
    done

    migrated=$((migrated + 1))
  done
  if [[ "$migrated" -gt 0 ]]; then
    info "Migrated ${migrated} reviews to folder layout"
  fi
}

_migrate_flat_reviews

# ─── Helpers ──────────────────────────────────────────────────────────────────

_repo_from_remote() {
  local -n __out=$1
  local dir="$2"
  local remote_url
  remote_url=$(git -C "$dir" remote get-url origin 2>/dev/null) || true
  if [[ "$remote_url" =~ github\.com[:/]([^/]+/[^/[:space:]]+) ]]; then
    __out="${BASH_REMATCH[1]}"
    __out="${__out%.git}"
  fi
}

_is_pr_ref() {
  local input="$1"
  [[ "$input" =~ $PR_URL_PATTERN || "$input" =~ $PR_NUMBER_PATTERN ]]
}

_self_review_wt_path() {
  local dir="${1:-}"
  if [[ -n "$dir" ]]; then
    git -C "$dir" rev-parse --show-toplevel 2>/dev/null || true
  else
    git rev-parse --show-toplevel 2>/dev/null || true
  fi
}

_self_review_repo() {
  local -n __out=$1
  local dir="$2" wt_path="$3" pr_input="$4"
  if [[ -n "$dir" && -z "$pr_input" ]]; then
    _repo_from_remote __out "${wt_path:-.}"
  else
    _extract_repo __out "${pr_input:-local}"
  fi
}

_extract_pr_number() {
  local -n __out=$1
  local input="$2"
  if [[ "$input" =~ $PR_URL_PATTERN ]]; then
    __out="${BASH_REMATCH[1]}"
  elif [[ "$input" =~ $PR_NUMBER_PATTERN ]]; then
    __out="$input"
  else
    err "Cannot extract PR number from: $input"
    exit 1
  fi
}

_extract_repo() {
  local -n __out=$1
  local input="$2"
  if [[ "$input" =~ $GITHUB_REPO_PATTERN ]]; then
    __out="${BASH_REMATCH[1]}"
  else
    __out=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null) || {
      err "Cannot determine repository from: $input"
      exit 1
    }
  fi
}

_review_file() {
  local -n __out=$1
  local repo_name="${2##*/}"
  local pr_number="$3"
  __out="${REVIEWS_DIR}/${repo_name}-${pr_number}/review${REVIEW_EXT}"
}

_display_review() {
  local file="$1"
  echo
  title "Review"
  echo
  cat "$file"
  echo
}

_format_usage() {
  local logs=()
  local f
  for f in "$@"; do
    if [[ -f "$f" ]]; then logs+=("$f"); fi
  done
  [[ ${#logs[@]} -gt 0 ]] || return 0

  local raw
  raw=$(grep -h '"type":"result"' "${logs[@]}" 2>/dev/null) || return 0
  [[ -n "$raw" ]] || return 0

  local cost tokens duration_ms
  read -r cost tokens duration_ms <<< "$(echo "$raw" | jq -rs '
    {
      cost: (map(.total_cost_usd // 0) | add),
      tokens: (map((.usage.input_tokens // 0) + (.usage.output_tokens // 0) + (.usage.cache_read_input_tokens // 0) + (.usage.cache_creation_input_tokens // 0)) | add),
      duration_ms: (map(.duration_ms // 0) | add)
    } | [.cost, .tokens, .duration_ms] | @tsv
  ' 2>/dev/null)" || return 0

  local tokens_fmt
  if (( tokens >= 1000000 )); then
    tokens_fmt="$(echo "$tokens" | awk '{printf "%.1fM", $1/1000000}')"
  elif (( tokens >= 1000 )); then
    tokens_fmt="$(echo "$tokens" | awk '{printf "%.0fk", $1/1000}')"
  else
    tokens_fmt="$tokens"
  fi

  local duration_s=$(( duration_ms / 1000 ))
  local mins=$(( duration_s / 60 ))
  local secs=$(( duration_s % 60 ))
  local duration_fmt
  if (( mins > 0 )); then
    duration_fmt="${mins}m ${secs}s"
  else
    duration_fmt="${secs}s"
  fi

  local cost_fmt
  cost_fmt=$(printf '$%.2f' "$cost")

  echo -e "  Usage:           ${cost_fmt} · ${tokens_fmt} tokens · ${duration_fmt}"
}

_print_summary() {
  local review_file="$1"
  local session_log="$2"
  local pr_url="${3:-}"
  local post_session_log="${4:-}"
  local branch_name="${5:-}"

  echo
  title "Summary"
  echo -e "  Review:          ${review_file}"
  echo -e "  Session log:     ${session_log}"
  [[ -n "$post_session_log" && -f "$post_session_log" ]] && \
    echo -e "  Post session:    ${post_session_log}"
  if [[ -n "$pr_url" ]]; then
    echo -e "  PR:              ${pr_url}"
  elif [[ -n "$branch_name" ]]; then
    echo -e "  Branch:          ${branch_name}"
  fi
  _format_usage "$session_log" "$post_session_log"
  echo
}

_count_severity() {
  local -n __out=$1
  local file="$2" prefix="$3"
  if [[ ! -f "$file" ]]; then
    __out=0
    return 0
  fi
  __out=$(grep -cE "^\s*- (\[ \] )?\*\*\[${prefix}[0-9]+\]\*\*" "$file" 2>/dev/null) || __out=0
  return 0
}

_json_summary() {
  local repo="$1"
  local pr_number="$2"
  local review_file="$3"

  local total=0 must_count=0
  local jq_args=(
    --arg repo "$repo"
    --arg pr "${pr_number:-}"
    --arg review_file "${review_file:-}"
  )
  local keys_expr=""

  local i
  for i in "${!SEVERITY_PREFIXES[@]}"; do
    local prefix="${SEVERITY_PREFIXES[$i]}"
    local key="${SEVERITY_JSON_KEYS[$i]}"
    local count
    _count_severity count "$review_file" "$prefix"
    total=$(( total + count ))
    jq_args+=(--argjson "$key" "$count")
    keys_expr+="${key}: \$${key}, "
    if [[ "$prefix" == "M" ]]; then must_count=$count; fi
  done

  local verdict="approve"
  if (( must_count > 0 )); then verdict="changes_requested"; fi

  # Extract cost/token/duration from session logs
  local cost_usd=0 input_tokens=0 output_tokens=0
  local cache_read_tokens=0 cache_write_tokens=0 duration_ms=0
  local review_dir
  review_dir="$(dirname "$review_file")"
  local session_log="${review_dir}/${FILENAME_SESSION}"
  local post_session_log="${review_dir}/${FILENAME_POST_SESSION}"
  local logs=()
  [[ -f "$session_log" ]] && logs+=("$session_log")
  [[ -f "$post_session_log" ]] && logs+=("$post_session_log")
  if [[ ${#logs[@]} -gt 0 ]]; then
    local raw
    raw=$(grep -h '"type":"result"' "${logs[@]}" 2>/dev/null) || true
    if [[ -n "$raw" ]]; then
      read -r cost_usd input_tokens output_tokens cache_read_tokens cache_write_tokens duration_ms <<< "$(echo "$raw" | jq -rs '
        {
          cost: (map(.total_cost_usd // 0) | add),
          input: (map(.usage.input_tokens // 0) | add),
          output: (map(.usage.output_tokens // 0) | add),
          cache_read: (map(.usage.cache_read_input_tokens // 0) | add),
          cache_write: (map(.usage.cache_creation_input_tokens // 0) | add),
          duration: (map(.duration_ms // 0) | add)
        } | [.cost, .input, .output, .cache_read, .cache_write, .duration] | @tsv
      ' 2>/dev/null)" || true
    fi
  fi

  local review_content_raw=""
  if [[ -f "$review_file" ]]; then
    review_content_raw=$(cat "$review_file" 2>/dev/null) || true
  fi

  jq_args+=(
    --argjson total "$total" --arg verdict "$verdict"
    --argjson cost_usd "${cost_usd:-0}"
    --argjson input_tokens "${input_tokens:-0}"
    --argjson output_tokens "${output_tokens:-0}"
    --argjson cache_read_tokens "${cache_read_tokens:-0}"
    --argjson cache_write_tokens "${cache_write_tokens:-0}"
    --argjson duration_ms "${duration_ms:-0}"
    --arg review_content "$review_content_raw"
  )

  local json
  json=$(jq -cn "${jq_args[@]}" \
    "{
      repo: \$repo,
      pr_number: (if \$pr == \"\" then null else (\$pr | tonumber) end),
      review_file: \$review_file,
      review_content: (if \$review_content == \"\" then null else \$review_content end),
      findings: { ${keys_expr}total: \$total },
      verdict: \$verdict,
      cost_usd: \$cost_usd,
      input_tokens: \$input_tokens,
      output_tokens: \$output_tokens,
      cache_read_tokens: \$cache_read_tokens,
      cache_write_tokens: \$cache_write_tokens,
      duration_ms: \$duration_ms
    }")
  echo "REVIEW_SUMMARY:${json}"
  return 0
}

_load_issue_provider() {
  local -n __provider=$1
  local -n __provider_opts=$2
  local wt_path="${3:-}"

  __provider="$ISSUE_PROVIDER_DEFAULT"
  __provider_opts=""

  local config_file=""
  if [[ -n "$wt_path" && -f "${wt_path}/.claude/review.yml" ]]; then
    config_file="${wt_path}/.claude/review.yml"
  elif [[ -f "${HOME}/.config/workbench/review.yml" ]]; then
    config_file="${HOME}/.config/workbench/review.yml"
  fi
  [[ -n "$config_file" ]] || return 0

  if command -v yq &>/dev/null; then
    __provider=$(yq -r '.issue_tracker.provider // "linear"' "$config_file" 2>/dev/null) || true
    __provider_opts=$(yq -r '.issue_tracker // {}' "$config_file" 2>/dev/null) || true
  else
    __provider=$(grep -E '^\s*provider:' "$config_file" 2>/dev/null | head -1 | sed 's/.*provider:\s*//' | tr -d ' "'"'" || true)
  fi
  [[ -n "$__provider" ]] || __provider="$ISSUE_PROVIDER_DEFAULT"
}

_extract_issue_id() {
  local -n __id=$1
  local provider="$2"
  local branch_name="$3"
  local pr_body="${4:-}"

  __id=""
  case "$provider" in
    linear|jira)
      __id=$(echo "$branch_name" | grep -oE "$ISSUE_PATTERN_JIRA_LINEAR" | head -1 || true)
      if [[ -z "$__id" && -n "$pr_body" ]]; then
        __id=$(echo "$pr_body" | grep -oE "$ISSUE_PATTERN_JIRA_LINEAR" | head -1 || true)
      fi
      ;;
    github)
      if [[ -n "$pr_body" ]]; then
        local match
        match=$(echo "$pr_body" | grep -oiE '(closes|fixes|resolves)\s+#[0-9]+' | head -1 || true)
        __id=$(echo "$match" | grep -oE '[0-9]+' || true)
      fi
      ;;
    none) ;;
  esac
}

_fetch_issue_context() {
  local -n __link=$1
  local -n __context=$2
  local provider="$3"
  local issue_id="$4"
  local repo="${5:-}"
  local provider_opts="${6:-}"

  __link=""
  __context=""
  [[ -n "$issue_id" ]] || return 0

  case "$provider" in
    linear)
      if command -v linear &>/dev/null; then
        __context=$(linear issue view "$issue_id" --json --no-comments 2>/dev/null) || true
        if [[ -n "$__context" ]]; then echo "✓ Found Linear issue: $issue_id"; fi
      fi
      ;;
    github)
      __link="${GITHUB_BASE_URL}/${repo}/issues/${issue_id}"
      if command -v gh &>/dev/null; then
        __context=$(gh issue view "$issue_id" --repo "$repo" --json title,body,comments 2>/dev/null) || true
        if [[ -n "$__context" ]]; then echo "✓ Found GitHub issue: #${issue_id}"; fi
      fi
      ;;
    jira)
      local jira_url=""
      if command -v yq &>/dev/null && [[ -n "$provider_opts" ]]; then
        jira_url=$(echo "$provider_opts" | yq -r '.jira_url // empty' 2>/dev/null) || true
      fi
      if [[ -n "$jira_url" ]]; then
        __link="${jira_url}/browse/${issue_id}"
      fi
      echo "✓ Found Jira issue: $issue_id"
      ;;
  esac
}

_archive_review() {
  local -n __prior_path=$1
  local review_file="$2"
  local session_log="$3"
  local review_dir
  review_dir="$(dirname "$review_file")"
  local archive_dir="${review_dir}/archives"
  local ts

  __prior_path=""
  if [[ -f "$review_file" ]]; then
    __prior_path="${review_dir}/${FILENAME_PRIOR}"
    cp "$review_file" "$__prior_path"

    mkdir -p "$archive_dir"
    ts=$(date +"$ARCHIVE_TIMESTAMP_FMT")
    mv "$review_file" "${archive_dir}/${ts}${REVIEW_EXT}"
    info "Archived prior review to archives/${ts}${REVIEW_EXT}"
  fi

  if [[ -f "$session_log" ]]; then
    mkdir -p "$archive_dir"
    ts=$(date +"$ARCHIVE_TIMESTAMP_FMT")
    mv "$session_log" "${archive_dir}/${ts}.session.jsonl"
  fi

  local post_log="${review_dir}/${FILENAME_POST_SESSION}"
  if [[ -f "$post_log" ]]; then
    mkdir -p "$archive_dir"
    ts=$(date +"$ARCHIVE_TIMESTAMP_FMT")
    mv "$post_log" "${archive_dir}/${ts}.post.jsonl"
  fi

  # Prune old archives
  local _old_archive
  # shellcheck disable=SC2012
  for _old_archive in $(ls -1t "${review_dir}/archives/"2*"${REVIEW_EXT}" 2>/dev/null | tail -n +$((ARCHIVE_KEEP_COUNT + 1)) || true); do
    rm -f "$_old_archive"
  done
  # shellcheck disable=SC2012
  for _old_archive in $(ls -1t "${review_dir}/archives/"2*.session.jsonl 2>/dev/null | tail -n +$((ARCHIVE_KEEP_COUNT + 1)) || true); do
    rm -f "$_old_archive"
  done
  # shellcheck disable=SC2012
  for _old_archive in $(ls -1t "${review_dir}/archives/"2*.post.jsonl 2>/dev/null | tail -n +$((ARCHIVE_KEEP_COUNT + 1)) || true); do
    rm -f "$_old_archive"
  done
}

_setup_review_worktree() {
  local -n __wt_path=$1
  local repo="$2"
  local pr_number="$3"
  local pr_head="$4"
  local repo_dir="${5:-}"

  local repo_root=""
  _find_repo_root repo_root "$repo" "$repo_dir"
  if [[ -z "$repo_root" ]]; then
    err "Cannot find local clone of ${repo}. Clone it first and re-run from within the repo."
    exit 1
  fi

  # Shallow clones break merge-base resolution — unshallow before worktree setup
  if [[ "$(git -C "$repo_root" rev-parse --is-shallow-repository 2>/dev/null)" == "true" ]]; then
    info "Unshallowing repository..."
    git -C "$repo_root" fetch --unshallow 2>/dev/null || true
  fi

  info "Setting up worktree for PR #${pr_number}..."
  local wt_json wt_fallback="false"
  wt_json=$(wt switch "pr:${pr_number}" --no-cd --no-hooks --format json -y -C "$repo_root" 2>/dev/null | grep '^{') || true
  __wt_path=$(echo "$wt_json" | jq -r '.path // empty' 2>/dev/null) || true

  if [[ -z "$__wt_path" ]]; then
    info "Branch deleted, fetching via PR ref..."
    git -C "$repo_root" fetch origin "pull/${pr_number}/head" 2>/dev/null || {
      err "Failed to fetch PR #${pr_number} ref"
      exit 1
    }
    __wt_path="${repo_root}/${WORKTREE_FALLBACK_DIR}/pr-${pr_number}-review"
    git -C "$repo_root" worktree remove --force "$__wt_path" 2>/dev/null || true
    git -C "$repo_root" worktree add --detach "$__wt_path" FETCH_HEAD 2>/dev/null || {
      err "Failed to create worktree for PR #${pr_number}"
      exit 1
    }
    wt_fallback="true"
    local pr_head_sha
    pr_head_sha=$(gh pr view "$pr_number" --repo "$repo" --json headRefOid --jq '.headRefOid' 2>/dev/null) || true
    info "Created detached worktree at ${pr_head_sha:0:7}"
  else
    git -C "$__wt_path" fetch origin "$pr_head" 2>/dev/null || true
    git -C "$__wt_path" reset --hard "origin/$pr_head" 2>/dev/null || true
  fi

  if [[ "$wt_fallback" == "true" ]]; then
    trap 'git -C "$repo_root" worktree remove --force "$__wt_path" 2>/dev/null || true' EXIT
  else
    trap 'wt remove "$pr_head" --no-hooks --force -y -C "$repo_root" 2>/dev/null || true' EXIT
  fi
}

usage() {
  cat <<EOF
Usage: claude-review [options] <pr_url_or_number>
       claude-review --self [<pr_url_or_number | branch_name>]
       claude-review <command> [args]

Commands:
  <pr_url_or_number>       Run review (default)
$(commands_usage)

Options:
  --no-post                  Skip all interactive prompts; run review and exit
  --post                     Run review then post automatically (leaves review PENDING)
  --submit                   Submit the review (use with --post for fully headless)
  --issue <link>             Attach an issue link for reviewer context
  --max-parallel <N>         Max concurrent group reviews (default: ${DEFAULT_MAX_PARALLEL})
  --max-cost <USD>           Max total review cost in USD (default: 20)
  --model <name>             Override model for all agents (e.g. sonnet, opus)
  --no-holistic              Skip holistic phase in multi-phase reviews
  --self                     Self-review: review your own code (accepts PR number, branch name, or none for current branch)
  --fix                      Apply fixes for review findings (requires --self)
  --skip-user-verification   Skip ownership check in --self mode
  --force                    Skip pending review and stale review warnings
  --repo-dir <path>          Path to local repo or worktree (skips auto-detection; aliases: --repo, --worktree)
  --json-summary             Suppress human output; emit JSON summary to stdout
EOF
}

_check_pending_review() {
  local repo="$1"
  local pr_number="$2"
  local force="$3"

  [[ "$force" == "true" ]] && return 0

  local gh_user
  gh_user=$(gh api user --jq '.login' 2>/dev/null) || true

  local pending_json
  pending_json=$(gh api "repos/${repo}/pulls/${pr_number}/reviews" \
    --jq "[.[] | select(.user.login == \"${gh_user}\" and .state == \"PENDING\")] | first // empty" 2>/dev/null) || true

  if [[ -n "$pending_json" && "$pending_json" != "null" ]]; then
    local pending_id comment_count
    pending_id=$(echo "$pending_json" | jq -r '.id') || true
    comment_count=$(gh api "repos/${repo}/pulls/${pr_number}/reviews/${pending_id}/comments" \
      --jq 'length' 2>/dev/null) || true

    warn "PENDING review exists with ${comment_count:-0} comments (not yet submitted)"
    if confirm "Delete the pending review before re-reviewing?"; then
      gh api "repos/${repo}/pulls/${pr_number}/reviews/${pending_id}" --method DELETE >/dev/null 2>&1 || true
      info "Deleted pending review"
    else
      info "Keeping pending review — new review will replace it at post time"
    fi
  fi
}

_check_stale_review() {
  local repo="$1"
  local pr_number="$2"
  local review_file="$3"
  local force="$4"

  [[ "$force" == "true" ]] && return 0
  [[ -f "$review_file" ]] || return 0

  local review_sha
  review_sha=$(grep -oP '<!-- head_sha: \K[a-f0-9]+' "$review_file" 2>/dev/null | head -1) || true
  [[ -n "$review_sha" ]] || return 0

  local pr_head_sha
  pr_head_sha=$(gh pr view "$pr_number" --repo "$repo" --json headRefOid --jq '.headRefOid' 2>/dev/null) || true
  [[ -n "$pr_head_sha" ]] || return 0

  if [[ "$review_sha" == "$pr_head_sha" ]]; then
    warn "No new commits since the last review (HEAD ${pr_head_sha:0:7})"
    confirm "Re-review anyway?" || exit 0
  else
    info "Incremental review: new commits since last review (${review_sha:0:7}..${pr_head_sha:0:7})"
  fi
}

_append_orchestrate_flags() {
  local -n __args=$1
  local no_holistic="$2"
  local max_cost="$3"
  local model="$4"
  __args+=(--generator-version "$(_generator_version)")
  [[ "$no_holistic" == "true" ]] && __args+=(--no-holistic)
  [[ -n "$max_cost" ]] && __args+=(--max-cost "$max_cost")
  [[ -n "$model" ]] && __args+=(--model "$model")
  return 0
}

_run_orchestrate() {
  "$(dirname "$_SELF")/${ORCHESTRATE_BIN}" "$@"
}

_resolve_prior_review() {
  local -n __prior=$1
  local review_file="$2"
  local session_log="$3"
  local resume="$4"

  local review_dir
  review_dir="$(dirname "$review_file")"

  __prior=""

  # Pipeline state exists — orchestrator handles resume/recovery internally
  if [[ "$resume" == "true" ]]; then
    if [[ -f "${review_dir}/${FILENAME_PRIOR}" ]]; then
      __prior="${review_dir}/${FILENAME_PRIOR}"
    fi
    return
  fi

  _archive_review __prior "$review_file" "$session_log"
}

_cleanup_prior_review() {
  local review_file="$1"
  local prior_review_path="$2"

  local review_dir
  review_dir="$(dirname "$review_file")"
  local pipeline_state="${review_dir}/${FILENAME_PIPELINE_STATE}"
  if [[ ! -f "$pipeline_state" ]]; then
    rm -f "$prior_review_path" 2>/dev/null
  fi
}

# ─── Commands ─────────────────────────────────────────────────────────────────

_run_review() {
  local pr_input="$1"
  local no_post="${2:-false}"
  local issue_link="${3:-}"
  local auto_post="${4:-false}"
  local max_parallel="${5:-$DEFAULT_MAX_PARALLEL}"
  local force="${6:-false}"
  local no_holistic="${7:-false}"
  local max_cost="${8:-}"
  local model="${9:-}"
  local auto_submit="${10:-false}"
  local repo_dir="${11:-}"

  # Headless modes skip interactive prompts
  if [[ "$no_post" == "true" || "$auto_post" == "true" ]]; then
    force="true"
  fi

  _prune_merged_reviews

  local pr_number
  _extract_pr_number pr_number "$pr_input"

  local repo
  _extract_repo repo "$pr_input"

  local review_file
  _review_file review_file "$repo" "$pr_number"
  local review_dir
  review_dir="$(dirname "$review_file")"
  mkdir -p "$review_dir"

  # ── Issue detection: auto-detect from branch/PR body before prompting ──
  local pr_meta
  pr_meta=$(gh pr view "$pr_number" --repo "$repo" --json headRefName,body 2>/dev/null) || true
  local pr_head pr_body
  pr_head=$(echo "$pr_meta" | jq -r '.headRefName // empty' 2>/dev/null) || true
  pr_body=$(echo "$pr_meta" | jq -r '.body // empty' 2>/dev/null) || true

  local issue_context="" detected_link=""
  if [[ -z "$issue_link" ]]; then
    local provider="" provider_opts=""
    _load_issue_provider provider provider_opts ""

    local issue_id=""
    _extract_issue_id issue_id "$provider" "$pr_head" "$pr_body"
    _fetch_issue_context detected_link issue_context "$provider" "$issue_id" "$repo" "$provider_opts"
    if [[ -n "$detected_link" ]]; then issue_link="$detected_link"; fi

    if [[ "$no_post" != "true" && "$auto_post" != "true" && -z "$issue_link" && -z "$issue_context" ]]; then
      read -rp "Issue link (optional, Enter to skip): " issue_link
    fi
  fi

  local pr_url="${GITHUB_BASE_URL}/${repo}/pull/${pr_number}"

  # ── Auto-detect incomplete pipeline (skip stale check if resuming) ──
  local review_dir
  review_dir="$(dirname "$review_file")"
  local has_pipeline_state="false"
  if [[ -f "${review_dir}/${FILENAME_PIPELINE_STATE}" ]]; then
    has_pipeline_state="true"
  fi

  # ── Pre-flight checks ──
  [[ "$has_pipeline_state" != "true" ]] && _check_stale_review "$repo" "$pr_number" "$review_file" "$force"
  _check_pending_review "$repo" "$pr_number" "$force"

  # ── Worktree setup ──
  local wt_path
  _setup_review_worktree wt_path "$repo" "$pr_number" "$pr_head" "$repo_dir"

  local session_log="${review_dir}/${FILENAME_SESSION}"

  local prior_review_path=""
  _resolve_prior_review prior_review_path "$review_file" "$session_log" "$has_pipeline_state"

  # ── Run orchestrator ──
  local orchestrate_args=(
    --repo "$repo"
    --pr "$pr_number"
    --review-file "$review_file"
    --wt-path "$wt_path"
    --reviews-dir "$REVIEWS_DIR"
    --session-log "$session_log"
  )
  [[ -n "$prior_review_path" && -f "$prior_review_path" ]] && orchestrate_args+=(--prior-review "$prior_review_path")
  [[ -n "$issue_link" ]] && orchestrate_args+=(--issue-link "$issue_link")
  [[ -n "$issue_context" ]] && orchestrate_args+=(--issue-context "$issue_context")
  orchestrate_args+=(--max-parallel "$max_parallel")
  _append_orchestrate_flags orchestrate_args "$no_holistic" "$max_cost" "$model"

  if ! _run_orchestrate "${orchestrate_args[@]}"; then
    err "Review orchestration failed"
    [[ -f "$session_log" ]] && echo -e "  Session log: ${session_log}" >&2
    exit 1
  fi

  if [[ ! -f "$review_file" ]]; then
    err "Review orchestration completed but produced no review file"
    [[ -f "$session_log" ]] && echo -e "  Session log: ${session_log}" >&2
    exit 1
  fi

  _cleanup_prior_review "$review_file" "$prior_review_path"

  _display_review "$review_file"

  if [[ "$no_post" == "true" ]]; then
    _print_summary "$review_file" "$session_log" "$pr_url"
    echo -e "  ${DIM}To post later: claude-review post ${pr_number}${NC}"
    return
  fi

  if [[ "$auto_post" == "true" ]]; then
    cmd_post "$repo" "$pr_number" "$auto_submit"
    local post_session_log="${review_dir}/${FILENAME_POST_SESSION}"
    _print_summary "$review_file" "$session_log" "$pr_url" "$post_session_log"
    return
  fi

  if ! confirm "Satisfied with the review?"; then
    _print_summary "$review_file" "$session_log" "$pr_url"
    echo -e "  ${DIM}Edit the file, then run: claude-review post ${pr_number}${NC}"
    exit 0
  fi

  if ! confirm "Post review to GitHub?"; then
    _print_summary "$review_file" "$session_log" "$pr_url"
    echo -e "  ${DIM}To post later: claude-review post ${pr_number}${NC}"
    return
  fi

  cmd_post "$repo" "$pr_number" "false"
  local post_session_log="${review_dir}/${FILENAME_POST_SESSION}"

  if confirm "Submit review now?"; then
    _submit_pending_review "$repo" "$pr_number" "$review_file"
  fi

  _print_summary "$review_file" "$session_log" "$pr_url" "$post_session_log"
}

_verify_pr_ownership() {
  local pr_number="$1"
  local repo="$2"
  local pr_author gh_user
  pr_author=$(gh pr view "$pr_number" --repo "$repo" --json author --jq '.author.login' 2>/dev/null) || true
  gh_user=$(gh api user --jq '.login' 2>/dev/null) || true
  [[ -z "$pr_author" || -z "$gh_user" || "$pr_author" == "$gh_user" ]] && return 0
  warn "PR #${pr_number} is owned by ${pr_author}, not ${gh_user}"
  confirm "Continue with self-review?" || exit 0
}

_find_repo_root() {
  local -n __out=$1
  local repo="$2"
  local explicit_dir="${3:-}"
  local repo_name="${repo##*/}"

  # Explicit path from --repo-dir
  if [[ -n "$explicit_dir" ]]; then
    if [[ -d "$explicit_dir" ]]; then
      __out="$explicit_dir"
      return 0
    fi
    return 1
  fi

  local git_toplevel
  git_toplevel=$(git rev-parse --show-toplevel 2>/dev/null) || true
  if [[ -n "$git_toplevel" ]]; then
    if [[ "$(basename "$git_toplevel")" == "$repo_name" ]]; then
      __out="$git_toplevel"
      return 0
    fi
    # Bare-repo worktree layout: toplevel is <repo>/<branch>, check parent
    local parent_dir
    parent_dir="$(dirname "$git_toplevel")"
    if [[ "$(basename "$parent_dir")" == "$repo_name" ]]; then
      __out="$parent_dir"
      return 0
    fi
  fi

  __out=$(gh repo view "$repo" --json name --jq '.name' 2>/dev/null | xargs -I{} find "$HOME/git" -maxdepth 2 -name "{}" -type d 2>/dev/null | head -1) || true
}

_switch_to_pr_branch() {
  local -n __wt_path=$1
  local -n __wt_cleanup=$2
  local pr_number="$3"
  local repo="$4"

  local pr_head
  pr_head=$(gh pr view "$pr_number" --repo "$repo" --json headRefName --jq '.headRefName' 2>/dev/null) || true
  [[ -n "$pr_head" ]] || return 0

  local current_branch
  current_branch=$(git -C "$__wt_path" rev-parse --abbrev-ref HEAD 2>/dev/null) || true
  [[ "$current_branch" != "$pr_head" ]] || return 0

  local repo_root=""
  _find_repo_root repo_root "$repo"
  [[ -n "$repo_root" ]] || return 0

  info "Switching to branch ${pr_head}..."
  local wt_json switched_path
  wt_json=$(wt switch "$pr_head" --no-cd --no-hooks --format json -y -C "$repo_root" 2>/dev/null | grep '^{') || true
  switched_path=$(echo "$wt_json" | jq -r '.path // empty' 2>/dev/null) || true
  if [[ -n "$switched_path" ]]; then
    __wt_path="$switched_path"
    __wt_cleanup="$pr_head"
    return 0
  fi

  # Fallback: git-native worktree when wt is unavailable
  local sanitized_branch="${pr_head//\//-}"
  local fallback_dir="${repo_root}/self-review-${sanitized_branch}"

  git -C "$repo_root" fetch origin "+refs/heads/${pr_head}:refs/remotes/origin/${pr_head}" 2>/dev/null || true

  if [[ -d "$fallback_dir" ]]; then
    git -C "$repo_root" worktree remove "$fallback_dir" --force 2>/dev/null || true
  fi
  git -C "$repo_root" worktree add --detach "$fallback_dir" "origin/${pr_head}" 2>/dev/null || true

  if [[ -d "$fallback_dir" ]]; then
    __wt_path="$fallback_dir"
    __wt_cleanup="$fallback_dir"
  fi
}

_switch_to_branch() {
  local -n __wt_path=$1
  local -n __wt_cleanup=$2
  local branch="$3"
  local repo="$4"

  local repo_root=""
  _find_repo_root repo_root "$repo"
  [[ -n "$repo_root" ]] || return 0

  info "Switching to branch ${branch}..."
  local wt_json switched_path
  wt_json=$(wt switch "$branch" --no-cd --no-hooks --format json -y -C "$repo_root" 2>/dev/null | grep '^{') || true
  switched_path=$(echo "$wt_json" | jq -r '.path // empty' 2>/dev/null) || true
  if [[ -n "$switched_path" ]]; then
    __wt_path="$switched_path"
    __wt_cleanup="$branch"
    return 0
  fi

  local sanitized_branch="${branch//\//-}"
  local fallback_dir="${repo_root}/self-review-${sanitized_branch}"

  git -C "$repo_root" fetch origin "+refs/heads/${branch}:refs/remotes/origin/${branch}" 2>/dev/null || true

  if [[ -d "$fallback_dir" ]]; then
    git -C "$repo_root" worktree remove "$fallback_dir" --force 2>/dev/null || true
  fi
  git -C "$repo_root" worktree add --detach "$fallback_dir" "origin/${branch}" 2>/dev/null || true

  if [[ -d "$fallback_dir" ]]; then
    __wt_path="$fallback_dir"
    __wt_cleanup="$fallback_dir"
  fi
}

_run_self_review() {
  local pr_input="${1:-}"
  local issue_link="${2:-}"
  local max_parallel="${3:-$DEFAULT_MAX_PARALLEL}"
  local skip_user_verification="${4:-false}"
  local force="${5:-false}"
  local no_holistic="${6:-false}"
  local max_cost="${7:-}"
  local model="${8:-}"
  local repo_dir="${9:-}"
  local fix_pass="${10:-false}"

  _prune_merged_reviews

  # Classify positional argument: PR ref, branch name, or empty
  local is_pr="false" is_branch="false"
  if [[ -n "$pr_input" ]]; then
    if _is_pr_ref "$pr_input"; then
      is_pr="true"
    else
      is_branch="true"
    fi
  fi

  local wt_path
  if [[ -n "$repo_dir" ]]; then
    wt_path=$(git -C "$repo_dir" rev-parse --show-toplevel 2>/dev/null) || {
      err "Not a git repository: $repo_dir"
      exit 1
    }
  else
    wt_path=$(git rev-parse --show-toplevel 2>/dev/null) || {
      err "Not in a git repository — pass --repo-dir to specify the repo"
      exit 1
    }
  fi

  local repo=""
  if [[ "$is_branch" == "true" || (-n "$repo_dir" && -z "$pr_input") ]]; then
    _repo_from_remote repo "$wt_path"
    [[ -n "$repo" ]] || { err "Cannot determine repository from remote URL"; exit 1; }
  else
    _extract_repo repo "${pr_input:-local}"
  fi

  local pr_number=""
  local wt_cleanup=""

  if [[ "$is_pr" == "true" ]]; then
    _extract_pr_number pr_number "$pr_input"
    [[ "$skip_user_verification" == "true" ]] || _verify_pr_ownership "$pr_number" "$repo"
    _switch_to_pr_branch wt_path wt_cleanup "$pr_number" "$repo"
  elif [[ "$is_branch" == "true" ]]; then
    _switch_to_branch wt_path wt_cleanup "$pr_input" "$repo"
  fi

  # ── Review file in centralized reviews directory ──
  local repo_name="${repo##*/}"
  local branch_name
  branch_name=$(git -C "$wt_path" rev-parse --abbrev-ref HEAD 2>/dev/null) || true
  local branch_sanitized="${branch_name//\//-}"
  local self_review_dir="${REVIEWS_DIR}/${repo_name}-self-${branch_sanitized}"
  mkdir -p "$self_review_dir"
  local review_file="${self_review_dir}/review${REVIEW_EXT}"

  local session_log="${self_review_dir}/${FILENAME_SESSION}"

  # ── Auto-detect incomplete pipeline (skip archive if resuming) ──
  local has_pipeline_state="false"
  if [[ -f "${self_review_dir}/${FILENAME_PIPELINE_STATE}" ]]; then
    has_pipeline_state="true"
  fi

  local prior_review_path=""
  _resolve_prior_review prior_review_path "$review_file" "$session_log" "$has_pipeline_state"

  local issue_context=""
  if [[ -z "$issue_link" ]]; then
    local provider="" provider_opts=""
    _load_issue_provider provider provider_opts "$wt_path"

    local issue_id=""
    _extract_issue_id issue_id "$provider" "$branch_name"
    local detected_link=""
    _fetch_issue_context detected_link issue_context "$provider" "$issue_id" "$repo" "$provider_opts"
    if [[ -n "$detected_link" ]]; then issue_link="$detected_link"; fi
  fi

  # ── Run orchestrator ──
  local orchestrate_args=(
    --repo "$repo"
    --review-file "$review_file"
    --wt-path "$wt_path"
    --reviews-dir "$REVIEWS_DIR"
    --session-log "$session_log"
    --mode self
  )
  [[ -n "$pr_number" ]] && orchestrate_args+=(--pr "$pr_number")
  [[ -n "$prior_review_path" && -f "$prior_review_path" ]] && orchestrate_args+=(--prior-review "$prior_review_path")
  [[ -n "$issue_link" ]] && orchestrate_args+=(--issue-link "$issue_link")
  [[ -n "$issue_context" ]] && orchestrate_args+=(--issue-context "$issue_context")
  orchestrate_args+=(--max-parallel "$max_parallel")
  [[ "$fix_pass" == "true" ]] && orchestrate_args+=(--fix)
  _append_orchestrate_flags orchestrate_args "$no_holistic" "$max_cost" "$model"

  if ! _run_orchestrate "${orchestrate_args[@]}"; then
    err "Review orchestration failed"
    [[ -f "$session_log" ]] && echo -e "  Session log: ${session_log}" >&2
    exit 1
  fi

  if [[ ! -f "$review_file" ]]; then
    err "Review orchestration completed but produced no review file"
    [[ -f "$session_log" ]] && echo -e "  Session log: ${session_log}" >&2
    exit 1
  fi

  _cleanup_prior_review "$review_file" "$prior_review_path"

  _display_review "$review_file"

  local pr_url=""
  [[ -n "$pr_number" ]] && pr_url="${GITHUB_BASE_URL}/${repo}/pull/${pr_number}"
  _print_summary "$review_file" "$session_log" "$pr_url" "" "$branch_name"

  # Emit JSON summary before worktree cleanup so review file is still readable
  if [[ -n "${_json_stdout:-}" ]]; then
    _json_summary "$repo" "$pr_number" "$review_file" >&"$_json_stdout"
  fi

  # Clean up worktree if we created one
  if [[ -n "$wt_cleanup" ]]; then
    if [[ -d "$wt_cleanup" ]]; then
      # Git-native worktree — remove by path
      git worktree remove "$wt_cleanup" --force 2>/dev/null || true
    else
      # wt-managed worktree — remove by branch name
      local repo_root
      repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || true
      wt remove "$wt_cleanup" --no-hooks --force -y -C "$repo_root" 2>/dev/null || true
    fi
  fi
}

_submit_pending_review() {
  local repo="$1"
  local pr_number="$2"
  local review_file="$3"

  local review_dir
  review_dir="$(dirname "$review_file")"
  local post_file="${review_dir}/${FILENAME_POST_SESSION}"
  if [[ ! -f "$post_file" ]]; then
    err "No post tracking file found: $post_file"
    return 1
  fi

  local review_id
  review_id=$(jq -r '.review_id' "$post_file" 2>/dev/null) || true
  if [[ -z "$review_id" || "$review_id" == "null" ]]; then
    err "Could not read review_id from $post_file"
    return 1
  fi

  info "Submitting review #${review_id}..."
  gh api "repos/${repo}/pulls/${pr_number}/reviews/${review_id}/events" \
    --method POST -f event=COMMENT >/dev/null 2>&1 \
    && info "Review #${review_id} submitted" \
    || warn "Failed to submit review #${review_id}"

  local tmp
  tmp=$(jq '.submitted = true' "$post_file") && echo "$tmp" > "$post_file"
}


cmd_post() {
  local repo="$1"
  local pr_number="$2"
  local submit="${3:-false}"

  local review_file
  _review_file review_file "$repo" "$pr_number"

  if [[ ! -f "$review_file" ]]; then
    err "No review file found: $review_file"
    echo -e "  ${DIM}Run: claude-review ${pr_number}${NC}"
    exit 1
  fi

  local submit_flag=()
  [[ "$submit" == "true" ]] && submit_flag=(--submit)

  "$(dirname "$_SELF")/review-post" \
    --repo "$repo" \
    --pr "$pr_number" \
    --review-file "$review_file" \
    "${submit_flag[@]}"
}

# ─── Main ─────────────────────────────────────────────────────────────────────

main() {
  local no_post="false"
  local auto_post="false"
  local auto_submit="false"
  local self_review="false"
  local fix_pass="false"
  local skip_user_verification="false"
  local force="false"
  local no_holistic="false"
  local issue_link=""
  local max_parallel="$DEFAULT_MAX_PARALLEL"
  local max_cost=""
  local model=""
  local json_summary="false"
  local repo_dir=""
  local positional=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --no-post)       no_post="true"; shift ;;
      --post)          auto_post="true"; shift ;;
      --submit)        auto_submit="true"; shift ;;
      --self)          self_review="true"; shift ;;
      --fix)           fix_pass="true"; shift ;;
      --skip-user-verification) skip_user_verification="true"; shift ;;
      --force)         force="true"; shift ;;
      --no-holistic)   no_holistic="true"; shift ;;
      --json-summary)  json_summary="true"; shift ;;
      --issue)         issue_link="${2:-}"; [[ -n "$issue_link" ]] || { err "--issue requires a value"; exit 1; }; shift 2 ;;
      --max-parallel)  max_parallel="${2:-}"; [[ -n "$max_parallel" ]] || { err "--max-parallel requires a value"; exit 1; }; shift 2 ;;
      --max-cost)     max_cost="${2:-}"; [[ -n "$max_cost" ]] || { err "--max-cost requires a value"; exit 1; }; shift 2 ;;
      --model)        model="${2:-}"; [[ -n "$model" ]] || { err "--model requires a value"; exit 1; }; shift 2 ;;
      --repo|--repo-dir|--worktree) repo_dir="${2:-}"; [[ -n "$repo_dir" ]] || { err "$1 requires a value"; exit 1; }; shift 2 ;;
      -V|--version)    print_version "claude-review"; exit 0 ;;
      -h|--help)       usage; exit 0 ;;
      *)               positional+=("$1"); shift ;;
    esac
  done

  # When --json-summary is set, redirect stdout to stderr so all human-readable
  # output (info, warn, subprocess progress) goes to stderr. JSON is emitted
  # to the saved original stdout fd at the end.
  local _json_stdout=""
  if [[ "$json_summary" == "true" ]]; then
    exec {_json_stdout}>&1
    exec 1>&2
  fi

  # Fall back to REPO_DIR env var when --repo-dir not specified
  if [[ -z "$repo_dir" && -n "${REPO_DIR:-}" ]]; then
    repo_dir="$REPO_DIR"
  fi

  if [[ "$fix_pass" == "true" && "$self_review" != "true" ]]; then
    err "--fix requires --self"
    exit 1
  fi

  if [[ "$self_review" == "true" ]]; then
    _run_self_review "${positional[0]:-}" "$issue_link" "$max_parallel" "$skip_user_verification" "$force" "$no_holistic" "$max_cost" "$model" "$repo_dir" "$fix_pass"
    if [[ -n "$_json_stdout" ]]; then
      exec {_json_stdout}>&-
    fi
    return
  fi

  if [[ "$no_post" == "true" && "$auto_post" == "true" ]]; then
    err "--no-post and --post are mutually exclusive"
    exit 1
  fi

  local command="${positional[0]:-}"

  case "$command" in
    gc)
      cmd_gc
      ;;
    post)
      local post_input="${positional[1]:-}"
      [[ -n "$post_input" ]] || { err "Usage: claude-review post <pr_url_or_number>"; exit 1; }
      local post_pr_number post_repo
      _extract_pr_number post_pr_number "$post_input"
      _extract_repo post_repo "$post_input"
      cmd_post "$post_repo" "$post_pr_number" "$auto_submit"
      if [[ "$json_summary" == "true" ]]; then
        local post_review_file
        _review_file post_review_file "$post_repo" "$post_pr_number"
        _json_summary "$post_repo" "$post_pr_number" "$post_review_file" >&"$_json_stdout"
        exec {_json_stdout}>&-
      fi
      ;;
    "")
      usage
      exit 1
      ;;
    *)
      _run_review "$command" "$no_post" "$issue_link" "$auto_post" "$max_parallel" "$force" "$no_holistic" "$max_cost" "$model" "$auto_submit" "$repo_dir"
      if [[ "$json_summary" == "true" ]]; then
        local rev_pr_number rev_repo rev_review_file
        _extract_pr_number rev_pr_number "$command"
        _extract_repo rev_repo "$command"
        _review_file rev_review_file "$rev_repo" "$rev_pr_number"
        _json_summary "$rev_repo" "$rev_pr_number" "$rev_review_file" >&"$_json_stdout"
        exec {_json_stdout}>&-
      fi
      ;;
  esac
}

_gc_dir_is_all_stale() {
  local dir="$1"
  local has_stale="false" has_recent="false"
  local _f
  while IFS= read -r -d '' _f; do
    has_stale="true"
    break
  done < <(find "$dir" -type f -mtime +${GC_STALE_DAYS} -print0 2>/dev/null)
  [[ "$has_stale" == "true" ]] || return 1

  while IFS= read -r -d '' _f; do
    has_recent="true"
    break
  done < <(find "$dir" -type f -not -mtime +${GC_STALE_DAYS} -print0 2>/dev/null)
  [[ "$has_recent" == "false" ]]
}

_gc_clean_intermediates() {
  local -n __count=$1
  local review_dir="$2"
  local intermediate
  for intermediate in "${review_dir}"group-*.md "${review_dir}"group-*.jsonl \
                      "${review_dir}"holistic.md "${review_dir}"holistic.jsonl \
                      "${review_dir}"synthesis.jsonl; do
    [[ -f "$intermediate" ]] || continue
    # Keep recent intermediates for debugging
    [[ -n "$(find "$intermediate" -mtime +${GC_STALE_DAYS} -print 2>/dev/null)" ]] || continue
    rm -f "$intermediate"
    __count=$((__count + 1))
  done
}

cmd_gc() {
  local cleaned=0

  for review_dir in "$REVIEWS_DIR"/*/; do
    [[ -d "$review_dir" ]] || continue

    local has_review="false"
    [[ -f "${review_dir}review${REVIEW_EXT}" ]] && has_review="true"

    # No review file and all files stale — remove entire directory
    if [[ "$has_review" == "false" ]] && _gc_dir_is_all_stale "$review_dir"; then
      rm -rf "$review_dir"
      info "GC: removed orphaned $(basename "${review_dir%/}")"
      cleaned=$((cleaned + 1))
      continue
    fi

    # Completed review (no pipeline) — remove intermediates older than GC_STALE_DAYS
    local has_pipeline="false"
    [[ -f "${review_dir}${FILENAME_PIPELINE_STATE}" ]] && has_pipeline="true"

    if [[ "$has_review" == "true" && "$has_pipeline" == "false" ]]; then
      _gc_clean_intermediates cleaned "$review_dir"
    fi
  done

  if [[ "$cleaned" -gt 0 ]]; then
    info "GC: cleaned ${cleaned} items"
  else
    info "GC: nothing to clean"
  fi
}

PRUNE_MAX_FILES=10

_prune_merged_reviews() {
  local pruned=0 checked=0

  for meta_file in "$REVIEWS_DIR"/*/meta.json; do
    [[ -f "$meta_file" ]] || continue
    (( checked >= PRUNE_MAX_FILES )) && break

    local repo pr_number
    read -r repo pr_number <<< "$(jq -r '[.repo // "", .pr_number // ""] | @tsv' "$meta_file" 2>/dev/null)" || continue

    if [[ -z "$repo" || -z "$pr_number" ]]; then
      continue
    fi

    checked=$((checked + 1))

    local state
    state=$(gh pr view "$pr_number" --repo "$repo" --json state --jq .state 2>/dev/null) || state=""

    if [[ "$state" == "MERGED" || "$state" == "CLOSED" ]]; then
      local review_dir
      review_dir="$(dirname "$meta_file")"
      rm -rf "$review_dir"
      info "Pruned ${repo}#${pr_number} (${state})"
      pruned=$((pruned + 1))
    fi
  done

  if [[ "$pruned" -gt 0 ]]; then
    info "Pruned ${pruned} merged/closed PRs"
  fi
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
