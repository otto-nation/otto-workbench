#!/usr/bin/env bash
# Run Claude's reviewer agent on a PR with local worktree checkout and iterative review support.
#
# Usage: claude-review [options] <pr_url_or_number>
#        claude-review post <pr_url_or_number>
#
# Commands:
#   <pr_url_or_number>   Run headless review, display results, prompt to post
#   post <pr_url_or_number>  Post an existing review file headlessly via poster agent
#
# Options:
#   --no-post            Skip all interactive prompts; run review and exit
#   --post               Run review then post automatically (fully headless)
#   --issue <link>       Attach an issue link for reviewer context
#
# When calling from Claude Code:
#   Run each review in a foreground Bash call (not backgrounded with &).
#   To review multiple PRs in parallel, use the Agent tool to dispatch
#   separate subagents — each runs one `claude-review --no-post <N>` call.

set -eo pipefail

_SELF="$(readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
# shellcheck source=/dev/null
. "$(dirname "$_SELF")/../../../lib/ui.sh"

REVIEWS_DIR="$HOME/.config/workbench/reviews"
mkdir -p "$REVIEWS_DIR"

# Migrate reviews from legacy location
if [[ -d "$HOME/.claude/reviews" ]]; then
  mv "$HOME/.claude/reviews"/*.md "$REVIEWS_DIR/" 2>/dev/null || true
  mv "$HOME/.claude/reviews"/*.jsonl "$REVIEWS_DIR/" 2>/dev/null || true
fi

# ─── Helpers ──────────────────────────────────────────────────────────────────

_extract_pr_number() {
  local -n __out=$1
  local input="$2"
  if [[ "$input" =~ /pull/([0-9]+) ]]; then
    __out="${BASH_REMATCH[1]}"
  elif [[ "$input" =~ ^[0-9]+$ ]]; then
    __out="$input"
  else
    err "Cannot extract PR number from: $input"
    exit 1
  fi
}

_extract_repo() {
  local -n __out=$1
  local input="$2"
  if [[ "$input" =~ github\.com/([^/]+/[^/]+) ]]; then
    __out="${BASH_REMATCH[1]}"
  else
    __out=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null) || {
      err "Cannot determine repository from: $input"
      exit 1
    }
  fi
}

_review_file() {
  local -n __out=$1
  local repo_name="${2##*/}"
  local pr_number="$3"
  __out="${REVIEWS_DIR}/${repo_name}-${pr_number}.md"
}

_display_review() {
  local file="$1"
  echo
  title "Review"
  echo
  cat "$file"
  echo
}

_print_summary() {
  local review_file="$1"
  local session_log="$2"
  local pr_url="$3"
  local post_session_log="${4:-}"

  echo
  title "Summary"
  echo -e "  Review:          ${review_file}"
  echo -e "  Session log:     ${session_log}"
  [[ -n "$post_session_log" && -f "$post_session_log" ]] && \
    echo -e "  Post session:    ${post_session_log}"
  echo -e "  PR:              ${pr_url}"
  echo
}

usage() {
  echo "Usage: claude-review [options] <pr_url_or_number>"
  echo "       claude-review post <pr_number>"
  echo
  echo "Options:"
  echo "  --no-post          Skip all interactive prompts; run review and exit"
  echo "  --post             Run review then post automatically (fully headless)"
  echo "  --issue <link>     Attach an issue link for reviewer context"
}

# ─── Commands ─────────────────────────────────────────────────────────────────

cmd_review() {
  local pr_input="$1"
  local no_post="${2:-false}"
  local issue_link="${3:-}"
  local auto_post="${4:-false}"

  local pr_number
  _extract_pr_number pr_number "$pr_input"

  local repo
  _extract_repo repo "$pr_input"

  local review_file
  _review_file review_file "$repo" "$pr_number"

  if [[ "$no_post" != "true" && "$auto_post" != "true" && -z "$issue_link" ]]; then
    read -rp "Issue link (optional, Enter to skip): " issue_link
  fi

  # Auto-fetch Linear issue from branch name
  local issue_context=""
  local pr_head
  pr_head=$(gh pr view "$pr_number" --repo "$repo" --json headRefName --jq '.headRefName' 2>/dev/null) || true
  local issue_id
  issue_id=$(echo "$pr_head" | grep -oE '[A-Z]+-[0-9]+' | head -1 || true)
  if [[ -z "$issue_link" && -n "$issue_id" ]] && command -v linear &>/dev/null; then
    issue_context=$(linear issue view "$issue_id" --json --no-comments 2>/dev/null) || true
    [[ -n "$issue_context" ]] && echo "✓ Found Linear issue: $issue_id"
  fi

  local pr_url="https://github.com/${repo}/pull/${pr_number}"

  # ── Worktree setup ──
  local repo_root=""
  local git_toplevel
  git_toplevel=$(git rev-parse --show-toplevel 2>/dev/null) || true
  local repo_name="${repo##*/}"
  if [[ -n "$git_toplevel" ]] && [[ "$(basename "$git_toplevel")" == "$repo_name" ]]; then
    repo_root="$git_toplevel"
  else
    repo_root=$(gh repo view "$repo" --json name --jq '.name' 2>/dev/null | xargs -I{} find "$HOME/git" -maxdepth 2 -name "{}" -type d 2>/dev/null | head -1) || true
  fi
  if [[ -z "$repo_root" ]]; then
    err "Cannot find local clone of ${repo}. Clone it first and re-run from within the repo."
    exit 1
  fi

  info "Setting up worktree for PR #${pr_number}..."
  local wt_json wt_path wt_fallback="false"
  wt_json=$(wt switch "pr:${pr_number}" --no-cd --no-hooks --format json -y -C "$repo_root" 2>/dev/null | grep '^{') || true
  wt_path=$(echo "$wt_json" | jq -r '.path // empty' 2>/dev/null) || true

  if [[ -z "$wt_path" ]]; then
    info "Branch deleted, fetching via PR ref..."
    git -C "$repo_root" fetch origin "pull/${pr_number}/head" 2>/dev/null || {
      err "Failed to fetch PR #${pr_number} ref"
      exit 1
    }
    wt_path="${repo_root}/.worktrees/pr-${pr_number}-review"
    git -C "$repo_root" worktree add --detach "$wt_path" FETCH_HEAD 2>/dev/null || {
      err "Failed to create worktree for PR #${pr_number}"
      exit 1
    }
    wt_fallback="true"
    local pr_head_sha
    pr_head_sha=$(gh pr view "$pr_number" --repo "$repo" --json headRefOid --jq '.headRefOid' 2>/dev/null) || true
    info "Created detached worktree at ${pr_head_sha:0:7}"
  else
    git -C "$wt_path" fetch origin "$pr_head" 2>/dev/null || true
    git -C "$wt_path" reset --hard "origin/$pr_head" 2>/dev/null || true
  fi

  if [[ "$wt_fallback" == "true" ]]; then
    trap 'git -C "$repo_root" worktree remove --force "$wt_path" 2>/dev/null || true' EXIT
  else
    trap 'wt remove "$pr_head" --no-hooks --force -y -C "$repo_root" 2>/dev/null || true' EXIT
  fi

  # ── Archive management ──
  local prior_review_path=""
  if [[ -f "$review_file" ]]; then
    prior_review_path="${review_file%.md}.prior.md"
    cp "$review_file" "$prior_review_path"
    local archive
    archive="${review_file%.md}.$(date +%Y%m%d-%H%M%S).md"
    mv "$review_file" "$archive"
    info "Archived prior review to $(basename "$archive")"
  fi

  local session_log="${review_file%.md}.session.jsonl"
  if [[ -f "$session_log" ]]; then
    mv "$session_log" "${session_log%.jsonl}.$(date +%Y%m%d-%H%M%S).jsonl"
  fi

  # Prune old archives — keep latest 3
  local _old_archive
  # shellcheck disable=SC2012
  for _old_archive in $(ls -t "${review_file%.md}".2*.md 2>/dev/null | tail -n +4); do
    rm -f "$_old_archive"
  done
  # shellcheck disable=SC2012
  for _old_archive in $(ls -t "${review_file%.md}".session.2*.jsonl 2>/dev/null | tail -n +4); do
    rm -f "$_old_archive"
  done

  # ── Run orchestrator ──
  local orchestrate_args=(
    --repo "$repo"
    --pr "$pr_number"
    --review-file "$review_file"
    --wt-path "$wt_path"
    --reviews-dir "$REVIEWS_DIR"
    --session-log "$session_log"
  )
  [[ -n "$prior_review_path" && -f "$prior_review_path" ]] && orchestrate_args+=(--prior-review "$prior_review_path")
  [[ -n "$issue_link" ]] && orchestrate_args+=(--issue-link "$issue_link")
  [[ -n "$issue_context" ]] && orchestrate_args+=(--issue-context "$issue_context")

  "$(dirname "$_SELF")/review-orchestrate" "${orchestrate_args[@]}"

  # Clean up temporary prior review copy
  rm -f "$prior_review_path" 2>/dev/null || true

  _display_review "$review_file"

  if [[ "$no_post" == "true" ]]; then
    _print_summary "$review_file" "$session_log" "$pr_url"
    echo -e "  ${DIM}To post later: claude-review post ${pr_number}${NC}"
    return
  fi

  if [[ "$auto_post" == "true" ]]; then
    cmd_post "$repo" "$pr_number"
    local post_session_log="${review_file%.md}.post.jsonl"
    _print_summary "$review_file" "$session_log" "$pr_url" "$post_session_log"
    return
  fi

  if ! confirm "Satisfied with the review?"; then
    _print_summary "$review_file" "$session_log" "$pr_url"
    echo -e "  ${DIM}Edit the file, then run: claude-review post ${pr_number}${NC}"
    exit 0
  fi

  if confirm "Post review to GitHub?"; then
    cmd_post "$repo" "$pr_number"
    local post_session_log="${review_file%.md}.post.jsonl"
    _print_summary "$review_file" "$session_log" "$pr_url" "$post_session_log"
  else
    _print_summary "$review_file" "$session_log" "$pr_url"
    echo -e "  ${DIM}To post later: claude-review post ${pr_number}${NC}"
  fi
}

cmd_post() {
  local repo="$1"
  local pr_number="$2"

  local review_file
  _review_file review_file "$repo" "$pr_number"

  if [[ ! -f "$review_file" ]]; then
    err "No review file found: $review_file"
    echo -e "  ${DIM}Run: claude-review ${pr_number}${NC}"
    exit 1
  fi

  local post_prompt
  post_prompt="Post review for PR #${pr_number} in ${repo}. Review file: ${review_file}"

  local skill_file
  skill_file="$(dirname "$_SELF")/../skills/pr-review/SKILL.md"

  local session_log="${review_file%.md}.post.jsonl"

  info "Posting review for PR #${pr_number}..."
  echo
  echo "$post_prompt" | claude -p --verbose --output-format stream-json \
    --permission-mode acceptEdits \
    --system-prompt-file "$skill_file" \
    --add-dir "$REVIEWS_DIR" \
    | "$(dirname "$_SELF")/review-stream-progress" "$session_log"
  echo

  local pending_review_id
  pending_review_id=$(gh api "repos/${repo}/pulls/${pr_number}/reviews" \
    --jq '[.[] | select(.state == "PENDING")] | first | .id' 2>/dev/null) || true

  info "Done. Review is PENDING — verify and submit from the GitHub UI."
  if [[ -n "$pending_review_id" && "$pending_review_id" != "null" ]]; then
    echo
    echo -e "  ${DIM}Submit: gh api repos/${repo}/pulls/${pr_number}/reviews/${pending_review_id}/events --method POST -f event=\"COMMENT\"${NC}"
  fi
}

# ─── Main ─────────────────────────────────────────────────────────────────────

main() {
  local no_post="false"
  local auto_post="false"
  local issue_link=""
  local positional=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --no-post)   no_post="true"; shift ;;
      --post)      auto_post="true"; shift ;;
      --issue)     issue_link="${2:-}"; [[ -n "$issue_link" ]] || { err "--issue requires a value"; exit 1; }; shift 2 ;;
      -h|--help)   usage; exit 0 ;;
      *)           positional+=("$1"); shift ;;
    esac
  done

  if [[ "$no_post" == "true" && "$auto_post" == "true" ]]; then
    err "--no-post and --post are mutually exclusive"
    exit 1
  fi

  local command="${positional[0]:-}"

  case "$command" in
    post)
      local post_input="${positional[1]:-}"
      [[ -n "$post_input" ]] || { err "Usage: claude-review post <pr_url_or_number>"; exit 1; }
      local post_pr_number post_repo
      _extract_pr_number post_pr_number "$post_input"
      _extract_repo post_repo "$post_input"
      cmd_post "$post_repo" "$post_pr_number"
      ;;
    "")
      usage
      exit 1
      ;;
    *)
      cmd_review "$command" "$no_post" "$issue_link" "$auto_post"
      ;;
  esac
}

main "$@"
