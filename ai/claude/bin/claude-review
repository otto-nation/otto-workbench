#!/usr/bin/env python3
"""Run Claude's reviewer agent on a PR with local worktree checkout and iterative review support."""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import signal
import subprocess
import sys
from datetime import datetime
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

import pr_context
import pr_state
try:
    from _version import version_string
except ImportError:
    def version_string(name):
        vf = Path(__file__).resolve().parent.parent / "VERSION"
        return f"{name} {vf.read_text().strip()}" if vf.is_file() else f"{name} unknown"
from review_common import (
    ANSI_DIM, ANSI_ERR, ANSI_INFO, ANSI_RESET, ANSI_WARN,
    ReviewMeta, SessionUsage, detect_repo, parse_session_log,
    review_meta_from_dict,
)
import review_issue
import review_worktree

BIN_DIR = Path(__file__).resolve().parent
REVIEWS_DIR = Path(os.environ.get("WORKBENCH_STATE_DIR", os.path.expanduser("~/.config/workbench"))) / "reviews"
LEGACY_REVIEWS_DIR = Path(os.environ.get("CLAUDE_DIR", os.path.expanduser("~/.claude"))) / "reviews"

REVIEW_EXT = ".md"
FILENAME_PRIOR = f"prior{REVIEW_EXT}"
FILENAME_SESSION = "session.jsonl"
FILENAME_POST_SESSION = "post.jsonl"
FILENAME_META = "meta.json"
FILENAME_PIPELINE_STATE = "pipeline.json"

ARCHIVE_KEEP_COUNT = 3
GC_STALE_DAYS = 7
DEFAULT_MAX_PARALLEL = 4
GITHUB_BASE_URL = "https://github.com"
PRUNE_MAX_FILES = 10

SEVERITY_PREFIXES = ["M", "S", "N", "I"]
SEVERITY_JSON_KEYS = ["must_fix", "should_fix", "nit", "idiom"]
ARCHIVE_TIMESTAMP_FMT = "%Y%m%d-%H%M%S"

PR_URL_RE = re.compile(r"/pull/(\d+)")
PR_NUMBER_RE = re.compile(r"^\d+$")
GITHUB_REPO_RE = re.compile(r"github\.com/([^/]+/[^/]+)")
SEVERITY_COUNT_RE_FMT = r"^\s*- (\[ \] )?\*\*\[{}[0-9]+\]\*\*"


def _info(msg: str) -> None:
    print(f"{ANSI_INFO} {msg}", file=sys.stderr, flush=True)


def _warn(msg: str) -> None:
    print(f"{ANSI_WARN} {msg}", file=sys.stderr, flush=True)


def _err(msg: str) -> None:
    print(f"{ANSI_ERR} {msg}", file=sys.stderr, flush=True)


# ── Startup migrations ──────────────────────────────────────────────────────

def _migrate_legacy_reviews() -> None:
    if not LEGACY_REVIEWS_DIR.is_dir():
        return
    files = [f for p in ("*.md", "*.jsonl") for f in LEGACY_REVIEWS_DIR.glob(p)]
    for f in files:
        dest = REVIEWS_DIR / f.name
        if not dest.exists():
            shutil.move(str(f), str(dest))


def _migrate_one_flat_review(flat_review: Path, dir_name: str) -> None:
    review_dir = REVIEWS_DIR / dir_name
    review_dir.mkdir(parents=True, exist_ok=True)
    shutil.move(str(flat_review), str(review_dir / f"review{REVIEW_EXT}"))

    suffix_map = {
        ".session.jsonl": "session.jsonl",
        ".meta.json": "meta.json",
        ".post.jsonl": "post.jsonl",
        ".pipeline.json": "pipeline.json",
        ".prior.md": "prior.md",
    }
    for suffix, new_name in suffix_map.items():
        flat_file = REVIEWS_DIR / f"{dir_name}{suffix}"
        if flat_file.is_file():
            shutil.move(str(flat_file), str(review_dir / new_name))

    intermediate_patterns = (
        f"{dir_name}.group-*.md", f"{dir_name}.group-*.jsonl",
        f"{dir_name}.holistic.md", f"{dir_name}.holistic.jsonl",
        f"{dir_name}.synthesis.jsonl",
    )
    intermediates = [f for p in intermediate_patterns for f in REVIEWS_DIR.glob(p)]
    for intermediate in intermediates:
        fname = intermediate.name.removeprefix(f"{dir_name}.")
        shutil.move(str(intermediate), str(review_dir / fname))

    archive_dir = review_dir / "archives"
    archive_patterns = (f"{dir_name}.2*.md", f"{dir_name}.session.2*.jsonl", f"{dir_name}.post.2*.jsonl")
    archives = [f for p in archive_patterns for f in REVIEWS_DIR.glob(p)]
    for archive in archives:
        archive_dir.mkdir(exist_ok=True)
        fname = archive.name.removeprefix(f"{dir_name}.")
        shutil.move(str(archive), str(archive_dir / fname))


def _migrate_flat_reviews() -> None:
    migrated = 0
    for flat_review in REVIEWS_DIR.glob(f"*{REVIEW_EXT}"):
        if not flat_review.is_file():
            continue
        dir_name = flat_review.stem
        review_dir = REVIEWS_DIR / dir_name
        if review_dir.is_dir():
            continue
        _migrate_one_flat_review(flat_review, dir_name)
        migrated += 1

    if migrated > 0:
        _info(f"Migrated {migrated} reviews to folder layout")


# ── Helpers ──────────────────────────────────────────────────────────────────

def _confirm(prompt: str) -> bool:
    try:
        is_tty = sys.stdin.isatty()
    except (EOFError, OSError):
        return True
    if is_tty:
        try:
            answer = input(f"{prompt} [Y/n] ")
        except (EOFError, OSError):
            return True
        return answer.lower() in ("", "y", "yes")
    try:
        with open("/dev/tty") as tty:
            print(f"{prompt} [Y/n] ", end="", flush=True, file=sys.stderr)
            answer = tty.readline().strip()
    except (EOFError, OSError):
        return True
    return answer.lower() in ("", "y", "yes")


def _prompt_optional(prompt: str) -> str:
    try:
        if sys.stdin.isatty():
            return input(prompt)
        with open("/dev/tty") as tty:
            print(prompt, end="", flush=True, file=sys.stderr)
            return tty.readline().strip()
    except (EOFError, OSError):
        return ""


def _is_pr_ref(s: str) -> bool:
    return bool(PR_URL_RE.search(s) or PR_NUMBER_RE.match(s))


def _extract_pr_number(pr_input: str) -> str:
    m = PR_URL_RE.search(pr_input)
    if m:
        return m.group(1)
    if PR_NUMBER_RE.match(pr_input):
        return pr_input
    _err(f"Cannot extract PR number from: {pr_input}")
    sys.exit(1)


def _extract_repo(pr_input: str) -> str:
    m = GITHUB_REPO_RE.search(pr_input)
    if m:
        repo = m.group(1)
        return repo.removesuffix(".git")
    r = subprocess.run(
        ["gh", "repo", "view", "--json", "nameWithOwner", "-q", ".nameWithOwner"],
        capture_output=True, text=True,
    )
    if r.returncode == 0 and r.stdout.strip():
        return r.stdout.strip()
    _err(f"Cannot determine repository from: {pr_input}")
    sys.exit(1)


def _review_file(repo: str, pr_number: str) -> Path:
    repo_name = repo.split("/")[-1]
    return REVIEWS_DIR / f"{repo_name}-{pr_number}" / f"review{REVIEW_EXT}"


def _display_review(path: Path) -> None:
    print()
    print("\033[1m─── Review ───\033[0m", file=sys.stderr)
    print()
    print(path.read_text())
    print()


def _format_usage(*log_paths: str) -> str:
    logs = [p for p in log_paths if p and os.path.isfile(p)]
    if not logs:
        return ""

    usages = [parse_session_log(p) for p in logs]
    cost = sum(u.cost for u in usages)
    tokens = sum(u.total_tokens for u in usages)
    duration_ms = sum(u.duration_ms for u in usages)

    if cost == 0.0 and tokens == 0 and duration_ms == 0:
        return ""

    if tokens >= 1_000_000:
        tokens_fmt = f"{tokens / 1_000_000:.1f}M"
    elif tokens >= 1000:
        tokens_fmt = f"{tokens // 1000}k"
    else:
        tokens_fmt = str(tokens)

    duration_s = duration_ms // 1000
    mins, secs = divmod(duration_s, 60)
    duration_fmt = f"{mins}m {secs}s" if mins > 0 else f"{secs}s"
    cost_fmt = f"${cost:.2f}"

    return f"  Usage:           {cost_fmt} · {tokens_fmt} tokens · {duration_fmt}"


def _print_summary(
    review_file: str,
    session_log: str,
    pr_url: str = "",
    post_session_log: str = "",
    branch_name: str = "",
) -> None:
    print(file=sys.stderr)
    print("\033[1m─── Summary ───\033[0m", file=sys.stderr)
    print(f"  Review:          {review_file}", file=sys.stderr)
    print(f"  Session log:     {session_log}", file=sys.stderr)
    if post_session_log and os.path.isfile(post_session_log):
        print(f"  Post session:    {post_session_log}", file=sys.stderr)
    if pr_url:
        print(f"  PR:              {pr_url}", file=sys.stderr)
    elif branch_name:
        print(f"  Branch:          {branch_name}", file=sys.stderr)
    usage_line = _format_usage(session_log, post_session_log)
    if usage_line:
        print(usage_line, file=sys.stderr)
    print(file=sys.stderr)


def _count_severity(file: Path, prefix: str) -> int:
    if not file.is_file():
        return 0
    try:
        text = file.read_text()
    except OSError:
        return 0
    pattern = SEVERITY_COUNT_RE_FMT.format(re.escape(prefix))
    return len(re.findall(pattern, text, re.MULTILINE))



def _read_review_meta(review_dir: Path) -> ReviewMeta:
    meta_file = review_dir / FILENAME_META
    if not meta_file.is_file():
        return ReviewMeta()
    try:
        return review_meta_from_dict(json.loads(meta_file.read_text()))
    except (json.JSONDecodeError, OSError):
        return ReviewMeta()


def _aggregate_session_usage(review_dir: Path | None) -> SessionUsage:
    if not review_dir:
        return SessionUsage()
    usages = [
        parse_session_log(str(review_dir / n))
        for n in (FILENAME_SESSION, FILENAME_POST_SESSION)
        if os.path.isfile(str(review_dir / n))
    ]
    if not usages:
        return SessionUsage()
    return SessionUsage(
        cost=sum(u.cost for u in usages),
        input_tokens=sum(u.input_tokens for u in usages),
        output_tokens=sum(u.output_tokens for u in usages),
        cache_read_tokens=sum(u.cache_read_tokens for u in usages),
        cache_write_tokens=sum(u.cache_write_tokens for u in usages),
        duration_ms=sum(u.duration_ms for u in usages),
    )


def _json_summary(repo: str, pr_number: str, review_file: str) -> str:
    counts = {}
    total = 0
    review_path = Path(review_file) if review_file else None
    for prefix, key in zip(SEVERITY_PREFIXES, SEVERITY_JSON_KEYS):
        c = _count_severity(review_path, prefix) if review_path else 0
        counts[key] = c
        total += c

    must_count = counts.get("must_fix", 0)
    verdict = "changes_requested" if must_count > 0 else "approve"

    review_dir = Path(review_file).parent if review_file else None
    usage = _aggregate_session_usage(review_dir)

    review_content = None
    if review_path and review_path.is_file():
        try:
            review_content = review_path.read_text()
        except OSError:
            pass

    meta = _read_review_meta(review_dir) if review_dir else ReviewMeta()

    summary = {
        "repo": repo,
        "pr_number": int(pr_number) if pr_number else None,
        "head_sha": meta.head_sha or None,
        "head_ref": meta.head_ref or None,
        "base_ref": meta.base_ref or None,
        "review_type": meta.review_type or None,
        "review_file": review_file,
        "review_content": review_content,
        "findings": {**counts, "total": total},
        "verdict": verdict,
        "cost_usd": usage.cost,
        "input_tokens": usage.input_tokens,
        "output_tokens": usage.output_tokens,
        "cache_read_tokens": usage.cache_read_tokens,
        "cache_write_tokens": usage.cache_write_tokens,
        "duration_ms": usage.duration_ms,
    }
    return f"REVIEW_SUMMARY:{json.dumps(summary)}"


def _update_pr_state(repo: str, pr_number: str, review_file: str, repo_dir: str, review_type: str = "") -> None:
    if not repo_dir or not review_file or not os.path.isfile(review_file):
        return

    review_path = Path(review_file)
    review_dir = review_path.parent

    finding_counts = {}
    for prefix, key in zip(SEVERITY_PREFIXES, SEVERITY_JSON_KEYS):
        c = _count_severity(review_path, prefix)
        if c > 0:
            finding_counts[key] = c

    must_count = finding_counts.get("must_fix", 0)
    verdict = "changes_requested" if must_count > 0 else "approve"
    meta = _read_review_meta(review_dir)
    usage = _aggregate_session_usage(review_dir)

    summary = pr_state.ReviewSummary(
        review_file=review_file,
        review_type=meta.review_type or review_type,
        head_sha=meta.head_sha,
        finding_counts=finding_counts,
        verdict=verdict,
        cost_usd=usage.cost,
        updated_at=pr_state.now_iso(),
    )

    try:
        ctx = pr_context.resolve(repo_dir=repo_dir)
    except SystemExit:
        return

    try:
        pr_state.apply_state_update(
            worktree_root=ctx.worktree_root,
            repo=ctx.repo,
            branch=ctx.branch,
            pr_number=ctx.pr_number,
            head_sha=ctx.head_sha,
            domain="review",
            data=pr_state._review_to_dict(summary),
        )
    except Exception:
        pass


def _archive_review(review_file: Path, session_log: str) -> str:
    review_dir = review_file.parent
    archive_dir = review_dir / "archives"
    prior_path = ""

    if review_file.is_file():
        prior_path = str(review_dir / FILENAME_PRIOR)
        shutil.copy2(str(review_file), prior_path)

        archive_dir.mkdir(exist_ok=True)
        ts = datetime.now().strftime(ARCHIVE_TIMESTAMP_FMT)
        shutil.move(str(review_file), str(archive_dir / f"{ts}{REVIEW_EXT}"))
        _info(f"Archived prior review to archives/{ts}{REVIEW_EXT}")

    if os.path.isfile(session_log):
        archive_dir.mkdir(exist_ok=True)
        ts = datetime.now().strftime(ARCHIVE_TIMESTAMP_FMT)
        shutil.move(session_log, str(archive_dir / f"{ts}.session.jsonl"))

    post_log = str(review_dir / FILENAME_POST_SESSION)
    if os.path.isfile(post_log):
        archive_dir.mkdir(exist_ok=True)
        ts = datetime.now().strftime(ARCHIVE_TIMESTAMP_FMT)
        shutil.move(post_log, str(archive_dir / f"{ts}.post.jsonl"))

    # Prune old archives
    for suffix in (REVIEW_EXT, ".session.jsonl", ".post.jsonl"):
        pattern = f"2*{suffix}"
        archives = sorted(archive_dir.glob(pattern), reverse=True) if archive_dir.is_dir() else []
        for old in archives[ARCHIVE_KEEP_COUNT:]:
            old.unlink(missing_ok=True)

    return prior_path


def _resolve_prior_review(review_file: Path, session_log: str, resume: bool) -> str:
    review_dir = review_file.parent
    if resume:
        prior = review_dir / FILENAME_PRIOR
        if prior.is_file():
            return str(prior)
        return ""
    return _archive_review(review_file, session_log)


def _cleanup_prior_review(review_file: Path, prior_path: str) -> None:
    if not prior_path:
        return
    review_dir = review_file.parent
    pipeline_state = review_dir / FILENAME_PIPELINE_STATE
    if not pipeline_state.is_file():
        try:
            os.unlink(prior_path)
        except OSError:
            pass


def _check_pending_review(repo: str, pr_number: str, force: bool) -> None:
    if force:
        return

    gh_user = ""
    try:
        r = subprocess.run(
            ["gh", "api", "user", "--jq", ".login"],
            capture_output=True, text=True,
        )
        gh_user = r.stdout.strip()
    except Exception:
        pass

    try:
        r = subprocess.run(
            ["gh", "api", f"repos/{repo}/pulls/{pr_number}/reviews",
             "--jq", f'[.[] | select(.user.login == "{gh_user}" and .state == "PENDING")] | first // empty'],
            capture_output=True, text=True,
        )
        pending_json = r.stdout.strip()
    except Exception:
        pending_json = ""

    if not pending_json or pending_json == "null":
        return

    try:
        pending = json.loads(pending_json)
        pending_id = pending.get("id")
    except (json.JSONDecodeError, TypeError):
        return

    comment_count = "0"
    try:
        r = subprocess.run(
            ["gh", "api", f"repos/{repo}/pulls/{pr_number}/reviews/{pending_id}/comments",
             "--jq", "length"],
            capture_output=True, text=True,
        )
        comment_count = r.stdout.strip() or "0"
    except Exception:
        pass

    _warn(f"PENDING review exists with {comment_count} comments (not yet submitted)")
    if not _confirm("Delete the pending review before re-reviewing?"):
        _info("Keeping pending review — new review will replace it at post time")
        return

    try:
        subprocess.run(
            ["gh", "api", f"repos/{repo}/pulls/{pr_number}/reviews/{pending_id}",
             "--method", "DELETE"],
            capture_output=True, text=True,
        )
        _info("Deleted pending review")
    except Exception:
        pass


def _check_stale_review(repo: str, pr_number: str, review_file: Path, force: bool) -> None:
    if force:
        return
    if not review_file.is_file():
        return

    try:
        text = review_file.read_text()
    except OSError:
        return
    m = re.search(r"<!-- head_sha: ([a-f0-9]+) -->", text)
    review_sha = m.group(1) if m else ""
    if not review_sha:
        return

    pr_head_sha = ""
    try:
        r = subprocess.run(
            ["gh", "pr", "view", pr_number, "--repo", repo,
             "--json", "headRefOid", "--jq", ".headRefOid"],
            capture_output=True, text=True,
        )
        pr_head_sha = r.stdout.strip()
    except Exception:
        pass
    if not pr_head_sha:
        return

    if review_sha == pr_head_sha:
        _warn(f"No new commits since the last review (HEAD {pr_head_sha[:7]})")
        if not _confirm("Re-review anyway?"):
            sys.exit(0)
    else:
        _info(f"Incremental review: new commits since last review ({review_sha[:7]}..{pr_head_sha[:7]})")


def _generator_version() -> str:
    try:
        ver = version_string("claude-review")
        return ver.splitlines()[-1] if ver else "unknown"
    except Exception:
        return "unknown"


def _submit_pending_review(repo: str, pr_number: str, review_file: str) -> None:
    review_dir = Path(review_file).parent
    post_file = review_dir / FILENAME_POST_SESSION
    if not post_file.is_file():
        _err(f"No post tracking file found: {post_file}")
        return

    try:
        data = json.loads(post_file.read_text())
        review_id = data.get("review_id")
    except (json.JSONDecodeError, OSError):
        review_id = None

    if not review_id:
        _err(f"Could not read review_id from {post_file}")
        return

    _info(f"Submitting review #{review_id}...")
    r = subprocess.run(
        ["gh", "api", f"repos/{repo}/pulls/{pr_number}/reviews/{review_id}/events",
         "--method", "POST", "-f", "event=COMMENT"],
        capture_output=True, text=True,
    )
    if r.returncode == 0:
        _info(f"Review #{review_id} submitted")
    else:
        _warn(f"Failed to submit review #{review_id}")

    try:
        data["submitted"] = True
        post_file.write_text(json.dumps(data))
    except Exception:
        pass


def _verify_pr_ownership(pr_number: str, repo: str) -> None:
    pr_author = ""
    gh_user = ""
    try:
        r = subprocess.run(
            ["gh", "pr", "view", pr_number, "--repo", repo,
             "--json", "author", "--jq", ".author.login"],
            capture_output=True, text=True,
        )
        pr_author = r.stdout.strip()
    except Exception:
        pass
    try:
        r = subprocess.run(
            ["gh", "api", "user", "--jq", ".login"],
            capture_output=True, text=True,
        )
        gh_user = r.stdout.strip()
    except Exception:
        pass

    if not pr_author or not gh_user or pr_author == gh_user:
        return

    _warn(f"PR #{pr_number} is owned by {pr_author}, not {gh_user}")
    if not _confirm("Continue with self-review?"):
        sys.exit(0)


def _find_repo_root(repo: str, explicit_dir: str = "") -> str:
    repo_name = repo.split("/")[-1]

    if explicit_dir:
        if os.path.isdir(explicit_dir):
            return explicit_dir
        return ""

    try:
        r = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True,
        )
        git_toplevel = r.stdout.strip()
    except Exception:
        git_toplevel = ""

    if git_toplevel:
        if os.path.basename(git_toplevel) == repo_name:
            return git_toplevel
        parent_dir = os.path.dirname(git_toplevel)
        if os.path.basename(parent_dir) == repo_name:
            return parent_dir

    try:
        r = subprocess.run(
            ["gh", "repo", "view", repo, "--json", "name", "--jq", ".name"],
            capture_output=True, text=True,
        )
        name = r.stdout.strip()
    except Exception:
        name = ""
    if not name:
        return ""

    home_git = os.path.expanduser("~/git")
    try:
        r2 = subprocess.run(
            ["find", home_git, "-maxdepth", "2", "-name", name, "-type", "d"],
            capture_output=True, text=True,
        )
        found = r2.stdout.strip().splitlines()
    except Exception:
        found = []
    return found[0] if found else ""


def _find_worktree_for_branch(branch: str) -> str:
    try:
        r = subprocess.run(
            ["git", "worktree", "list"],
            capture_output=True, text=True,
        )
    except Exception:
        return ""
    for line in r.stdout.splitlines():
        if f"[{branch}]" in line:
            return line.split()[0]
    return ""


def _resolve_bare_repo_worktree(branch: str = "") -> str:
    if branch:
        path = _find_worktree_for_branch(branch)
        if path:
            return path

    default_branch = "main"
    try:
        r = subprocess.run(
            ["git", "symbolic-ref", "refs/remotes/origin/HEAD"],
            capture_output=True, text=True,
        )
        ref = r.stdout.strip()
        if ref:
            default_branch = ref.replace("refs/remotes/origin/", "")
    except Exception:
        pass

    path = _find_worktree_for_branch(default_branch)
    if path:
        return path

    _err(f"Bare repository — no worktree found for {branch or default_branch}. Pass --repo-dir to specify a worktree")
    sys.exit(1)


def _fail_orchestration(msg: str, session_log: str) -> None:
    _err(msg)
    if os.path.isfile(session_log):
        print(f"  Session log: {session_log}", file=sys.stderr)
    sys.exit(1)


def _build_orchestrate_args(
    *,
    pr_number: str, repo: str, review_file: Path, wt_path: str,
    session_log: str, prior_review_path: str, issue_link: str,
    issue_context: str, max_parallel: int, no_holistic: bool,
    max_cost: float | None, model: str | None, mode: str = "",
    fix_pass: bool = False,
) -> list[str]:
    args = [
        str(BIN_DIR / "review-orchestrate"),
        "--repo", repo,
        "--review-file", str(review_file),
        "--repo-dir", wt_path,
        "--reviews-dir", str(REVIEWS_DIR),
        "--session-log", session_log,
    ]
    if pr_number:
        args += ["--pr", pr_number]
    if mode:
        args += ["--mode", mode]
    if prior_review_path and os.path.isfile(prior_review_path):
        args += ["--prior-review", prior_review_path]
    if issue_link:
        args += ["--issue", issue_link]
    if issue_context:
        args += ["--issue-context", issue_context]
    args += ["--max-parallel", str(max_parallel)]
    args += ["--generator-version", _generator_version()]
    if fix_pass:
        args.append("--fix")
    if no_holistic:
        args.append("--no-holistic")
    if max_cost:
        args += ["--max-cost", str(max_cost)]
    if model:
        args += ["--model", model]
    return args


def _run_review_body(
    pr_number, repo, review_file, review_dir, wt_path,
    session_log, prior_review_path, issue_link, issue_context,
    max_parallel, no_holistic, max_cost, model, no_post, auto_post,
    auto_submit, pr_url,
) -> None:
    orchestrate_args = _build_orchestrate_args(
        pr_number=pr_number, repo=repo, review_file=review_file,
        wt_path=wt_path, session_log=session_log,
        prior_review_path=prior_review_path, issue_link=issue_link,
        issue_context=issue_context, max_parallel=max_parallel,
        no_holistic=no_holistic, max_cost=max_cost, model=model,
    )
    rc = subprocess.run(orchestrate_args).returncode
    if rc != 0:
        _fail_orchestration("Review orchestration failed", session_log)
    if not review_file.is_file():
        _fail_orchestration("Review orchestration completed but produced no review file", session_log)

    _cleanup_prior_review(review_file, prior_review_path)
    _display_review(review_file)

    if no_post:
        _print_summary(str(review_file), session_log, pr_url)
        print(f"  {ANSI_DIM}To post later: claude-review post {pr_number}{ANSI_RESET}", file=sys.stderr)
        return

    if auto_post:
        cmd_post(repo, pr_number, auto_submit)
        post_session_log = str(review_dir / FILENAME_POST_SESSION)
        _print_summary(str(review_file), session_log, pr_url, post_session_log)
        return

    if not _confirm("Satisfied with the review?"):
        _print_summary(str(review_file), session_log, pr_url)
        print(f"  {ANSI_DIM}Edit the file, then run: claude-review post {pr_number}{ANSI_RESET}", file=sys.stderr)
        sys.exit(0)

    if not _confirm("Post review to GitHub?"):
        _print_summary(str(review_file), session_log, pr_url)
        print(f"  {ANSI_DIM}To post later: claude-review post {pr_number}{ANSI_RESET}", file=sys.stderr)
        return

    cmd_post(repo, pr_number, False)
    post_session_log = str(review_dir / FILENAME_POST_SESSION)

    if _confirm("Submit review now?"):
        _submit_pending_review(repo, pr_number, str(review_file))

    _print_summary(str(review_file), session_log, pr_url, post_session_log)


# ── Main flows ───────────────────────────────────────────────────────────────

def _run_review(args) -> None:
    pr_input = args.positional[0] if args.positional else ""
    no_post = args.no_post
    auto_post = args.post
    auto_submit = args.submit
    issue_link = args.issue or ""
    max_parallel = args.max_parallel
    force = args.force
    no_holistic = args.no_holistic
    max_cost = args.max_cost
    model = args.model
    repo_dir = args.repo_dir or ""

    if no_post or auto_post:
        force = True

    _prune_merged_reviews()

    pr_number = _extract_pr_number(pr_input)
    repo = _extract_repo(pr_input)

    review_file = _review_file(repo, pr_number)
    review_dir = review_file.parent
    review_dir.mkdir(parents=True, exist_ok=True)

    # Issue detection
    pr_meta = {}
    try:
        r = subprocess.run(
            ["gh", "pr", "view", pr_number, "--repo", repo,
             "--json", "headRefName,body"],
            capture_output=True, text=True,
        )
        if r.returncode == 0:
            pr_meta = json.loads(r.stdout)
    except Exception:
        pass

    pr_head = pr_meta.get("headRefName", "")
    pr_body = pr_meta.get("body", "")

    issue_context = ""
    detected_link = ""
    if not issue_link:
        provider_info = review_issue.load_issue_provider()
        issue_id = review_issue.extract_issue_id(provider_info.name, pr_head, pr_body)
        issue_result = review_issue.fetch_issue_context(
            provider_info.name, issue_id, repo, provider_info.options,
        )
        detected_link = issue_result.link
        issue_context = issue_result.context
        if detected_link:
            issue_link = detected_link

        if not no_post and not auto_post and not issue_link and not issue_context:
            issue_link = _prompt_optional("Issue link (optional, Enter to skip): ")

    pr_url = f"{GITHUB_BASE_URL}/{repo}/pull/{pr_number}"

    has_pipeline_state = (review_dir / FILENAME_PIPELINE_STATE).is_file()

    if not has_pipeline_state:
        _check_stale_review(repo, pr_number, review_file, force)
    _check_pending_review(repo, pr_number, force)

    # Worktree setup
    repo_root = _find_repo_root(repo, repo_dir)
    if not repo_root:
        _err(f"Cannot find local clone of {repo}. Clone it first and re-run from within the repo.")
        sys.exit(1)

    wt_result = review_worktree.setup_pr_worktree(repo, pr_number, repo_root, pr_head)
    wt_path = wt_result.path

    session_log = str(review_dir / FILENAME_SESSION)
    prior_review_path = _resolve_prior_review(review_file, session_log, has_pipeline_state)

    try:
        _run_review_body(
            pr_number, repo, review_file, review_dir, wt_path,
            session_log, prior_review_path, issue_link, issue_context,
            max_parallel, no_holistic, max_cost, model, no_post, auto_post,
            auto_submit, pr_url,
        )
    finally:
        review_worktree.cleanup_worktree(wt_result, repo_root)


def _cleanup_self_review_worktree(wt_cleanup, repo_dir: str) -> None:
    original_repo_dir = repo_dir or ""
    if not original_repo_dir:
        try:
            r = subprocess.run(
                ["git", "rev-parse", "--show-toplevel"],
                capture_output=True, text=True,
            )
            original_repo_dir = r.stdout.strip()
        except Exception:
            pass
    if original_repo_dir:
        review_worktree.cleanup_worktree(wt_cleanup, original_repo_dir)


def _run_self_review_body(
    repo, pr_number, wt_path, issue_link, max_parallel,
    no_holistic, max_cost, model, fix_pass, args,
) -> None:
    repo_name = repo.split("/")[-1]
    try:
        r = subprocess.run(
            ["git", "-C", wt_path, "rev-parse", "--abbrev-ref", "HEAD"],
            capture_output=True, text=True,
        )
        branch_name = r.stdout.strip()
    except Exception:
        branch_name = ""

    branch_sanitized = branch_name.replace("/", "-")
    self_review_dir = REVIEWS_DIR / f"{repo_name}-self-{branch_sanitized}"
    self_review_dir.mkdir(parents=True, exist_ok=True)
    review_file = self_review_dir / f"review{REVIEW_EXT}"
    session_log = str(self_review_dir / FILENAME_SESSION)

    has_pipeline_state = (self_review_dir / FILENAME_PIPELINE_STATE).is_file()
    prior_review_path = _resolve_prior_review(review_file, session_log, has_pipeline_state)

    issue_context = ""
    if not issue_link:
        provider_info = review_issue.load_issue_provider(wt_path)
        issue_id = review_issue.extract_issue_id(provider_info.name, branch_name)
        issue_result = review_issue.fetch_issue_context(
            provider_info.name, issue_id, repo, provider_info.options,
        )
        detected_link = issue_result.link
        issue_context = issue_result.context
        if detected_link:
            issue_link = detected_link

    orchestrate_args = _build_orchestrate_args(
        pr_number=pr_number, repo=repo, review_file=review_file,
        wt_path=wt_path, session_log=session_log,
        prior_review_path=prior_review_path, issue_link=issue_link,
        issue_context=issue_context, max_parallel=max_parallel,
        no_holistic=no_holistic, max_cost=max_cost, model=model,
        mode="self", fix_pass=fix_pass,
    )

    rc = subprocess.run(orchestrate_args).returncode
    if rc != 0:
        _fail_orchestration("Review orchestration failed", session_log)
    if not review_file.is_file():
        _fail_orchestration("Review orchestration completed but produced no review file", session_log)

    _cleanup_prior_review(review_file, prior_review_path)
    _display_review(review_file)

    pr_url = f"{GITHUB_BASE_URL}/{repo}/pull/{pr_number}" if pr_number else ""
    _print_summary(str(review_file), session_log, pr_url, "", branch_name)

    _update_pr_state(repo, pr_number, str(review_file), wt_path, "self")

    json_stdout = getattr(args, "_json_stdout", None)
    if json_stdout is not None:
        summary = _json_summary(repo, pr_number, str(review_file))
        os.write(json_stdout, (summary + "\n").encode())


def _resolve_wt_path(repo_dir: str, pr_input: str) -> str:
    if repo_dir:
        try:
            r = subprocess.run(
                ["git", "-C", repo_dir, "rev-parse", "--show-toplevel"],
                capture_output=True, text=True,
            )
        except Exception:
            _err(f"Not a git repository: {repo_dir}")
            sys.exit(1)
        if r.returncode != 0:
            _err(f"Not a git repository: {repo_dir}")
            sys.exit(1)
        return r.stdout.strip()

    r = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        capture_output=True, text=True,
    )
    if r.returncode == 0:
        return r.stdout.strip()

    r2 = subprocess.run(
        ["git", "rev-parse", "--is-bare-repository"],
        capture_output=True, text=True,
    )
    if r2.stdout.strip() == "true":
        return _resolve_bare_repo_worktree(pr_input)

    _err("Not in a git repository — pass --repo-dir to specify the repo")
    sys.exit(1)


def _resolve_branch_input(pr_input: str, repo_dir: str) -> str:
    resolve_dir = repo_dir or "."
    try:
        r = subprocess.run(
            ["resolve-branch", pr_input],
            capture_output=True, text=True, cwd=resolve_dir,
        )
        if r.returncode == 0 and r.stdout.strip():
            return r.stdout.strip()
    except Exception:
        pass
    return pr_input


def _run_self_review(args) -> None:
    pr_input = args.positional[0] if args.positional else ""
    issue_link = args.issue or ""
    max_parallel = args.max_parallel
    skip_user_verification = args.skip_user_verification
    force = args.force
    no_holistic = args.no_holistic
    max_cost = args.max_cost
    model = args.model
    repo_dir = args.repo_dir or ""
    fix_pass = args.fix

    _prune_merged_reviews()

    is_pr = False
    is_branch = False
    if pr_input:
        if _is_pr_ref(pr_input):
            is_pr = True
        else:
            is_branch = True

    if is_branch:
        pr_input = _resolve_branch_input(pr_input, repo_dir)

    wt_path = _resolve_wt_path(repo_dir, pr_input)

    if is_branch or (repo_dir and not pr_input):
        r = subprocess.run(
            ["gh", "repo", "view", "--json", "nameWithOwner", "-q", ".nameWithOwner"],
            capture_output=True, text=True, cwd=wt_path,
        )
        repo = r.stdout.strip()
        if not repo:
            _err("Cannot determine repository from remote URL")
            sys.exit(1)
    else:
        repo = _extract_repo(pr_input or "local")

    pr_number = ""
    wt_cleanup: review_worktree.WorktreeResult | None = None

    if is_pr:
        pr_number = _extract_pr_number(pr_input)
        if not skip_user_verification:
            _verify_pr_ownership(pr_number, repo)
        wt_cleanup = review_worktree.switch_to_pr_branch(pr_number, repo, wt_path)
        if wt_cleanup:
            wt_path = wt_cleanup.path
    elif is_branch:
        wt_cleanup = review_worktree.switch_to_branch(pr_input, wt_path)
        if wt_cleanup:
            wt_path = wt_cleanup.path

    try:
        _run_self_review_body(
            repo, pr_number, wt_path, issue_link, max_parallel,
            no_holistic, max_cost, model, fix_pass, args,
        )
    finally:
        if wt_cleanup:
            _cleanup_self_review_worktree(wt_cleanup, repo_dir)


# ── Subcommands ──────────────────────────────────────────────────────────────

def cmd_post(repo: str, pr_number: str, submit: bool) -> None:
    review_file = _review_file(repo, pr_number)
    if not review_file.is_file():
        _err(f"No review file found: {review_file}")
        print(f"  {ANSI_DIM}Run: claude-review {pr_number}{ANSI_RESET}", file=sys.stderr)
        sys.exit(1)

    post_args = [
        str(BIN_DIR / "review-post"),
        "--pr", pr_number,
        "--review-file", str(review_file),
    ]
    if submit:
        post_args.append("--submit")

    subprocess.run(post_args, check=False)


def cmd_threads(args) -> None:
    pr_input = args.positional[1] if len(args.positional) > 1 else ""
    threads_args = [str(BIN_DIR / "review-threads")]

    if pr_input:
        pr_number = _extract_pr_number(pr_input)
        threads_args += ["--pr", pr_number]

    if args.resolve_verified:
        threads_args.append("--resolve-verified")
    if args.repo_dir:
        threads_args += ["--repo-dir", args.repo_dir]

    subprocess.run(threads_args, check=False)


def cmd_rebuild(args) -> None:
    pr_input = args.positional[1] if len(args.positional) > 1 else ""
    if not pr_input:
        _err("Usage: claude-review rebuild <pr_url_or_number>")
        sys.exit(1)

    pr_number = _extract_pr_number(pr_input)
    pr_repo = _extract_repo(pr_input)
    review_file = _review_file(pr_repo, pr_number)
    review_dir = review_file.parent

    if not review_dir.is_dir():
        _err(f"No review directory found: {review_dir}")
        sys.exit(1)

    subprocess.run(
        [str(BIN_DIR / "review-rebuild"), "--review-dir", str(review_dir), "--pr", pr_number],
        check=False,
    )


def cmd_summary(args) -> None:
    pr_input = args.positional[1] if len(args.positional) > 1 else ""
    if not pr_input:
        _err("Usage: claude-review summary <pr_url_or_number>")
        sys.exit(1)

    pr_number = _extract_pr_number(pr_input)
    pr_repo = _extract_repo(pr_input)
    review_file = _review_file(pr_repo, pr_number)

    if not review_file.is_file():
        _err(f"No review file found: {review_file}")
        sys.exit(1)

    print(_json_summary(pr_repo, pr_number, str(review_file)))


def cmd_gc() -> None:
    cleaned = 0
    for review_dir in REVIEWS_DIR.iterdir():
        if not review_dir.is_dir():
            continue

        has_review = (review_dir / f"review{REVIEW_EXT}").is_file()

        if not has_review and _gc_dir_is_all_stale(review_dir):
            shutil.rmtree(review_dir, ignore_errors=True)
            _info(f"GC: removed orphaned {review_dir.name}")
            cleaned += 1
            continue

        has_pipeline = (review_dir / FILENAME_PIPELINE_STATE).is_file()
        if has_review and not has_pipeline:
            cleaned += _gc_clean_intermediates(review_dir)

    if cleaned > 0:
        _info(f"GC: cleaned {cleaned} items")
    else:
        _info("GC: nothing to clean")


def _gc_dir_is_all_stale(d: Path) -> bool:
    try:
        files = [f for f in d.rglob("*") if f.is_file()]
    except OSError:
        return False
    if not files:
        return False
    now = datetime.now().timestamp()
    return all((now - f.stat().st_mtime) / 86400 > GC_STALE_DAYS for f in files)


def _gc_clean_intermediates(review_dir: Path) -> int:
    count = 0
    patterns = [
        "group-*.md", "group-*.jsonl",
        "holistic.md", "holistic.jsonl",
        "synthesis.jsonl",
    ]
    files = [f for p in patterns for f in review_dir.glob(p) if f.is_file()]
    now = datetime.now().timestamp()
    for f in files:
        age_days = (now - f.stat().st_mtime) / 86400
        if age_days > GC_STALE_DAYS:
            f.unlink(missing_ok=True)
            count += 1
    return count


def _prune_merged_reviews() -> None:
    pruned = 0
    checked = 0

    for meta_file in REVIEWS_DIR.glob(f"*/{FILENAME_META}"):
        if checked >= PRUNE_MAX_FILES:
            break

        meta = _read_review_meta(meta_file.parent)
        if not meta.repo or not meta.pr_number:
            continue

        checked += 1

        try:
            r = subprocess.run(
                ["gh", "pr", "view", str(meta.pr_number), "--repo", meta.repo,
                 "--json", "state", "--jq", ".state"],
                capture_output=True, text=True,
            )
            state = r.stdout.strip()
        except Exception:
            state = ""

        if state in ("MERGED", "CLOSED"):
            review_dir = meta_file.parent
            shutil.rmtree(review_dir, ignore_errors=True)
            _info(f"Pruned {meta.repo}#{meta.pr_number} ({state})")
            pruned += 1

    if pruned > 0:
        _info(f"Pruned {pruned} merged/closed PRs")


# ── Main ─────────────────────────────────────────────────────────────────────

def main() -> None:
    signal.signal(signal.SIGINT, lambda *_: (print("", file=sys.stderr), _info("Interrupted"), sys.exit(130)))

    parser = argparse.ArgumentParser(
        prog="claude-review",
        description="Run Claude's reviewer agent on a PR",
        add_help=True,
    )
    parser.add_argument("--no-post", action="store_true")
    parser.add_argument("--post", action="store_true")
    parser.add_argument("--submit", action="store_true")
    parser.add_argument("--self", action="store_true", dest="self_review")
    parser.add_argument("--fix", action="store_true")
    parser.add_argument("--skip-user-verification", action="store_true")
    parser.add_argument("--force", action="store_true")
    parser.add_argument("--no-holistic", action="store_true")
    parser.add_argument("--resolve-verified", action="store_true")
    parser.add_argument("--json-summary", action="store_true")
    parser.add_argument("--issue")
    parser.add_argument("--max-parallel", type=int, default=DEFAULT_MAX_PARALLEL)
    parser.add_argument("--max-cost", type=float)
    parser.add_argument("--model")
    parser.add_argument("--repo-dir", "--repo", "--worktree", dest="repo_dir")
    parser.add_argument("--branch")
    parser.add_argument("--pr")
    parser.add_argument("-V", "--version", action="store_true")
    parser.add_argument("args", nargs="*")

    parsed = parser.parse_args()

    if parsed.version:
        print(version_string("claude-review"))
        sys.exit(0)

    # JSON summary: save real stdout, redirect stdout to stderr
    _json_stdout_fd = None
    if parsed.json_summary:
        _json_stdout_fd = os.dup(sys.stdout.fileno())
        os.dup2(sys.stderr.fileno(), sys.stdout.fileno())
        sys.stdout = os.fdopen(sys.stdout.fileno(), "w", closefd=False)

    if not parsed.repo_dir and os.environ.get("REPO_DIR"):
        parsed.repo_dir = os.environ["REPO_DIR"]

    # Flatten positional args, incorporating --pr and --branch from dispatcher
    parsed.positional = list(parsed.args)
    if parsed.pr and not parsed.positional:
        parsed.positional = [parsed.pr]

    # Startup migrations
    REVIEWS_DIR.mkdir(parents=True, exist_ok=True)
    _migrate_legacy_reviews()
    _migrate_flat_reviews()

    if parsed.fix and not parsed.self_review:
        _err("--fix requires --self")
        sys.exit(1)

    if parsed.self_review:
        parsed._json_stdout = _json_stdout_fd
        _run_self_review(parsed)
        if _json_stdout_fd is not None:
            os.close(_json_stdout_fd)
        return

    if parsed.no_post and parsed.post:
        _err("--no-post and --post are mutually exclusive")
        sys.exit(1)

    command = parsed.positional[0] if parsed.positional else ""

    if command == "gc":
        cmd_gc()
    elif command in ("post", "rebuild", "summary", "threads"):
        sub_input = parsed.positional[1] if len(parsed.positional) > 1 else ""
        if command in ("post", "rebuild") and not sub_input:
            _err(f"Usage: claude-review {command} <pr_url_or_number>")
            sys.exit(1)

        ctx = pr_context.resolve(
            pr=sub_input or parsed.pr,
            repo_dir=parsed.repo_dir,
        )
        pr_num = str(ctx.pr_number) if ctx.pr_number else ""

        if command == "post":
            review_file = _review_file(ctx.repo, pr_num)
            cmd_post(ctx.repo, pr_num, parsed.submit)
            _update_pr_state(ctx.repo, pr_num, str(review_file), parsed.repo_dir or "", "pr")
            if _json_stdout_fd is not None:
                summary = _json_summary(ctx.repo, pr_num, str(review_file))
                os.write(_json_stdout_fd, (summary + "\n").encode())
                os.close(_json_stdout_fd)
        elif command == "rebuild":
            review_file = _review_file(ctx.repo, pr_num)
            cmd_rebuild(parsed)
            _update_pr_state(ctx.repo, pr_num, str(review_file), parsed.repo_dir or "", "pr")
            if _json_stdout_fd is not None:
                summary = _json_summary(ctx.repo, pr_num, str(review_file))
                os.write(_json_stdout_fd, (summary + "\n").encode())
                os.close(_json_stdout_fd)
        elif command == "summary":
            cmd_summary(parsed)
        elif command == "threads":
            cmd_threads(parsed)
    elif not command:
        parser.print_help()
        sys.exit(1)
    else:
        # Default: treat as PR number/URL
        ctx = pr_context.resolve(
            pr=command,
            repo_dir=parsed.repo_dir,
        )
        rev_pr_number = str(ctx.pr_number) if ctx.pr_number else _extract_pr_number(command)
        rev_review_file = _review_file(ctx.repo, rev_pr_number)
        _run_review(parsed)
        _update_pr_state(ctx.repo, rev_pr_number, str(rev_review_file), parsed.repo_dir or "", "pr")
        if _json_stdout_fd is not None:
            summary = _json_summary(ctx.repo, rev_pr_number, str(rev_review_file))
            os.write(_json_stdout_fd, (summary + "\n").encode())
            os.close(_json_stdout_fd)


if __name__ == "__main__":
    main()
