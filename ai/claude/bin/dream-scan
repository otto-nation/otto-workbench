#!/usr/bin/env python3
"""Scan session transcripts and memory state for dream consolidation.

Replaces Phases 1+2 of the dream skill (Orient + Gather Signal).
Outputs a structured markdown report to stdout.

Usage:
  dream-scan [--days N] [--home DIR]
"""

from __future__ import annotations

import argparse
import json
import os
import re
import sys
from datetime import datetime, timedelta
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))
sys.path.insert(0, str(Path(__file__).resolve().parent))
from _version import version_string as _version_string  # noqa: E402
from trail import Trail, add_trail_args  # noqa: E402


# ── Constants ────────────────────────────────────────────────────────────────

MAX_TEXT_LENGTH = 500
TEXT_PREVIEW_LENGTH = 200
MIN_TEXT_LENGTH = 10
DEFAULT_DAYS = 7

RECORD_TYPE_USER = "user"
CONTENT_TYPE_TEXT = "text"
FRONTMATTER_DELIMITER = "---"
MEMORY_INDEX = "MEMORY.md"
LAST_DREAM_FILE = ".last-dream"
JSONL_GLOB = "*.jsonl"
TOPIC_GLOB = "*.md"

PROJECTS_PATH = Path(".claude") / "projects"

DATE_FMT = "%Y-%m-%d"
DATETIME_FMT = "%Y-%m-%d %H:%M"

SIGNAL_PATTERNS: dict[str, re.Pattern] = {
    "correction": re.compile(
        r"\b(?:actually|wrong|incorrect|not right|stop doing|don't do"
        r"|I said|I meant|that's not|correction)\b"
        r"|(?:^|\W)no,",
        re.IGNORECASE,
    ),
    "preference": re.compile(
        r"\b(?:I prefer|always use|never use|I like|I don't like|I want"
        r"|from now on|going forward|remember that|keep in mind"
        r"|make sure to|default to)\b",
        re.IGNORECASE,
    ),
    "decision": re.compile(
        r"\b(?:let's go with|I decided|we're using|the plan is"
        r"|switch to|move to|chosen|picked|decision|we agreed)\b",
        re.IGNORECASE,
    ),
    "pattern": re.compile(
        r"\b(?:every time|keep forgetting|as usual|same as before"
        r"|like last time|we always|the usual)\b"
        r"|(?:^|\W)again\b",
        re.IGNORECASE,
    ),
    "review_feedback": re.compile(
        r"\b(?:accepted|rejected|won't-fix|false positive|not applying)\b",
        re.IGNORECASE,
    ),
}

SIGNAL_PRIORITY = ["correction", "preference", "decision", "pattern", "review_feedback"]

STALE_DAYS = 90


# ── Output helpers ───────────────────────────────────────────────────────────

_NO_COLOR = bool(os.environ.get("NO_COLOR")) or not sys.stderr.isatty()
_INFO = "" if _NO_COLOR else "\033[1;34m→\033[0m"
_WARN = "" if _NO_COLOR else "\033[1;33m⚠\033[0m"


def _info(msg: str) -> None:
    print(f"{_INFO} {msg}", file=sys.stderr, flush=True)


def _warn(msg: str) -> None:
    print(f"{_WARN} {msg}", file=sys.stderr, flush=True)


# ── Core functions ───────────────────────────────────────────────────────────


def extract_user_text(record: dict) -> str | None:
    if record.get("type") != RECORD_TYPE_USER:
        return None
    content = record.get("message", {}).get("content", "")

    text = _extract_text_from_content(content)
    if not text or len(text) < MIN_TEXT_LENGTH or text.startswith("<"):
        return None
    return text


def _extract_text_from_content(content: str | list | None) -> str | None:
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        texts = [b.get("text", "") for b in content if isinstance(b, dict) and b.get("type") == CONTENT_TYPE_TEXT]
        return " ".join(texts) if texts else None
    return None


def classify_signal(text: str) -> str | None:
    for category in SIGNAL_PRIORITY:
        if SIGNAL_PATTERNS[category].search(text):
            return category
    return None


def parse_frontmatter(path: str | Path) -> dict:
    path = Path(path)
    if not path.exists():
        return {}
    lines = path.read_text().splitlines()
    return _parse_frontmatter_lines(lines)


def _parse_frontmatter_lines(lines: list[str]) -> dict:
    try:
        start = lines.index(FRONTMATTER_DELIMITER) + 1
        end = lines.index(FRONTMATTER_DELIMITER, start)
    except ValueError:
        return {}
    result: dict[str, str] = {}
    for line in lines[start:end]:
        if line.startswith(" ") or ":" not in line:
            continue
        key, _, value = line.partition(":")
        result[key.strip()] = value.strip()
    return result


# ── Scanning ─────────────────────────────────────────────────────────────────


def _read_last_dream(memory_dir: Path) -> str | None:
    stamp = memory_dir / LAST_DREAM_FILE
    if not stamp.exists():
        return None
    try:
        ts = int(stamp.read_text().strip())
        return datetime.fromtimestamp(ts).strftime(DATETIME_FMT)
    except (ValueError, OSError):
        return None


def _scan_topic_file(f: Path, now: datetime) -> dict:
    fm = parse_frontmatter(f)
    mtime = datetime.fromtimestamp(f.stat().st_mtime)
    age_days = (now - mtime).days
    return {
        "filename": f.name,
        "name": fm.get("name", ""),
        "description": fm.get("description", ""),
        "type": fm.get("type", ""),
        "size": f.stat().st_size,
        "modified": mtime.strftime(DATE_FMT),
        "stale": age_days > STALE_DAYS,
        "age_days": age_days,
    }


def scan_memory_state(home: Path) -> list[dict]:
    projects_dir = home / PROJECTS_PATH
    if not projects_dir.exists():
        return []

    now = datetime.now()
    states = []
    for memory_dir in sorted(projects_dir.glob("*/memory")):
        if not memory_dir.is_dir():
            continue
        memory_md = memory_dir / MEMORY_INDEX
        if not memory_md.exists():
            continue
        topic_files = [
            _scan_topic_file(f, now)
            for f in sorted(memory_dir.glob(TOPIC_GLOB))
            if f.name != MEMORY_INDEX
        ]
        states.append({
            "project_id": memory_dir.parent.name,
            "line_count": len(memory_md.read_text().splitlines()),
            "last_dream": _read_last_dream(memory_dir),
            "topic_files": topic_files,
        })
    return states


def _extract_signals_from_file(jsonl_file: Path, project_id: str) -> list[dict]:
    session_date = datetime.fromtimestamp(jsonl_file.stat().st_mtime).strftime(DATE_FMT)
    try:
        raw_lines = jsonl_file.read_text().splitlines()
    except OSError:
        _warn(f"Could not read {jsonl_file}")
        return []
    results = [_classify_line(line, project_id, session_date) for line in raw_lines]
    return [sig for sig in results if sig is not None]


def _classify_line(raw_line: str, project_id: str, session_date: str) -> dict | None:
    raw_line = raw_line.strip()
    if not raw_line:
        return None
    try:
        record = json.loads(raw_line)
    except json.JSONDecodeError:
        return None
    text = extract_user_text(record)
    if text is None:
        return None
    category = classify_signal(text)
    if category is None:
        return None
    return {
        "category": category,
        "text": text[:MAX_TEXT_LENGTH],
        "project_id": project_id,
        "session_date": session_date,
    }


def scan_sessions(home: Path, days: int) -> list[dict]:
    projects_dir = home / PROJECTS_PATH
    if not projects_dir.exists():
        return []

    cutoff = datetime.now() - timedelta(days=days)
    signals = []
    for project_dir in sorted(projects_dir.iterdir()):
        if not project_dir.is_dir():
            continue
        signals.extend(_scan_project_sessions(project_dir, cutoff))
    return signals


def _scan_project_sessions(project_dir: Path, cutoff: datetime) -> list[dict]:
    project_id = project_dir.name
    signals = []
    for jsonl_file in sorted(project_dir.glob(JSONL_GLOB)):
        try:
            mtime = datetime.fromtimestamp(jsonl_file.stat().st_mtime)
        except OSError:
            continue
        if mtime < cutoff:
            continue
        signals.extend(_extract_signals_from_file(jsonl_file, project_id))
    return signals


# ── Report ───────────────────────────────────────────────────────────────────


def _format_memory_state(state: dict) -> list[str]:
    lines = [f"### {state['project_id']}"]
    lines.append(f"MEMORY.md: {state['line_count']} lines")
    if state["last_dream"]:
        lines.append(f"Last dream: {state['last_dream']}")
    lines.append("")

    if not state["topic_files"]:
        return lines

    lines.append("| File | Name | Description | Type | Modified | Age |")
    lines.append("|------|------|-------------|------|----------|-----|")
    for tf in state["topic_files"]:
        stale_marker = " **STALE**" if tf["stale"] else ""
        lines.append(
            f"| {tf['filename']} | {tf['name']} | {tf['description']} "
            f"| {tf['type']} | {tf['modified']} | {tf['age_days']}d{stale_marker} |"
        )
    lines.append("")

    stale_files = [tf for tf in state["topic_files"] if tf["stale"]]
    if stale_files:
        lines.append(f"**Stale entries (>90 days):** {', '.join(tf['filename'] for tf in stale_files)}")
        lines.append("")
    return lines


def _format_signal_category(category: str, cat_signals: list[dict]) -> list[str]:
    lines = [f"### {category} ({len(cat_signals)})\n"]
    for sig in cat_signals:
        lines.append(f"- **[{sig['session_date']}]** `{sig['project_id']}`")
        text_preview = sig["text"].replace("\n", " ")[:TEXT_PREVIEW_LENGTH]
        lines.append(f"  > {text_preview}")
        lines.append("")
    return lines


def format_report(memory_states: list[dict], signals: list[dict]) -> str:
    lines: list[str] = ["## Memory State\n"]
    lines.extend(_format_memory_section(memory_states))
    lines.append("## Session Signals\n")
    lines.extend(_format_signals_section(signals))
    return "\n".join(lines)


def _format_memory_section(states: list[dict]) -> list[str]:
    if not states:
        return ["No memory directories found.\n"]
    lines: list[str] = []
    for state in states:
        lines.extend(_format_memory_state(state))
    return lines


def _format_signals_section(signals: list[dict]) -> list[str]:
    if not signals:
        return ["No signals found in recent sessions.\n"]
    lines: list[str] = []
    for category in SIGNAL_PRIORITY:
        cat_signals = [s for s in signals if s["category"] == category]
        if not cat_signals:
            continue
        lines.extend(_format_signal_category(category, cat_signals))
    return lines


# ── Main ─────────────────────────────────────────────────────────────────────


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Scan session transcripts and memory state for dream consolidation.",
        usage="dream-scan [--days N] [--home DIR]",
    )
    parser.add_argument("-V", "--version", action="store_true", help="print version and exit")
    parser.add_argument("--days", type=int, default=DEFAULT_DAYS, help=f"scan sessions from last N days (default: {DEFAULT_DAYS})")
    parser.add_argument("--home", type=str, default=os.environ.get("HOME", ""), help="home directory override (for testing)")
    add_trail_args(parser)
    args = parser.parse_args()

    if args.version:
        print(_version_string("dream-scan"))
        raise SystemExit(0)

    home = Path(args.home)
    log_dir = os.path.expanduser("~/.config/workbench/logs/dream-scan")
    trail = Trail.start(
        script="dream-scan",
        artifact_dir=log_dir,
        context={"days": args.days},
        debug=args.debug,
    )

    try:
        _info(f"Scanning sessions from last {args.days} days")
        _info(f"Home: {home}")

        memory_states = scan_memory_state(home)
        _info(f"Found {len(memory_states)} project(s) with memory")
        trail.info("scan_memories", f"found {len(memory_states)} memory files across {sum(len(s.get('topic_files', [])) for s in memory_states)} topics")

        signals = scan_sessions(home, args.days)
        _info(f"Found {len(signals)} signal(s)")
        trail.info("scan_sessions", f"scanned sessions from last {args.days} days, found {len(signals)} signals")

        report = format_report(memory_states, signals)
        trail.info("generate_report", f"report generated, {len(report)} chars")
        print(report)
    except Exception as exc:
        trail.error("unexpected_error", str(exc))
        raise
    finally:
        trail.finish()


if __name__ == "__main__":
    main()
