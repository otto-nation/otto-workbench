#!/usr/bin/env python3
"""Unified PR lifecycle CLI.

Thin dispatch layer — each subcommand delegates to an external script.
Structured JSON on stdout, status messages on stderr.

Subcommands:
  pr status                             Show unified dashboard from cached state
  pr ci [--run N] [ci-check flags...]   Fetch CI failures (exit 0=green, 1=red)
  pr review [target] [--self] [--fix]   Run code review (exit 0=approve, 1=changes)
      [--post] [--no-post]
  pr comments [--resolve-verified]      Fetch PR review threads
  pr triage                             Classify and verify review threads
  pr repair [target]                    Repair broken review artifacts
  pr fix                                Fix all fixable (review, CI, comments)
  pr post [target] [--submit]           Post existing review to GitHub
  pr gc                                 Clean up stale review artifacts
  pr rebase [--fix] [--push] [--abort]  Rebase onto origin/main (exit 3=conflicts)

Global flags:
  --repo-dir PATH    Git worktree directory
  --branch NAME      Branch name
  --pr NUMBER/URL    PR number or URL
"""

import argparse
import json
import subprocess
import sys
from pathlib import Path

BIN_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(BIN_DIR.parent / "lib"))

import pr_context
import pr_state


# ── Helpers ─────────────────────────────────────────────────────────────────


def _now_iso() -> str:
    return pr_state.now_iso()


def _load_or_init(ctx: pr_context.ResolvedContext) -> pr_state.PRState:
    """Load existing state or create a fresh one from resolved context."""
    return pr_state.load_or_init(
        worktree_root=ctx.worktree_root,
        repo=ctx.repo,
        branch=ctx.branch,
        pr_number=ctx.pr_number,
        head_sha=ctx.head_sha,
    )


def _parse_review_summary(output: str) -> dict | None:
    """Extract REVIEW_SUMMARY:{json} from claude-review output."""
    prefix = "REVIEW_SUMMARY:"
    lines = [l for l in output.splitlines() if l.startswith(prefix)]
    if not lines:
        return None
    try:
        return json.loads(lines[0][len(prefix):])
    except (json.JSONDecodeError, TypeError):
        return None


def _is_pr_target(target: str | None) -> bool:
    """Check if target looks like a PR URL or number (not a branch name)."""
    if not target:
        return False
    if target.isdigit():
        return True
    if "github.com" in target and "/pull/" in target:
        return True
    return False



# ── Subcommands ─────────────────────────────────────────────────────────────


def _render_ci_section(ci: pr_state.CISummary) -> list[str]:
    if not ci.updated_at:
        return ["**CI**: not checked yet"]
    icon = "green" if ci.conclusion == "success" else "red"
    lines = [f"**CI** ({icon}): {ci.conclusion} — {ci.failure_count} failure(s)"]
    for kind, count in sorted(ci.failure_kinds.items()):
        lines.append(f"  {kind}: {count}")
    if ci.last_run_number:
        lines.append(f"  run #{ci.last_run_number}")
    return lines


def _render_review_section(rev: pr_state.ReviewSummary) -> list[str]:
    if not rev.updated_at:
        return ["**Review**: not run yet"]
    lines = [f"**Review** ({rev.review_type}): {rev.verdict}"]
    if rev.finding_counts:
        parts = [f"{sev}: {count}" for sev, count in sorted(rev.finding_counts.items())]
        lines.append(f"  findings: {', '.join(parts)}")
    if rev.cost_usd:
        lines.append(f"  cost: ${rev.cost_usd:.2f}")
    return lines


def _render_comments_section(c: pr_state.CommentsSummary) -> list[str]:
    if not c.updated_at:
        return ["**Comments**: not checked yet"]
    lines = [f"**Comments**: {c.total_threads} thread(s)"]
    if c.by_state:
        parts = [f"{s}: {ct}" for s, ct in sorted(c.by_state.items())]
        lines.append(f"  {', '.join(parts)}")
    if c.blocking_reviewers:
        lines.append(f"  blocking: {', '.join(c.blocking_reviewers)}")
    return lines


def _render_triage_section(t: pr_state.TriageSummary) -> list[str]:
    if not t.updated_at:
        return ["**Triage**: not run yet"]
    lines = [f"**Triage**: {t.total} threads — {t.actionable} actionable ({t.valid} valid), {t.questions} questions"]
    return lines


def _render_rebase_section(r: pr_state.RebaseSummary) -> list[str]:
    if not r.updated_at:
        return ["**Rebase**: not run yet"]
    if r.conflicts_resolved == 0:
        desc = f"clean rebase — {r.commits_replayed} commit(s) replayed"
    else:
        desc = f"resolved {r.conflicts_resolved} file(s) across {r.commits_replayed} commit(s)"
    if r.force_pushed:
        desc += ", force-pushed"
    return [f"**Rebase**: {desc}"]


def cmd_status(args, extra, ctx: pr_context.ResolvedContext) -> int:
    """Render unified status dashboard from cached state."""
    state = pr_state.load_state(ctx.worktree_root)

    pr_label = f"#{state.identity.pr_number}" if state and state.identity.pr_number else "(no PR)"
    branch = state.identity.branch if state else ctx.branch
    repo = state.identity.repo if state else ctx.repo

    lines = [f"## PR Status — {repo} {pr_label} ({branch})", ""]

    if not state:
        lines.append("No status data yet. Run: pr ci, pr review, or pr comments")
        print("\n".join(lines), file=sys.stderr)
        return 0

    lines += _render_ci_section(state.ci)
    lines.append("")
    lines += _render_review_section(state.review)
    lines.append("")
    lines += _render_comments_section(state.comments)
    lines.append("")
    lines += _render_triage_section(state.triage)
    lines.append("")
    lines += _render_rebase_section(state.rebase)
    lines.append("")
    lines.append(_merge_readiness(state))

    print("\n".join(lines), file=sys.stderr)

    json.dump(pr_state.state_to_dict(state), sys.stdout, indent=2)
    print()
    return 0


def _merge_readiness(state: pr_state.PRState) -> str:
    ci_green = state.ci.conclusion == "success" if state.ci.updated_at else None
    has_must_fix = state.review.finding_counts.get("M", 0) > 0 if state.review.updated_at else None
    has_blockers = bool(state.comments.blocking_reviewers) if state.comments.updated_at else None

    if ci_green is True and has_must_fix is False and has_blockers is False:
        return "**Merge readiness**: ready"
    issues = []
    if ci_green is False:
        issues.append("CI failing")
    if has_must_fix is True:
        issues.append("must-fix findings")
    if has_blockers is True:
        issues.append("blocking reviewers")
    if ci_green is None or has_must_fix is None or has_blockers is None:
        unchecked = []
        if ci_green is None:
            unchecked.append("CI")
        if has_must_fix is None:
            unchecked.append("review")
        if has_blockers is None:
            unchecked.append("comments")
        issues.append(f"not checked: {', '.join(unchecked)}")
    return f"**Merge readiness**: blocked — {'; '.join(issues)}" if issues else "**Merge readiness**: ready"


def cmd_ci(args, extra, ctx: pr_context.ResolvedContext) -> int:
    """Delegate to ci-check."""
    tool = str(BIN_DIR / "ci-check")
    ci_args = [tool]
    if ctx.branch:
        ci_args += ["--branch", ctx.branch]
    if args.pr or ctx.pr_number:
        ci_args += ["--pr", str(args.pr or ctx.pr_number)]
    if hasattr(args, "run") and args.run:
        ci_args += ["--run", str(args.run)]
    ci_args += ["--repo-dir", str(ctx.worktree_root)]
    ci_args += extra
    return subprocess.run(ci_args).returncode


def cmd_review(args, extra, ctx: pr_context.ResolvedContext) -> int:
    """Delegate to claude-review."""
    tool = str(BIN_DIR / "claude-review")
    review_args = [tool]

    is_self = args.self_review or not _is_pr_target(args.target)

    if is_self:
        review_args.append("--self")
        if args.fix:
            review_args.append("--fix")
        if args.target:
            review_args.append(args.target)
    else:
        if args.target:
            review_args.append(args.target)

    if args.auto_post:
        review_args.append("--post")
    if args.no_post:
        review_args.append("--no-post")

    if ctx.worktree_root:
        review_args += ["--repo-dir", str(ctx.worktree_root)]

    review_args += extra
    return subprocess.run(review_args).returncode


def cmd_comments(args, extra, ctx: pr_context.ResolvedContext) -> int:
    """Delegate to review-threads."""
    tool = str(BIN_DIR / "review-threads")
    threads_args = [tool]
    if ctx.pr_number:
        threads_args += ["--pr", str(ctx.pr_number)]
    if args.resolve_verified:
        threads_args.append("--resolve-verified")
    threads_args += ["--repo-dir", str(ctx.worktree_root)]
    threads_args += extra
    return subprocess.run(threads_args).returncode


def cmd_triage(args, extra, ctx: pr_context.ResolvedContext) -> int:
    """Delegate to review-thread-triage."""
    tool = str(BIN_DIR / "review-thread-triage")
    triage_args = [tool]
    if ctx.pr_number:
        triage_args += ["--pr", str(ctx.pr_number)]
    if ctx.worktree_root:
        triage_args += ["--repo-dir", str(ctx.worktree_root)]
    triage_args += extra
    return subprocess.run(triage_args).returncode


def cmd_repair(args, extra, ctx: pr_context.ResolvedContext) -> int:
    """Repair broken review artifacts via summary or rebuild."""
    tool = str(BIN_DIR / "claude-review")
    target = getattr(args, "target", None)
    if not target and ctx.pr_number:
        target = str(ctx.pr_number)

    # Step 1: try claude-review summary
    summary_args = [tool, "summary"]
    if target:
        summary_args.append(target)
    if ctx.worktree_root:
        summary_args += ["--repo-dir", str(ctx.worktree_root)]
    summary_args += extra

    result = subprocess.run(summary_args, capture_output=True, text=True)

    if result.returncode == 0:
        if result.stderr:
            print(result.stderr, file=sys.stderr, end="")
        if result.stdout:
            print(result.stdout, end="")

        # Update review state from summary output
        summary_data = _parse_review_summary(result.stdout)
        if summary_data:
            findings = summary_data.get("findings", {})
            finding_counts = {
                k: v for k, v in findings.items()
                if k != "total" and isinstance(v, int) and v > 0
            }
            state = _load_or_init(ctx)
            pr_state.update_review(state, pr_state.ReviewSummary(
                review_file=summary_data.get("review_file", ""),
                review_type=state.review.review_type or "pr",
                head_sha=summary_data.get("head_sha", ""),
                finding_counts=finding_counts,
                verdict=summary_data.get("verdict", ""),
                cost_usd=summary_data.get("cost_usd", 0.0),
                updated_at=_now_iso(),
            ))
            pr_state.save_state(ctx.worktree_root, state)

        return 0

    # Step 2: summary failed — try claude-review rebuild
    print("summary failed, trying rebuild...", file=sys.stderr)
    rebuild_args = [tool, "rebuild", "--json-summary"]
    if target:
        rebuild_args.append(target)
    if ctx.worktree_root:
        rebuild_args += ["--repo-dir", str(ctx.worktree_root)]
    rebuild_args += extra

    result = subprocess.run(rebuild_args, capture_output=True, text=True)

    if result.stderr:
        print(result.stderr, file=sys.stderr, end="")
    if result.stdout:
        print(result.stdout, end="")

    if result.returncode == 0:
        summary_data = _parse_review_summary(result.stdout)
        if summary_data:
            findings = summary_data.get("findings", {})
            finding_counts = {
                k: v for k, v in findings.items()
                if k != "total" and isinstance(v, int) and v > 0
            }
            state = _load_or_init(ctx)
            pr_state.update_review(state, pr_state.ReviewSummary(
                review_file=summary_data.get("review_file", ""),
                review_type=state.review.review_type or "pr",
                head_sha=summary_data.get("head_sha", ""),
                finding_counts=finding_counts,
                verdict=summary_data.get("verdict", ""),
                cost_usd=summary_data.get("cost_usd", 0.0),
                updated_at=_now_iso(),
            ))
            pr_state.save_state(ctx.worktree_root, state)

    return result.returncode


def cmd_fix(args, extra, ctx: pr_context.ResolvedContext) -> int:
    """Run fix passes for CI, review, and comments."""
    state = pr_state.load_state(ctx.worktree_root)
    if not state:
        print("No state yet. Run pr ci, pr review, or pr comments first.", file=sys.stderr)
        return 1

    exit_code = 0

    # 1. Review fix (has a script-level --fix via claude-review)
    if state.review.updated_at and sum(state.review.finding_counts.values()) > 0:
        print("## Fixing review findings...", file=sys.stderr)
        review_args = [str(BIN_DIR / "claude-review"), "--self", "--fix"]
        review_args += ["--repo-dir", str(ctx.worktree_root)]
        review_args += extra
        r = subprocess.run(review_args)
        if r.returncode != 0:
            exit_code = 1

    # 2. CI and comments don't have script-level fix passes yet — report
    if state.ci.updated_at and state.ci.failure_count > 0:
        infra_count = state.ci.failure_kinds.get("infra", 0) + state.ci.failure_kinds.get("flaky", 0)
        fixable = state.ci.failure_count - infra_count
        if fixable > 0:
            print(f"\n## CI: {fixable} fixable failure(s) — run pr ci --fix", file=sys.stderr)

    actionable = state.comments.by_state.get("new", 0) + state.comments.by_state.get("contested", 0)
    if state.comments.updated_at and actionable > 0:
        print(f"\n## Comments: {actionable} actionable thread(s) — run pr comments --fix", file=sys.stderr)

    return exit_code


def cmd_post(args, extra, ctx: pr_context.ResolvedContext) -> int:
    """Delegate to claude-review post."""
    tool = str(BIN_DIR / "claude-review")
    target = getattr(args, "target", None)
    if not target and ctx.pr_number:
        target = str(ctx.pr_number)
    if not target:
        print("pr post: requires a PR number or URL", file=sys.stderr)
        return 1

    post_args = [tool, "post", target]
    if args.submit:
        post_args.append("--submit")
    if ctx.worktree_root:
        post_args += ["--repo-dir", str(ctx.worktree_root)]
    post_args += extra

    result = subprocess.run(post_args)
    return result.returncode


def cmd_gc(args, extra, ctx: pr_context.ResolvedContext) -> int:
    """Delegate to claude-review gc."""
    tool = str(BIN_DIR / "claude-review")
    gc_args = [tool, "gc"]
    gc_args += extra

    result = subprocess.run(gc_args)
    return result.returncode


def cmd_rebase(args, extra, ctx: pr_context.ResolvedContext) -> int:
    """Delegate to pr-rebase."""
    rebase_args = [str(BIN_DIR / "pr-rebase"), "--repo-dir", str(ctx.worktree_root)]
    if args.abort:
        rebase_args.append("--abort")
    if args.push:
        rebase_args.append("--push")
    if args.fix:
        rebase_args.append("--fix")
    rebase_args += extra
    result = subprocess.run(rebase_args)
    return result.returncode


# ── CLI ─────────────────────────────────────────────────────────────────────


_USAGE = """\
pr — PR lifecycle management

Usage: pr [global flags] <command> [flags]

Commands:
  status      Show CI, review, and comment status dashboard
  ci          Check CI failures
  review      Run code review (--self for pre-merge, --fix to auto-fix)
  comments    Fetch PR review threads
  triage      Classify and verify review threads
  fix         Auto-fix review findings, CI failures, and comments
  rebase      Rebase onto origin/main with AI conflict resolution
  repair      Repair broken review artifacts
  post        Post existing review to GitHub
  gc          Clean up stale review artifacts

Global flags:
  --repo-dir PATH    Git worktree directory
  --branch NAME      Branch name
  --pr NUM|URL       PR number or URL

Run 'pr <command> -h' for details on a specific command."""


_GLOBAL_FLAGS_EPILOG = """\

Global flags (passed before the subcommand):
  --repo-dir PATH    Git worktree directory
  --branch NAME      Branch name
  --pr NUM|URL       PR number or URL"""


def _sub_epilog(tool: str | None = None) -> str:
    parts = []
    if tool:
        parts.append(f"Unrecognized flags are passed through to {tool}.")
    parts.append(_GLOBAL_FLAGS_EPILOG)
    return "\n".join(parts)


def main():
    parser = argparse.ArgumentParser(
        prog="pr",
        description="PR lifecycle management",
        add_help=False,
    )
    parser.add_argument("-h", "--help", action="store_true", dest="help")
    parser.add_argument("--repo-dir", "--repo", "--worktree",
                        dest="repo_dir",
                        help="Git worktree directory")
    parser.add_argument("--branch", help="Branch name")
    parser.add_argument("--pr", help="PR number or URL")

    sub = parser.add_subparsers(dest="command")
    fmt = argparse.RawDescriptionHelpFormatter

    # pr status
    sub.add_parser("status", help="Show CI, review, and comment status",
                   description="Show unified dashboard from cached state.\n\nDisplays CI, review, comments, triage, and rebase status with merge readiness.",
                   epilog=_GLOBAL_FLAGS_EPILOG,
                   formatter_class=fmt)

    # pr ci
    ci_p = sub.add_parser("ci", help="CI failure status",
                          description="Fetch and display CI failures for the current PR.\n\nDelegates to ci-check. Exit 0 = green, exit 1 = failures found.",
                          epilog=_sub_epilog("ci-check"),
                          formatter_class=fmt)
    ci_p.add_argument("--run", type=int, help="Specific workflow run ID (default: latest)")

    # pr review
    review_p = sub.add_parser("review", help="Run code review",
                              description="Run AI code review on a PR or the current branch.\n\nWithout --self, reviews a PR (pass number/URL as target).\nWith --self, reviews uncommitted changes for pre-merge checks.",
                              epilog=_sub_epilog("claude-review"),
                              formatter_class=fmt)
    review_p.add_argument("target", nargs="?",
                          help="PR URL/number (review others) or branch (self)")
    review_p.add_argument("--self", dest="self_review", action="store_true",
                          help="Self-review the current branch (pre-merge)")
    review_p.add_argument("--fix", action="store_true",
                          help="Auto-fix findings after review")
    review_p.add_argument("--post", dest="auto_post", action="store_true",
                          help="Post review as PR comments")
    review_p.add_argument("--no-post", action="store_true",
                          help="Skip posting (local review only)")

    # pr comments
    comments_p = sub.add_parser("comments", help="PR review thread status",
                                description="Fetch and display PR review threads.\n\nShows thread counts by state (new, resolved, contested) and blocking reviewers.",
                                epilog=_sub_epilog("review-threads"),
                                formatter_class=fmt)
    comments_p.add_argument("--resolve-verified", action="store_true",
                            help="Auto-resolve threads verified as fixed")

    # pr triage
    sub.add_parser("triage", help="Classify and verify review threads",
                   description="Classify review threads as actionable, valid, or questions.\n\nDelegates to review-thread-triage.",
                   epilog=_sub_epilog("review-thread-triage"),
                   formatter_class=fmt)

    # pr repair
    repair_p = sub.add_parser("repair", help="Repair broken review artifacts",
                              description="Repair broken or incomplete review artifacts.\n\nTries summary first, falls back to full rebuild if needed.",
                              epilog=_sub_epilog("claude-review"),
                              formatter_class=fmt)
    repair_p.add_argument("target", nargs="?", help="PR URL/number")

    # pr fix
    sub.add_parser("fix", help="Fix CI + review + comments",
                   description="Auto-fix all fixable issues: review findings, CI failures, and comments.\n\nRequires prior runs of pr ci, pr review, or pr comments.",
                   epilog=_GLOBAL_FLAGS_EPILOG,
                   formatter_class=fmt)

    # pr post
    post_p = sub.add_parser("post", help="Post existing review to GitHub",
                            description="Post a previously generated review as PR comments.\n\nRequires a review file from a prior pr review run.",
                            epilog=_sub_epilog("claude-review"),
                            formatter_class=fmt)
    post_p.add_argument("target", nargs="?", help="PR URL/number")
    post_p.add_argument("--submit", action="store_true",
                        help="Submit as a formal GitHub review (not just comments)")

    # pr gc
    sub.add_parser("gc", help="Clean up stale review artifacts",
                   description="Remove stale review artifacts from ~/.config/workbench/reviews/.",
                   epilog=_sub_epilog("claude-review"),
                   formatter_class=fmt)

    # pr rebase
    rebase_p = sub.add_parser("rebase", help="Rebase onto origin/main with AI conflict resolution",
                              description="Rebase the current branch onto origin/main.\n\nUses AI to resolve merge conflicts. Exit 0 = clean, exit 3 = unresolved conflicts.",
                              epilog=_GLOBAL_FLAGS_EPILOG,
                              formatter_class=fmt)
    rebase_p.add_argument("--fix", action="store_true",
                          help="Autonomous mode — resolve conflicts and force-push without confirmation")
    rebase_p.add_argument("--push", action="store_true",
                          help="Force-push after successful rebase")
    rebase_p.add_argument("--abort", action="store_true",
                          help="Abort an in-progress rebase")

    args, extra = parser.parse_known_args()

    if args.help or not args.command:
        print(_USAGE, file=sys.stderr)
        sys.exit(0)

    ctx = pr_context.resolve(
        pr=getattr(args, "pr", None),
        branch=getattr(args, "branch", None),
        repo_dir=getattr(args, "repo_dir", None),
    )

    dispatch = {
        "status": cmd_status,
        "ci": cmd_ci,
        "review": cmd_review,
        "comments": cmd_comments,
        "triage": cmd_triage,
        "repair": cmd_repair,
        "fix": cmd_fix,
        "post": cmd_post,
        "gc": cmd_gc,
        "rebase": cmd_rebase,
    }

    sys.exit(dispatch[args.command](args, extra, ctx))


if __name__ == "__main__":
    main()
