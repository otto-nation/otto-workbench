#!/usr/bin/env python3
"""Resolve PR context and output JSON.

CLI entry point for pr_context.resolve(). Enables bash scripts to use
the same canonical resolution logic as Python scripts.

Usage:
  pr-context-resolve [--pr NUMBER] [--branch NAME] [--repo-dir PATH]
"""

import argparse
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

import pr_context


def main():
    parser = argparse.ArgumentParser(description="Resolve PR context to JSON")
    parser.add_argument("--pr", help="PR number or URL")
    parser.add_argument("--branch", help="Branch name (resolved via resolve-branch)")
    parser.add_argument("--repo-dir", "--worktree",
                        help="Git worktree directory")
    args = parser.parse_args()

    ctx = pr_context.resolve(
        pr=args.pr, branch=args.branch, repo_dir=args.repo_dir,
    )

    json.dump({
        "repo": ctx.repo,
        "branch": ctx.branch,
        "pr_number": ctx.pr_number,
        "worktree_root": str(ctx.worktree_root) if ctx.worktree_root else None,
        "head_sha": ctx.head_sha,
    }, sys.stdout, indent=2)
    print()


if __name__ == "__main__":
    main()
