#!/usr/bin/env python3
"""Rebase current branch onto origin/main with conflict detection and AI resolution.

Manages the git rebase lifecycle: start, resume, abort, and force-push.
With --fix, automatically resolves merge conflicts using claude -p.
Outputs structured JSON on stdout and status messages on stderr.
Updates PR state in <worktree>/ignore/pr/state.json.

Exit codes:
  0  Success (clean rebase or operation completed)
  1  Error (pre-flight failure, git error)
  3  Conflicts detected (JSON report on stdout)

Usage:
  pr-rebase                           # start or resume rebase
  pr-rebase --fix                     # resolve conflicts, rebase, and force-push
  pr-rebase --push                    # force-push after completed rebase
  pr-rebase --abort                   # abort in-progress rebase
  pr-rebase --repo-dir <path>         # specify worktree directory
"""

import argparse
import json
import shutil
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

import pr_context
import pr_state


# ── Git helpers ─────────────────────────────────────────────────────────────


def _git_dir(cwd: str) -> Path:
    """Return the .git directory path for the repo."""
    git_dir = subprocess.run(
        ["git", "rev-parse", "--git-dir"],
        capture_output=True, text=True, cwd=cwd,
    ).stdout.strip()
    return Path(git_dir) if Path(git_dir).is_absolute() else Path(cwd) / git_dir


def _detect_rebase_in_progress(cwd: str) -> bool:
    """Check if a rebase is currently in progress."""
    git_path = _git_dir(cwd)
    return (git_path / "rebase-merge").is_dir() or (git_path / "rebase-apply").is_dir()


def _detect_conflicts(cwd: str) -> list[str]:
    """Return list of conflicted file paths."""
    r = subprocess.run(
        ["git", "diff", "--name-only", "--diff-filter=U"],
        capture_output=True, text=True, cwd=cwd,
    )
    return [f for f in r.stdout.strip().splitlines() if f]


def _rebase_head_info(cwd: str) -> tuple[str, str]:
    """Return (short SHA, subject) of the commit being rebased."""
    sha = subprocess.run(
        ["git", "rev-parse", "--short", "REBASE_HEAD"],
        capture_output=True, text=True, cwd=cwd,
    ).stdout.strip()
    subject = subprocess.run(
        ["git", "log", "-1", "--format=%s", "REBASE_HEAD"],
        capture_output=True, text=True, cwd=cwd,
    ).stdout.strip()
    return sha, subject


_PICK_COMMANDS = {
    "pick", "p", "reword", "r", "edit", "e",
    "squash", "s", "fixup", "f", "drop", "d",
}


def _remaining_rebase_commits(cwd: str) -> int:
    """Count remaining commits in the rebase todo."""
    git_path = _git_dir(cwd)
    todo = git_path / "rebase-merge" / "git-rebase-todo"
    if todo.exists():
        return sum(
            1 for line in todo.read_text().splitlines()
            if line.strip() and not line.startswith("#")
            and line.split()[0] in _PICK_COMMANDS
        )
    next_file = git_path / "rebase-apply" / "next"
    last_file = git_path / "rebase-apply" / "last"
    if next_file.exists() and last_file.exists():
        try:
            return int(last_file.read_text().strip()) - int(next_file.read_text().strip())
        except ValueError:
            return 0
    return 0


def _conflict_report(cwd: str, status: str = "conflicts") -> dict:
    """Build a conflict report dict for JSON output."""
    conflicts = _detect_conflicts(cwd)
    sha, subject = _rebase_head_info(cwd)
    remaining = _remaining_rebase_commits(cwd)
    return {
        "status": status,
        "files": conflicts,
        "rebase_head": sha,
        "rebase_head_subject": subject,
        "remaining_commits": remaining,
    }


def _commits_ahead(cwd: str) -> int:
    """Count commits ahead of origin/main."""
    out = subprocess.run(
        ["git", "rev-list", "--count", "origin/main..HEAD"],
        capture_output=True, text=True, cwd=cwd,
    ).stdout.strip()
    return int(out) if out.isdigit() else 0


# ── Conflict resolution ────────────────────────────────────────────────────

_RESOLVE_BEGIN = "<<<RESOLVED>>>"
_RESOLVE_END = "<<<END_RESOLVED>>>"

_CONFLICT_MARKER_HEADS = ("<<<<<<< ", "=======", ">>>>>>> ")


def _is_binary(path: Path) -> bool:
    """Check if a file is binary by looking for null bytes in the first 8KB."""
    try:
        chunk = path.read_bytes()[:8192]
        return b"\x00" in chunk
    except OSError:
        return False


def _build_resolve_prompt(filepath: str, content: str, sha: str, subject: str) -> str:
    """Build a prompt for claude -p to resolve a merge conflict."""
    return (
        "You are resolving a merge conflict during a git rebase onto origin/main.\n"
        "\n"
        f"File: {filepath}\n"
        f"Commit being applied: {sha} — {subject}\n"
        "\n"
        "In a rebase, conflict markers mean:\n"
        "- <<<<<<< HEAD = the base side (origin/main or previously rebased commits)\n"
        "- ======= separates the two sides\n"
        f"- >>>>>>> {sha} = the branch's changes being replayed\n"
        "\n"
        "Merge both sides, preserving the intent of both. If both sides add "
        "non-overlapping content, keep both. If they modify the same lines, "
        "combine them sensibly.\n"
        "\n"
        f"Output the resolved file between {_RESOLVE_BEGIN} and {_RESOLVE_END} markers.\n"
        "No explanation, no markdown fencing, no commentary outside the markers.\n"
        "\n"
        f"{_RESOLVE_BEGIN}\n"
        "(your resolved content here)\n"
        f"{_RESOLVE_END}\n"
        "\n"
        "--- FILE CONTENT WITH CONFLICT MARKERS ---\n"
        f"{content}"
    )


def _parse_resolved_content(stdout: str) -> str | None:
    """Extract resolved file content from claude -p output."""
    begin = stdout.find(_RESOLVE_BEGIN)
    end = stdout.find(_RESOLVE_END)
    if begin != -1 and end != -1 and end > begin:
        resolved = stdout[begin + len(_RESOLVE_BEGIN):end]
        if resolved.startswith("\n"):
            resolved = resolved[1:]
        if resolved.endswith("\n"):
            resolved = resolved[:-1]
        # Final newline for POSIX compliance
        return resolved + "\n"

    # Fallback: use raw stdout if it contains no conflict markers
    for marker in _CONFLICT_MARKER_HEADS:
        if marker in stdout:
            return None
    return stdout if stdout.strip() else None


def _resolve_file_conflicts(
    conflicts: list[str], cwd: str, sha: str, subject: str,
) -> list[str] | None:
    """Resolve conflicted files using claude -p. Returns resolved paths or None on failure."""
    resolved = []
    go_dirs: set[str] = set()

    for filepath in conflicts:
        full_path = Path(cwd) / filepath

        if _is_binary(full_path):
            print(f"  Cannot resolve binary file: {filepath}", file=sys.stderr)
            return None

        # go.sum: accept theirs and regenerate after
        if filepath.endswith("go.sum"):
            subprocess.run(["git", "checkout", "--theirs", filepath], cwd=cwd)
            subprocess.run(["git", "add", filepath], cwd=cwd)
            go_dirs.add(str(full_path.parent))
            resolved.append(filepath)
            print(f"  Accepted theirs: {filepath} (will regenerate)", file=sys.stderr)
            continue

        try:
            content = full_path.read_text()
        except OSError as e:
            print(f"  Cannot read {filepath}: {e}", file=sys.stderr)
            return None

        prompt = _build_resolve_prompt(filepath, content, sha, subject)
        result = subprocess.run(
            ["claude", "-p", "--bare"],
            input=prompt,
            capture_output=True,
            text=True,
        )
        if result.returncode != 0:
            print(f"  claude -p failed for {filepath} (exit {result.returncode})", file=sys.stderr)
            return None

        resolved_content = _parse_resolved_content(result.stdout)
        if resolved_content is None:
            print(f"  Failed to parse resolution for {filepath}", file=sys.stderr)
            return None

        full_path.write_text(resolved_content)
        subprocess.run(["git", "add", filepath], cwd=cwd)
        resolved.append(filepath)
        print(f"  Resolved: {filepath}", file=sys.stderr)

        if filepath.endswith("go.mod"):
            go_dirs.add(str(full_path.parent))

    # Regenerate go.sum for any directories with resolved go.mod/go.sum
    for go_dir in go_dirs:
        print(f"  Running go mod tidy in {Path(go_dir).name}/...", file=sys.stderr)
        r = subprocess.run(
            ["go", "mod", "tidy"],
            cwd=go_dir,
            capture_output=True, text=True,
        )
        if r.returncode != 0:
            print(f"  Warning: go mod tidy failed: {r.stderr.strip()}", file=sys.stderr)
        go_sum = Path(go_dir) / "go.sum"
        if go_sum.exists():
            subprocess.run(["git", "add", "go.sum"], cwd=go_dir)

    return resolved


def _resolve_and_continue(cwd: str) -> tuple[list[str], int] | None:
    """AI-assisted conflict resolution loop.

    Returns (files_resolved, commits_with_conflicts) on success, or None on failure.
    """
    if not shutil.which("claude"):
        return None

    all_resolved: list[str] = []
    commits_conflicted = 0

    while True:
        conflicts = _detect_conflicts(cwd)
        if not conflicts:
            break

        commits_conflicted += 1
        sha, subject = _rebase_head_info(cwd)
        remaining = _remaining_rebase_commits(cwd)
        print(
            f"Resolving {len(conflicts)} conflict(s) in {sha} — {subject} "
            f"({remaining} commits remaining)...",
            file=sys.stderr,
        )

        resolved = _resolve_file_conflicts(conflicts, cwd, sha, subject)
        if resolved is None:
            return None
        all_resolved.extend(resolved)

        r = subprocess.run(
            ["git", "-c", "core.editor=true", "rebase", "--continue"],
            cwd=cwd,
        )
        if r.returncode == 0 and not _detect_rebase_in_progress(cwd):
            break
        if r.returncode == 0:
            continue

        # Continue failed — check for new conflicts on the next commit
        new_conflicts = _detect_conflicts(cwd)
        if not new_conflicts:
            print(f"rebase --continue failed (exit {r.returncode})", file=sys.stderr)
            return None
        # Loop again with new conflicts

    return all_resolved, commits_conflicted


# ── State helpers ───────────────────────────────────────────────────────────


def _load_or_init(ctx: pr_context.ResolvedContext) -> pr_state.PRState:
    """Load existing state or create a fresh one from resolved context."""
    return pr_state.load_or_init(
        worktree_root=ctx.worktree_root,
        repo=ctx.repo,
        branch=ctx.branch,
        pr_number=ctx.pr_number,
        head_sha=ctx.head_sha,
    )


def _handle_conflicts(
    cwd: str, ctx: pr_context.ResolvedContext, fix: bool,
    status: str = "conflicts",
) -> int:
    """Handle detected conflicts: resolve with AI (--fix) or report and exit 3."""
    if not fix:
        report = _conflict_report(cwd, status=status)
        json.dump(report, sys.stdout, indent=2)
        print()
        return 3

    result = _resolve_and_continue(cwd)
    if result is None:
        print("AI conflict resolution failed — aborting rebase.", file=sys.stderr)
        subprocess.run(["git", "rebase", "--abort"], cwd=cwd)
        return 1
    return _rebase_success(cwd, ctx, fix, resolved=result)


# ── Subcommands ─────────────────────────────────────────────────────────────


def cmd_abort(cwd: str, ctx: pr_context.ResolvedContext) -> int:
    """Abort an in-progress rebase and reset state."""
    print("Aborting rebase...", file=sys.stderr)
    r = subprocess.run(["git", "rebase", "--abort"], cwd=cwd)
    if r.returncode == 0:
        state = _load_or_init(ctx)
        pr_state.update_rebase(state, pr_state.RebaseSummary())
        pr_state.save_state(ctx.worktree_root, state)
        print("Rebase aborted.", file=sys.stderr)
    return r.returncode


def cmd_push(cwd: str, ctx: pr_context.ResolvedContext) -> int:
    """Force-push after a completed rebase."""
    if _detect_rebase_in_progress(cwd):
        print("Cannot push — rebase still in progress.", file=sys.stderr)
        return 1

    print("Force-pushing...", file=sys.stderr)
    r = subprocess.run(["git", "push", "--force-with-lease"], cwd=cwd)
    if r.returncode != 0:
        return r.returncode

    state = _load_or_init(ctx)
    target_base = state.rebase.target_base or subprocess.run(
        ["git", "rev-parse", "origin/main"],
        capture_output=True, text=True, cwd=cwd,
    ).stdout.strip()
    commits = state.rebase.commits_replayed or _commits_ahead(cwd)

    pr_state.update_rebase(state, pr_state.RebaseSummary(
        target_base=target_base,
        commits_replayed=commits,
        conflicts_resolved=state.rebase.conflicts_resolved,
        files_resolved=state.rebase.files_resolved,
        force_pushed=True,
        updated_at=pr_state.now_iso(),
    ))
    pr_state.save_state(ctx.worktree_root, state)
    print("Force-pushed successfully.", file=sys.stderr)
    return 0


def cmd_start(cwd: str, ctx: pr_context.ResolvedContext, fix: bool) -> int:
    """Start or resume a rebase onto origin/main."""
    if _detect_rebase_in_progress(cwd):
        return _resume(cwd, ctx, fix)
    return _fresh(cwd, ctx, fix)


def _resume(cwd: str, ctx: pr_context.ResolvedContext, fix: bool) -> int:
    """Resume an in-progress rebase."""
    print("Detected in-progress rebase — resuming...", file=sys.stderr)

    conflicts = _detect_conflicts(cwd)
    if conflicts:
        return _handle_conflicts(cwd, ctx, fix, status="conflicts_resuming")

    r = subprocess.run(
        ["git", "-c", "core.editor=true", "rebase", "--continue"],
        cwd=cwd,
    )
    if r.returncode == 0:
        return _rebase_success(cwd, ctx, fix)

    conflicts = _detect_conflicts(cwd)
    if conflicts:
        return _handle_conflicts(cwd, ctx, fix)

    return r.returncode


def _fresh(cwd: str, ctx: pr_context.ResolvedContext, fix: bool) -> int:
    """Start a fresh rebase onto origin/main."""
    if ctx.branch in ("main", "master"):
        print("Cannot rebase — currently on protected branch.", file=sys.stderr)
        return 1

    status = subprocess.run(
        ["git", "status", "--porcelain"],
        capture_output=True, text=True, cwd=cwd,
    )
    if status.stdout.strip():
        print("Cannot rebase — working tree has uncommitted changes.", file=sys.stderr)
        return 1

    print("Fetching origin...", file=sys.stderr)
    fetch = subprocess.run(["git", "fetch", "origin"], cwd=cwd)
    if fetch.returncode != 0:
        print("Warning: fetch failed — rebasing against potentially stale origin/main.", file=sys.stderr)

    print("Rebasing onto origin/main...", file=sys.stderr)
    r = subprocess.run(["git", "rebase", "origin/main"], cwd=cwd)

    if r.returncode == 0:
        return _rebase_success(cwd, ctx, fix)

    conflicts = _detect_conflicts(cwd)
    if conflicts:
        return _handle_conflicts(cwd, ctx, fix)

    return r.returncode


def _rebase_success(
    cwd: str, ctx: pr_context.ResolvedContext, fix: bool,
    resolved: tuple[list[str], int] | None = None,
) -> int:
    """Handle rebase completion — update state and optionally force-push."""
    commits = _commits_ahead(cwd)
    state = _load_or_init(ctx)
    files_resolved = resolved[0] if resolved else []
    conflicts_resolved = resolved[1] if resolved else 0

    if fix:
        label = "Rebase complete" if not resolved else (
            f"Rebase complete — resolved {len(files_resolved)} file(s) "
            f"across {conflicts_resolved} commit(s)"
        )
        print(f"{label} — force-pushing...", file=sys.stderr)
        r = subprocess.run(["git", "push", "--force-with-lease"], cwd=cwd)
        pr_state.update_rebase(state, pr_state.RebaseSummary(
            target_base="origin/main",
            commits_replayed=commits,
            conflicts_resolved=conflicts_resolved,
            files_resolved=files_resolved,
            force_pushed=r.returncode == 0,
            updated_at=pr_state.now_iso(),
        ))
        pr_state.save_state(ctx.worktree_root, state)
        report = {
            "status": "clean",
            "commits_replayed": commits,
            "conflicts_resolved": conflicts_resolved,
            "files_resolved": files_resolved,
            "force_pushed": r.returncode == 0,
        }
        json.dump(report, sys.stdout, indent=2)
        print()
        if r.returncode == 0:
            print("Force-pushed.", file=sys.stderr)
        else:
            print("Force-push failed.", file=sys.stderr)
        return r.returncode

    pr_state.update_rebase(state, pr_state.RebaseSummary(
        target_base="origin/main",
        commits_replayed=commits,
        conflicts_resolved=conflicts_resolved,
        files_resolved=files_resolved,
        force_pushed=False,
        updated_at=pr_state.now_iso(),
    ))
    pr_state.save_state(ctx.worktree_root, state)
    report = {
        "status": "clean",
        "commits_replayed": commits,
        "conflicts_resolved": conflicts_resolved,
        "files_resolved": files_resolved,
    }
    json.dump(report, sys.stdout, indent=2)
    print()
    print("Rebase clean — run `pr rebase --push` to force-push.", file=sys.stderr)
    return 0


# ── CLI ─────────────────────────────────────────────────────────────────────


def main():
    parser = argparse.ArgumentParser(
        prog="pr-rebase",
        description="Rebase onto origin/main with conflict detection and force-push",
    )
    parser.add_argument("--repo-dir", "--worktree",
                        dest="repo_dir",
                        help="Git worktree directory")
    parser.add_argument("--branch", help="Branch name (injected by pr dispatcher)")
    parser.add_argument("--pr", help="PR number (injected by pr dispatcher)")
    parser.add_argument("--fix", action="store_true",
                        help="Autonomous mode — resolve conflicts with AI, rebase, and force-push")
    parser.add_argument("--push", action="store_true",
                        help="Force-push after successful rebase")
    parser.add_argument("--abort", action="store_true",
                        help="Abort in-progress rebase")

    args = parser.parse_args()

    ctx = pr_context.resolve(
        repo_dir=args.repo_dir, branch=args.branch, pr=args.pr,
    )
    cwd = str(ctx.worktree_root)

    if args.abort:
        sys.exit(cmd_abort(cwd, ctx))
    elif args.push:
        sys.exit(cmd_push(cwd, ctx))
    else:
        sys.exit(cmd_start(cwd, ctx, args.fix))


if __name__ == "__main__":
    main()
