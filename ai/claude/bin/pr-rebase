#!/usr/bin/env python3
"""Rebase current branch onto origin/main with conflict detection and AI resolution.

Manages the git rebase lifecycle: start, resume, abort, and force-push.
With --fix, automatically resolves merge conflicts using AI.
Outputs structured JSON on stdout and status messages on stderr.
Updates PR state in <worktree>/.workbench/state.json.

Exit codes:
  0  Success (clean rebase or operation completed)
  1  Error (pre-flight failure, git error)
  3  Conflicts detected (JSON report on stdout)

Usage:
  pr-rebase                           # start or resume rebase
  pr-rebase --fix                     # resolve conflicts, rebase, and force-push
  pr-rebase --push                    # force-push after completed rebase
  pr-rebase --abort                   # abort in-progress rebase
  pr-rebase --repo-dir <path>         # specify worktree directory
"""

import argparse
import json
import subprocess
import sys
import traceback
from contextlib import contextmanager
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

import ai_backend
import log
import pr_context
import pr_state
from trail import Trail, add_trail_args


# Module-level trail instance — set in main() after context is resolved.
# Inner helper functions use _trail for instrumentation without changing signatures.
_trail: Trail | None = None


def _terr(action: str, detail: str, **kwargs) -> None:
    if _trail:
        _trail.error(action, detail, **kwargs)


_TARGET_REF = "origin/main"

_GIT_REBASE_MERGE_DIR = "rebase-merge"
_GIT_REBASE_APPLY_DIR = "rebase-apply"
_GIT_REBASE_TODO = "git-rebase-todo"
_GIT_REBASE_NEXT = "next"
_GIT_REBASE_LAST = "last"


# ── Git helpers ─────────────────────────────────────────────────────────────


def _git_dir(cwd: str) -> Path:
    """Return the .git directory path for the repo."""
    git_dir = subprocess.run(
        ["git", "rev-parse", "--git-dir"],
        capture_output=True, text=True, cwd=cwd,
    ).stdout.strip()
    return Path(git_dir) if Path(git_dir).is_absolute() else Path(cwd) / git_dir


def _detect_rebase_in_progress(cwd: str) -> bool:
    """Check if a rebase is currently in progress."""
    git_path = _git_dir(cwd)
    return (git_path / _GIT_REBASE_MERGE_DIR).is_dir() or (git_path / _GIT_REBASE_APPLY_DIR).is_dir()


def _detect_conflicts(cwd: str) -> list[str]:
    """Return list of conflicted file paths."""
    r = subprocess.run(
        ["git", "diff", "--name-only", "--diff-filter=U"],
        capture_output=True, text=True, cwd=cwd,
    )
    return [f for f in r.stdout.strip().splitlines() if f]


def _rebase_head_info(cwd: str) -> tuple[str, str]:
    """Return (short SHA, subject) of the commit being rebased."""
    sha = subprocess.run(
        ["git", "rev-parse", "--short", "REBASE_HEAD"],
        capture_output=True, text=True, cwd=cwd,
    ).stdout.strip()
    subject = subprocess.run(
        ["git", "log", "-1", "--format=%s", "REBASE_HEAD"],
        capture_output=True, text=True, cwd=cwd,
    ).stdout.strip()
    return sha, subject


_PICK_COMMANDS = {
    "pick", "p", "reword", "r", "edit", "e",
    "squash", "s", "fixup", "f", "drop", "d",
}


def _remaining_rebase_commits(cwd: str) -> int:
    """Count remaining commits in the rebase todo."""
    git_path = _git_dir(cwd)
    todo = git_path / _GIT_REBASE_MERGE_DIR / _GIT_REBASE_TODO
    if todo.exists():
        return sum(
            1 for line in todo.read_text().splitlines()
            if line.strip() and not line.startswith("#")
            and line.split()[0] in _PICK_COMMANDS
        )
    next_file = git_path / _GIT_REBASE_APPLY_DIR / _GIT_REBASE_NEXT
    last_file = git_path / _GIT_REBASE_APPLY_DIR / _GIT_REBASE_LAST
    if next_file.exists() and last_file.exists():
        try:
            return int(last_file.read_text().strip()) - int(next_file.read_text().strip())
        except ValueError:
            return 0
    return 0


def _conflict_report(cwd: str, status: str = "conflicts") -> dict:
    """Build a conflict report dict for JSON output."""
    conflicts = _detect_conflicts(cwd)
    sha, subject = _rebase_head_info(cwd)
    remaining = _remaining_rebase_commits(cwd)
    return {
        "status": status,
        "files": conflicts,
        "rebase_head": sha,
        "rebase_head_subject": subject,
        "remaining_commits": remaining,
    }


def _commits_ahead(cwd: str) -> int:
    """Count commits ahead of the target ref."""
    out = subprocess.run(
        ["git", "rev-list", "--count", f"{_TARGET_REF}..HEAD"],
        capture_output=True, text=True, cwd=cwd,
    ).stdout.strip()
    return int(out) if out.isdigit() else 0


def _is_empty_patch(cwd: str) -> bool:
    """Check if the current rebase step has no changes (patch already applied upstream)."""
    staged = subprocess.run(
        ["git", "diff", "--cached", "--quiet"],
        cwd=cwd,
    )
    unstaged = subprocess.run(
        ["git", "diff", "--quiet"],
        cwd=cwd,
    )
    return staged.returncode == 0 and unstaged.returncode == 0


# ── Conflict resolution ────────────────────────────────────────────────────

_RESOLVE_BEGIN = "<<<RESOLVED>>>"
_RESOLVE_END = "<<<END_RESOLVED>>>"

_CONFLICT_MARKER_HEADS = ("<<<<<<< ", "=======", ">>>>>>> ")


def _is_binary(path: Path) -> bool:
    """Check if a file is binary by looking for null bytes in the first 8KB."""
    try:
        chunk = path.read_bytes()[:8192]
        return b"\x00" in chunk
    except OSError:
        return False


def _build_resolve_prompt(filepath: str, content: str, sha: str, subject: str) -> str:
    """Build a prompt to resolve a merge conflict."""
    return (
        f"You are resolving a merge conflict during a git rebase onto {_TARGET_REF}.\n"
        "\n"
        f"File: {filepath}\n"
        f"Commit being applied: {sha} — {subject}\n"
        "\n"
        "In a rebase, conflict markers mean:\n"
        f"- <<<<<<< HEAD = the base side ({_TARGET_REF} or previously rebased commits)\n"
        "- ======= separates the two sides\n"
        f"- >>>>>>> {sha} = the branch's changes being replayed\n"
        "\n"
        "Merge both sides, preserving the intent of both. If both sides add "
        "non-overlapping content, keep both. If they modify the same lines, "
        "combine them sensibly.\n"
        "\n"
        f"Output the resolved file between {_RESOLVE_BEGIN} and {_RESOLVE_END} markers.\n"
        "No explanation, no markdown fencing, no commentary outside the markers.\n"
        "\n"
        f"{_RESOLVE_BEGIN}\n"
        "(your resolved content here)\n"
        f"{_RESOLVE_END}\n"
        "\n"
        "--- FILE CONTENT WITH CONFLICT MARKERS ---\n"
        f"{content}"
    )


def _parse_resolved_content(stdout: str) -> str | None:
    """Extract resolved file content from AI output."""
    begin = stdout.find(_RESOLVE_BEGIN)
    end = stdout.find(_RESOLVE_END)
    if begin == -1 or end == -1 or end <= begin:
        return None

    resolved = stdout[begin + len(_RESOLVE_BEGIN):end]
    if resolved.startswith("\n"):
        resolved = resolved[1:]
    if resolved.endswith("\n"):
        resolved = resolved[:-1]

    # Reject if conflict markers survived
    for marker in _CONFLICT_MARKER_HEADS:
        if marker in resolved:
            return None

    return resolved + "\n"


def _git_add(filepath: str, cwd: str) -> bool:
    """Stage a file and return True on success."""
    r = subprocess.run(["git", "add", filepath], cwd=cwd)
    if r.returncode != 0:
        log.error(f"git add failed for {filepath}")
    return r.returncode == 0


def _accept_theirs_and_stage(filepath: str, parent: Path, cwd: str) -> bool:
    """Accept theirs for a generated file and stage it."""
    r = subprocess.run(["git", "checkout", "--theirs", filepath], cwd=cwd)
    if r.returncode != 0:
        log.error(f"git checkout --theirs failed for {filepath}")
        return False
    if not _git_add(filepath, cwd):
        return False
    log.info(f"Accepted theirs: {filepath} (will regenerate)")
    return True


def _resolve_single_file(
    filepath: str, full_path: Path, sha: str, subject: str, cwd: str,
) -> str | None:
    """Resolve a single conflicted text file via AI. Returns filepath or None."""
    try:
        content = full_path.read_text()
    except OSError as e:
        log.error(f"Cannot read {filepath}: {e}")
        return None

    prompt = _build_resolve_prompt(filepath, content, sha, subject)
    stdout, rc = ai_backend.prompt(prompt)
    if rc != 0:
        _terr("resolve_conflicts", f"AI prompt failed for {filepath}", data={"filepath": filepath, "exit_code": rc})
        log.error(f"ai prompt failed for {filepath} (exit {rc})")
        return None

    resolved_content = _parse_resolved_content(stdout)
    if resolved_content is None:
        _terr("resolve_conflicts", f"failed to parse resolution for {filepath}", data={"filepath": filepath})
        log.error(f"Failed to parse resolution for {filepath}")
        return None

    full_path.write_text(resolved_content)
    if not _git_add(filepath, cwd):
        return None
    log.ok(f"Resolved: {filepath}")
    return filepath


def _resolve_one(
    filepath: str, full_path: Path, sha: str, subject: str,
    cwd: str, go_dirs: set[Path],
) -> bool:
    """Resolve a single conflicted file — dispatch by type."""
    if filepath.endswith("go.sum"):
        if _trail:
            _trail.decision(
                "special_file",
                f"accepting theirs for {filepath}",
                reason="auto-resolved file type (go.sum)",
            )
        ok = _accept_theirs_and_stage(filepath, full_path.parent, cwd)
        if ok:
            go_dirs.add(full_path.parent)
        return ok

    result = _resolve_single_file(filepath, full_path, sha, subject, cwd)
    if result is None:
        return False
    if _trail:
        _trail.info("resolve_conflict", f"resolved {filepath}", data={"commit": sha, "method": "ai"})
    if filepath.endswith("go.mod"):
        go_dirs.add(full_path.parent)
    return True


def _resolve_file_conflicts(
    conflicts: list[str], cwd: str, sha: str, subject: str,
) -> list[str] | None:
    """Resolve conflicted files via AI. Returns resolved paths or None on failure."""
    resolved = []
    go_dirs: set[Path] = set()

    for filepath in conflicts:
        full_path = Path(cwd) / filepath

        if _is_binary(full_path):
            _terr("resolve_conflicts", f"binary file: {filepath}", data={"filepath": filepath})
            log.error(f"Cannot resolve binary file: {filepath}")
            return None

        ok = _resolve_one(filepath, full_path, sha, subject, cwd, go_dirs)
        if not ok:
            return None
        resolved.append(filepath)

    # Regenerate go.sum for any directories with resolved go.mod/go.sum
    for go_dir in go_dirs:
        log.info(f"Running go mod tidy in {go_dir.name}/...")
        r = subprocess.run(
            ["go", "mod", "tidy"],
            cwd=str(go_dir),
            capture_output=True, text=True,
        )
        if r.returncode != 0:
            _terr("resolve_conflicts", f"go mod tidy failed in {go_dir.name}", data={"stderr": r.stderr.strip()})
            log.error(f"go mod tidy failed: {r.stderr.strip()}")
            return None
        go_sum = go_dir / "go.sum"
        if go_sum.exists():
            _git_add("go.sum", str(go_dir))

    return resolved


# ── Rebase lifecycle ───────────────────────────────────────────────────────

_MAX_REBASE_STEPS = 500


def _drive_to_completion(
    cwd: str, ctx: pr_context.ResolvedContext, fix: bool,
) -> int:
    """Drive an in-progress rebase to completion, handling all intermediate states.

    Loops until the rebase finishes, handling conflicts (via AI when --fix),
    empty commits (via --skip), and stuck states (fallback to --skip).
    """
    with _trail.span("drive_to_completion") if _trail else _nullspan():
        return _drive_loop(cwd, ctx, fix)


def _drive_loop(
    cwd: str, ctx: pr_context.ResolvedContext, fix: bool,
) -> int:
    all_resolved: list[str] = []
    commits_conflicted: list[int] = [0]

    for _ in range(_MAX_REBASE_STEPS):
        if not _detect_rebase_in_progress(cwd):
            resolved = (all_resolved, commits_conflicted[0]) if commits_conflicted[0] else None
            return _rebase_success(cwd, ctx, fix, resolved=resolved)

        rc = _drive_one_step(cwd, ctx, fix, all_resolved, commits_conflicted)
        if rc is not None:
            return rc

    _terr("drive_to_completion", f"rebase did not complete after {_MAX_REBASE_STEPS} steps")
    log.error(f"Rebase did not complete after {_MAX_REBASE_STEPS} steps — aborting.")
    subprocess.run(["git", "rebase", "--abort"], cwd=cwd)
    return 1


def _drive_one_step(
    cwd: str, ctx: pr_context.ResolvedContext, fix: bool,
    all_resolved: list[str], commits_conflicted: list[int],
) -> int | None:
    conflicts = _detect_conflicts(cwd)
    if not conflicts:
        return _step_advance(cwd)

    rc = _step_conflicts(cwd, ctx, fix, conflicts, all_resolved)
    if rc is not None:
        return rc
    commits_conflicted[0] += 1
    return None


def _step_conflicts(
    cwd: str, ctx: pr_context.ResolvedContext, fix: bool,
    conflicts: list[str], all_resolved: list[str],
) -> int | None:
    """Handle a rebase step with conflicts. Returns exit code to stop, or None to continue."""
    sha, subject = _rebase_head_info(cwd)
    remaining = _remaining_rebase_commits(cwd)

    if not fix:
        report = _conflict_report(cwd)
        json.dump(report, sys.stdout, indent=2)
        print()
        return 3

    if not ai_backend.is_available():
        _terr("resolve_conflicts", "AI backend unavailable")
        log.error("Cannot resolve conflicts — AI backend unavailable.")
        report = _conflict_report(cwd)
        json.dump(report, sys.stdout, indent=2)
        print()
        return 3

    log.info(
        f"Resolving {len(conflicts)} conflict(s) in {sha} — {subject} "
        f"({remaining} remaining)..."
    )
    if _trail:
        _trail.decision(
            "step", f"resolving {len(conflicts)} conflict(s)",
            reason=f"commit {sha} has unmerged files",
            data={"commit": sha, "files": conflicts, "remaining": remaining},
        )

    resolved = _resolve_file_conflicts(conflicts, cwd, sha, subject)
    if resolved is None:
        _terr("resolve_conflicts", "AI resolution failed, aborting rebase")
        log.error("AI conflict resolution failed — aborting rebase.")
        subprocess.run(["git", "rebase", "--abort"], cwd=cwd)
        return 1
    all_resolved.extend(resolved)

    r = subprocess.run(
        ["git", "-c", "core.editor=true", "rebase", "--continue"],
        capture_output=True, text=True, cwd=cwd,
    )
    if r.returncode != 0 and r.stderr.strip():
        log.dim(r.stderr.strip())
    return None


def _step_advance(cwd: str) -> int | None:
    """Advance rebase when there are no conflicts. Returns exit code to stop, or None to continue."""
    if _is_empty_patch(cwd):
        sha, subject = _rebase_head_info(cwd)
        log.info(f"Skipping empty commit {sha} — {subject}")
        if _trail:
            _trail.decision(
                "step", f"skipping empty commit {sha}",
                reason="patch already applied upstream",
                data={"commit": sha, "subject": subject},
            )
        subprocess.run(["git", "rebase", "--skip"], cwd=cwd)
        return None

    r = subprocess.run(
        ["git", "-c", "core.editor=true", "rebase", "--continue"],
        capture_output=True, text=True, cwd=cwd,
    )
    if r.returncode == 0:
        return None

    log.warn("rebase --continue failed without conflicts — trying --skip")
    if r.stderr.strip():
        log.dim(r.stderr.strip())
    if _trail:
        _trail.warn(
            "step", "falling back to --skip",
            data={"stderr": r.stderr.strip(), "exit_code": r.returncode},
        )
    subprocess.run(["git", "rebase", "--skip"], cwd=cwd)
    return None


@contextmanager
def _nullspan():
    yield


# ── State helpers ───────────────────────────────────────────────────────────


def _load_or_init(ctx: pr_context.ResolvedContext) -> pr_state.PRState:
    """Load existing state or create a fresh one from resolved context."""
    return pr_state.load_or_init(
        worktree_root=ctx.worktree_root,
        repo=ctx.repo,
        branch=ctx.branch,
        pr_number=ctx.pr_number,
        head_sha=ctx.head_sha,
    )


# ── Subcommands ─────────────────────────────────────────────────────────────


def cmd_abort(cwd: str, ctx: pr_context.ResolvedContext) -> int:
    """Abort an in-progress rebase and reset state."""
    log.info("Aborting rebase...")
    r = subprocess.run(["git", "rebase", "--abort"], cwd=cwd)
    if r.returncode == 0:
        state = _load_or_init(ctx)
        pr_state.update_rebase(state, pr_state.RebaseSummary())
        pr_state.save_state(ctx.worktree_root, state)
        log.ok("Rebase aborted.")
    return r.returncode


def cmd_push(cwd: str, ctx: pr_context.ResolvedContext) -> int:
    """Force-push after a completed rebase."""
    if _detect_rebase_in_progress(cwd):
        _terr("push", "rebase still in progress")
        log.error("Cannot push — rebase still in progress.")
        return 1

    log.info("Force-pushing...")
    r = subprocess.run(["git", "push", "--force-with-lease"], cwd=cwd)
    if r.returncode != 0:
        _terr("push", "force-push failed", data={"exit_code": r.returncode})
        return r.returncode

    state = _load_or_init(ctx)
    target_base = state.rebase.target_base or subprocess.run(
        ["git", "rev-parse", _TARGET_REF],
        capture_output=True, text=True, cwd=cwd,
    ).stdout.strip()
    commits = state.rebase.commits_replayed or _commits_ahead(cwd)

    pr_state.update_rebase(state, pr_state.RebaseSummary(
        target_base=target_base,
        commits_replayed=commits,
        conflicts_resolved=state.rebase.conflicts_resolved,
        files_resolved=state.rebase.files_resolved,
        force_pushed=True,
        updated_at=pr_state.now_iso(),
    ))
    pr_state.save_state(ctx.worktree_root, state)
    log.ok("Force-pushed successfully.")
    return 0


def cmd_start(cwd: str, ctx: pr_context.ResolvedContext, fix: bool) -> int:
    """Start or resume a rebase onto origin/main."""
    if _detect_rebase_in_progress(cwd):
        if _trail:
            _trail.decision(
                "rebase_state",
                "detected in-progress rebase",
                reason="rebase-merge or rebase-apply directory exists",
            )
        log.info("Detected in-progress rebase — resuming...")
        return _drive_to_completion(cwd, ctx, fix)

    if _trail:
        _trail.decision(
            "rebase_state",
            "starting fresh rebase",
            reason="no in-progress rebase detected",
        )
    return _fresh(cwd, ctx, fix)


def _fresh(cwd: str, ctx: pr_context.ResolvedContext, fix: bool) -> int:
    """Start a fresh rebase onto the target ref."""
    if ctx.branch in ("main", "master"):
        _terr("preflight", f"on protected branch {ctx.branch}")
        log.error("Cannot rebase — currently on protected branch.")
        return 1

    status = subprocess.run(
        ["git", "status", "--porcelain", "--untracked-files=no"],
        capture_output=True, text=True, cwd=cwd,
    )
    if status.stdout.strip():
        _terr("preflight", "working tree has uncommitted changes")
        log.error("Cannot rebase — working tree has uncommitted changes.")
        return 1

    log.info("Fetching origin...")
    fetch = subprocess.run(
        ["git", "fetch", "origin"],
        capture_output=True, text=True, cwd=cwd,
    )
    if fetch.returncode != 0:
        log.warn(f"Fetch failed — rebasing against potentially stale {_TARGET_REF}.")
        if fetch.stderr.strip():
            log.dim(fetch.stderr.strip())

    log.info(f"Rebasing onto {_TARGET_REF}...")
    r = subprocess.run(
        ["git", "rebase", _TARGET_REF],
        capture_output=True, text=True, cwd=cwd,
    )

    if r.returncode == 0 and not _detect_rebase_in_progress(cwd):
        return _rebase_success(cwd, ctx, fix)

    if not _detect_rebase_in_progress(cwd):
        _terr("rebase", f"git rebase failed (exit {r.returncode})", data={"stderr": r.stderr.strip()})
        log.error(f"git rebase failed (exit {r.returncode})")
        if r.stderr.strip():
            log.dim(r.stderr.strip())
        return 1

    return _drive_to_completion(cwd, ctx, fix)


def _rebase_success(
    cwd: str, ctx: pr_context.ResolvedContext, fix: bool,
    resolved: tuple[list[str], int] | None = None,
) -> int:
    """Handle rebase completion — update state and optionally force-push."""
    commits = _commits_ahead(cwd)
    state = _load_or_init(ctx)
    files_resolved = resolved[0] if resolved else []
    conflicts_resolved = resolved[1] if resolved else 0

    if fix:
        label = "Rebase complete" if not resolved else (
            f"Rebase complete — resolved {len(files_resolved)} file(s) "
            f"across {conflicts_resolved} commit(s)"
        )
        log.info(f"{label} — force-pushing...")
        r = subprocess.run(["git", "push", "--force-with-lease"], cwd=cwd)
        if r.returncode == 0:
            _trail and _trail.info("force_push", "force-pushed to remote")
        else:
            _terr("force_push", "force-push failed", data={"exit_code": r.returncode})
        pr_state.update_rebase(state, pr_state.RebaseSummary(
            target_base=_TARGET_REF,
            commits_replayed=commits,
            conflicts_resolved=conflicts_resolved,
            files_resolved=files_resolved,
            force_pushed=r.returncode == 0,
            updated_at=pr_state.now_iso(),
        ))
        pr_state.save_state(ctx.worktree_root, state)
        report = {
            "status": "clean",
            "commits_replayed": commits,
            "conflicts_resolved": conflicts_resolved,
            "files_resolved": files_resolved,
            "force_pushed": r.returncode == 0,
        }
        json.dump(report, sys.stdout, indent=2)
        print()
        if r.returncode == 0:
            log.ok("Force-pushed.")
        else:
            log.error("Force-push failed.")
        return r.returncode

    pr_state.update_rebase(state, pr_state.RebaseSummary(
        target_base=_TARGET_REF,
        commits_replayed=commits,
        conflicts_resolved=conflicts_resolved,
        files_resolved=files_resolved,
        force_pushed=False,
        updated_at=pr_state.now_iso(),
    ))
    pr_state.save_state(ctx.worktree_root, state)
    report = {
        "status": "clean",
        "commits_replayed": commits,
        "conflicts_resolved": conflicts_resolved,
        "files_resolved": files_resolved,
    }
    json.dump(report, sys.stdout, indent=2)
    print()
    log.ok("Rebase clean — run `pr rebase --push` to force-push.")
    return 0


# ── CLI ─────────────────────────────────────────────────────────────────────


def main():
    parser = argparse.ArgumentParser(
        prog="pr-rebase",
        description="Rebase onto origin/main with conflict detection and force-push",
    )
    parser.add_argument("--repo-dir", "--worktree",
                        dest="repo_dir",
                        help="Git worktree directory")
    parser.add_argument("--branch", help="Branch name (injected by pr dispatcher)")
    parser.add_argument("--pr", help="PR number (injected by pr dispatcher)")
    parser.add_argument("--fix", action="store_true",
                        help="Autonomous mode — resolve conflicts with AI, rebase, and force-push")
    parser.add_argument("--push", action="store_true",
                        help="Force-push after successful rebase")
    parser.add_argument("--abort", action="store_true",
                        help="Abort in-progress rebase")
    add_trail_args(parser)

    args = parser.parse_args()

    ctx = pr_context.resolve(
        repo_dir=args.repo_dir, branch=args.branch, pr=args.pr,
    )
    cwd = str(ctx.worktree_root)

    global _trail
    _trail = Trail.start(
        script="pr-rebase",
        artifact_dir=str(Path(cwd) / pr_state.STATE_DIR),
        context={"repo": ctx.repo, "pr": ctx.pr_number, "branch": ctx.branch},
        debug=args.debug,
    )
    try:
        if args.abort:
            _trail.decision("mode", "selected abort", reason="--abort flag set")
            sys.exit(cmd_abort(cwd, ctx))
        elif args.push:
            _trail.decision("mode", "selected push", reason="--push flag set")
            sys.exit(cmd_push(cwd, ctx))
        else:
            mode = "fix" if args.fix else "start"
            _trail.decision("mode", f"selected {mode}", reason="--fix flag set" if args.fix else "default mode")
            sys.exit(cmd_start(cwd, ctx, args.fix))
    except Exception as exc:
        _trail.error("unexpected_error", str(exc), data={"traceback": traceback.format_exc()})
        raise
    finally:
        _trail.finish()


if __name__ == "__main__":
    main()
