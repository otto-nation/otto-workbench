#!/usr/bin/env python3
"""Rebase current branch onto origin/main with conflict detection and AI resolution.

Manages the git rebase lifecycle: start, resume, abort, and force-push.
With --fix, automatically resolves merge conflicts using AI.
Outputs structured JSON on stdout and status messages on stderr.
Updates PR state in <worktree>/.workbench/state.json.

Exit codes:
  0  Success (clean rebase or operation completed)
  1  Error (pre-flight failure, git error)
  3  Conflicts detected (JSON report on stdout)

Usage:
  pr-rebase                           # start or resume rebase
  pr-rebase --fix                     # resolve conflicts, rebase, and force-push
  pr-rebase --push                    # force-push after completed rebase
  pr-rebase --abort                   # abort in-progress rebase
  pr-rebase --repo-dir <path>         # specify worktree directory
"""

import argparse
import json
import subprocess
import sys
import traceback
from contextlib import nullcontext
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

import ai_backend
import log
import pr_context
import pr_state
from trail import Trail, add_trail_args


# Module-level trail instance — set in main() after context is resolved.
# Inner helper functions use _trail for instrumentation without changing signatures.
_trail: Trail | None = None


def _terr(action: str, detail: str, **kwargs) -> None:
    if _trail:
        _trail.error(action, detail, **kwargs)


_TARGET_REF = "origin/main"

_GIT_REBASE_MERGE_DIR = "rebase-merge"
_GIT_REBASE_APPLY_DIR = "rebase-apply"
_GIT_REBASE_TODO = "git-rebase-todo"
_GIT_REBASE_NEXT = "next"
_GIT_REBASE_LAST = "last"


# ── Git helpers ─────────────────────────────────────────────────────────────


def _git_dir(cwd: str) -> Path:
    """Return the .git directory path for the repo."""
    git_dir = subprocess.run(
        ["git", "rev-parse", "--git-dir"],
        capture_output=True, text=True, cwd=cwd,
    ).stdout.strip()
    return Path(git_dir) if Path(git_dir).is_absolute() else Path(cwd) / git_dir


def _detect_rebase_in_progress(cwd: str) -> bool:
    """Check if a rebase is currently in progress."""
    git_path = _git_dir(cwd)
    return (git_path / _GIT_REBASE_MERGE_DIR).is_dir() or (git_path / _GIT_REBASE_APPLY_DIR).is_dir()


def _detect_conflicts(cwd: str) -> list[str]:
    """Return list of conflicted file paths."""
    r = subprocess.run(
        ["git", "diff", "--name-only", "--diff-filter=U"],
        capture_output=True, text=True, cwd=cwd,
    )
    return [f for f in r.stdout.strip().splitlines() if f]


def _rebase_head_info(cwd: str) -> tuple[str, str]:
    """Return (short SHA, subject) of the commit being rebased."""
    sha = subprocess.run(
        ["git", "rev-parse", "--short", "REBASE_HEAD"],
        capture_output=True, text=True, cwd=cwd,
    ).stdout.strip()
    subject = subprocess.run(
        ["git", "log", "-1", "--format=%s", "REBASE_HEAD"],
        capture_output=True, text=True, cwd=cwd,
    ).stdout.strip()
    return sha, subject


_PICK_COMMANDS = {
    "pick", "p", "reword", "r", "edit", "e",
    "squash", "s", "fixup", "f", "drop", "d",
}


def _remaining_rebase_commits(cwd: str) -> int:
    """Count remaining commits in the rebase todo."""
    git_path = _git_dir(cwd)
    todo = git_path / _GIT_REBASE_MERGE_DIR / _GIT_REBASE_TODO
    if todo.exists():
        return sum(
            1 for line in todo.read_text().splitlines()
            if line.strip() and not line.startswith("#")
            and line.split()[0] in _PICK_COMMANDS
        )
    next_file = git_path / _GIT_REBASE_APPLY_DIR / _GIT_REBASE_NEXT
    last_file = git_path / _GIT_REBASE_APPLY_DIR / _GIT_REBASE_LAST
    if next_file.exists() and last_file.exists():
        try:
            return int(last_file.read_text().strip()) - int(next_file.read_text().strip())
        except ValueError:
            return 0
    return 0


def _conflict_report(cwd: str, status: str = "conflicts") -> dict:
    """Build a conflict report dict for JSON output."""
    conflicts = _detect_conflicts(cwd)
    sha, subject = _rebase_head_info(cwd)
    remaining = _remaining_rebase_commits(cwd)
    return {
        "status": status,
        "files": conflicts,
        "rebase_head": sha,
        "rebase_head_subject": subject,
        "remaining_commits": remaining,
    }


def _commits_ahead(cwd: str) -> int:
    """Count commits ahead of the target ref."""
    out = subprocess.run(
        ["git", "rev-list", "--count", f"{_TARGET_REF}..HEAD"],
        capture_output=True, text=True, cwd=cwd,
    ).stdout.strip()
    return int(out) if out.isdigit() else 0


def _is_empty_patch(cwd: str) -> bool:
    """Check if the current rebase step has no changes (patch already applied upstream)."""
    staged = subprocess.run(
        ["git", "diff", "--cached", "--quiet"],
        capture_output=True, cwd=cwd,
    )
    unstaged = subprocess.run(
        ["git", "diff", "--quiet"],
        capture_output=True, cwd=cwd,
    )
    return staged.returncode == 0 and unstaged.returncode == 0


# ── Conflict resolution ────────────────────────────────────────────────────

_RESOLVE_BEGIN = "<<<RESOLVED>>>"
_RESOLVE_END = "<<<END_RESOLVED>>>"

_CONFLICT_MARKER_PREFIXES = ("<<<<<<< ", "=======", ">>>>>>> ")

_GENERATED_HEADER_PATTERNS = ("DO NOT EDIT", "@generated", "Code generated")


def _is_generated_file(filepath: str, full_path: Path, cwd: str) -> tuple[bool, str]:
    """Detect generated files using repo-agnostic signals.

    Returns (is_generated, detection_method).
    """
    r = subprocess.run(
        ["git", "check-attr", "linguist-generated", "--", filepath],
        capture_output=True, text=True, cwd=cwd,
    )
    if r.returncode == 0 and ": true" in r.stdout:
        return True, "gitattributes"

    try:
        with open(full_path) as f:
            header = "".join(f.readline() for _ in range(5))
        if any(p in header for p in _GENERATED_HEADER_PATTERNS):
            return True, "header"
    except OSError:
        pass

    return False, ""


def _detect_delete_conflict(filepath: str, cwd: str) -> str | None:
    """Detect modify/delete conflicts by checking git index stages.

    During a rebase, stage 2 = ours (target), stage 3 = theirs (branch commit).
    A missing stage means that side deleted the file.

    Returns:
        "ours_deleted" if target deleted the file, branch modifies it
        "theirs_deleted" if branch commit deletes the file, target has it
        None if both stages present (normal content conflict)
    """
    r = subprocess.run(
        ["git", "ls-files", "-u", "--stage", "--", filepath],
        capture_output=True, text=True, cwd=cwd,
    )
    if r.returncode != 0 or not r.stdout.strip():
        return None

    stages = set()
    for line in r.stdout.strip().splitlines():
        # Format: <mode> <hash> <stage>\t<filepath>
        parts = line.split("\t")[0].split()
        if len(parts) >= 3 and parts[2].isdigit():
            stages.add(int(parts[2]))

    if not stages:
        return None

    if 2 not in stages:
        return "ours_deleted"
    if 3 not in stages:
        return "theirs_deleted"
    return None


def _resolve_delete_conflict(filepath: str, sha: str, cwd: str, delete_type: str) -> bool:
    """Resolve a modify/delete conflict by accepting the deletion."""
    if delete_type == "theirs_deleted":
        reason = f"commit {sha} deletes this file"
    else:
        reason = f"deleted on target, commit {sha} modifies stale version"

    if _trail:
        _trail.decision(
            "delete_conflict",
            f"accepting deletion for {filepath}",
            reason=f"{reason} (modify/delete conflict)",
        )

    r = subprocess.run(["git", "rm", "--force", filepath], cwd=cwd)
    if r.returncode != 0:
        log.error(f"git rm failed for {filepath}")
        return False
    log.info(f"Accepted deletion: {filepath} ({reason})")
    return True


def _get_ours_content(filepath: str, cwd: str) -> str | None:
    """Get the target-side (HEAD) version of a file from git index stage 2.

    During a rebase conflict, stage 2 holds the 'ours' side — the target branch
    state before the conflicting commit is applied. Returns None if unavailable
    (e.g. file is new on the branch).
    """
    r = subprocess.run(
        ["git", "show", f":2:{filepath}"],
        capture_output=True, text=True, cwd=cwd,
    )
    return r.stdout if r.returncode == 0 else None


def _get_commit_diff(filepath: str, cwd: str) -> str | None:
    """Get the diff of REBASE_HEAD for a specific file.

    Shows what the commit being replayed intended to change, helping the AI
    understand the branch's intent separately from the conflict markers.
    """
    r = subprocess.run(
        ["git", "diff", "REBASE_HEAD^", "REBASE_HEAD", "--", filepath],
        capture_output=True, text=True, cwd=cwd,
    )
    return r.stdout.strip() if r.returncode == 0 and r.stdout.strip() else None


def _is_binary(path: Path) -> bool:
    """Check if a file is binary by looking for null bytes in the first 8KB."""
    try:
        chunk = path.read_bytes()[:8192]
        return b"\x00" in chunk
    except OSError:
        return False


def _build_resolve_prompt(
    filepath: str, content: str, sha: str, subject: str,
    *, ours_content: str | None = None, commit_diff: str | None = None,
) -> str:
    """Build a prompt to resolve a merge conflict."""
    parts = [
        f"You are resolving a merge conflict during a git rebase onto {_TARGET_REF}.\n",
        f"\nFile: {filepath}\n",
        f"Commit being applied: {sha} — {subject}\n",
        "\nIn a rebase, conflict markers mean:\n",
        f"- <<<<<<< HEAD = the base side ({_TARGET_REF} or previously rebased commits)\n",
        "- ======= separates the two sides\n",
        f"- >>>>>>> {sha} = the branch's changes being replayed\n",
    ]

    if ours_content is not None:
        normalized = ours_content if ours_content.endswith("\n") else ours_content + "\n"
        parts.append(
            "\n--- BASE VERSION (target side before this commit) ---\n"
            f"{normalized}"
            "--- END BASE VERSION ---\n"
        )

    if commit_diff is not None:
        parts.append(
            "\n--- COMMIT DIFF (what this commit intended to change) ---\n"
            f"{commit_diff}\n"
            "--- END COMMIT DIFF ---\n"
        )

    merge_instructions = (
        "\nMerge both sides, preserving the intent of the commit being applied "
        "onto the current base-side structure."
    )
    if ours_content is not None:
        merge_instructions += (
            " The base version above shows the current state of identifiers, "
            "types, and structure — if anything was renamed or restructured on "
            "the base side, use the base-side names."
        )
    merge_instructions += (
        " If both sides add non-overlapping content, keep both. "
        "If they modify the same lines, combine them sensibly.\n"
    )
    parts.append(merge_instructions)

    parts.append(
        f"\nOutput the resolved file between {_RESOLVE_BEGIN} and {_RESOLVE_END} markers.\n"
        "No explanation, no markdown fencing, no commentary outside the markers.\n"
        f"\n{_RESOLVE_BEGIN}\n"
        "(your resolved content here)\n"
        f"{_RESOLVE_END}\n"
        "\n--- FILE CONTENT WITH CONFLICT MARKERS ---\n"
        f"{content}"
    )

    return "".join(parts)


def _has_conflict_markers(text: str) -> str | None:
    """Check for git conflict markers at the start of lines. Returns the marker found, or None."""
    for line in text.splitlines():
        match = next((m for m in _CONFLICT_MARKER_PREFIXES if line.startswith(m)), None)
        if match:
            return match
    return None


def _parse_resolved_content(stdout: str) -> tuple[str | None, str]:
    """Extract resolved file content from AI output.

    Returns (resolved_content, failure_reason). failure_reason is empty on success.
    """
    begin = stdout.find(_RESOLVE_BEGIN)
    end = stdout.find(_RESOLVE_END)
    if begin == -1 and end == -1:
        return None, "missing_both_markers"
    if begin == -1:
        return None, "missing_begin_marker"
    if end == -1:
        return None, "missing_end_marker"
    if end <= begin:
        return None, "end_before_begin"

    resolved = stdout[begin + len(_RESOLVE_BEGIN):end]
    if resolved.startswith("\n"):
        resolved = resolved[1:]
    if resolved.endswith("\n"):
        resolved = resolved[:-1]

    surviving = _has_conflict_markers(resolved)
    if surviving:
        return None, f"surviving_conflict_marker:{surviving.strip()}"

    return resolved + "\n", ""


# ── Chunked conflict resolution ──────────────────────────────────────────

_CONFLICT_CONTEXT_LINES = 30
_CHUNKED_MIN_LINES = 200
_CHUNKED_MAX_CONFLICT_RATIO = 0.5


def _extract_conflict_blocks(
    content: str, context_lines: int = _CONFLICT_CONTEXT_LINES,
) -> list[dict]:
    """Extract conflict blocks with surrounding context from file content."""
    lines = content.splitlines(keepends=True)
    blocks = []
    i = 0
    while i < len(lines):
        if not lines[i].startswith("<<<<<<< "):
            i += 1
            continue
        start = i
        j = i + 1
        while j < len(lines) and not lines[j].startswith(">>>>>>> "):
            j += 1
        if j >= len(lines):
            break
        end = j
        ctx_start = max(0, start - context_lines)
        ctx_end = min(len(lines), end + 1 + context_lines)
        blocks.append({
            "index": len(blocks) + 1,
            "start": start,
            "end": end,
            "conflict": "".join(lines[start:end + 1]),
            "context_before": "".join(lines[ctx_start:start]),
            "context_after": "".join(lines[end + 1:ctx_end]),
        })
        i = end + 1
    return blocks


def _conflict_line_count(blocks: list[dict]) -> int:
    """Total lines occupied by conflict markers across all blocks."""
    return sum(b["end"] - b["start"] + 1 for b in blocks)


def _should_chunk(content: str, blocks: list[dict]) -> bool:
    """Decide whether to use chunked resolution based on file size and conflict ratio."""
    total = content.count("\n") + 1
    if total <= _CHUNKED_MIN_LINES:
        return False
    return _conflict_line_count(blocks) / total < _CHUNKED_MAX_CONFLICT_RATIO


def _build_chunked_prompt(
    filepath: str,
    blocks: list[dict],
    sha: str,
    subject: str,
    commit_diff: str | None = None,
) -> str:
    """Build a prompt containing only conflict blocks with context."""
    parts = [
        f"You are resolving merge conflicts during a git rebase onto {_TARGET_REF}.\n",
        f"\nFile: {filepath}\n",
        f"Commit being applied: {sha} — {subject}\n",
        "\nIn a rebase, conflict markers mean:\n",
        f"- <<<<<<< HEAD = the base side ({_TARGET_REF} or previously rebased commits)\n",
        "- ======= separates the two sides\n",
        f"- >>>>>>> {sha} = the branch's changes being replayed\n",
    ]

    if commit_diff is not None:
        parts.append(
            "\n--- COMMIT DIFF (what this commit intended to change) ---\n"
            f"{commit_diff}\n"
            "--- END COMMIT DIFF ---\n"
        )

    parts.append(
        "\nMerge both sides, preserving the intent of the commit being applied "
        "onto the current base-side structure. "
        "If both sides add non-overlapping content, keep both. "
        "If they modify the same lines, combine them sensibly.\n"
    )

    for block in blocks:
        n = block["index"]
        parts.append(f"\n--- CONFLICT {n} ---\n")
        if block["context_before"]:
            parts.append(block["context_before"])
        parts.append(block["conflict"])
        if block["context_after"]:
            parts.append(block["context_after"])
        parts.append(f"--- END CONFLICT {n} ---\n")

    parts.append(
        "\nFor each conflict, output ONLY the resolved replacement for the "
        "conflict markers (everything from <<<<<<< through >>>>>>>). "
        "Do NOT include the surrounding context lines.\n"
        "No explanation, no markdown fencing, no commentary outside the markers.\n\n"
    )
    for block in blocks:
        n = block["index"]
        parts.append(
            f"{_RESOLVE_BEGIN}_{n}\n"
            f"(resolved content for conflict {n})\n"
            f"{_RESOLVE_END}_{n}\n"
        )

    return "".join(parts)


def _parse_chunked_resolutions(
    stdout: str, num_blocks: int,
) -> tuple[list[str] | None, str]:
    """Extract per-block resolutions from AI output.

    Returns (list_of_resolutions, failure_reason). failure_reason is empty on success.
    """
    resolutions = []
    for i in range(1, num_blocks + 1):
        begin_marker = f"{_RESOLVE_BEGIN}_{i}"
        end_marker = f"{_RESOLVE_END}_{i}"
        begin = stdout.find(begin_marker)
        end = stdout.find(end_marker)
        if begin == -1 or end == -1 or end <= begin:
            return None, f"missing_markers_for_block_{i}"
        resolved = stdout[begin + len(begin_marker):end]
        if resolved.startswith("\n"):
            resolved = resolved[1:]
        if resolved.endswith("\n"):
            resolved = resolved[:-1]
        surviving = _has_conflict_markers(resolved)
        if surviving:
            return None, f"surviving_conflict_marker_in_block_{i}:{surviving.strip()}"
        resolutions.append(resolved + "\n")
    return resolutions, ""


def _splice_resolutions(
    content: str, blocks: list[dict], resolutions: list[str],
) -> str:
    """Replace conflict markers in content with resolved text."""
    lines = content.splitlines(keepends=True)
    for block, resolution in reversed(list(zip(blocks, resolutions))):
        lines[block["start"]:block["end"] + 1] = resolution.splitlines(keepends=True)
    return "".join(lines)


def _git_add(filepath: str, cwd: str) -> bool:
    """Stage a file and return True on success."""
    r = subprocess.run(["git", "add", filepath], cwd=cwd)
    if r.returncode != 0:
        log.error(f"git add failed for {filepath}")
    return r.returncode == 0


def _accept_theirs_and_stage(filepath: str, parent: Path, cwd: str) -> bool:
    """Accept theirs for a generated file and stage it."""
    r = subprocess.run(["git", "checkout", "--theirs", filepath], cwd=cwd)
    if r.returncode != 0:
        log.error(f"git checkout --theirs failed for {filepath}")
        return False
    if not _git_add(filepath, cwd):
        return False
    log.info(f"Accepted theirs: {filepath} (will regenerate)")
    return True


def _resolve_single_file(
    filepath: str, full_path: Path, sha: str, subject: str, cwd: str,
) -> str | None:
    """Resolve a single conflicted text file via AI. Returns filepath or None."""
    try:
        content = full_path.read_text()
    except OSError as e:
        log.error(f"Cannot read {filepath}: {e}")
        return None

    blocks = _extract_conflict_blocks(content)
    if blocks and _should_chunk(content, blocks):
        return _resolve_chunked(filepath, full_path, content, blocks, sha, subject, cwd)
    return _resolve_full_file(filepath, full_path, content, sha, subject, cwd)


def _resolve_full_file(
    filepath: str, full_path: Path, content: str,
    sha: str, subject: str, cwd: str,
) -> str | None:
    """Resolve via full-file prompt (small files or heavily conflicted)."""
    ours_content = _get_ours_content(filepath, cwd)
    commit_diff = _get_commit_diff(filepath, cwd)
    prompt = _build_resolve_prompt(
        filepath, content, sha, subject,
        ours_content=ours_content, commit_diff=commit_diff,
    )
    stdout, rc = ai_backend.prompt(prompt)
    if rc != 0:
        _terr("resolve_conflicts", f"AI prompt failed for {filepath}", data={"filepath": filepath, "exit_code": rc})
        log.error(f"ai prompt failed for {filepath} (exit {rc})")
        return None

    resolved_content, failure_reason = _parse_resolved_content(stdout)
    if resolved_content is None:
        _terr(
            "resolve_conflicts",
            f"failed to parse resolution for {filepath}",
            data={
                "filepath": filepath,
                "reason": failure_reason,
                "stdout_len": len(stdout),
                "stdout_tail": stdout[-200:] if stdout else "",
            },
        )
        log.error(f"Failed to parse resolution for {filepath} ({failure_reason})")
        return None

    full_path.write_text(resolved_content)
    if not _git_add(filepath, cwd):
        return None
    log.ok(f"Resolved: {filepath}")
    return filepath


def _resolve_chunked(
    filepath: str, full_path: Path, content: str,
    blocks: list[dict], sha: str, subject: str, cwd: str,
) -> str | None:
    """Resolve via chunked prompt (large files with small conflicts)."""
    commit_diff = _get_commit_diff(filepath, cwd)
    prompt = _build_chunked_prompt(filepath, blocks, sha, subject, commit_diff)
    _trail and _trail.info(
        "chunked_resolve", f"using chunked resolution for {filepath}",
        data={"blocks": len(blocks), "total_lines": content.count("\n") + 1},
    )
    stdout, rc = ai_backend.prompt(prompt)
    if rc != 0:
        _terr("resolve_conflicts", f"AI prompt failed for {filepath}", data={"filepath": filepath, "exit_code": rc})
        log.error(f"ai prompt failed for {filepath} (exit {rc})")
        return None

    resolutions, failure_reason = _parse_chunked_resolutions(stdout, len(blocks))
    if resolutions is None:
        _terr(
            "resolve_conflicts",
            f"failed to parse chunked resolution for {filepath}",
            data={"filepath": filepath, "reason": failure_reason},
        )
        log.error(f"Failed to parse chunked resolution for {filepath} ({failure_reason})")
        return None

    resolved_content = _splice_resolutions(content, blocks, resolutions)
    full_path.write_text(resolved_content)
    if not _git_add(filepath, cwd):
        return None
    log.ok(f"Resolved: {filepath} ({len(blocks)} conflict(s), chunked)")
    return filepath


def _resolve_one(
    filepath: str, full_path: Path, sha: str, subject: str,
    cwd: str, go_dirs: set[Path],
) -> bool:
    """Resolve a single conflicted file — dispatch by type."""
    if filepath.endswith("go.sum"):
        if _trail:
            _trail.decision(
                "special_file",
                f"accepting theirs for {filepath}",
                reason="auto-resolved file type (go.sum)",
            )
        ok = _accept_theirs_and_stage(filepath, full_path.parent, cwd)
        if ok:
            go_dirs.add(full_path.parent)
        return ok

    delete_type = _detect_delete_conflict(filepath, cwd)
    if delete_type is not None:
        return _resolve_delete_conflict(filepath, sha, cwd, delete_type)

    result = _resolve_single_file(filepath, full_path, sha, subject, cwd)
    if result is None:
        return False
    if _trail:
        _trail.info("resolve_conflict", f"resolved {filepath}", data={"commit": sha, "method": "ai"})
    if filepath.endswith("go.mod"):
        go_dirs.add(full_path.parent)
    return True


def _resolve_generated(filepath: str, full_path: Path, cwd: str, method: str) -> bool:
    """Accept theirs for a generated file. Returns True on success."""
    _trail and _trail.decision(
        "generated_file", f"accepting theirs for {filepath}",
        reason=f"generated file detected via {method}",
    )
    return _accept_theirs_and_stage(filepath, full_path.parent, cwd)


def _resolve_file_conflicts(
    conflicts: list[str], cwd: str, sha: str, subject: str,
) -> list[str] | None:
    """Resolve conflicted files via AI. Returns resolved paths or None on failure."""
    resolved = []
    go_dirs: set[Path] = set()

    for filepath in conflicts:
        full_path = Path(cwd) / filepath

        generated, method = _is_generated_file(filepath, full_path, cwd)
        if generated and not _resolve_generated(filepath, full_path, cwd, method):
            return None
        if generated:
            resolved.append(filepath)
            continue

        if _is_binary(full_path):
            _terr("resolve_conflicts", f"binary file: {filepath}", data={"filepath": filepath})
            log.error(f"Cannot resolve binary file: {filepath}")
            return None

        ok = _resolve_one(filepath, full_path, sha, subject, cwd, go_dirs)
        if not ok:
            return None
        resolved.append(filepath)

    # Regenerate go.sum for any directories with resolved go.mod/go.sum
    for go_dir in go_dirs:
        log.info(f"Running go mod tidy in {go_dir.name}/...")
        r = subprocess.run(
            ["go", "mod", "tidy"],
            cwd=str(go_dir),
            capture_output=True, text=True,
        )
        if r.returncode != 0:
            _terr("resolve_conflicts", f"go mod tidy failed in {go_dir.name}", data={"stderr": r.stderr.strip()})
            log.error(f"go mod tidy failed: {r.stderr.strip()}")
            return None
        r = subprocess.run(["git", "add", "-u"], cwd=str(go_dir))
        if r.returncode != 0:
            _terr("resolve_conflicts", f"git add -u failed in {go_dir.name}")
            log.error(f"git add -u failed in {go_dir.name}")
            return None

    return resolved


# ── Rebase lifecycle ───────────────────────────────────────────────────────

_MAX_REBASE_STEPS = 500


def _drive_to_completion(
    cwd: str, ctx: pr_context.ResolvedContext, fix: bool,
) -> int:
    """Drive an in-progress rebase to completion, handling all intermediate states.

    Loops until the rebase finishes, handling conflicts (via AI when --fix),
    empty commits (via --skip), and stuck states (abort on unexpected failure).
    """
    with _trail.span("drive_to_completion") if _trail else nullcontext():
        return _drive_loop(cwd, ctx, fix)


def _drive_loop(
    cwd: str, ctx: pr_context.ResolvedContext, fix: bool,
) -> int:
    all_resolved: list[str] = []
    commits_conflicted = 0

    for _ in range(_MAX_REBASE_STEPS):
        if not _detect_rebase_in_progress(cwd):
            resolved = (all_resolved, commits_conflicted) if commits_conflicted else None
            return _rebase_success(cwd, ctx, fix, resolved=resolved)

        rc, conflict_found = _drive_one_step(cwd, fix, all_resolved)
        if rc is not None:
            return rc
        if conflict_found:
            commits_conflicted += 1

    _terr("drive_to_completion", f"rebase did not complete after {_MAX_REBASE_STEPS} steps")
    log.error(f"Rebase did not complete after {_MAX_REBASE_STEPS} steps — aborting.")
    subprocess.run(["git", "rebase", "--abort"], cwd=cwd)
    return 1


def _drive_one_step(
    cwd: str, fix: bool,
    all_resolved: list[str],
) -> tuple[int | None, bool]:
    conflicts = _detect_conflicts(cwd)
    if not conflicts:
        return _step_advance(cwd), False

    rc = _step_conflicts(cwd, fix, conflicts, all_resolved)
    if rc is not None:
        return rc, False
    return None, True


def _step_conflicts(
    cwd: str, fix: bool,
    conflicts: list[str], all_resolved: list[str],
) -> int | None:
    """Handle a rebase step with conflicts. Returns exit code to stop, or None to continue."""
    if not fix:
        report = _conflict_report(cwd)
        json.dump(report, sys.stdout, indent=2)
        print()
        return 3

    if not ai_backend.is_available():
        _terr("resolve_conflicts", "AI backend unavailable")
        log.error("Cannot resolve conflicts — AI backend unavailable.")
        report = _conflict_report(cwd)
        json.dump(report, sys.stdout, indent=2)
        print()
        return 3

    sha, subject = _rebase_head_info(cwd)
    remaining = _remaining_rebase_commits(cwd)

    log.info(
        f"Resolving {len(conflicts)} conflict(s) in {sha} — {subject} "
        f"({remaining} remaining)..."
    )
    if _trail:
        _trail.decision(
            "step", f"resolving {len(conflicts)} conflict(s)",
            reason=f"commit {sha} has unmerged files",
            data={"commit": sha, "files": conflicts, "remaining": remaining},
        )

    resolved = _resolve_file_conflicts(conflicts, cwd, sha, subject)
    if resolved is None:
        _terr("resolve_conflicts", "AI resolution failed, aborting rebase")
        log.error("AI conflict resolution failed — aborting rebase.")
        subprocess.run(["git", "rebase", "--abort"], cwd=cwd)
        return 1
    all_resolved.extend(resolved)

    # Stage any remaining unstaged changes from post-resolution fixups (e.g. go mod tidy)
    unstaged = subprocess.run(
        ["git", "diff", "--name-only"],
        capture_output=True, text=True, cwd=cwd,
    )
    if unstaged.stdout.strip():
        subprocess.run(["git", "add", "-u"], cwd=cwd)

    r = subprocess.run(
        ["git", "-c", "core.editor=true", "rebase", "--continue"],
        capture_output=True, text=True, cwd=cwd,
    )
    if r.returncode == 0:
        return None

    if r.stderr.strip():
        log.dim(r.stderr.strip())

    # rebase --continue returns non-zero when the current commit is applied
    # but the *next* commit has conflicts — that's normal, not a failure.
    if _detect_rebase_in_progress(cwd):
        return None

    _terr("step_conflicts", "rebase --continue failed after resolution", data={"stderr": r.stderr.strip()})
    log.error("rebase --continue failed after conflict resolution — aborting.")
    subprocess.run(["git", "rebase", "--abort"], cwd=cwd)
    return 1


def _step_advance(cwd: str) -> int | None:
    """Advance rebase when there are no conflicts. Returns exit code to stop, or None to continue."""
    if _is_empty_patch(cwd):
        sha, subject = _rebase_head_info(cwd)
        log.info(f"Skipping empty commit {sha} — {subject}")
        if _trail:
            _trail.decision(
                "step", f"skipping empty commit {sha}",
                reason="patch already applied upstream",
                data={"commit": sha, "subject": subject},
            )
        r = subprocess.run(["git", "rebase", "--skip"], cwd=cwd)
        if r.returncode != 0:
            log.error(f"git rebase --skip failed (exit {r.returncode})")
            return 1
        return None

    r = subprocess.run(
        ["git", "-c", "core.editor=true", "rebase", "--continue"],
        capture_output=True, text=True, cwd=cwd,
    )
    if r.returncode == 0:
        return None

    if r.stderr.strip():
        log.dim(r.stderr.strip())

    # rebase --continue can return non-zero when the next commit has conflicts
    if _detect_rebase_in_progress(cwd):
        return None

    log.warn("rebase --continue failed without conflicts — aborting")
    if _trail:
        _trail.warn(
            "step", "aborting after --continue failure",
            data={"stderr": r.stderr.strip(), "exit_code": r.returncode},
        )
    subprocess.run(["git", "rebase", "--abort"], cwd=cwd)
    return 1


# ── Stash helpers ──────────────────────────────────────────────────────────

_STASH_MSG = "pr-rebase: auto-stash"


def _auto_stash(cwd: str) -> bool | None:
    """Stash uncommitted changes if the working tree is dirty.

    Returns True if stashed, False if tree was clean, None if stash failed.
    """
    status = subprocess.run(
        ["git", "status", "--porcelain", "--untracked-files=no"],
        capture_output=True, text=True, cwd=cwd,
    )
    if not status.stdout.strip():
        return False

    log.info("Stashing uncommitted changes...")
    r = subprocess.run(
        ["git", "stash", "push", "-m", _STASH_MSG],
        capture_output=True, text=True, cwd=cwd,
    )
    if r.returncode != 0:
        log.error(f"git stash failed: {r.stderr.strip()}")
        return None
    if _trail:
        _trail.info("stash", "auto-stashed uncommitted changes")
    return True


def _auto_unstash(cwd: str, fix: bool) -> None:
    """Pop stashed changes, resolving conflicts if needed."""
    r = subprocess.run(
        ["git", "stash", "pop"],
        capture_output=True, text=True, cwd=cwd,
    )
    if r.returncode == 0:
        log.ok("Restored stashed changes.")
        return

    conflicts = _detect_conflicts(cwd)
    if not conflicts:
        log.error(f"git stash pop failed: {r.stderr.strip()}")
        return

    if not fix or not ai_backend.is_available():
        log.warn(f"Stash pop has {len(conflicts)} conflict(s) — resolve manually, then `git stash drop`.")
        return

    log.info(f"Resolving {len(conflicts)} stash conflict(s)...")
    for filepath in conflicts:
        full_path = Path(cwd) / filepath
        if _is_binary(full_path):
            log.warn(f"Cannot resolve binary stash conflict: {filepath}")
            continue
        try:
            content = full_path.read_text()
        except OSError:
            continue
        prompt = (
            "You are resolving a conflict after restoring uncommitted changes "
            "(git stash pop) onto a rebased branch.\n\n"
            f"File: {filepath}\n\n"
            "<<<<<<< Updated upstream = the rebased branch state\n"
            "======= separates the two sides\n"
            ">>>>>>> Stashed changes = the user's uncommitted work\n\n"
            "Preserve the user's uncommitted changes where possible, merged "
            "with any structural changes from the rebase.\n\n"
            f"Output the resolved file between {_RESOLVE_BEGIN} and {_RESOLVE_END} markers.\n"
            "No explanation, no markdown fencing.\n\n"
            f"{_RESOLVE_BEGIN}\n(your resolved content here)\n{_RESOLVE_END}\n\n"
            f"--- FILE CONTENT WITH CONFLICT MARKERS ---\n{content}"
        )
        stdout, rc = ai_backend.prompt(prompt)
        if rc != 0:
            log.error(f"AI resolution failed for stash conflict: {filepath}")
            continue
        resolved_content, failure_reason = _parse_resolved_content(stdout)
        if resolved_content is None:
            _terr(
                "resolve_stash_conflicts",
                f"failed to parse stash resolution for {filepath}",
                data={
                    "filepath": filepath,
                    "reason": failure_reason,
                    "stdout_len": len(stdout),
                    "stdout_tail": stdout[-200:] if stdout else "",
                },
            )
            log.error(f"Failed to parse stash resolution for {filepath} ({failure_reason})")
            continue
        full_path.write_text(resolved_content)
        if not _git_add(filepath, cwd):
            log.error(f"Failed to stage resolved stash conflict: {filepath}")
            continue
        log.ok(f"Resolved stash conflict: {filepath}")

    remaining = _detect_conflicts(cwd)
    if remaining:
        log.warn(f"{len(remaining)} stash conflict(s) remain — resolve manually, then `git stash drop`.")
    else:
        r = subprocess.run(["git", "stash", "drop"], cwd=cwd, capture_output=True, text=True)
        if r.returncode != 0:
            log.warn(f"git stash drop failed: {r.stderr.strip()}")
        else:
            log.ok("Restored stashed changes.")


# ── State helpers ───────────────────────────────────────────────────────────


def _load_or_init(ctx: pr_context.ResolvedContext) -> pr_state.PRState:
    """Load existing state or create a fresh one from resolved context."""
    return pr_state.load_or_init(
        worktree_root=ctx.worktree_root,
        repo=ctx.repo,
        branch=ctx.branch,
        pr_number=ctx.pr_number,
        head_sha=ctx.head_sha,
    )


# ── Push helper ─────────────────────────────────────────────────────────────


def _force_push(cwd: str) -> int:
    """Force-push, auto-committing if the pre-push hook regenerates files.

    Pre-push hooks may run generators (e.g. generate-tool-context) that update
    tracked files, causing the push to fail. When this happens, commit the
    regenerated files and retry once.
    """
    r = subprocess.run(["git", "push", "--force-with-lease"], cwd=cwd)
    if r.returncode == 0:
        return 0

    status = subprocess.run(
        ["git", "status", "--porcelain", "--untracked-files=no"],
        capture_output=True, text=True, cwd=cwd,
    )
    if not status.stdout.strip():
        return r.returncode

    modified = [
        line[3:] for line in status.stdout.splitlines()
        if line.startswith(" M ")
    ]
    if not modified:
        return r.returncode

    if _trail:
        _trail.info("force_push", "committing regenerated files before retry", data={"files": modified})
    log.info("Committing regenerated files...")
    ar = subprocess.run(["git", "add", "-u"], cwd=cwd)
    if ar.returncode != 0:
        log.error("Failed to stage regenerated files.")
        return r.returncode
    cr = subprocess.run(
        ["git", "commit", "-m", "chore(docs): regenerate after rebase"],
        capture_output=True, text=True, cwd=cwd,
    )
    if cr.returncode != 0:
        log.error("Failed to commit regenerated files.")
        return r.returncode

    log.info("Retrying force-push...")
    retry = subprocess.run(["git", "push", "--force-with-lease"], cwd=cwd)
    return retry.returncode


# ── Subcommands ─────────────────────────────────────────────────────────────


def cmd_abort(cwd: str, ctx: pr_context.ResolvedContext) -> int:
    """Abort an in-progress rebase and reset state."""
    log.info("Aborting rebase...")
    r = subprocess.run(["git", "rebase", "--abort"], cwd=cwd)
    if r.returncode == 0:
        state = _load_or_init(ctx)
        pr_state.update_rebase(state, pr_state.RebaseSummary())
        pr_state.save_state(ctx.worktree_root, state)
        log.ok("Rebase aborted.")
    return r.returncode


def cmd_push(cwd: str, ctx: pr_context.ResolvedContext) -> int:
    """Force-push after a completed rebase."""
    if _detect_rebase_in_progress(cwd):
        _terr("push", "rebase still in progress")
        log.error("Cannot push — rebase still in progress.")
        return 1

    log.info("Force-pushing...")
    push_rc = _force_push(cwd)
    if push_rc != 0:
        _terr("push", "force-push failed", data={"exit_code": push_rc})
        return push_rc

    state = _load_or_init(ctx)
    target_base = state.rebase.target_base or subprocess.run(
        ["git", "rev-parse", _TARGET_REF],
        capture_output=True, text=True, cwd=cwd,
    ).stdout.strip()
    commits = state.rebase.commits_replayed or _commits_ahead(cwd)

    pr_state.update_rebase(state, pr_state.RebaseSummary(
        target_base=target_base,
        commits_replayed=commits,
        conflicts_resolved=state.rebase.conflicts_resolved,
        files_resolved=state.rebase.files_resolved,
        force_pushed=True,
        updated_at=pr_state.now_iso(),
    ))
    pr_state.save_state(ctx.worktree_root, state)
    log.ok("Force-pushed successfully.")
    return 0


def cmd_start(cwd: str, ctx: pr_context.ResolvedContext, fix: bool) -> int:
    """Start or resume a rebase onto origin/main."""
    if _detect_rebase_in_progress(cwd):
        if _trail:
            _trail.decision(
                "rebase_state",
                "detected in-progress rebase",
                reason="rebase-merge or rebase-apply directory exists",
            )
        log.info("Detected in-progress rebase — resuming...")
        return _drive_to_completion(cwd, ctx, fix)

    stashed = _auto_stash(cwd)
    if stashed is None:
        return 1

    if _trail:
        _trail.decision(
            "rebase_state",
            "starting fresh rebase",
            reason="no in-progress rebase detected",
        )
    rc = _fresh(cwd, ctx, fix)

    if stashed:
        _auto_unstash(cwd, fix)

    return rc


def _fresh(cwd: str, ctx: pr_context.ResolvedContext, fix: bool) -> int:
    """Start a fresh rebase onto the target ref."""
    if ctx.branch in ("main", "master"):
        _terr("preflight", f"on protected branch {ctx.branch}")
        log.error("Cannot rebase — currently on protected branch.")
        return 1

    log.info("Fetching origin...")
    fetch = subprocess.run(
        ["git", "fetch", "origin"],
        capture_output=True, text=True, cwd=cwd,
    )
    if fetch.returncode != 0:
        log.warn(f"Fetch failed — rebasing against potentially stale {_TARGET_REF}.")
        if fetch.stderr.strip():
            log.dim(fetch.stderr.strip())

    log.info(f"Rebasing onto {_TARGET_REF}...")
    r = subprocess.run(
        ["git", "rebase", _TARGET_REF],
        capture_output=True, text=True, cwd=cwd,
    )

    if r.returncode == 0 and not _detect_rebase_in_progress(cwd):
        return _rebase_success(cwd, ctx, fix)

    if not _detect_rebase_in_progress(cwd):
        _terr("rebase", f"git rebase failed (exit {r.returncode})", data={"stderr": r.stderr.strip()})
        log.error(f"git rebase failed (exit {r.returncode})")
        if r.stderr.strip():
            log.dim(r.stderr.strip())
        return 1

    return _drive_to_completion(cwd, ctx, fix)


def _rebase_success(
    cwd: str, ctx: pr_context.ResolvedContext, fix: bool,
    resolved: tuple[list[str], int] | None = None,
) -> int:
    """Handle rebase completion — update state and optionally force-push."""
    commits = _commits_ahead(cwd)
    state = _load_or_init(ctx)
    files_resolved = resolved[0] if resolved else []
    conflicts_resolved = resolved[1] if resolved else 0

    if fix:
        label = "Rebase complete" if not resolved else (
            f"Rebase complete — resolved {len(files_resolved)} file(s) "
            f"across {conflicts_resolved} commit(s)"
        )
        log.info(f"{label} — force-pushing...")
        push_rc = _force_push(cwd)
        if push_rc == 0:
            _trail and _trail.info("force_push", "force-pushed to remote")
        else:
            _terr("force_push", "force-push failed", data={"exit_code": push_rc})
        pr_state.update_rebase(state, pr_state.RebaseSummary(
            target_base=_TARGET_REF,
            commits_replayed=commits,
            conflicts_resolved=conflicts_resolved,
            files_resolved=files_resolved,
            force_pushed=push_rc == 0,
            updated_at=pr_state.now_iso(),
        ))
        pr_state.save_state(ctx.worktree_root, state)
        report = {
            "status": "clean",
            "commits_replayed": commits,
            "conflicts_resolved": conflicts_resolved,
            "files_resolved": files_resolved,
            "force_pushed": push_rc == 0,
        }
        json.dump(report, sys.stdout, indent=2)
        print()
        if push_rc == 0:
            log.ok("Force-pushed.")
        else:
            log.error("Force-push failed.")
        return push_rc

    pr_state.update_rebase(state, pr_state.RebaseSummary(
        target_base=_TARGET_REF,
        commits_replayed=commits,
        conflicts_resolved=conflicts_resolved,
        files_resolved=files_resolved,
        force_pushed=False,
        updated_at=pr_state.now_iso(),
    ))
    pr_state.save_state(ctx.worktree_root, state)
    report = {
        "status": "clean",
        "commits_replayed": commits,
        "conflicts_resolved": conflicts_resolved,
        "files_resolved": files_resolved,
    }
    json.dump(report, sys.stdout, indent=2)
    print()
    log.ok("Rebase clean — run `pr rebase --push` to force-push.")
    return 0


# ── CLI ─────────────────────────────────────────────────────────────────────


def main():
    parser = argparse.ArgumentParser(
        prog="pr-rebase",
        description="Rebase onto origin/main with conflict detection and force-push",
    )
    parser.add_argument("--repo-dir", "--worktree",
                        dest="repo_dir",
                        help="Git worktree directory")
    parser.add_argument("--branch", help="Branch name (injected by pr dispatcher)")
    parser.add_argument("--pr", help="PR number (injected by pr dispatcher)")
    parser.add_argument("--fix", action="store_true",
                        help="Autonomous mode — resolve conflicts with AI, rebase, and force-push")
    parser.add_argument("--push", action="store_true",
                        help="Force-push after successful rebase")
    parser.add_argument("--abort", action="store_true",
                        help="Abort in-progress rebase")
    add_trail_args(parser)

    args = parser.parse_args()

    ctx = pr_context.resolve(
        repo_dir=args.repo_dir, branch=args.branch, pr=args.pr,
    )
    cwd = str(ctx.worktree_root)

    global _trail
    _trail = Trail.start(
        script="pr-rebase",
        artifact_dir=str(Path(cwd) / pr_state.STATE_DIR),
        context={"repo": ctx.repo, "pr": ctx.pr_number, "branch": ctx.branch},
        debug=args.debug,
    )
    try:
        if args.abort:
            _trail.decision("mode", "selected abort", reason="--abort flag set")
            sys.exit(cmd_abort(cwd, ctx))
        elif args.push:
            _trail.decision("mode", "selected push", reason="--push flag set")
            sys.exit(cmd_push(cwd, ctx))
        else:
            mode = "fix" if args.fix else "start"
            _trail.decision("mode", f"selected {mode}", reason="--fix flag set" if args.fix else "default mode")
            sys.exit(cmd_start(cwd, ctx, args.fix))
    except Exception as exc:
        _trail.error("unexpected_error", str(exc), data={"traceback": traceback.format_exc()})
        raise
    finally:
        _trail.finish()


if __name__ == "__main__":
    main()
