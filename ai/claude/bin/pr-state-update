#!/usr/bin/env python3
"""CLI helper for updating unified PR state from external scripts.

Reads a domain-specific JSON payload from stdin and applies it to the
PR state file. Best-effort: always exits 0, errors go to stderr.

Usage:
  echo '{"total":5,"actionable":2}' | pr-state-update --domain triage --repo-dir /path
"""

import argparse
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

import pr_context
import pr_state


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="pr-state-update",
        description="Update unified PR state from stdin JSON",
    )
    parser.add_argument("--domain", required=True,
                        choices=sorted(pr_state._DOMAIN_DESERIALIZERS),
                        help="State domain to update")
    parser.add_argument("--repo-dir", required=True,
                        help="Git worktree directory")
    args = parser.parse_args()

    try:
        data = json.load(sys.stdin)
    except (json.JSONDecodeError, ValueError) as exc:
        print(f"pr-state-update: invalid JSON on stdin: {exc}", file=sys.stderr)
        return

    try:
        ctx = pr_context.resolve(repo_dir=args.repo_dir)
    except SystemExit:
        print("pr-state-update: could not resolve PR context", file=sys.stderr)
        return

    try:
        pr_state.apply_state_update(
            worktree_root=ctx.worktree_root,
            repo=ctx.repo,
            branch=ctx.branch,
            pr_number=ctx.pr_number,
            head_sha=ctx.head_sha,
            domain=args.domain,
            data=data,
        )
    except Exception as exc:
        print(f"pr-state-update: {exc}", file=sys.stderr)


if __name__ == "__main__":
    main()
