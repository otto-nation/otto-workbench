#!/usr/bin/env python3
"""Scan PR review comments and cross-reference against coding rules.

Replaces Phase 1 of the retro skill (Orient).
Outputs a structured markdown report to stdout.

Usage:
  retro-scan [--home DIR] [--workbench DIR]
"""

from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from _version import version_string as _version_string  # noqa: E402


# ── Constants ────────────────────────────────────────────────────────────────

DEFAULT_WORKBENCH = "~/git/personal/otto-nation/otto-workbench/main"
WORKBENCH_ENV_VAR = "OTTO_WORKBENCH"

RULES_REL = Path("ai") / "guidelines" / "rules"

MACHINE_MD_REL = Path(".claude") / "machine" / "machine.md"
LAST_RETRO_REL = Path(".claude") / ".last-retro"

DATE_FMT = "%Y-%m-%d"

REGISTRY_TABLE_PATTERN = re.compile(r"^\|\s*(\S+)\s*\|\s*(\S+)\s*\|")
REGISTRY_SEPARATOR = re.compile(r"^\|\s*[-]+")

SSH_REMOTE_PATTERN = re.compile(r"git@github\.com:(.+?)(?:\.git)?$")
HTTPS_REMOTE_PATTERN = re.compile(r"https://github\.com/(.+?)(?:\.git)?$")

NOISE_PATTERNS = re.compile(
    r"^(?:lgtm|looks good|:?\+1:?|approved|nit:?\s*$|\U0001f44d)", re.IGNORECASE
)

COMMENT_BODY_MAX = 500

REVIEWS_DIR_REL = Path(".config") / "workbench" / "reviews"

FINDING_RE = re.compile(
    r"^- \[[ x]\] \*\*\[([MSNI])(\d+)\]\*\*\s+"
    r"(?:\*\*)?`([^`]+)`(?:\*\*)?\s*—\s*(.+)",
)

REVIEW_HEADER_RE = re.compile(
    r"^#\s+(?:Self-)?Review:\s+(\S+)\s*(?:—|#)",
)


# ── Output helpers ───────────────────────────────────────────────────────────

_NO_COLOR = bool(os.environ.get("NO_COLOR")) or not sys.stderr.isatty()
_INFO = "" if _NO_COLOR else "\033[1;34m→\033[0m"
_WARN = "" if _NO_COLOR else "\033[1;33m⚠\033[0m"


def _info(msg: str) -> None:
    print(f"{_INFO} {msg}", file=sys.stderr, flush=True)


def _warn(msg: str) -> None:
    print(f"{_WARN} {msg}", file=sys.stderr, flush=True)


# ── Project registry ────────────────────────────────────────────────────────

def parse_project_registry(machine_md_path: str) -> list[dict]:
    path = Path(machine_md_path)
    if not path.exists():
        return []
    lines = path.read_text().splitlines()
    results = []
    for line in lines:
        if REGISTRY_SEPARATOR.match(line):
            continue
        m = REGISTRY_TABLE_PATTERN.match(line)
        if m and m.group(1) != "Project":
            results.append({"name": m.group(1), "path": m.group(2)})
    return results


def resolve_github_remote(remote_url: str) -> str | None:
    for pattern in (SSH_REMOTE_PATTERN, HTTPS_REMOTE_PATTERN):
        m = pattern.match(remote_url)
        if m:
            return m.group(1)
    return None


def get_repo_remote(repo_path: str) -> str | None:
    try:
        result = subprocess.run(
            ["git", "-C", repo_path, "remote", "get-url", "origin"],
            capture_output=True, text=True, timeout=5,
        )
        if result.returncode == 0:
            return result.stdout.strip()
    except (subprocess.TimeoutExpired, FileNotFoundError):
        pass
    return None


# ── Comment filtering ───────────────────────────────────────────────────────

def is_noise(body: str) -> bool:
    stripped = body.strip()
    if len(stripped) < 3:
        return True
    return bool(NOISE_PATTERNS.match(stripped))


def parse_review_comment(comment: dict) -> dict:
    body = comment.get("body", "")
    return {
        "author": comment.get("user", {}).get("login", "unknown"),
        "body": body[:COMMENT_BODY_MAX],
        "path": comment.get("path"),
        "line": comment.get("line"),
        "url": comment.get("html_url", ""),
    }


# ── GitHub API fetching ─────────────────────────────────────────────────────

_RETRO_QUERY = """
query($owner: String!, $name: String!) {
  repository(owner: $owner, name: $name) {
    pullRequests(states: MERGED, first: 50, orderBy: {field: UPDATED_AT, direction: DESC}) {
      nodes {
        number
        title
        mergedAt
        author { login }
        reviewThreads(first: 100) {
          totalCount
          nodes {
            path
            line
            comments(first: 50) {
              nodes {
                author { login }
                body
              }
            }
          }
        }
        comments(first: 100) {
          totalCount
          nodes {
            author { login }
            body
          }
        }
      }
    }
  }
}
"""


def _gh_api(endpoint: str, repo: str) -> list[dict]:
    try:
        result = subprocess.run(
            ["gh", "api", "--paginate", f"repos/{repo}/{endpoint}"],
            capture_output=True, text=True, timeout=30,
        )
        if result.returncode != 0:
            _warn(f"gh api failed for {repo}/{endpoint}: {result.stderr.strip()}")
            return []
        return json.loads(result.stdout)
    except (subprocess.TimeoutExpired, FileNotFoundError, json.JSONDecodeError) as e:
        _warn(f"gh api error for {repo}/{endpoint}: {e}")
        return []


def _read_last_retro(home: Path) -> int:
    stamp = home / LAST_RETRO_REL
    if not stamp.exists():
        return 0
    try:
        return int(stamp.read_text().strip())
    except (ValueError, OSError):
        return 0


def _graphql_comment_to_dict(node: dict, path: str | None, line: int | None) -> dict:
    """Convert a single GraphQL comment node to the retro-scan comment format."""
    return {
        "author": (node.get("author") or {}).get("login", "unknown"),
        "body": (node.get("body") or "")[:COMMENT_BODY_MAX],
        "path": path, "line": line, "url": "",
    }


def _flatten_thread_comments(thread_nodes: list[dict]) -> list[dict]:
    """Flatten review thread nodes into comment dicts."""
    raw = [
        _graphql_comment_to_dict(c, thread.get("path"), thread.get("line"))
        for thread in thread_nodes
        for c in thread.get("comments", {}).get("nodes", [])
    ]
    return [c for c in raw if not is_noise(c["body"])]


def _flatten_issue_comments(comment_nodes: list[dict]) -> list[dict]:
    """Flatten issue comment nodes into comment dicts."""
    raw = [_graphql_comment_to_dict(c, None, None) for c in comment_nodes]
    return [c for c in raw if not is_noise(c["body"])]


def _parse_pr_node(pr_node: dict, since_date: str) -> dict | None:
    """Parse a single GraphQL PR node into the retro-scan format."""
    merged_at = pr_node.get("mergedAt", "")
    if not merged_at or merged_at < since_date:
        return None

    threads_data = pr_node.get("reviewThreads", {})
    total_threads = threads_data.get("totalCount", 0)
    thread_nodes = threads_data.get("nodes", [])
    if total_threads > len(thread_nodes):
        _warn(f"PR #{pr_node['number']}: {total_threads} threads but only {len(thread_nodes)} fetched")

    comments_data = pr_node.get("comments", {})
    total_comments = comments_data.get("totalCount", 0)
    comment_nodes = comments_data.get("nodes", [])
    if total_comments > len(comment_nodes):
        _warn(f"PR #{pr_node['number']}: {total_comments} issue comments but only {len(comment_nodes)} fetched")

    all_comments = _flatten_thread_comments(thread_nodes)
    all_comments.extend(_flatten_issue_comments(comment_nodes))

    if not all_comments:
        return None
    return {
        "number": pr_node.get("number"),
        "title": pr_node.get("title", ""),
        "user": {"login": (pr_node.get("author") or {}).get("login", "")},
        "merged_at": merged_at,
        "comments": all_comments,
    }


def fetch_repo_review_data(repo: str, since_ts: int) -> list[dict]:
    """Fetch merged PRs with review data in a single GraphQL query.

    Returns list of dicts with: number, title, author, merged_at, comments.
    Each comment has: author, body, path (optional), line (optional).
    """
    since_date = (
        datetime.fromtimestamp(since_ts, tz=timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
        if since_ts > 0 else "2020-01-01T00:00:00Z"
    )
    owner, name = repo.split("/", 1)
    cmd = [
        "gh", "api", "graphql",
        "-f", f"query={_RETRO_QUERY}",
        "-F", f"owner={owner}",
        "-F", f"name={name}",
    ]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        if result.returncode != 0:
            _warn(f"GraphQL query failed for {repo}: {result.stderr.strip()}")
            return _fetch_repo_review_data_rest(repo, since_ts)
        data = json.loads(result.stdout)
    except (subprocess.TimeoutExpired, FileNotFoundError, json.JSONDecodeError) as e:
        _warn(f"GraphQL error for {repo}: {e}")
        return _fetch_repo_review_data_rest(repo, since_ts)

    pr_nodes = (
        data.get("data", {})
        .get("repository", {})
        .get("pullRequests", {})
        .get("nodes", [])
    )

    results = []
    for pr_node in pr_nodes:
        parsed = _parse_pr_node(pr_node, since_date)
        if parsed:
            results.append(parsed)
    return results


def _fetch_repo_review_data_rest(repo: str, since_ts: int) -> list[dict]:
    """REST fallback for fetch_repo_review_data."""
    merged_prs = fetch_merged_prs(repo, since_ts)
    results = []
    for pr in merged_prs:
        comments = fetch_pr_comments(repo, pr["number"])
        if comments:
            results.append({
                "number": pr["number"],
                "title": pr.get("title", ""),
                "user": pr.get("user", {}),
                "merged_at": pr.get("merged_at", ""),
                "comments": comments,
            })
    return results


def fetch_merged_prs(repo: str, since_ts: int) -> list[dict]:
    since_date = datetime.fromtimestamp(since_ts, tz=timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ") if since_ts > 0 else "2020-01-01T00:00:00Z"
    endpoint = "pulls?state=closed&sort=updated&direction=desc&per_page=100"
    prs = _gh_api(endpoint, repo)
    return [
        pr for pr in prs
        if pr.get("merged_at") and pr["merged_at"] >= since_date
    ]


def fetch_pr_comments(repo: str, pr_number: int) -> list[dict]:
    review_comments = _gh_api(f"pulls/{pr_number}/comments", repo)
    issue_comments = _gh_api(f"issues/{pr_number}/comments", repo)
    all_comments = []
    for c in review_comments:
        parsed = parse_review_comment(c)
        if not is_noise(parsed["body"]):
            all_comments.append(parsed)
    for c in issue_comments:
        parsed = parse_review_comment(c)
        if not is_noise(parsed["body"]):
            all_comments.append(parsed)
    return all_comments


# ── Rules loading and matching ──────────────────────────────────────────────

STOP_WORDS = frozenset({
    "a", "an", "the", "is", "are", "was", "were", "be", "been", "being",
    "have", "has", "had", "do", "does", "did", "will", "would", "could",
    "should", "may", "might", "shall", "can", "need", "dare", "ought",
    "used", "to", "of", "in", "for", "on", "with", "at", "by", "from",
    "as", "into", "through", "during", "before", "after", "above", "below",
    "between", "out", "off", "over", "under", "again", "further", "then",
    "once", "here", "there", "when", "where", "why", "how", "all", "each",
    "every", "both", "few", "more", "most", "other", "some", "such", "no",
    "nor", "not", "only", "own", "same", "so", "than", "too", "very",
    "just", "don", "should", "now", "and", "but", "or", "if", "this",
    "that", "it", "its", "they", "them", "their", "we", "us", "our",
    "you", "your", "any", "up", "what", "which", "who",
})

KEYWORD_PATTERN = re.compile(r"[a-z][a-z_-]{2,}")

MIN_KEYWORD_OVERLAP = 1


def _extract_keywords(text: str) -> set[str]:
    words = set(KEYWORD_PATTERN.findall(text.lower()))
    return words - STOP_WORDS


def load_rules(workbench: Path) -> list[dict]:
    rules_dir = workbench / RULES_REL
    if not rules_dir.exists():
        return []
    results = []
    for f in sorted(rules_dir.glob("*.md")):
        content = f.read_text()
        keywords = _extract_keywords(content)
        bullets = [
            line.strip().removeprefix("- ")
            for line in content.splitlines()
            if line.strip().startswith("- ")
        ]
        results.append({
            "filename": f.name,
            "keywords": keywords,
            "bullets": bullets,
            "content": content,
        })
    return results


def find_nearest_rule(comment_body: str, rules: list[dict]) -> dict | None:
    comment_keywords = _extract_keywords(comment_body)
    if not comment_keywords:
        return None
    best_match = None
    best_score = 0
    for rule in rules:
        overlap = len(comment_keywords & rule["keywords"])
        if overlap > best_score and overlap >= MIN_KEYWORD_OVERLAP:
            best_score = overlap
            best_match = rule
    return best_match


# ── Report formatting ───────────────────────────────────────────────────────

def _format_comment_location(comment: dict) -> str:
    if not comment.get("path"):
        return ""
    loc = f" (inline: {comment['path']}"
    if comment.get("line"):
        loc += f":{comment['line']}"
    return loc + ")"


def _format_comment(comment: dict) -> list[str]:
    lines: list[str] = []
    location = _format_comment_location(comment)
    lines.append(f"- **Comment by @{comment['author']}**{location}")
    lines.append(f"  > {comment['body'][:200]}")
    if comment.get("direction"):
        lines.append(f"  - Direction: {comment['direction']}")
    nr = comment.get("nearest_rule")
    if nr:
        lines.append(f"  - Nearest rule: {nr['filename']} (\"{nr.get('match_snippet', '')}\")")
    else:
        lines.append("  - Nearest rule: (none)")
    lines.append("")
    return lines


def _format_pr(pr: dict) -> list[str]:
    if not pr.get("comments"):
        return []
    lines: list[str] = []
    lines.append(f"#### PR #{pr['number']}: {pr['title']} (merged {pr['merged_at']})")
    lines.append("")
    for comment in pr["comments"]:
        lines.extend(_format_comment(comment))
    return lines


def format_report(scan_data: dict) -> str:
    repos = scan_data.get("repos", [])
    rules_summary = scan_data.get("rules_summary", [])

    total_prs = sum(len(r.get("prs", [])) for r in repos)
    total_comments = sum(
        len(pr.get("comments", []))
        for r in repos for pr in r.get("prs", [])
    )

    lines: list[str] = []
    lines.append("# Retro Scan Report")
    version = _version_string("retro-scan").split("\n")[0]
    lines.append(f"<!-- generated: {datetime.now().strftime(DATE_FMT)} | scanner: {version} -->")
    lines.append(f"<!-- repos: {len(repos)} | prs: {total_prs} | comments: {total_comments} -->")
    lines.append("")

    if not repos or total_comments == 0:
        lines.append("No PR comments found in the scan window.")
        lines.append("")
        return "\n".join(lines)

    lines.append("## PR Comments by Repo")
    lines.append("")

    for repo in repos:
        lines.append(f"### {repo['github']}")
        lines.append("")
        for pr in repo.get("prs", []):
            lines.extend(_format_pr(pr))

    lines.append("## Rules Coverage Summary")
    lines.append("")
    if rules_summary:
        lines.append("| Rule file | Matched comments |")
        lines.append("|-----------|-----------------|")
        for rs in rules_summary:
            lines.append(f"| {rs['filename']} | {rs['matched']} |")
        lines.append("")

    return "\n".join(lines)


def _get_github_login() -> str:
    try:
        result = subprocess.run(
            ["gh", "api", "user", "--jq", ".login"],
            capture_output=True, text=True, timeout=10,
        )
        return result.stdout.strip() if result.returncode == 0 else ""
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return ""


def _best_matching_bullet(comment_body: str, rule: dict) -> str:
    comment_kw = _extract_keywords(comment_body)
    best_bullet = ""
    best_overlap = 0
    for bullet in rule.get("bullets", []):
        bullet_kw = _extract_keywords(bullet)
        overlap = len(comment_kw & bullet_kw)
        if overlap > best_overlap:
            best_overlap = overlap
            best_bullet = bullet
    return best_bullet[:100] if best_bullet else rule["filename"]


# ── Scanning ─────────────────────────────────────────────────────────────────


def _annotate_comment(
    comment: dict, pr_author: str, git_user: str,
    rules: list[dict], rule_match_counts: dict[str, dict],
) -> bool:
    comment["direction"] = "received" if pr_author == git_user else "gave"
    nearest = find_nearest_rule(comment["body"], rules)
    if nearest:
        comment["nearest_rule"] = {
            "filename": nearest["filename"],
            "match_snippet": _best_matching_bullet(comment["body"], nearest),
        }
        rule_match_counts[nearest["filename"]]["matched"] += 1
        return False
    comment["nearest_rule"] = None
    return True


def _process_pr(
    pr: dict, github_slug: str, git_user: str,
    rules: list[dict], rule_match_counts: dict[str, dict],
) -> dict | None:
    pr_author = pr.get("user", {}).get("login", "")
    comments = fetch_pr_comments(github_slug, pr["number"])
    if not comments:
        return None
    unmatched = 0
    for comment in comments:
        if _annotate_comment(comment, pr_author, git_user, rules, rule_match_counts):
            unmatched += 1
    return {
        "number": pr["number"],
        "title": pr.get("title", ""),
        "author": pr_author,
        "merged_at": pr.get("merged_at", "")[:10],
        "comments": comments,
        "unmatched": unmatched,
    }


def _scan_repo(
    repo: dict, last_retro_ts: int, rules: list[dict],
    git_user: str, rule_match_counts: dict[str, dict],
) -> dict:
    _info(f"Fetching PRs for {repo['github']}...")
    pr_data = fetch_repo_review_data(repo["github"], last_retro_ts)
    _info(f"  Found {len(pr_data)} merged PR(s) with comments")

    repo_prs: list[dict] = []
    unmatched = 0
    for pr in pr_data:
        pr_author = pr.get("user", {}).get("login", "")
        comments = pr["comments"]
        um = sum(
            1 for c in comments
            if _annotate_comment(c, pr_author, git_user, rules, rule_match_counts)
        )
        unmatched += um
        repo_prs.append({
            "number": pr["number"],
            "title": pr.get("title", ""),
            "author": pr_author,
            "merged_at": pr.get("merged_at", "")[:10],
            "comments": comments,
        })
    return {"prs": repo_prs, "unmatched": unmatched}


# ── Local review scanning ──────────────────────────────────────────────────


def _parse_file_ref(file_ref: str) -> tuple[str, int | None]:
    if ":" not in file_ref:
        return file_ref, None
    parts = file_ref.split(":", 1)
    try:
        return parts[0], int(parts[1])
    except ValueError:
        return parts[0], None


def _parse_review_findings(content: str) -> list[dict]:
    findings: list[dict] = []
    for line in content.splitlines():
        m = FINDING_RE.match(line.strip())
        if not m:
            continue
        severity, _num, file_ref, description = m.groups()
        path, line_num = _parse_file_ref(file_ref)
        findings.append({
            "severity": severity,
            "path": path,
            "line": line_num,
            "body": description.strip(),
        })
    return findings


def _extract_repo_from_review(content: str, dir_name: str) -> str:
    m = REVIEW_HEADER_RE.search(content)
    if m:
        return m.group(1)
    parts = dir_name.split("-self-", 1)
    if len(parts) == 2:
        return parts[0]
    parts = dir_name.rsplit("-", 1)
    if len(parts) == 2 and parts[1].isdigit():
        return parts[0]
    return dir_name


def _finding_to_comment(
    finding: dict, source: str, review_file: Path,
    rules: list[dict], rule_match_counts: dict[str, dict],
) -> tuple[dict, bool]:
    comment = {
        "author": source,
        "body": f"[{finding['severity']}] {finding['body']}",
        "path": finding["path"],
        "line": finding["line"],
        "url": "",
        "direction": "received",
        "source_file": str(review_file),
    }
    nearest = find_nearest_rule(comment["body"], rules)
    if nearest:
        comment["nearest_rule"] = {
            "filename": nearest["filename"],
            "match_snippet": _best_matching_bullet(comment["body"], nearest),
        }
        rule_match_counts[nearest["filename"]]["matched"] += 1
        return comment, False
    comment["nearest_rule"] = None
    return comment, True


def _scan_review_dir(
    review_dir: Path, rules: list[dict],
    rule_match_counts: dict[str, dict],
) -> tuple[str, dict, int] | None:
    review_file = review_dir / "review.md"
    if not review_file.exists():
        return None

    content = review_file.read_text()
    findings = _parse_review_findings(content)
    if not findings:
        return None

    dir_name = review_dir.name
    repo_key = _extract_repo_from_review(content, dir_name)
    source = "self-review" if "-self-" in dir_name else "claude-review"

    unmatched = 0
    comments: list[dict] = []
    for f in findings:
        comment, was_unmatched = _finding_to_comment(
            f, source, review_file, rules, rule_match_counts,
        )
        if was_unmatched:
            unmatched += 1
        comments.append(comment)

    pr_entry = {
        "number": f"local:{dir_name}",
        "title": f"Local review ({source})",
        "author": source,
        "merged_at": "",
        "comments": comments,
    }
    return repo_key, pr_entry, unmatched


def scan_local_reviews(
    home: Path, rules: list[dict], rule_match_counts: dict[str, dict],
) -> tuple[list[dict], int]:
    reviews_dir = home / REVIEWS_DIR_REL
    if not reviews_dir.exists():
        return [], 0

    local_repos: dict[str, list[dict]] = {}
    unmatched = 0

    for review_dir in sorted(reviews_dir.iterdir()):
        if not review_dir.is_dir():
            continue
        result = _scan_review_dir(review_dir, rules, rule_match_counts)
        if not result:
            continue
        repo_key, pr_entry, dir_unmatched = result
        unmatched += dir_unmatched
        local_repos.setdefault(repo_key, []).append(pr_entry)

    result_list = [
        {"github": f"local/{repo_key}", "prs": prs}
        for repo_key, prs in local_repos.items()
    ]

    _info(f"Found {sum(len(r['prs']) for r in result_list)} local review(s)")
    return result_list, unmatched


# ── Main ─────────────────────────────────────────────────────────────────────


def main() -> None:
    default_wb = os.environ.get(WORKBENCH_ENV_VAR, DEFAULT_WORKBENCH)

    parser = argparse.ArgumentParser(
        description="Scan PR review comments and cross-reference against coding rules.",
        usage="retro-scan [--home DIR] [--workbench DIR]",
    )
    parser.add_argument("-V", "--version", action="store_true", help="print version and exit")
    parser.add_argument("--home", type=str, default=os.environ.get("HOME", ""), help="home directory override")
    parser.add_argument("--workbench", type=str, default=default_wb, help=f"workbench directory (default: ${WORKBENCH_ENV_VAR} or {DEFAULT_WORKBENCH})")
    args = parser.parse_args()

    if args.version:
        print(_version_string("retro-scan"))
        raise SystemExit(0)

    home = Path(os.path.expanduser(args.home))
    workbench = Path(os.path.expanduser(args.workbench)).resolve()

    _info(f"Home: {home}")
    _info(f"Workbench: {workbench}")

    machine_md = home / MACHINE_MD_REL
    projects = parse_project_registry(str(machine_md))
    _info(f"Found {len(projects)} project(s) in registry")

    repos: list[dict] = []
    for proj in projects:
        remote_url = get_repo_remote(proj["path"])
        if not remote_url:
            _warn(f"No git remote for {proj['name']} at {proj['path']}")
            continue
        github_slug = resolve_github_remote(remote_url)
        if not github_slug:
            _warn(f"Non-GitHub remote for {proj['name']}: {remote_url}")
            continue
        repos.append({**proj, "github": github_slug})
    _info(f"Resolved {len(repos)} GitHub repo(s)")

    rules = load_rules(workbench)
    _info(f"Loaded {len(rules)} rule file(s)")

    last_retro_ts = _read_last_retro(home)
    if last_retro_ts > 0:
        _info(f"Last retro: {datetime.fromtimestamp(last_retro_ts).strftime(DATE_FMT)}")
    else:
        _info("No previous retro found — scanning all available PRs")

    git_user = _get_github_login()

    scan_repos: list[dict] = []
    rule_match_counts: dict[str, dict] = {r["filename"]: {"matched": 0} for r in rules}
    unmatched_count = 0

    for repo in repos:
        result = _scan_repo(repo, last_retro_ts, rules, git_user, rule_match_counts)
        unmatched_count += result["unmatched"]
        if result["prs"]:
            scan_repos.append({"github": repo["github"], "prs": result["prs"]})

    local_repos, local_unmatched = scan_local_reviews(home, rules, rule_match_counts)
    scan_repos.extend(local_repos)
    unmatched_count += local_unmatched

    rules_summary = []
    for r in rules:
        rc = rule_match_counts[r["filename"]]
        rules_summary.append({
            "filename": r["filename"],
            "matched": rc["matched"],
        })
    if unmatched_count:
        rules_summary.append({"filename": "(no rule)", "matched": unmatched_count})

    scan_data = {"repos": scan_repos, "rules_summary": rules_summary}
    report = format_report(scan_data)
    print(report)


if __name__ == "__main__":
    main()
