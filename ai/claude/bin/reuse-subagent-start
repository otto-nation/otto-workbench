#!/usr/bin/env python3
"""SubagentStart hook: inject reuse level into spawned subagents.

Emits the active reuse level so subagents inherit the parent session's mode.
Skips ceiling scan (too expensive for subagent startup).

Usage (called by settings.json SubagentStart hook):
  reuse-subagent-start
"""

from __future__ import annotations

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from _reuse_levels import (  # noqa: E402
    DEFAULT_LEVEL,
    LEVEL_DESCRIPTIONS,
    read_level,
)


def main() -> None:
    level = read_level()
    # Intentionally compare against DEFAULT_LEVEL ("full"), not read_default().
    # Subagents don't receive SessionStart, so they won't discover a configured
    # default unless we inject it here. We inject whenever the level differs from
    # the universal baseline so a user-configured default (e.g. "lite") is not
    # silently lost. reuse-session-start uses read_default() because a top-level
    # session already ran at full before the default was applied.
    if level != DEFAULT_LEVEL:
        print(f"Reuse level: {level} — {LEVEL_DESCRIPTIONS.get(level, '')}")


if __name__ == "__main__":
    main()
