#!/usr/bin/env python3
"""Review orchestration for claude-review.

Handles everything between "worktree is ready" and "review file is written":
PR metadata fetching, prompt template rendering, Claude agent invocation,
stream progress display, file grouping, and review merging.

Called by claude-review (bash wrapper) which handles worktree lifecycle,
archive management, and interactive prompts.

Usage:
  review-orchestrate --repo OWNER/REPO --pr NUMBER --review-file PATH \
    --wt-path PATH --reviews-dir PATH [--session-log PATH] \
    [--prior-review PATH] [--issue-link URL] [--issue-context JSON]
"""

import argparse
import json
import os
import re
import subprocess
import sys
from dataclasses import dataclass
from datetime import date
from pathlib import Path
from string import Template


# ── Data types ────────────────────────────────────────────────────────────────

@dataclass
class PRMetadata:
    title: str
    body: str
    head: str
    base: str
    head_sha: str
    additions: int
    deletions: int
    changed_files: int
    files: list[dict]

    @property
    def total_lines(self):
        return self.additions + self.deletions

    @property
    def file_stats(self):
        if self.total_lines <= 500:
            return ""
        sorted_files = sorted(
            self.files, key=lambda f: f["additions"] + f["deletions"], reverse=True
        )
        return "\n".join(
            f"  - {f['path']} (+{f['additions']} -{f['deletions']})"
            for f in sorted_files
        )

    @property
    def all_files_formatted(self):
        return "\n".join(
            f"  - {f['path']} (+{f['additions']} -{f['deletions']})"
            for f in self.files
        )


@dataclass
class PRContext:
    commits: str = ""
    reviews: str = "[]"
    review_comments: str = "[]"
    comments: str = "[]"


@dataclass
class Group:
    name: str
    files: list[str]
    lines: int


# ── Constants ─────────────────────────────────────────────────────────────────

MULTI_PHASE_LINE_THRESHOLD = 500
MULTI_PHASE_FILE_THRESHOLD = 10
MAX_GROUP_LINES = 800

TIER1_BASENAMES = {
    "CLAUDE.md", ".cursorrules", "AGENTS.md", "GEMINI.md",
    "go.mod", "package.json", "package-lock.json", "requirements.txt", "Gemfile",
}
TIER1_EXTENSIONS = {".proto", ".graphql"}
TIER1_PATH_SEGMENTS = {
    "migrations", "auth", "crypto", "permissions",
    "vault", "network-policies", "authorization-policies",
}
TIER3_BASENAMES_SUFFIXES = (
    ".pb.go", "_pb2.py", "_pb.ts", "_pb2_grpc.py",
    ".latest.sql", ".ko.yaml",
)
TIER3_PATH_SEGMENTS = {"gen", "testdata"}


# ── Tier classification ──────────────────────────────────────────────────────

def classify_tier(path: str) -> int:
    parts = path.split("/")
    basename = parts[-1]

    if any(seg in TIER3_PATH_SEGMENTS for seg in parts):
        return 3
    if basename == "go.sum" or basename.endswith(TIER3_BASENAMES_SUFFIXES):
        return 3
    if basename in TIER1_BASENAMES:
        return 1
    if any(basename.endswith(ext) for ext in TIER1_EXTENSIONS):
        return 1
    if any(seg in TIER1_PATH_SEGMENTS for seg in parts):
        return 1
    return 2


# ── File grouping ─────────────────────────────────────────────────────────────

def group_files(pr: PRMetadata) -> list[Group]:
    file_lines = {f["path"]: f["additions"] + f["deletions"] for f in pr.files}

    tiers: dict[int, list[str]] = {1: [], 2: [], 3: []}
    tier_lines: dict[int, int] = {1: 0, 2: 0, 3: 0}

    for path, lines in file_lines.items():
        t = classify_tier(path)
        tiers[t].append(path)
        tier_lines[t] += lines

    groups: list[Group] = []

    if tiers[1]:
        groups.append(Group("tier1-critical", tiers[1], tier_lines[1]))

    dir_files: dict[str, list[str]] = {}
    dir_lines: dict[str, int] = {}
    dir_order: list[str] = []
    for f in tiers[2]:
        d = f.split("/")[0]
        if d not in dir_files:
            dir_files[d] = []
            dir_lines[d] = 0
            dir_order.append(d)
        dir_files[d].append(f)
        dir_lines[d] += file_lines[f]

    for d in dir_order:
        files = dir_files[d]
        total = dir_lines[d]
        if total > MAX_GROUP_LINES:
            sub_files: list[str] = []
            sub_lines = 0
            sub_idx = 1
            for f in files:
                fl = file_lines[f]
                if sub_lines + fl > MAX_GROUP_LINES and sub_files:
                    groups.append(Group(f"{d}-{sub_idx}", sub_files, sub_lines))
                    sub_files = []
                    sub_lines = 0
                    sub_idx += 1
                sub_files.append(f)
                sub_lines += fl
            if sub_files:
                groups.append(Group(f"{d}-{sub_idx}", sub_files, sub_lines))
        else:
            groups.append(Group(d, files, total))

    if tiers[3]:
        groups.append(Group("tier3-generated", tiers[3], tier_lines[3]))

    return groups


# ── Review merging ────────────────────────────────────────────────────────────

def _extract_section(content: str, header: str) -> str:
    pattern = rf"^## {re.escape(header)}\s*\n"
    m = re.search(pattern, content, re.MULTILINE)
    if not m:
        return ""
    start = m.end()
    next_header = re.search(r"^## ", content[start:], re.MULTILINE)
    end = start + next_header.start() if next_header else len(content)
    return content[start:end].strip()


def renumber_section(prefix: str, text: str, offset: int) -> tuple[str, int]:
    if not text:
        return "", 0
    count = len(re.findall(rf"\[{prefix}\d+\]", text))
    if offset > 0:
        for i in range(count, 0, -1):
            text = text.replace(f"[{prefix}{i}]", f"[{prefix}{i + offset}]")
    return text, count


def merge_reviews(group_files: list[str]) -> str:
    merged_triage = ""
    merged_must = ""
    merged_should = ""
    merged_nit = ""
    m_offset = s_offset = n_offset = 0

    for path in group_files:
        p = Path(path)
        if not p.exists():
            continue
        content = p.read_text()

        triage = _extract_section(content, "File Triage")
        must = _extract_section(content, "Must fix")
        should = _extract_section(content, "Should fix")
        nit = _extract_section(content, "Nit")

        if triage:
            merged_triage += triage + "\n"

        text, count = renumber_section("M", must, m_offset)
        if text:
            merged_must += text + "\n"
        m_offset += count

        text, count = renumber_section("S", should, s_offset)
        if text:
            merged_should += text + "\n"
        s_offset += count

        text, count = renumber_section("N", nit, n_offset)
        if text:
            merged_nit += text + "\n"
        n_offset += count

    parts = [f"## File Triage\n{merged_triage}"]
    if merged_must:
        parts.append(f"## Must fix\n{merged_must}")
    if merged_should:
        parts.append(f"## Should fix\n{merged_should}")
    if merged_nit:
        parts.append(f"## Nit\n{merged_nit}")

    return "\n".join(parts)


# ── PR data fetching ──────────────────────────────────────────────────────────

def _run(cmd: list[str], check: bool = True) -> str:
    r = subprocess.run(cmd, capture_output=True, text=True)
    if check and r.returncode != 0:
        return ""
    return r.stdout.strip()


def fetch_pr_metadata(repo: str, pr_number: str) -> PRMetadata:
    raw = _run([
        "gh", "pr", "view", pr_number, "--repo", repo,
        "--json", "title,body,headRefName,baseRefName,headRefOid,"
                  "additions,deletions,changedFiles,files",
    ])
    if not raw:
        print(f"error: failed to fetch PR #{pr_number} from {repo}", file=sys.stderr)
        sys.exit(1)
    data = json.loads(raw)
    return PRMetadata(
        title=data["title"],
        body=data.get("body") or "",
        head=data["headRefName"],
        base=data["baseRefName"],
        head_sha=data["headRefOid"],
        additions=data["additions"],
        deletions=data["deletions"],
        changed_files=data["changedFiles"],
        files=[
            {"path": f["path"], "additions": f["additions"], "deletions": f["deletions"]}
            for f in data["files"]
        ],
    )


def fetch_pr_context(repo: str, pr_number: str) -> PRContext:
    commits = _run([
        "gh", "pr", "view", pr_number, "--repo", repo,
        "--json", "commits",
        "--jq", '[.commits[] | .messageHeadline] | join("\\n")',
    ], check=False)
    reviews = _run([
        "gh", "api", f"repos/{repo}/pulls/{pr_number}/reviews",
        "--jq", '[.[] | {user: .user.login, state, body}]',
    ], check=False) or "[]"
    review_comments = _run([
        "gh", "api", f"repos/{repo}/pulls/{pr_number}/comments",
        "--jq", '[.[] | {id, path, line, body, user: .user.login, in_reply_to_id}]',
    ], check=False) or "[]"
    comments = _run([
        "gh", "api", f"repos/{repo}/issues/{pr_number}/comments",
        "--jq", '[.[] | {user: .user.login, body}]',
    ], check=False) or "[]"
    return PRContext(
        commits=commits,
        reviews=reviews,
        review_comments=review_comments,
        comments=comments,
    )


# ── Template rendering ────────────────────────────────────────────────────────

def _template_dir() -> Path:
    return Path(__file__).resolve().parent.parent / "lib" / "review-templates"


def _build_pr_header(pr: PRMetadata, ctx: PRContext) -> str:
    lines = [
        "## PR metadata",
        f"- **Title:** {pr.title}",
        f"- **Branch:** {pr.head} → {pr.base}",
        f"- **Size:** +{pr.additions} -{pr.deletions} across {pr.changed_files} files",
        "",
        "### Description",
        pr.body or "_No description provided._",
        "",
        "### Commits",
        ctx.commits or "_No commits._",
    ]
    if pr.file_stats:
        lines += ["", "### File breakdown (sorted by churn)", pr.file_stats]
    return "\n".join(lines)


def _build_reviews_section(ctx: PRContext) -> str:
    return f"""
## Existing reviews and comments
Skip these — do NOT re-fetch from the GitHub API. This data is current as of script invocation.

### Submitted reviews
{ctx.reviews}

### Inline review comments
{ctx.review_comments}

### General PR comments
{ctx.comments}"""


def _build_env_section(wt_path: str) -> str:
    return f"""
## Environment
PR branch checked out at: {wt_path}
Read source files directly from this path. Do NOT fetch files via the GitHub API."""


def _build_issue_section(issue_link: str, issue_context: str) -> str:
    if issue_link:
        return f"\n## Related issue\n{issue_link}"
    if issue_context:
        return f"\n## Related issue\n{issue_context}"
    return ""


def _build_prior_section(prior_review: str, context: str = "") -> str:
    if not prior_review:
        return ""
    default = "This is a re-review. For each prior finding, mark fixed findings as resolved and carry forward open ones."
    return f"""
## Prior review
{context or default}

<prior_review>
{prior_review}
</prior_review>"""


def render_template(name: str, **kwargs) -> str:
    path = _template_dir() / name
    tmpl = Template(path.read_text())
    return tmpl.safe_substitute(**kwargs)


def build_prompt(
    template_name: str,
    repo: str,
    pr: PRMetadata,
    ctx: PRContext,
    wt_path: str,
    review_file: str,
    issue_link: str = "",
    issue_context: str = "",
    prior_review: str = "",
    **extra,
) -> str:
    pr_header = _build_pr_header(pr, ctx)
    reviews_section = _build_reviews_section(ctx)
    env_section = _build_env_section(wt_path)
    issue_section = _build_issue_section(issue_link, issue_context)

    if template_name == "single-agent.md":
        prior_ctx = (
            "This is a re-review. Below are the findings from the previous review. "
            "For each prior finding:\n"
            "- If the issue has been fixed, note it as resolved and omit from the new review\n"
            "- If the issue is still present, carry it forward\n"
            "- Add any new findings from changes since the last review"
        )
        prior_section = _build_prior_section(prior_review, prior_ctx)
        return render_template(
            "single-agent.md",
            pr_number=extra.get("pr_number", ""),
            repo=repo,
            pr_header=pr_header,
            reviews_section=reviews_section,
            env_section=env_section,
            issue_section=issue_section,
            prior_section=prior_section,
            review_file=review_file,
        )

    if template_name == "holistic.md":
        return render_template(
            "holistic.md",
            pr_number=extra.get("pr_number", ""),
            repo=repo,
            pr_header=pr_header,
            all_files_formatted=pr.all_files_formatted,
            reviews_section=reviews_section,
            issue_section=issue_section,
            env_section=env_section,
            holistic_output=extra["holistic_output"],
        )

    if template_name == "group.md":
        prior_section = _build_prior_section(
            prior_review,
            "This is a re-review. Below are the prior findings. "
            "Carry forward findings relevant to YOUR files only. "
            "Mark fixed findings as resolved.",
        )
        holistic_content = extra.get("holistic_content", "")
        holistic_block = ""
        if holistic_content:
            holistic_block = (
                f"\n## Holistic context\n"
                f"The following assessment was produced by scanning all "
                f"{pr.changed_files} files in this PR.\n"
                f"Use it to inform your detailed review — especially the flags section.\n\n"
                f"{holistic_content}"
            )
        return render_template(
            "group.md",
            pr_number=extra.get("pr_number", ""),
            repo=repo,
            pr_header=pr_header,
            group_idx=extra["group_idx"],
            group_count=extra["group_count"],
            group_name=extra["group_name"],
            holistic_block=holistic_block,
            group_files_formatted=extra["group_files_formatted"],
            reviews_section=reviews_section,
            issue_section=issue_section,
            env_section=env_section,
            group_output=extra["group_output"],
            prior_section=prior_section,
        )

    if template_name == "synthesis.md":
        prior_section = _build_prior_section(
            prior_review,
            "Include a ## Resolved section noting which prior findings were fixed.",
        )
        return render_template(
            "synthesis.md",
            pr_number=extra.get("pr_number", ""),
            repo=repo,
            pr_header=pr_header,
            pr_title=pr.title,
            pr_head_sha=pr.head_sha,
            holistic_content=extra.get("holistic_content") or "_No holistic assessment available._",
            group_count=extra["group_count"],
            merged_content=extra["merged_content"],
            review_file=review_file,
            wt_path=wt_path,
            today=date.today().isoformat(),
            prior_section=prior_section,
        )

    raise ValueError(f"Unknown template: {template_name}")


# ── Stream progress ───────────────────────────────────────────────────────────

DIM = "\033[2m"
NC = "\033[0m"


def stream_progress(process: subprocess.Popen, session_log: str):
    prev_label = ""
    with open(session_log, "w") as log:
        for raw_line in process.stdout:
            log.write(raw_line)
            log.flush()
            try:
                data = json.loads(raw_line)
            except (json.JSONDecodeError, ValueError):
                continue
            if data.get("type") != "assistant":
                continue
            contents = data.get("message", {}).get("content", [])
            for block in contents:
                if block.get("type") != "tool_use":
                    continue
                inp = block.get("input", {})
                name = block.get("name", "")
                if inp.get("description"):
                    label = inp["description"]
                elif name == "Read":
                    label = "Read " + (inp.get("file_path", "").split("/")[-1] or "")
                elif name == "Grep":
                    label = "Grep " + inp.get("pattern", "")
                elif name == "Glob":
                    label = "Glob " + inp.get("pattern", "")
                elif name == "Write":
                    label = "Write " + (inp.get("file_path", "").split("/")[-1] or "")
                else:
                    label = name
                if label and label != prev_label:
                    print(f"  {DIM}▸ {label}{NC}", flush=True)
                    prev_label = label


# ── Agent invocation ──────────────────────────────────────────────────────────

def invoke_agent(prompt: str, session_log: str, wt_path: str, reviews_dir: str):
    proc = subprocess.Popen(
        [
            "claude", "-p", "--verbose", "--output-format", "stream-json",
            "--permission-mode", "acceptEdits",
            "--add-dir", reviews_dir, "--add-dir", wt_path,
            "--agent", "reviewer",
        ],
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )
    proc.stdin.write(prompt)
    proc.stdin.close()
    stream_progress(proc, session_log)
    proc.wait()


# ── Review pipelines ──────────────────────────────────────────────────────────

def _info(msg: str):
    print(f"\033[1;34m▸\033[0m {msg}", flush=True)


def _warn(msg: str):
    print(f"\033[1;33m⚠\033[0m {msg}", file=sys.stderr, flush=True)


def run_single_agent(
    repo: str, pr_number: str, pr: PRMetadata, ctx: PRContext,
    wt_path: str, review_file: str, session_log: str, reviews_dir: str,
    issue_link: str, issue_context: str, prior_review: str,
):
    prompt = build_prompt(
        "single-agent.md", repo, pr, ctx, wt_path, review_file,
        issue_link=issue_link, issue_context=issue_context,
        prior_review=prior_review, pr_number=pr_number,
    )
    _info(f"Running review agent on PR #{pr_number} ({pr.title})...")
    print()
    invoke_agent(prompt, session_log, wt_path, reviews_dir)
    print()

    if not Path(review_file).exists():
        print(f"error: review file not found: {review_file}", file=sys.stderr)
        print(f"  Session log: {session_log}", file=sys.stderr)
        sys.exit(1)


def run_multi_phase(
    repo: str, pr_number: str, pr: PRMetadata, ctx: PRContext,
    wt_path: str, review_file: str, session_log: str, reviews_dir: str,
    issue_link: str, issue_context: str, prior_review: str,
):
    groups = group_files(pr)
    group_count = len(groups)

    _info(f"Large PR ({pr.total_lines} lines, {pr.changed_files} files) — {group_count} file groups")

    # Phase 1: Holistic scan
    holistic_output = review_file.replace(".md", ".holistic.md")
    holistic_log = review_file.replace(".md", ".holistic.jsonl")

    holistic_prompt = build_prompt(
        "holistic.md", repo, pr, ctx, wt_path, review_file,
        issue_link=issue_link, issue_context=issue_context,
        pr_number=pr_number, holistic_output=holistic_output,
    )
    _info(f"Phase 1/{group_count}: Holistic scan...")
    print()
    invoke_agent(holistic_prompt, holistic_log, wt_path, reviews_dir)
    print()

    holistic_content = ""
    if Path(holistic_output).exists():
        holistic_content = Path(holistic_output).read_text()
    else:
        _warn("Holistic scan produced no output — continuing without it")

    # Phase 2: Group reviews
    group_outputs: list[str] = []
    failed_groups: list[str] = []

    for i, grp in enumerate(groups, 1):
        group_files_formatted = "\n".join(
            f"  - {f['path']} (+{f['additions']} -{f['deletions']})"
            for f in pr.files if f["path"] in grp.files
        )
        group_output = review_file.replace(".md", f".group-{i}.md")
        group_log = review_file.replace(".md", f".group-{i}.jsonl")
        group_outputs.append(group_output)

        group_prompt = build_prompt(
            "group.md", repo, pr, ctx, wt_path, review_file,
            issue_link=issue_link, issue_context=issue_context,
            prior_review=prior_review, pr_number=pr_number,
            group_idx=i, group_count=group_count, group_name=grp.name,
            group_files_formatted=group_files_formatted,
            group_output=group_output, holistic_content=holistic_content,
        )
        _info(f"Phase 2: Group {i}/{group_count} — {grp.name} ({grp.lines} lines)...")
        print()
        invoke_agent(group_prompt, group_log, wt_path, reviews_dir)
        print()

        if not Path(group_output).exists():
            _warn(f"Group {i} ({grp.name}) produced no output")
            failed_groups.append(grp.name)

    # Phase 3: Merge
    _info("Phase 3: Merging findings...")
    merged_content = merge_reviews(group_outputs)

    if failed_groups:
        merged_content += "\n## Review gaps\n"
        merged_content += "The following file groups were not reviewed due to agent failure:\n"
        for fg in failed_groups:
            merged_content += f"- {fg}\n"

    # Phase 4: Synthesis
    synthesis_log = review_file.replace(".md", ".synthesis.jsonl")

    synthesis_prompt = build_prompt(
        "synthesis.md", repo, pr, ctx, wt_path, review_file,
        prior_review=prior_review, pr_number=pr_number,
        holistic_content=holistic_content, group_count=group_count,
        merged_content=merged_content,
    )
    _info("Phase 4: Synthesis...")
    print()
    invoke_agent(synthesis_prompt, synthesis_log, wt_path, reviews_dir)
    print()

    if not Path(review_file).exists():
        _warn("Synthesis agent failed — falling back to mechanical merge")
        today = date.today().isoformat()
        fallback = (
            f"# Review: {repo}#{pr_number} — {pr.title}\n"
            f"<!-- date: {today} -->\n"
            f"<!-- head_sha: {pr.head_sha} -->\n\n"
            f"## Summary\n"
            f"Multi-phase review of {pr.changed_files} files across {group_count} groups. "
            f"Synthesis agent failed — findings below are from individual group reviews.\n\n"
            f"{merged_content}\n\n"
            f"## Verdict\n"
            f"Manual review of findings required — synthesis was not completed.\n"
        )
        Path(review_file).write_text(fallback)

    # Consolidate logs
    group_logs = [review_file.replace(".md", f".group-{i}.jsonl") for i in range(1, len(group_outputs) + 1)]
    try:
        with open(session_log, "w") as out:
            for log_path in [holistic_log] + group_logs + [synthesis_log]:
                p = Path(log_path)
                if p.exists():
                    out.write(p.read_text())
    except OSError:
        pass

    # Clean up intermediate files
    for path in [holistic_output, holistic_log] + group_outputs + group_logs + [synthesis_log]:
        try:
            Path(path).unlink()
        except FileNotFoundError:
            pass


# ── Main ──────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(description="Review orchestration for claude-review")
    parser.add_argument("--repo", required=True, help="GitHub owner/repo")
    parser.add_argument("--pr", required=True, help="PR number")
    parser.add_argument("--review-file", required=True, help="Output review file path")
    parser.add_argument("--wt-path", required=True, help="Worktree path")
    parser.add_argument("--reviews-dir", required=True, help="Reviews directory")
    parser.add_argument("--session-log", help="Session log path")
    parser.add_argument("--prior-review", help="Path to prior review file for iterative context")
    parser.add_argument("--issue-link", default="", help="Issue URL")
    parser.add_argument("--issue-context", default="", help="Issue context JSON")
    args = parser.parse_args()

    session_log = args.session_log or args.review_file.replace(".md", ".session.jsonl")

    _info("Fetching PR metadata...")
    pr = fetch_pr_metadata(args.repo, args.pr)

    _info("Fetching PR context...")
    ctx = fetch_pr_context(args.repo, args.pr)

    prior_review = ""
    if args.prior_review and Path(args.prior_review).exists():
        prior_review = Path(args.prior_review).read_text()

    is_large = (
        pr.total_lines > MULTI_PHASE_LINE_THRESHOLD
        or pr.changed_files > MULTI_PHASE_FILE_THRESHOLD
    )
    mode = "multi" if is_large else "single"

    if is_large:
        run_multi_phase(
            args.repo, args.pr, pr, ctx, args.wt_path, args.review_file,
            session_log, args.reviews_dir,
            args.issue_link, args.issue_context, prior_review,
        )
    else:
        run_single_agent(
            args.repo, args.pr, pr, ctx, args.wt_path, args.review_file,
            session_log, args.reviews_dir,
            args.issue_link, args.issue_context, prior_review,
        )

    result = {
        "review_file": args.review_file,
        "session_log": session_log,
        "mode": mode,
    }
    json.dump(result, sys.stdout)
    print()


if __name__ == "__main__":
    main()
