#!/usr/bin/env python3
"""Review orchestration for claude-review.

Handles everything between "worktree is ready" and "review file is written":
PR metadata fetching, prompt template rendering, Claude agent invocation,
stream progress display, file grouping, and review merging.

Called by claude-review (bash wrapper) which handles worktree lifecycle,
archive management, and interactive prompts.

Usage:
  review-orchestrate --repo OWNER/REPO --pr NUMBER --review-file PATH \
    --wt-path PATH --reviews-dir PATH [--session-log PATH] \
    [--prior-review PATH] [--issue-link URL] [--issue-context JSON]
"""

import argparse
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

import review_common as _rc  # noqa: E402
import review_findings as _rf  # noqa: E402
import review_preflight as _rp  # noqa: E402
import review_prompt as _rpmt  # noqa: E402
import review_agent as _ra  # noqa: E402
import review_pipeline as _rpl  # noqa: E402

from review_common import *  # noqa: E402,F403
from review_findings import *  # noqa: E402,F403
from review_preflight import *  # noqa: E402,F403
from review_prompt import *  # noqa: E402,F403
from review_agent import *  # noqa: E402,F403
from review_pipeline import *  # noqa: E402,F403

# Re-export private names for test backward compatibility
def __getattr__(name):
    for mod in (_rc, _rf, _rp, _rpmt, _ra, _rpl):
        try:
            return getattr(mod, name)
        except AttributeError:
            continue
    raise AttributeError(f"module 'review_orchestrate' has no attribute {name!r}")


# ── Main ──────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(description="Review orchestration for claude-review")
    parser.add_argument("--repo", required=True, help="GitHub owner/repo")
    parser.add_argument("--pr", default="", help="PR number (optional in self mode)")
    parser.add_argument("--review-file", required=True, help="Output review file path")
    parser.add_argument("--wt-path", required=True, help="Worktree path")
    parser.add_argument("--reviews-dir", required=True, help="Reviews directory")
    parser.add_argument("--session-log", help="Session log path")
    parser.add_argument("--prior-review", help="Path to prior review file for iterative context")
    parser.add_argument("--issue-link", default="", help="Issue URL")
    parser.add_argument("--issue-context", default="", help="Issue context JSON")
    parser.add_argument("--max-parallel", type=int, default=DEFAULT_MAX_PARALLEL,
                        help=f"Max concurrent group reviews (default: {DEFAULT_MAX_PARALLEL})")
    parser.add_argument("--no-holistic", action="store_true",
                        help="Skip holistic phase in multi-phase reviews")
    parser.add_argument("--generator-version", default="",
                        help="Version string to embed in review metadata")
    parser.add_argument("--mode", choices=[MODE_PR, MODE_SELF], default=MODE_PR,
                        help="Review mode: pr (default) or self")
    parser.add_argument("--max-cost", type=float, default=DEFAULT_MAX_COST,
                        help=f"Max total review cost in USD (default: {DEFAULT_MAX_COST})")
    parser.add_argument("--model", default="",
                        help="Override model for all agents (e.g. sonnet, opus)")
    args = parser.parse_args()

    if args.mode == MODE_PR and not args.pr:
        print("error: --pr is required in pr mode", file=sys.stderr)
        sys.exit(1)

    session_log = args.session_log or _derive_path(args.review_file, FILENAME_SESSION)

    pr, ctx = _fetch_metadata(args.repo, args.pr, args.mode, args.wt_path)

    prior_review = ""
    if args.prior_review and Path(args.prior_review).exists():
        prior_review = Path(args.prior_review).read_text()

    job = ReviewJob(
        repo=args.repo, pr_number=args.pr, pr=pr, ctx=ctx,
        wt_path=args.wt_path, review_file=args.review_file,
        session_log=session_log, reviews_dir=args.reviews_dir,
        issue_link=args.issue_link, issue_context=args.issue_context,
        prior_review=prior_review, mode=args.mode,
        generator_version=args.generator_version,
        model=args.model,
    )

    _info("Collecting file data...")
    job.preflight = collect_preflight_data(job)

    is_large = (
        pr.total_lines > MULTI_PHASE_LINE_THRESHOLD
        or pr.changed_files > MULTI_PHASE_FILE_THRESHOLD
    )
    pipeline = PIPELINE_MULTI if is_large else PIPELINE_SINGLE

    if is_large:
        run_multi_phase(
            job, max_parallel=args.max_parallel,
            skip_holistic=args.no_holistic, max_cost=args.max_cost,
        )
    else:
        run_single_agent(job)

    result = {
        "review_file": job.review_file,
        "session_log": job.session_log,
        "mode": pipeline,
    }
    json.dump(result, sys.stdout)
    print()


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        sys.exit(130)
