#!/usr/bin/env python3
"""Review orchestration for claude-review.

Handles everything between "worktree is ready" and "review file is written":
PR metadata fetching, prompt template rendering, Claude agent invocation,
stream progress display, file grouping, and review merging.

Called by claude-review (bash wrapper) which handles worktree lifecycle,
archive management, and interactive prompts.

Usage:
  review-orchestrate --repo OWNER/REPO --pr NUMBER --review-file PATH \
    --wt-path PATH --reviews-dir PATH [--session-log PATH] \
    [--prior-review PATH] [--issue-link URL] [--issue-context JSON]
"""

import argparse
import json
import os
import re
import stat
import subprocess
import sys
import threading
from concurrent.futures import ThreadPoolExecutor, as_completed
from dataclasses import dataclass, field
from datetime import date
from pathlib import Path
from string import Template


# ── Data types ────────────────────────────────────────────────────────────────

@dataclass
class PRMetadata:
    title: str
    body: str
    head: str
    base: str
    head_sha: str
    additions: int
    deletions: int
    changed_files: int
    files: list[dict]

    @property
    def total_lines(self):
        return self.additions + self.deletions

    @property
    def file_stats(self):
        if self.total_lines <= MULTI_PHASE_LINE_THRESHOLD:
            return ""
        sorted_files = sorted(
            self.files, key=lambda f: f["additions"] + f["deletions"], reverse=True
        )
        return "\n".join(
            FILE_STAT_FMT.format(**f) for f in sorted_files
        )

    @property
    def all_files_formatted(self):
        return "\n".join(
            FILE_STAT_FMT.format(**f) for f in self.files
        )


@dataclass
class PRContext:
    commits: str = ""
    reviews: str = "[]"
    review_comments: str = "[]"
    comments: str = "[]"


@dataclass
class Group:
    name: str
    files: list[str]
    lines: int


MODE_PR = "pr"
MODE_SELF = "self"


@dataclass
class ReviewJob:
    repo: str
    pr_number: str
    pr: PRMetadata
    ctx: PRContext
    wt_path: str
    review_file: str
    session_log: str
    reviews_dir: str
    issue_link: str = ""
    issue_context: str = ""
    prior_review: str = ""
    mode: str = MODE_PR
    preflight: "PreflightData | None" = None


@dataclass
class PreflightData:
    diff: str
    commit_log: str
    file_contents: dict[str, str]
    file_permissions: dict[str, str]
    claude_md: str
    context_md: str
    review_checklists: dict[str, str] = field(default_factory=dict)


# ── Constants ─────────────────────────────────────────────────────────────────

REVIEW_EXT = ".md"

MULTI_PHASE_LINE_THRESHOLD = 500
MULTI_PHASE_FILE_THRESHOLD = 10
MAX_GROUP_LINES = 800
DEFAULT_MAX_PARALLEL = 4

DEFAULT_BASE_BRANCH = "main"
GIT_RANGE_TO_HEAD = f"origin/{DEFAULT_BASE_BRANCH}..HEAD"

SECTION_FILE_TRIAGE = "File Triage"
SECTION_MUST_FIX = "Must fix"
SECTION_SHOULD_FIX = "Should fix"
SECTION_NIT = "Nit"
SECTION_IDIOMS = "Idioms"

FINDING_PREFIX_MUST = "M"
FINDING_PREFIX_SHOULD = "S"
FINDING_PREFIX_NIT = "N"
FINDING_PREFIX_IDIOMS = "I"

FINDING_SECTIONS = [
    (SECTION_MUST_FIX, FINDING_PREFIX_MUST),
    (SECTION_SHOULD_FIX, FINDING_PREFIX_SHOULD),
    (SECTION_NIT, FINDING_PREFIX_NIT),
    (SECTION_IDIOMS, FINDING_PREFIX_IDIOMS),
]

GROUP_TIER1 = "tier1-critical"
GROUP_TIER3 = "tier3-generated"

TEMPLATE_SINGLE = "single-agent.md"
TEMPLATE_HOLISTIC = "holistic.md"
TEMPLATE_GROUP = "group.md"
TEMPLATE_SYNTHESIS = "synthesis.md"
TEMPLATE_SELF_REVIEW = "self-review.md"
TEMPLATE_SELF_SYNTHESIS = "self-review-synthesis.md"

SUFFIX_PRIOR = ".prior.md"
SUFFIX_SESSION = ".session.jsonl"
SUFFIX_HOLISTIC = ".holistic.md"
SUFFIX_HOLISTIC_LOG = ".holistic.jsonl"
SUFFIX_SYNTHESIS_LOG = ".synthesis.jsonl"
SUFFIX_GROUP = ".group-{}.md"
SUFFIX_GROUP_LOG = ".group-{}.jsonl"

PIPELINE_MULTI = "multi"
PIPELINE_SINGLE = "single"

TEMPLATE_DIR_REL = Path("lib") / "review-templates"

FILE_STAT_FMT = "  - {path} (+{additions} -{deletions})"
META_DATE = "<!-- date: {today} -->"
META_HEAD_SHA = "<!-- head_sha: {head_sha} -->"
FALLBACK_SUMMARY = "Synthesis agent failed — findings below are from individual group reviews."

ANSI_DIM = "\033[2m"
ANSI_RESET = "\033[0m"
ANSI_INFO = "\033[1;34m▸\033[0m"
ANSI_WARN = "\033[1;33m⚠\033[0m"

TIER1_BASENAMES = {
    "CLAUDE.md", ".cursorrules", "AGENTS.md", "GEMINI.md",
    "go.mod", "package.json", "package-lock.json", "requirements.txt", "Gemfile",
}
TIER1_EXTENSIONS = {".proto", ".graphql"}
TIER1_PATH_SEGMENTS = {
    "migrations", "auth", "crypto", "permissions",
    "vault", "network-policies", "authorization-policies",
}
TIER3_BASENAMES = {"go.sum"}
TIER3_BASENAMES_SUFFIXES = (
    ".pb.go", "_pb2.py", "_pb.ts", "_pb2_grpc.py",
    ".latest.sql", ".ko.yaml",
)
TIER3_PATH_SEGMENTS = {"gen", "testdata"}

MAX_PREFLIGHT_BYTES = 500_000
MAX_FILE_BYTES = 100_000
MAX_TRUNCATED_LINES = 500


# ── Pre-flight data collection ───────────────────────────────────────────────

def _read_file_safe(path: Path) -> str:
    try:
        content = path.read_text()
        byte_len = len(content.encode())
        if byte_len > MAX_FILE_BYTES:
            lines = content.splitlines(keepends=True)
            truncated = "".join(lines[:MAX_TRUNCATED_LINES])
            return f"{truncated}\n\n<truncated — file is {byte_len // 1024}KB, showing first {MAX_TRUNCATED_LINES} lines>"
        return content
    except FileNotFoundError:
        return "<file deleted>"
    except UnicodeDecodeError:
        try:
            size = path.stat().st_size
        except OSError:
            size = 0
        return f"<binary file, {size} bytes>"
    except PermissionError:
        return "<permission denied>"


def _file_permissions(path: Path) -> str:
    try:
        mode = path.stat().st_mode
        return oct(stat.S_IMODE(mode))
    except OSError:
        return "?"


def collect_preflight_data(job: "ReviewJob") -> "PreflightData | None":
    wt = Path(job.wt_path)
    base = job.pr.base or DEFAULT_BASE_BRANCH
    git_range = f"origin/{base}...HEAD"
    git_range_log = f"origin/{base}..HEAD"

    diff = _run(["git", "diff", git_range], cwd=job.wt_path)
    commit_log = _run(["git", "log", "--stat", "--reverse", git_range_log], cwd=job.wt_path)

    file_contents: dict[str, str] = {}
    file_permissions: dict[str, str] = {}
    total_size = 0
    for f in job.pr.files:
        p = wt / f["path"]
        content = _read_file_safe(p)
        file_contents[f["path"]] = content
        file_permissions[f["path"]] = _file_permissions(p)
        total_size += len(content.encode())
    if total_size > MAX_PREFLIGHT_BYTES:
        _warn(f"Preflight data too large ({total_size // 1024}KB) — agent will read files directly")
        return None

    claude_md = ""
    for name in ("CLAUDE.md", ".claude/CLAUDE.md"):
        p = wt / name
        if p.exists():
            claude_md = _read_file_safe(p)
            break

    context_md = ""
    ctx_path = wt / ".claude" / "context.md"
    if ctx_path.exists():
        context_md = _read_file_safe(ctx_path)

    review_checklists: dict[str, str] = {}
    review_dir = wt / ".claude" / "review"
    if review_dir.is_dir():
        for checklist in sorted(review_dir.glob("*.md")):
            review_checklists[checklist.name] = _read_file_safe(checklist)

    return PreflightData(
        diff=diff,
        commit_log=commit_log,
        file_contents=file_contents,
        file_permissions=file_permissions,
        claude_md=claude_md,
        context_md=context_md,
        review_checklists=review_checklists,
    )


def format_preflight_data(
    data: PreflightData,
    file_filter: list[str] | None = None,
) -> str:
    parts = [
        "## Pre-collected data",
        "",
        "Use this data directly. Do NOT re-read these files, re-run git diff, re-run git log,",
        "or re-fetch PR reviews via gh api. Only use Read/Bash for files NOT listed here",
        "(cross-references, callers, tests, config files outside the PR).",
    ]

    parts += ["", "### Full diff", "", "```diff", data.diff, "```"]

    if data.commit_log:
        parts += ["", "### Commit history", "", "```", data.commit_log, "```"]

    parts += ["", "### Changed file contents"]
    files_to_include = file_filter or list(data.file_contents.keys())
    for path in files_to_include:
        content = data.file_contents.get(path, "<file not collected>")
        perms = data.file_permissions.get(path, "?")
        parts.append(f"\n<file path=\"{path}\" permissions=\"{perms}\">")
        parts.append(content)
        parts.append("</file>")

    if data.claude_md:
        parts += ["", "### Project context", "", "#### CLAUDE.md", "", data.claude_md]
    if data.context_md:
        parts += ["", "#### .claude/context.md", "", data.context_md]
    if data.review_checklists:
        parts.append("\n#### Review checklists")
        for name, content in data.review_checklists.items():
            parts += [f"\n##### {name}", "", content]

    return "\n".join(parts)


# ── Tier classification ──────────────────────────────────────────────────────

def classify_tier(path: str) -> int:
    parts = path.split("/")
    basename = parts[-1]

    if any(seg in TIER3_PATH_SEGMENTS for seg in parts):
        return 3
    if basename in TIER3_BASENAMES or basename.endswith(TIER3_BASENAMES_SUFFIXES):
        return 3
    if basename in TIER1_BASENAMES:
        return 1
    if any(basename.endswith(ext) for ext in TIER1_EXTENSIONS):
        return 1
    if any(seg in TIER1_PATH_SEGMENTS for seg in parts):
        return 1
    return 2


# ── File grouping ─────────────────────────────────────────────────────────────

def _split_large_dir(name: str, files: list[str], file_lines: dict[str, int]) -> list[Group]:
    groups: list[Group] = []
    sub_files: list[str] = []
    sub_lines = 0
    sub_idx = 1
    for f in files:
        fl = file_lines[f]
        if sub_lines + fl > MAX_GROUP_LINES and sub_files:
            groups.append(Group(f"{name}-{sub_idx}", sub_files, sub_lines))
            sub_files = []
            sub_lines = 0
            sub_idx += 1
        sub_files.append(f)
        sub_lines += fl
    if sub_files:
        groups.append(Group(f"{name}-{sub_idx}", sub_files, sub_lines))
    return groups


def group_files(pr: PRMetadata) -> list[Group]:
    file_lines = {f["path"]: f["additions"] + f["deletions"] for f in pr.files}

    tiers: dict[int, list[str]] = {1: [], 2: [], 3: []}
    tier_lines: dict[int, int] = {1: 0, 2: 0, 3: 0}

    for path, lines in file_lines.items():
        t = classify_tier(path)
        tiers[t].append(path)
        tier_lines[t] += lines

    groups: list[Group] = []

    if tiers[1]:
        groups.append(Group(GROUP_TIER1, tiers[1], tier_lines[1]))

    dir_files: dict[str, list[str]] = {}
    dir_lines: dict[str, int] = {}
    dir_order: list[str] = []
    for f in tiers[2]:
        d = f.split("/")[0]
        if d not in dir_files:
            dir_files[d] = []
            dir_lines[d] = 0
            dir_order.append(d)
        dir_files[d].append(f)
        dir_lines[d] += file_lines[f]

    for d in dir_order:
        files = dir_files[d]
        total = dir_lines[d]
        if total > MAX_GROUP_LINES:
            groups.extend(_split_large_dir(d, files, file_lines))
        else:
            groups.append(Group(d, files, total))

    if tiers[3]:
        groups.append(Group(GROUP_TIER3, tiers[3], tier_lines[3]))

    return groups


# ── Review merging ────────────────────────────────────────────────────────────

def _extract_section(content: str, header: str) -> str:
    pattern = rf"^## {re.escape(header)}\s*\n"
    m = re.search(pattern, content, re.MULTILINE)
    if not m:
        return ""
    start = m.end()
    next_header = re.search(r"^## ", content[start:], re.MULTILINE)
    end = start + next_header.start() if next_header else len(content)
    return content[start:end].strip()


def renumber_section(prefix: str, text: str, offset: int) -> tuple[str, int]:
    if not text:
        return "", 0
    count = len(re.findall(rf"\[{prefix}\d+\]", text))
    if offset > 0:
        for i in range(count, 0, -1):
            text = text.replace(f"[{prefix}{i}]", f"[{prefix}{i + offset}]")
    return text, count


def renumber_findings(review_file: str) -> None:
    """Renumber finding IDs to be sequential in order of first appearance.

    After synthesis, the agent may reorganize findings by category, leaving
    gaps in the numbering (e.g., S1-S17 then S19, skipping S18). This
    function scans the file for all [M#], [S#], [N#] IDs and renumbers
    them so each prefix runs 1, 2, 3, ... in order of first appearance.
    Also updates unbracketed cross-references (e.g., "see S14" in verdicts).
    """
    path = Path(review_file)
    if not path.exists():
        return
    text = path.read_text()

    for _, prefix in FINDING_SECTIONS:
        seen_ids: list[int] = []
        for m in re.finditer(rf"\[{prefix}(\d+)\]", text):
            num = int(m.group(1))
            if num not in seen_ids:
                seen_ids.append(num)

        remap = {}
        for new_num, old_num in enumerate(seen_ids, 1):
            if old_num != new_num:
                remap[old_num] = new_num

        if not remap:
            continue

        placeholder = "\x00"
        # Bracketed IDs: [S19] → [S1]
        for old_num in sorted(remap, reverse=True):
            text = text.replace(f"[{prefix}{old_num}]", f"[{placeholder}{prefix}{remap[old_num]}]")
        text = text.replace(placeholder, "")

        # Unbracketed cross-references: "S19" in verdicts, summaries, nit refs
        # Use word boundary to avoid matching S1 inside S10
        for old_num in sorted(remap, reverse=True):
            text = re.sub(
                rf"(?<!\[)(?<!\x00){prefix}{old_num}(?!\d)(?!\])",
                f"\x00{prefix}{remap[old_num]}",
                text,
            )
        text = text.replace("\x00", "")

    path.write_text(text)


def merge_reviews(group_files: list[str]) -> str:
    merged_triage = ""
    merged: dict[str, str] = {section: "" for section, _ in FINDING_SECTIONS}
    offsets: dict[str, int] = {section: 0 for section, _ in FINDING_SECTIONS}

    for path in group_files:
        p = Path(path)
        if not p.exists():
            continue
        content = p.read_text()

        triage = _extract_section(content, SECTION_FILE_TRIAGE)
        if triage:
            merged_triage += triage + "\n"

        for section, prefix in FINDING_SECTIONS:
            raw = _extract_section(content, section)
            text, count = renumber_section(prefix, raw, offsets[section])
            if text:
                merged[section] += text + "\n"
            offsets[section] += count

    parts = [f"## {SECTION_FILE_TRIAGE}\n{merged_triage}"]
    for section, _ in FINDING_SECTIONS:
        if merged[section]:
            parts.append(f"## {section}\n{merged[section]}")

    return "\n".join(parts)


# ── PR data fetching ──────────────────────────────────────────────────────────

def _run(cmd: list[str], check: bool = True, cwd: str | None = None) -> str:
    r = subprocess.run(cmd, capture_output=True, text=True, cwd=cwd)
    if check and r.returncode != 0:
        return ""
    return r.stdout.strip()


def fetch_branch_metadata(wt_path: str) -> PRMetadata:
    head_sha = _run(["git", "rev-parse", "HEAD"], cwd=wt_path)
    branch = _run(["git", "rev-parse", "--abbrev-ref", "HEAD"], cwd=wt_path)

    log_output = _run(["git", "log", GIT_RANGE_TO_HEAD, "--oneline"], cwd=wt_path)
    first_subject = log_output.split("\n")[0].split(" ", 1)[-1] if log_output else branch
    title = first_subject

    numstat = _run(["git", "diff", "--numstat", GIT_RANGE_TO_HEAD], cwd=wt_path)
    files = []
    total_add = 0
    total_del = 0
    for line in numstat.strip().split("\n"):
        if not line:
            continue
        parts = line.split("\t")
        if len(parts) < 3:
            continue
        add = int(parts[0]) if parts[0] != "-" else 0
        delete = int(parts[1]) if parts[1] != "-" else 0
        files.append({"path": parts[2], "additions": add, "deletions": delete})
        total_add += add
        total_del += delete

    return PRMetadata(
        title=title,
        body="",
        head=branch,
        base=DEFAULT_BASE_BRANCH,
        head_sha=head_sha,
        additions=total_add,
        deletions=total_del,
        changed_files=len(files),
        files=files,
    )


def fetch_pr_metadata(repo: str, pr_number: str) -> PRMetadata:
    raw = _run([
        "gh", "pr", "view", pr_number, "--repo", repo,
        "--json", "title,body,headRefName,baseRefName,headRefOid,"
                  "additions,deletions,changedFiles,files",
    ])
    if not raw:
        print(f"error: failed to fetch PR #{pr_number} from {repo}", file=sys.stderr)
        sys.exit(1)
    data = json.loads(raw)
    return PRMetadata(
        title=data["title"],
        body=data.get("body") or "",
        head=data["headRefName"],
        base=data["baseRefName"],
        head_sha=data["headRefOid"],
        additions=data["additions"],
        deletions=data["deletions"],
        changed_files=data["changedFiles"],
        files=[
            {"path": f["path"], "additions": f["additions"], "deletions": f["deletions"]}
            for f in data["files"]
        ],
    )


def fetch_pr_context(repo: str, pr_number: str) -> PRContext:
    cmds = {
        "commits": [
            "gh", "pr", "view", pr_number, "--repo", repo,
            "--json", "commits",
            "--jq", '[.commits[] | .messageHeadline] | join("\\n")',
        ],
        "reviews": [
            "gh", "api", f"repos/{repo}/pulls/{pr_number}/reviews",
            "--jq", '[.[] | {user: .user.login, state, body}]',
        ],
        "review_comments": [
            "gh", "api", f"repos/{repo}/pulls/{pr_number}/comments",
            "--jq", '[.[] | {id, path, line, body, user: .user.login, in_reply_to_id}]',
        ],
        "comments": [
            "gh", "api", f"repos/{repo}/issues/{pr_number}/comments",
            "--jq", '[.[] | {user: .user.login, body}]',
        ],
    }
    results = {}
    with ThreadPoolExecutor(max_workers=4) as pool:
        futures = {pool.submit(_run, cmd, check=False): name for name, cmd in cmds.items()}
        for future in as_completed(futures):
            results[futures[future]] = future.result()
    return PRContext(
        commits=results["commits"],
        reviews=results["reviews"] or "[]",
        review_comments=results["review_comments"] or "[]",
        comments=results["comments"] or "[]",
    )


# ── Template rendering ────────────────────────────────────────────────────────

def _template_dir() -> Path:
    return Path(__file__).resolve().parent.parent / TEMPLATE_DIR_REL


def _build_pr_header(pr: PRMetadata, ctx: PRContext) -> str:
    lines = [
        "## PR metadata",
        f"- **Title:** {pr.title}",
        f"- **Branch:** {pr.head} → {pr.base}",
        f"- **Size:** +{pr.additions} -{pr.deletions} across {pr.changed_files} files",
        "",
        "### Description",
        pr.body or "_No description provided._",
        "",
        "### Commits",
        ctx.commits or "_No commits._",
    ]
    if pr.file_stats:
        lines += ["", "### File breakdown (sorted by churn)", pr.file_stats]
    return "\n".join(lines)


def _build_reviews_section(ctx: PRContext) -> str:
    return f"""
## Existing reviews and comments
Skip these — do NOT re-fetch from the GitHub API. This data is current as of script invocation.

### Submitted reviews
{ctx.reviews}

### Inline review comments
{ctx.review_comments}

### General PR comments
{ctx.comments}"""


def _build_env_section(wt_path: str, has_preflight: bool = False) -> str:
    if has_preflight:
        return f"""
## Environment
PR branch checked out at: {wt_path}
File contents and diffs are in the Pre-collected data section. Use Read/Bash only for files NOT in the PR (callers, tests, cross-references)."""
    return f"""
## Environment
PR branch checked out at: {wt_path}
Read source files directly from this path. Do NOT fetch files via the GitHub API."""


def _build_holistic_block(holistic_content: str, changed_files: int) -> str:
    if not holistic_content:
        return ""
    return (
        f"\n## Holistic context\n"
        f"The following assessment was produced by scanning all "
        f"{changed_files} files in this PR.\n"
        f"Use it to inform your detailed review — especially the flags section.\n\n"
        f"{holistic_content}"
    )


def _build_issue_section(issue_link: str, issue_context: str) -> str:
    if issue_link:
        return f"\n## Related issue\n{issue_link}"
    if issue_context:
        return f"\n## Related issue\n{issue_context}"
    return ""


def _build_prior_section(prior_review: str, context: str = "") -> str:
    if not prior_review:
        return ""
    default = "This is a re-review. For each prior finding, mark fixed findings as resolved and carry forward open ones."
    return f"""
## Prior review
{context or default}

<prior_review>
{prior_review}
</prior_review>"""


def render_template(name: str, **kwargs) -> str:
    path = _template_dir() / name
    tmpl = Template(path.read_text())
    return tmpl.safe_substitute(**kwargs)


def _build_preflight_section(
    job: "ReviewJob", file_filter: list[str] | None = None,
) -> str:
    if not job.preflight:
        return ""
    return format_preflight_data(job.preflight, file_filter=file_filter)


def build_prompt(template_name: str, job: ReviewJob, **extra) -> str:
    today = date.today().isoformat()
    has_preflight = job.preflight is not None
    pr_header = _build_pr_header(job.pr, job.ctx)
    reviews_section = _build_reviews_section(job.ctx)
    env_section = _build_env_section(job.wt_path, has_preflight=has_preflight)
    issue_section = _build_issue_section(job.issue_link, job.issue_context)

    if template_name == TEMPLATE_SELF_REVIEW:
        prior_ctx = (
            "This is a re-review of your own code. Below are the findings from the previous self-review. "
            "For each prior finding:\n"
            "- If the issue has been fixed, omit it from the new review\n"
            "- If the issue is still present, carry it forward\n"
            "- Add any new findings from changes since the last review"
        )
        prior_section = _build_prior_section(job.prior_review, prior_ctx)
        return render_template(
            TEMPLATE_SELF_REVIEW,
            branch_name=extra.get("branch_name", job.pr.head),
            repo=job.repo,
            pr_header=pr_header,
            preflight_data=_build_preflight_section(job),
            env_section=env_section,
            issue_section=issue_section,
            prior_section=prior_section,
            review_file=job.review_file,
        )

    if template_name == TEMPLATE_SELF_SYNTHESIS:
        prior_section = _build_prior_section(
            job.prior_review,
            "Omit prior findings that have been fixed. Carry forward open ones.",
        )
        return render_template(
            TEMPLATE_SELF_SYNTHESIS,
            branch_name=extra.get("branch_name", job.pr.head),
            repo=job.repo,
            pr_header=pr_header,
            pr_head_sha=job.pr.head_sha,
            holistic_content=extra.get("holistic_content") or "_No holistic assessment available._",
            group_count=extra["group_count"],
            merged_content=extra["merged_content"],
            preflight_data=_build_preflight_section(job),
            review_file=job.review_file,
            wt_path=job.wt_path,
            today=today,
            prior_section=prior_section,
        )

    if template_name == TEMPLATE_SINGLE:
        prior_ctx = (
            "This is a re-review. Below are the findings from the previous review. "
            "For each prior finding:\n"
            "- If the issue has been fixed, note it as resolved and omit from the new review\n"
            "- If the issue is still present, carry it forward\n"
            "- Add any new findings from changes since the last review"
        )
        prior_section = _build_prior_section(job.prior_review, prior_ctx)
        return render_template(
            TEMPLATE_SINGLE,
            pr_number=job.pr_number,
            repo=job.repo,
            pr_header=pr_header,
            preflight_data=_build_preflight_section(job),
            reviews_section=reviews_section,
            env_section=env_section,
            issue_section=issue_section,
            prior_section=prior_section,
            review_file=job.review_file,
        )

    if template_name == TEMPLATE_HOLISTIC:
        return render_template(
            TEMPLATE_HOLISTIC,
            pr_number=job.pr_number,
            repo=job.repo,
            pr_header=pr_header,
            all_files_formatted=job.pr.all_files_formatted,
            preflight_data=_build_preflight_section(job),
            reviews_section=reviews_section,
            issue_section=issue_section,
            env_section=env_section,
            holistic_output=extra["holistic_output"],
        )

    if template_name == TEMPLATE_GROUP:
        prior_section = _build_prior_section(
            job.prior_review,
            "This is a re-review. Below are the prior findings. "
            "Carry forward findings relevant to YOUR files only. "
            "Mark fixed findings as resolved.",
        )
        holistic_block = _build_holistic_block(
            extra.get("holistic_content", ""), job.pr.changed_files,
        )
        group_files = extra.get("group_file_paths", [])
        group_preflight = _build_preflight_section(job, file_filter=group_files or None)
        return render_template(
            TEMPLATE_GROUP,
            pr_number=job.pr_number,
            repo=job.repo,
            pr_header=pr_header,
            group_idx=extra["group_idx"],
            group_count=extra["group_count"],
            group_name=extra["group_name"],
            holistic_block=holistic_block,
            group_files_formatted=extra["group_files_formatted"],
            preflight_data=group_preflight,
            reviews_section=reviews_section,
            issue_section=issue_section,
            env_section=env_section,
            group_output=extra["group_output"],
            prior_section=prior_section,
        )

    if template_name == TEMPLATE_SYNTHESIS:
        prior_section = _build_prior_section(
            job.prior_review,
            "Include a ## Resolved section noting which prior findings were fixed.",
        )
        return render_template(
            TEMPLATE_SYNTHESIS,
            pr_number=job.pr_number,
            repo=job.repo,
            pr_header=pr_header,
            pr_title=job.pr.title,
            pr_head_sha=job.pr.head_sha,
            holistic_content=extra.get("holistic_content") or "_No holistic assessment available._",
            group_count=extra["group_count"],
            merged_content=extra["merged_content"],
            preflight_data=_build_preflight_section(job),
            reviews_section=reviews_section,
            review_file=job.review_file,
            wt_path=job.wt_path,
            today=today,
            prior_section=prior_section,
        )

    raise ValueError(f"Unknown template: {template_name}")


# ── Stream progress ───────────────────────────────────────────────────────────

def _tool_label_from_block(block: dict) -> str:
    if block.get("type") != "tool_use":
        return ""
    inp = block.get("input", {})
    name = block.get("name", "")
    if inp.get("description"):
        return inp["description"]
    if name == "Read":
        return "Read " + (inp.get("file_path", "").split("/")[-1] or "")
    if name == "Grep":
        return "Grep " + inp.get("pattern", "")
    if name == "Glob":
        return "Glob " + inp.get("pattern", "")
    if name == "Write":
        return "Write " + (inp.get("file_path", "").split("/")[-1] or "")
    return name


def stream_progress(process: subprocess.Popen, session_log: str, label: str = ""):
    prev_tool = ""
    prefix = f"  {ANSI_DIM}[{label}]{ANSI_RESET} " if label else ""
    with open(session_log, "w") as log:
        for raw_line in process.stdout:
            log.write(raw_line)
            log.flush()
            try:
                data = json.loads(raw_line)
            except (json.JSONDecodeError, ValueError):
                continue
            if data.get("type") != "assistant":
                continue
            for block in data.get("message", {}).get("content", []):
                tool_label = _tool_label_from_block(block)
                if not tool_label or tool_label == prev_tool:
                    continue
                with _print_lock:
                    print(f"{prefix}  {ANSI_DIM}▸ {tool_label}{ANSI_RESET}", flush=True)
                prev_tool = tool_label


# ── Agent invocation ──────────────────────────────────────────────────────────

def invoke_agent(prompt: str, session_log: str, wt_path: str, reviews_dir: str, label: str = ""):
    proc = subprocess.Popen(
        [
            "claude", "-p", "--verbose", "--output-format", "stream-json",
            "--permission-mode", "acceptEdits",
            "--add-dir", reviews_dir, "--add-dir", wt_path,
            "--agent", "reviewer",
        ],
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )
    proc.stdin.write(prompt)
    proc.stdin.close()
    stream_progress(proc, session_log, label=label)
    proc.wait()


# ── Review pipelines ──────────────────────────────────────────────────────────

_print_lock = threading.Lock()


def _info(msg: str):
    with _print_lock:
        print(f"{ANSI_INFO} {msg}", flush=True)


def _warn(msg: str):
    with _print_lock:
        print(f"{ANSI_WARN} {msg}", file=sys.stderr, flush=True)


def run_single_agent(job: ReviewJob):
    template = TEMPLATE_SELF_REVIEW if job.mode == MODE_SELF else TEMPLATE_SINGLE
    prompt = build_prompt(
        template, job, branch_name=job.pr.head,
    )
    label = f"branch {job.pr.head}" if job.mode == MODE_SELF else f"PR #{job.pr_number} ({job.pr.title})"
    _info(f"Running review agent on {label}...")
    print()
    invoke_agent(prompt, job.session_log, job.wt_path, job.reviews_dir)
    print()

    if not Path(job.review_file).exists():
        print(f"error: review file not found: {job.review_file}", file=sys.stderr)
        print(f"  Session log: {job.session_log}", file=sys.stderr)
        sys.exit(1)

    renumber_findings(job.review_file)


def _review_group(
    i: int, grp: Group, job: ReviewJob,
    group_count: int, holistic_content: str,
) -> tuple[int, str, str | None]:
    group_files_formatted = "\n".join(
        FILE_STAT_FMT.format(**f)
        for f in job.pr.files if f["path"] in grp.files
    )
    group_output = job.review_file.replace(REVIEW_EXT, SUFFIX_GROUP.format(i))
    group_log = job.review_file.replace(REVIEW_EXT, SUFFIX_GROUP_LOG.format(i))

    group_prompt = build_prompt(
        TEMPLATE_GROUP, job,
        group_idx=i, group_count=group_count, group_name=grp.name,
        group_files_formatted=group_files_formatted,
        group_file_paths=grp.files,
        group_output=group_output, holistic_content=holistic_content,
    )
    _info(f"Phase 2: Group {i}/{group_count} — {grp.name} ({grp.lines} lines)...")
    invoke_agent(group_prompt, group_log, job.wt_path, job.reviews_dir, label=grp.name)

    failed = None
    if not Path(group_output).exists():
        _warn(f"Group {i} ({grp.name}) produced no output")
        failed = grp.name
    else:
        _info(f"Phase 2: Group {i}/{group_count} — {grp.name} done")

    return (i, group_output, failed)


def _phase_holistic(job: ReviewJob, group_count: int) -> tuple[str, str, str]:
    holistic_output = job.review_file.replace(REVIEW_EXT, SUFFIX_HOLISTIC)
    holistic_log = job.review_file.replace(REVIEW_EXT, SUFFIX_HOLISTIC_LOG)

    prompt = build_prompt(
        TEMPLATE_HOLISTIC, job, holistic_output=holistic_output,
    )
    _info(f"Phase 1/{group_count}: Holistic scan...")
    print()
    invoke_agent(prompt, holistic_log, job.wt_path, job.reviews_dir)
    print()

    holistic_content = ""
    if Path(holistic_output).exists():
        holistic_content = Path(holistic_output).read_text()
    else:
        _warn("Holistic scan produced no output — continuing without it")

    return holistic_content, holistic_output, holistic_log


def _phase_group_reviews(
    groups: list[Group], job: ReviewJob,
    group_count: int, holistic_content: str, max_parallel: int,
) -> tuple[list[str], list[str]]:
    group_outputs = [job.review_file.replace(REVIEW_EXT, SUFFIX_GROUP.format(i)) for i in range(1, group_count + 1)]
    failed_groups: list[str] = []

    workers = min(max_parallel, group_count)
    if workers <= 1:
        for i, grp in enumerate(groups, 1):
            _, _, failed = _review_group(i, grp, job, group_count, holistic_content)
            if failed:
                failed_groups.append(failed)
    else:
        _info(f"Phase 2: Reviewing {group_count} groups ({workers} parallel)...")
        print()
        with ThreadPoolExecutor(max_workers=workers) as pool:
            futures = {
                pool.submit(_review_group, i, grp, job, group_count, holistic_content): i
                for i, grp in enumerate(groups, 1)
            }
            for future in as_completed(futures):
                _, _, failed = future.result()
                if failed:
                    failed_groups.append(failed)
        print()

    return group_outputs, failed_groups


def _phase_merge(group_outputs: list[str], failed_groups: list[str]) -> str:
    _info("Phase 3: Merging findings...")
    merged_content = merge_reviews(group_outputs)

    if failed_groups:
        merged_content += "\n## Review gaps\n"
        merged_content += "The following file groups were not reviewed due to agent failure:\n"
        for fg in failed_groups:
            merged_content += f"- {fg}\n"

    return merged_content


def _phase_synthesis(
    job: ReviewJob, holistic_content: str,
    group_count: int, merged_content: str,
) -> str:
    synthesis_log = job.review_file.replace(REVIEW_EXT, SUFFIX_SYNTHESIS_LOG)
    synthesis_template = TEMPLATE_SELF_SYNTHESIS if job.mode == MODE_SELF else TEMPLATE_SYNTHESIS

    prompt = build_prompt(
        synthesis_template, job,
        holistic_content=holistic_content, group_count=group_count,
        merged_content=merged_content, branch_name=job.pr.head,
    )
    _info("Phase 4: Synthesis...")
    print()
    invoke_agent(prompt, synthesis_log, job.wt_path, job.reviews_dir)
    print()

    if not Path(job.review_file).exists():
        _warn("Synthesis agent failed — falling back to mechanical merge")
        today = date.today().isoformat()
        meta = f"{META_DATE.format(today=today)}\n{META_HEAD_SHA.format(head_sha=job.pr.head_sha)}\n"
        if job.mode == MODE_SELF:
            fallback = (
                f"# Self-Review: {job.repo} — {job.pr.head}\n"
                f"{meta}\n"
                f"## Summary\n"
                f"Multi-phase self-review of {job.pr.changed_files} files across {group_count} groups. "
                f"{FALLBACK_SUMMARY}\n\n"
                f"{merged_content}\n"
            )
        else:
            fallback = (
                f"# Review: {job.repo}#{job.pr_number} — {job.pr.title}\n"
                f"{meta}\n"
                f"## Summary\n"
                f"Multi-phase review of {job.pr.changed_files} files across {group_count} groups. "
                f"{FALLBACK_SUMMARY}\n\n"
                f"{merged_content}\n\n"
                f"## Verdict\n"
                f"Manual review of findings required — synthesis was not completed.\n"
            )
        Path(job.review_file).write_text(fallback)

    renumber_findings(job.review_file)

    return synthesis_log


def _consolidate_and_cleanup(
    job: ReviewJob,
    holistic_output: str, holistic_log: str,
    group_outputs: list[str], synthesis_log: str,
):
    group_logs = [job.review_file.replace(REVIEW_EXT, SUFFIX_GROUP_LOG.format(i)) for i in range(1, len(group_outputs) + 1)]
    try:
        with open(job.session_log, "w") as out:
            for log_path in [holistic_log] + group_logs + [synthesis_log]:
                p = Path(log_path)
                if p.exists():
                    out.write(p.read_text())
    except OSError:
        pass

    for path in [holistic_output, holistic_log] + group_outputs + group_logs + [synthesis_log]:
        try:
            Path(path).unlink()
        except FileNotFoundError:
            pass


def run_multi_phase(job: ReviewJob, max_parallel: int = DEFAULT_MAX_PARALLEL):
    groups = group_files(job.pr)
    group_count = len(groups)

    _info(f"Large PR ({job.pr.total_lines} lines, {job.pr.changed_files} files) — {group_count} file groups")

    holistic_content, holistic_output, holistic_log = _phase_holistic(job, group_count)

    group_outputs, failed_groups = _phase_group_reviews(
        groups, job, group_count, holistic_content, max_parallel,
    )

    merged_content = _phase_merge(group_outputs, failed_groups)

    synthesis_log = _phase_synthesis(job, holistic_content, group_count, merged_content)

    _consolidate_and_cleanup(job, holistic_output, holistic_log, group_outputs, synthesis_log)


# ── Main ──────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(description="Review orchestration for claude-review")
    parser.add_argument("--repo", required=True, help="GitHub owner/repo")
    parser.add_argument("--pr", default="", help="PR number (optional in self mode)")
    parser.add_argument("--review-file", required=True, help="Output review file path")
    parser.add_argument("--wt-path", required=True, help="Worktree path")
    parser.add_argument("--reviews-dir", required=True, help="Reviews directory")
    parser.add_argument("--session-log", help="Session log path")
    parser.add_argument("--prior-review", help="Path to prior review file for iterative context")
    parser.add_argument("--issue-link", default="", help="Issue URL")
    parser.add_argument("--issue-context", default="", help="Issue context JSON")
    parser.add_argument("--max-parallel", type=int, default=DEFAULT_MAX_PARALLEL,
                        help=f"Max concurrent group reviews (default: {DEFAULT_MAX_PARALLEL})")
    parser.add_argument("--mode", choices=[MODE_PR, MODE_SELF], default=MODE_PR,
                        help="Review mode: pr (default) or self")
    args = parser.parse_args()

    if args.mode == MODE_PR and not args.pr:
        print("error: --pr is required in pr mode", file=sys.stderr)
        sys.exit(1)

    session_log = args.session_log or args.review_file.replace(REVIEW_EXT, SUFFIX_SESSION)

    if args.mode == MODE_SELF and not args.pr:
        _info("Gathering branch metadata...")
        pr = fetch_branch_metadata(args.wt_path)
        ctx = PRContext()
    else:
        _info("Fetching PR data...")
        with ThreadPoolExecutor(max_workers=2) as pool:
            pr_future = pool.submit(fetch_pr_metadata, args.repo, args.pr)
            if args.mode == MODE_SELF:
                ctx = PRContext()
                pr = pr_future.result()
            else:
                ctx_future = pool.submit(fetch_pr_context, args.repo, args.pr)
                pr = pr_future.result()
                ctx = ctx_future.result()

    prior_review = ""
    if args.prior_review and Path(args.prior_review).exists():
        prior_review = Path(args.prior_review).read_text()

    job = ReviewJob(
        repo=args.repo, pr_number=args.pr, pr=pr, ctx=ctx,
        wt_path=args.wt_path, review_file=args.review_file,
        session_log=session_log, reviews_dir=args.reviews_dir,
        issue_link=args.issue_link, issue_context=args.issue_context,
        prior_review=prior_review, mode=args.mode,
    )

    _info("Collecting file data...")
    job.preflight = collect_preflight_data(job)

    is_large = (
        pr.total_lines > MULTI_PHASE_LINE_THRESHOLD
        or pr.changed_files > MULTI_PHASE_FILE_THRESHOLD
    )
    pipeline = PIPELINE_MULTI if is_large else PIPELINE_SINGLE

    if is_large:
        run_multi_phase(job, max_parallel=args.max_parallel)
    else:
        run_single_agent(job)

    result = {
        "review_file": job.review_file,
        "session_log": job.session_log,
        "mode": pipeline,
    }
    json.dump(result, sys.stdout)
    print()


if __name__ == "__main__":
    main()
