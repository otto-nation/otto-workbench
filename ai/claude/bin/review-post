#!/usr/bin/env python3
"""Post a review file to GitHub as a PENDING PR review.

Parses a markdown review file (produced by claude-review), validates
finding positions against the PR diff, renumbers findings by posted
location (inline first, then body), and creates a PENDING review via
the GitHub API.

Usage:
  review-post --repo OWNER/REPO --pr NUMBER --review-file PATH
              [--severity M,S,N] [--dry-run]
"""

from __future__ import annotations

import argparse
import functools
import json
import re
import subprocess
import sys
import tempfile
import time
from dataclasses import dataclass
from pathlib import Path


# ── Constants ────────────────────────────────────────────────────────────────

SEVERITY_MUST = "M"
SEVERITY_SHOULD = "S"
SEVERITY_NIT = "N"

SEVERITY_LABELS = {
    SEVERITY_MUST: "must-fix",
    SEVERITY_SHOULD: "should-fix",
    SEVERITY_NIT: "nit",
}

SECTION_HEADERS = {
    "## Must fix": SEVERITY_MUST,
    "## Should fix": SEVERITY_SHOULD,
    "## Nit": SEVERITY_NIT,
}

CLASS_INLINE = "inline"
CLASS_FILE_LEVEL = "file_level"
CLASS_SKIPPED = "skipped"

DIFF_SIDE_RIGHT = "RIGHT"
REVIEW_STATE_PENDING = "PENDING"

MAX_RETRIES = 3
RETRY_BACKOFF_BASE = 5
RETRY_DELAY = 2

HEAD_SHA_RE = re.compile(r"<!-- head_sha: ([a-f0-9]+) -->")

ANSI_INFO = "\033[1;34m●\033[0m"
ANSI_WARN = "\033[1;33m●\033[0m"
ANSI_ERR = "\033[1;31m●\033[0m"


# ── Data structures ──────────────────────────────────────────────────────────


@dataclass
class Finding:
    id: str
    severity: str
    seq: int
    path: str
    line: int | None
    end_line: int | None
    body: str
    full_path: str = ""
    posted_id: str = ""
    classification: str = ""
    skip_reason: str = ""


# ── Parsing ──────────────────────────────────────────────────────────────────

# Two-stage parsing:
# 1. Match the finding ID: - **[S1]**
# 2. Extract the path section (everything between the ID and the em-dash)
FINDING_ID_RE = re.compile(
    r"^- (?:\[ \] )?"           # list item, optional checkbox
    r"(?:~~)?"                   # optional strikethrough start
    r"\*\*\[([MSNI])(\d+)\]\*\*" # [S1] or [I1] in bold
    r"\s+"
)

# Extracts path section from after the finding ID.
# Handles: **path:line**, `path:line`, **`path:line`**
PATH_SECTION_RE = re.compile(
    r"\*\*`(.+?)`\*\*"   # **`path`** (bold + backtick)
    r"|"
    r"\*\*(.+?)\*\*"     # **path** (bold only)
    r"|"
    r"`(.+?)`"           # `path` (backtick only)
)
FIRST_FILE_RE = re.compile(
    r"([a-zA-Z0-9_/.:-]+\.\w+)"   # filename with extension
    r"(?::(\d+)(?:[-–](\d+))?)?"   # optional :line or :start-end
)

STRIKETHROUGH_RE = re.compile(r"^- ~~\*\*\[")


def _extract_path(after_id: str) -> tuple[str, int | None, int | None]:
    """Extract (path, line, end_line) from the text after a finding ID."""
    section_match = PATH_SECTION_RE.match(after_id)
    if not section_match:
        return "", None, None

    section_text = section_match.group(1) or section_match.group(2) or section_match.group(3) or ""
    file_match = FIRST_FILE_RE.match(section_text)
    if not file_match:
        return "", None, None

    path = file_match.group(1).strip()
    line_num = int(file_match.group(2)) if file_match.group(2) else None
    end_line = int(file_match.group(3)) if file_match.group(3) else None
    return path, line_num, end_line


def _extract_body_text(line: str) -> str:
    """Extract finding body from the text after the em-dash separator."""
    em_dash_pos = line.find("—")
    if em_dash_pos != -1:
        return line[em_dash_pos + 1:].strip()

    for sep in (" -- ", " - "):
        pos = line.find(sep)
        if pos != -1:
            return line[pos + len(sep):].strip()

    return ""


def _parse_finding_line(stripped: str) -> Finding | None:
    """Parse a single markdown line into a Finding, or None if it isn't one."""
    id_match = FINDING_ID_RE.match(stripped)
    if not id_match:
        return None

    sev = id_match.group(1)
    seq = int(id_match.group(2))
    path, line_num, end_line = _extract_path(stripped[id_match.end():])
    body = _extract_body_text(stripped)

    return Finding(
        id=f"{sev}{seq}", severity=sev, seq=seq,
        path=path, line=line_num, end_line=end_line, body=body,
    )


def _finalize_finding(finding: Finding, body_lines: list[str]):
    """Set a finding's body from accumulated continuation lines."""
    body = "\n".join(body_lines).strip()
    body = re.sub(r"\n+###[^\n]*$", "", body, flags=re.DOTALL).strip()
    finding.body = body


def parse_findings(text: str) -> list[Finding]:
    """Extract findings from review markdown."""
    findings: list[Finding] = []
    current_severity: str | None = None
    body_lines: list[str] = []

    for raw_line in text.split("\n"):
        stripped = raw_line.strip()

        if stripped in SECTION_HEADERS:
            if findings:
                _finalize_finding(findings[-1], body_lines)
                body_lines = []
            current_severity = SECTION_HEADERS[stripped]
            continue

        if stripped.startswith("## "):
            if findings:
                _finalize_finding(findings[-1], body_lines)
                body_lines = []
            current_severity = None
            continue

        if current_severity is None:
            continue

        if stripped.startswith("### ") or STRIKETHROUGH_RE.match(stripped):
            if findings:
                _finalize_finding(findings[-1], body_lines)
                body_lines = []
            continue

        finding = _parse_finding_line(stripped)
        if finding:
            if findings:
                _finalize_finding(findings[-1], body_lines)
            body_lines = [finding.body] if finding.body else []
            findings.append(finding)
            continue

        if findings and stripped:
            body_lines.append(stripped)

    if findings:
        _finalize_finding(findings[-1], body_lines)

    return findings


# ── Diff parsing and classification ──────────────────────────────────────────

def parse_diff_hunks(diff_text: str) -> dict[str, list[tuple[int, int]]]:
    """Parse unified diff into {path: [(start, end), ...]} for the new side."""
    hunks: dict[str, list[tuple[int, int]]] = {}
    current_file: str | None = None
    file_re = re.compile(r"^\+\+\+ b/(.+)")
    hunk_re = re.compile(r"^@@ -\d+(?:,\d+)? \+(\d+)(?:,(\d+))? @@")

    for line in diff_text.splitlines():
        m = file_re.match(line)
        if m:
            current_file = m.group(1)
            hunks.setdefault(current_file, [])
            continue
        m = hunk_re.match(line)
        if m and current_file is not None:
            start = int(m.group(1))
            length = int(m.group(2)) if m.group(2) is not None else 1
            hunks[current_file].append((start, start + length - 1))

    return hunks


def _resolve_path(path: str, hunks: dict[str, list]) -> str | None:
    """Resolve a possibly-bare filename to a full diff path."""
    if path in hunks:
        return path

    # Try basename matching
    basename = path.rsplit("/", 1)[-1] if "/" in path else path
    matches = [p for p in hunks if p.endswith("/" + basename) or p == basename]
    if len(matches) == 1:
        return matches[0]

    # Try partial path matching (e.g., "service/file.go" matching "pkg/service/file.go")
    if "/" in path:
        matches = [p for p in hunks if p.endswith("/" + path)]
        if len(matches) == 1:
            return matches[0]

    return None


def classify_findings(
    findings: list[Finding], diff_text: str
) -> tuple[list[Finding], list[Finding], list[Finding]]:
    """Classify findings as inline, file_level, or skipped."""
    hunks = parse_diff_hunks(diff_text)
    inline, file_level, skipped = [], [], []

    for f in findings:
        resolved = _resolve_path(f.path, hunks)

        if resolved is None:
            f.classification = CLASS_SKIPPED
            f.skip_reason = "path not in diff"
            skipped.append(f)
        elif f.line is None:
            f.classification = CLASS_FILE_LEVEL
            f.full_path = resolved
            f.skip_reason = "no line number"
            file_level.append(f)
        elif not any(s <= f.line <= e for s, e in hunks[resolved]):
            f.classification = CLASS_FILE_LEVEL
            f.full_path = resolved
            f.skip_reason = f"line {f.line} not in any diff hunk"
            file_level.append(f)
        else:
            f.classification = CLASS_INLINE
            f.full_path = resolved
            inline.append(f)

    return inline, file_level, skipped


# ── Renumbering ──────────────────────────────────────────────────────────────

def renumber_for_posting(
    inline: list[Finding], body: list[Finding]
) -> tuple[list[Finding], list[Finding]]:
    """Renumber findings sequentially by posted location.

    Inline findings sorted by (path, line) get IDs first,
    body findings continue the sequence. Each severity prefix
    is numbered independently.
    """
    inline_sorted = sorted(inline, key=lambda f: (f.full_path or f.path, f.line or 0))

    counters = {SEVERITY_MUST: 1, SEVERITY_SHOULD: 1, SEVERITY_NIT: 1}
    for f in inline_sorted:
        f.posted_id = f"{f.severity}{counters[f.severity]}"
        counters[f.severity] += 1
    for f in body:
        f.posted_id = f"{f.severity}{counters[f.severity]}"
        counters[f.severity] += 1

    return inline_sorted, body


# ── Formatting ───────────────────────────────────────────────────────────────

def format_inline_comment(f: Finding) -> dict:
    """Format a finding as a GitHub inline review comment."""
    label = f"**[{f.posted_id}] [{SEVERITY_LABELS[f.severity]}]**"
    body = f"{label} {f.body}"

    comment: dict = {
        "path": f.full_path,
        "side": DIFF_SIDE_RIGHT,
        "body": body,
    }

    if f.end_line is not None and f.line is not None and f.end_line > f.line:
        comment["start_line"] = f.line
        comment["line"] = f.end_line
        comment["start_side"] = DIFF_SIDE_RIGHT
    elif f.line is not None:
        comment["line"] = f.line

    return comment


def _format_path_ref(f: Finding) -> str:
    """Format a finding's path as a backtick-wrapped reference."""
    ref = f.path
    if f.line is not None:
        ref += f":{f.line}"
        if f.end_line is not None:
            ref += f"-{f.end_line}"
    return f"`{ref}`"


def format_body_text(
    body_findings: list[Finding],
    has_inline: bool,
    severity_filter: set[str],
) -> str:
    """Format the review body text with body/skipped findings."""
    labels = [SEVERITY_LABELS[s] for s in (SEVERITY_MUST, SEVERITY_SHOULD, SEVERITY_NIT) if s in severity_filter]

    if has_inline:
        parts = [f"Have some comments marked as {', '.join(labels)}."]
    else:
        parts = [f"Review findings ({', '.join(labels)}):"]

    if not body_findings:
        return "\n".join(parts)

    parts.append("")
    if has_inline:
        parts.append("**Findings not in the diff (file-level):**")
    parts.append("")

    for f in body_findings:
        label = f"**[{f.posted_id}] [{SEVERITY_LABELS[f.severity]}]**"
        parts.append(f"- {label} {_format_path_ref(f)} — {f.body}")

    return "\n".join(parts)


# ── Permalink resolution ─────────────────────────────────────────────────────

_PERMALINK_REF_RE = re.compile(
    r"(?:see |at )"
    r"`?([a-zA-Z0-9_/.:-]+\.(?:go|ts|py|sql|yaml|yml|json|md))"
    r":(\d+)(?:[-–](\d+))?`?"
)


def _build_permalink(repo: str, sha: str, m: re.Match) -> str:
    """Build a GitHub permalink from a source reference match."""
    path, start, end = m.group(1), m.group(2), m.group(3)
    url = f"https://github.com/{repo}/blob/{sha}/{path}#L{start}"
    if end:
        url += f"-L{end}"
    display = f"`{path}:{start}{f'-{end}' if end else ''}`"
    return f"[{display}]({url})"


def resolve_permalinks(findings: list[Finding], repo: str) -> list[Finding]:
    """Convert source references to GitHub permalink URLs."""
    try:
        result = subprocess.run(
            ["git", "rev-parse", "origin/main"],
            capture_output=True, text=True, timeout=5,
        )
        if result.returncode != 0:
            return findings
        main_sha = result.stdout.strip()
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return findings

    replacer = functools.partial(_build_permalink, repo, main_sha)
    for f in findings:
        f.body = _PERMALINK_REF_RE.sub(replacer, f.body)

    return findings


# ── GitHub API ───────────────────────────────────────────────────────────────

def _gh_api(endpoint: str, method: str = "GET", input_file: str | None = None) -> tuple[int, str]:
    """Call gh api and return (exit_code, stdout)."""
    cmd = ["gh", "api", endpoint]
    if method != "GET":
        cmd.extend(["--method", method])
    if input_file:
        cmd.extend(["--input", input_file])

    result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
    return result.returncode, result.stdout


def _get_head_sha(repo: str, pr: str) -> str:
    """Get the HEAD SHA of a PR."""
    result = subprocess.run(
        ["gh", "pr", "view", pr, "--repo", repo, "--json", "headRefOid", "--jq", ".headRefOid"],
        capture_output=True, text=True, timeout=15,
    )
    if result.returncode != 0:
        _err(f"Failed to get PR HEAD: {result.stderr.strip()}")
        sys.exit(1)
    return result.stdout.strip()


def _get_diff(repo: str, pr: str) -> str:
    """Get the PR diff."""
    result = subprocess.run(
        ["gh", "api", f"repos/{repo}/pulls/{pr}",
         "--header", "Accept: application/vnd.github.v3.diff"],
        capture_output=True, text=True, timeout=30,
    )
    if result.returncode != 0:
        _err(f"Failed to get diff: {result.stderr.strip()}")
        sys.exit(1)
    return result.stdout


def _check_existing_pending(repo: str, pr: str) -> int | None:
    """Check for existing PENDING review and return its ID."""
    try:
        result = subprocess.run(
            ["gh", "api", f"repos/{repo}/pulls/{pr}/reviews",
             "--jq", f'[.[] | select(.state == "{REVIEW_STATE_PENDING}")] | first | .id'],
            capture_output=True, text=True, timeout=15,
        )
        if result.returncode == 0 and result.stdout.strip() not in ("", "null"):
            return int(result.stdout.strip())
    except (ValueError, subprocess.TimeoutExpired):
        pass
    return None


def post_review(repo: str, pr: str, payload: dict) -> dict | None:
    """Post a PENDING review to GitHub."""
    # Check for existing PENDING review
    existing_id = _check_existing_pending(repo, pr)
    if existing_id:
        _warn(f"Deleting existing PENDING review #{existing_id}")
        _gh_api(f"repos/{repo}/pulls/{pr}/reviews/{existing_id}", method="DELETE")

    with tempfile.NamedTemporaryFile(
        mode="w", suffix=".json", prefix="review-post-", delete=False
    ) as tmp:
        json.dump(payload, tmp, ensure_ascii=False)
        tmp_path = tmp.name

    try:
        for attempt in range(MAX_RETRIES):
            rc, stdout = _gh_api(
                f"repos/{repo}/pulls/{pr}/reviews",
                method="POST",
                input_file=tmp_path,
            )
            if rc == 0:
                return json.loads(stdout)

            if "secondary rate limit" in stdout.lower() or '"message": "forbidden"' in stdout.lower():
                wait = 2 ** attempt * RETRY_BACKOFF_BASE
                _warn(f"Rate limited, waiting {wait}s...")
                time.sleep(wait)
                continue

            _err(f"GitHub API error (attempt {attempt + 1}/{MAX_RETRIES}): {stdout[:200]}")
            if attempt < MAX_RETRIES - 1:
                time.sleep(RETRY_DELAY)

        _err(f"Failed to post review after {MAX_RETRIES} attempts")
        sys.exit(1)
    finally:
        Path(tmp_path).unlink(missing_ok=True)


# ── Output helpers ───────────────────────────────────────────────────────────

def _info(msg: str):
    print(f"{ANSI_INFO} {msg}", flush=True)


def _warn(msg: str):
    print(f"{ANSI_WARN} {msg}", file=sys.stderr, flush=True)


def _err(msg: str):
    print(f"{ANSI_ERR} {msg}", file=sys.stderr, flush=True)


# ── Post tracking ───────────────────────────────────────────────────────────

def write_post_tracking(
    review_file: str, review_id: int, commit_id: str,
    inline_count: int, body_count: int, skipped_count: int,
):
    """Write a post tracking entry alongside the review file."""
    base = review_file.removesuffix(".md") if review_file.endswith(".md") else review_file
    post_file = base + ".post.jsonl"
    entry = {
        "review_id": review_id,
        "commit_id": commit_id,
        "posted_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "inline_count": inline_count,
        "body_count": body_count,
        "skipped_count": skipped_count,
    }
    with open(post_file, "w") as f:
        json.dump(entry, f)
        f.write("\n")


# ── Main ─────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(description="Post a review file to GitHub")
    parser.add_argument("--repo", required=True, help="GitHub owner/repo")
    parser.add_argument("--pr", required=True, help="PR number")
    parser.add_argument("--review-file", required=True, help="Path to review markdown file")
    parser.add_argument("--severity", default="M,S,N",
                        help="Severity levels to post (comma-separated, default: M,S,N)")
    parser.add_argument("--dry-run", action="store_true",
                        help="Parse and classify without posting")
    args = parser.parse_args()

    review_path = Path(args.review_file)
    if not review_path.exists():
        _err(f"Review file not found: {review_path}")
        sys.exit(1)

    severity_filter = set(args.severity.upper().split(","))
    text = review_path.read_text()

    # Parse head_sha from review metadata
    sha_match = HEAD_SHA_RE.search(text)
    review_sha = sha_match.group(1) if sha_match else None

    # 1. Parse findings
    all_findings = parse_findings(text)
    _info(f"Parsed {len(all_findings)} findings from review file")

    # 2. Filter by severity
    findings = [f for f in all_findings if f.severity in severity_filter]
    filtered = len(all_findings) - len(findings)
    if filtered:
        _info(f"Filtered to {len(findings)} findings (excluded {filtered} by severity)")

    if not findings:
        _warn("No findings to post")
        sys.exit(0)

    # 3. Get PR state
    head_sha = _get_head_sha(args.repo, args.pr) if not args.dry_run else (review_sha or "dry-run")
    if review_sha and not args.dry_run and review_sha != head_sha:
        _warn(f"Review was written against {review_sha[:7]}, PR HEAD is now {head_sha[:7]}")

    # 4. Get diff and classify
    if args.dry_run:
        _info("Fetching diff for classification...")
    diff_text = _get_diff(args.repo, args.pr)
    inline, file_level, skipped = classify_findings(findings, diff_text)
    _info(f"Classified: {len(inline)} inline, {len(file_level)} file-level, {len(skipped)} skipped")

    # 5. Combine body findings (file-level + skipped)
    body_findings = file_level + skipped

    # 6. Resolve permalinks
    findings_for_links = inline + body_findings
    resolve_permalinks(findings_for_links, args.repo)

    # 7. Renumber by posted location
    inline, body_findings = renumber_for_posting(inline, body_findings)

    # 8. Format
    inline_comments = [format_inline_comment(f) for f in inline]
    body_text = format_body_text(body_findings, len(inline) > 0, severity_filter)

    # 9. Build payload
    commit_id = review_sha or head_sha
    payload = {
        "commit_id": commit_id,
        "body": body_text,
    }
    if inline_comments:
        payload["comments"] = inline_comments

    # 10. Dry-run output or post
    if args.dry_run:
        print()
        print(json.dumps(payload, indent=2, ensure_ascii=False))
        print()
        _info(f"Inline: {', '.join(f.posted_id for f in inline) or 'none'}")
        _info(f"Body: {', '.join(f.posted_id for f in body_findings) or 'none'}")
        if skipped:
            for f in skipped:
                _warn(f"Skipped {f.id}: {f.skip_reason} ({f.path})")
        return

    # Post
    _info(f"Posting review ({len(inline_comments)} inline, {len(body_findings)} body)...")
    result = post_review(args.repo, args.pr, payload)

    if result:
        review_id = result.get("id", 0)
        _info(f"Review created: #{review_id} ({REVIEW_STATE_PENDING})")
        write_post_tracking(
            args.review_file, review_id, commit_id,
            len(inline_comments), len(body_findings), len(skipped),
        )


if __name__ == "__main__":
    main()
