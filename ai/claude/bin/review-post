#!/usr/bin/env python3
"""Post a review file to GitHub as a PR review.

Parses a markdown review file (produced by claude-review), validates
finding positions against the PR diff, renumbers findings by posted
location (inline first, then body), and creates a PENDING review via
the GitHub API. Pass --submit to submit the review immediately.

Usage:
  review-post --repo OWNER/REPO --pr NUMBER --review-file PATH
              [--severity M,S,N] [--dry-run]
"""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

import review_common as _rc  # noqa: E402
import review_dedup as _rd  # noqa: E402
import review_findings as _rfi  # noqa: E402
import review_format as _rfmt  # noqa: E402
import review_github as _rg  # noqa: E402
import review_posting as _rp  # noqa: E402

from review_common import *  # noqa: E402,F403
from review_dedup import *  # noqa: E402,F403
from review_findings import *  # noqa: E402,F403
from review_format import *  # noqa: E402,F403
from review_github import *  # noqa: E402,F403
from review_posting import *  # noqa: E402,F403

from review_common import SEVERITY_LABELS, _err, _info, _warn  # noqa: E402
from review_dedup import dedup_against_posted  # noqa: E402
from review_findings import (  # noqa: E402
    Finding, parse_findings,
    _close_previous, _extract_body_text, _extract_path,
    _finalize_finding, _is_section_boundary, _match_severity_header,
    _parse_finding_line, parse_diff_hunks,
)
from review_format import (  # noqa: E402
    CLASS_FILE_LEVEL, CLASS_INLINE,
    classify_findings, format_body_text, format_inline_comment,
    renumber_for_posting, resolve_permalinks,
    _format_path_ref, _format_finding_line, _resolve_path, _hunk_end,
    _build_permalink,
)
from review_github import (  # noqa: E402
    _fetch_pr_metadata, _get_diff,
    _gh_api, _check_existing_pending, _fetch_json_list,
    _is_rate_limited, _is_line_resolution_error,
    _handle_api_attempt, _post_with_retries, _count_new_commits,
    LineResolutionError,
)
from review_dedup import (  # noqa: E402
    _word_set, _jaccard, _extract_body_findings, _fetch_bot_comments,
)
from review_posting import (  # noqa: E402
    DEFAULT_CHUNK_SIZE, HEAD_SHA_RE,
    _post_and_track, _post_as_comment, _print_dry_run,
    _chunk_comments, _post_chunked_review, post_review,
    _submit_review, write_post_tracking, _format_submit_command,
    _reclassify_and_retry,
)

_SUBMODULES = (_rc, _rd, _rfi, _rfmt, _rg, _rp)


class _ProxyModule(type(sys.modules[__name__])):
    def __getattr__(self, name):
        for mod in _SUBMODULES:
            try:
                return getattr(mod, name)
            except AttributeError:
                continue
        raise AttributeError(f"module 'review_post' has no attribute {name!r}")

    def __setattr__(self, name, value):
        for mod in _SUBMODULES:
            if hasattr(mod, name):
                setattr(mod, name, value)
                super().__setattr__(name, value)
                return
        super().__setattr__(name, value)


sys.modules[__name__].__class__ = _ProxyModule


# ── Main ─────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(description="Post a review file to GitHub")
    parser.add_argument("--repo", required=True, help="GitHub owner/repo")
    parser.add_argument("--pr", required=True, help="PR number")
    parser.add_argument("--review-file", required=True, help="Path to review markdown file")
    all_sevs = ",".join(SEVERITY_LABELS)
    parser.add_argument("--severity", default=all_sevs,
                        help=f"Severity levels to post (comma-separated, default: {all_sevs})")
    parser.add_argument("--dry-run", action="store_true",
                        help="Parse and classify without posting")
    parser.add_argument("--submit", action="store_true",
                        help="Submit the review after posting (default: leave PENDING)")
    parser.add_argument("--chunk-size", type=int, default=DEFAULT_CHUNK_SIZE,
                        help=f"Max inline comments per review chunk (default: {DEFAULT_CHUNK_SIZE})")
    args = parser.parse_args()

    review_path = Path(args.review_file)
    if not review_path.exists():
        _err(f"Review file not found: {review_path}")
        sys.exit(1)

    sidecar: dict = {}
    sidecar_path = review_path.parent / "meta.json"
    if sidecar_path.exists():
        try:
            sidecar = json.loads(sidecar_path.read_text())
        except (json.JSONDecodeError, OSError):
            pass

    severity_filter = set(args.severity.upper().split(","))
    text = review_path.read_text()

    sha_match = HEAD_SHA_RE.search(text)
    review_sha = sha_match.group(1) if sha_match else None

    all_findings = parse_findings(text)
    _info(f"Parsed {len(all_findings)} findings from review file")

    findings = [f for f in all_findings if f.severity in severity_filter]
    filtered = len(all_findings) - len(findings)
    if filtered:
        _info(f"Filtered to {len(findings)} findings (excluded {filtered} by severity)")

    if not findings:
        _warn("No findings to post")
        sys.exit(0)

    head_sha = sidecar.get("head_sha", "")
    head_ref = sidecar.get("head_ref", "")
    base_ref = sidecar.get("base_ref", "")
    if not args.dry_run:
        pr_meta = _fetch_pr_metadata(args.repo, args.pr)
        head_sha = pr_meta["head_sha"]
        head_ref = head_ref or pr_meta["head_ref"]
        base_ref = base_ref or pr_meta["base_ref"]
    else:
        head_sha = head_sha or review_sha or "dry-run"

    sha_drifted = review_sha and review_sha != head_sha
    if sha_drifted and not args.dry_run:
        _warn(f"Review was written against {review_sha[:7]}, PR HEAD is now {head_sha[:7]}")
        _info("Posting as comment (inline positions may be inaccurate)")
        _post_as_comment(
            args, findings, severity_filter, review_sha, head_sha,
            head_ref, base_ref,
        )
        return

    if args.dry_run:
        _info("Fetching diff for classification...")
    diff_text = sidecar.get("diff") or _get_diff(args.repo, args.pr)
    inline, file_level, skipped = classify_findings(findings, diff_text)
    _info(f"Classified: {len(inline)} inline, {len(file_level)} file-level, {len(skipped)} skipped")

    all_postable = inline + file_level
    if not args.dry_run and all_postable:
        kept, deduped = dedup_against_posted(all_postable, args.repo, args.pr)
        if deduped:
            _info(f"Skipped {len(deduped)} findings duplicating existing comments")
            skipped.extend(deduped)
            inline = [f for f in kept if f.classification == CLASS_INLINE]
            file_level = [f for f in kept if f.classification == CLASS_FILE_LEVEL]

    body_findings = file_level + skipped

    findings_for_links = inline + body_findings
    resolve_permalinks(findings_for_links, args.repo, diff_text, head_ref, base_ref)

    inline, body_findings = renumber_for_posting(inline, body_findings)

    inline_comments = [format_inline_comment(f) for f in inline]
    body_text = format_body_text(body_findings, len(inline) > 0, severity_filter)

    commit_id = head_sha
    chunk_size = args.chunk_size

    if args.dry_run:
        payload = {
            "commit_id": commit_id,
            "body": body_text,
        }
        if inline_comments:
            payload["comments"] = inline_comments
        _print_dry_run(payload, inline, body_findings, skipped, chunk_size)
        return

    _post_and_track(
        args, inline_comments, body_text,
        inline, body_findings, skipped,
        commit_id, head_sha, chunk_size, severity_filter,
    )


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        sys.exit(130)
