#!/usr/bin/env python3
"""Read Claude stream-json from stdin, show progress labels, save raw log.

Usage: claude -p --output-format stream-json ... | review-stream-progress SESSION_LOG
"""

import json
import sys

DIM = "\033[2m"
NC = "\033[0m"


def main():
    if len(sys.argv) < 2:
        print("Usage: review-stream-progress SESSION_LOG", file=sys.stderr)
        sys.exit(1)

    session_log = sys.argv[1]
    prev_label = ""

    with open(session_log, "w") as log:
        for raw_line in sys.stdin:
            log.write(raw_line)
            log.flush()
            try:
                data = json.loads(raw_line)
            except (json.JSONDecodeError, ValueError):
                continue
            if data.get("type") != "assistant":
                continue
            for block in data.get("message", {}).get("content", []):
                if block.get("type") != "tool_use":
                    continue
                inp = block.get("input", {})
                name = block.get("name", "")
                if inp.get("description"):
                    label = inp["description"]
                elif name == "Read":
                    label = "Read " + (inp.get("file_path", "").split("/")[-1] or "")
                elif name == "Grep":
                    label = "Grep " + inp.get("pattern", "")
                elif name == "Glob":
                    label = "Glob " + inp.get("pattern", "")
                elif name == "Write":
                    label = "Write " + (inp.get("file_path", "").split("/")[-1] or "")
                else:
                    label = name
                if label and label != prev_label:
                    print(f"  {DIM}▸ {label}{NC}", flush=True)
                    prev_label = label


if __name__ == "__main__":
    main()
