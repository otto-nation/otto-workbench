#!/usr/bin/env bash
set -euo pipefail

_SELF="$(readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
WORKBENCH_DIR="$(git -C "$(dirname "$_SELF")" rev-parse --show-toplevel)"
# shellcheck source=/dev/null
. "$WORKBENCH_DIR/lib/ui.sh"

usage() {
  local exit_code="${1:-1}"
  local out=2
  [[ "$exit_code" -eq 0 ]] && out=1
  cat >&"$out" <<EOF
Usage: review-thread-triage [OPTIONS]

Classify and verify PR review threads using AI.

Options:
  --pr <number>      PR number
  --branch <name>    Branch name (resolved via resolve-branch)
  --repo-dir <path>  Git worktree directory
  -h, --help         Show this help

At least one of --pr or --branch is required.
EOF
  exit "$exit_code"
}

pr_number=""
branch=""
repo_dir=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage 0 ;;
    --pr) pr_number="$2"; shift 2 ;;
    --branch) branch="$2"; shift 2 ;;
    --repo-dir|--repo|--worktree) repo_dir="$2"; shift 2 ;;
    *) usage ;;
  esac
done

if [[ -z "$pr_number" && -z "$branch" ]]; then
  usage
fi

if [[ -z "$repo_dir" ]]; then
  repo_dir=$(git rev-parse --show-toplevel 2>/dev/null) || {
    err "Not in a git repository — pass --repo-dir to specify the repo"
    exit 1
  }
fi

# Build review-threads arguments — let it handle context resolution via pr_context
rt_args=()
[[ -n "$pr_number" ]] && rt_args+=(--pr "$pr_number")
[[ -n "$branch" ]] && rt_args+=(--branch "$branch")
[[ -n "$repo_dir" ]] && rt_args+=(--repo-dir "$repo_dir")

threads_json=$(review-threads "${rt_args[@]}")
# Backfill pr_number when only --branch was given (review-threads resolves it)
pr_number=$(printf '%s' "$threads_json" | jq -r '.pr_number // empty' 2>/dev/null) || true

thread_count=$(printf '%s' "$threads_json" | jq '[.threads[] | select(.state != "resolved")] | length')

if [[ "$thread_count" -eq 0 ]]; then
  echo '{"threads":[],"stats":{"total":0,"actionable":0,"questions":0,"approvals":0,"conflicting":0,"valid":0,"invalid":0}}'
  exit 0
fi

non_resolved=$(printf '%s' "$threads_json" | jq '[.threads[] | select(.state != "resolved")]')

code_context=""
while IFS=$'\t' read -r file line; do
  if [[ -z "$file" || "$file" == "null" ]]; then
    continue
  fi
  filepath="$repo_dir/$file"
  if [[ ! -f "$filepath" ]]; then
    continue
  fi
  start=$((line > 10 ? line - 10 : 1))
  end=$((line + 10))
  snippet=$(sed -n "${start},${end}p" "$filepath" 2>/dev/null || true)
  if [[ -n "$snippet" ]]; then
    code_context="${code_context}
--- ${file}:${start}-${end} ---
${snippet}
---
"
  fi
done < <(printf '%s' "$non_resolved" | jq -r '.[] | [.file // "null", .line // 0] | @tsv')

prompt="You are a code review triage assistant. Analyze these PR review threads and classify each one.

For each thread, provide:
1. classification: one of 'actionable_suggestion', 'question', 'approval', 'conflicting'
2. verification (only for actionable_suggestion): one of 'valid', 'invalid', 'needs_discussion'
3. reasoning: one sentence explaining your classification/verification
4. summary: one-line summary of the thread

Thread data:
${non_resolved}

${code_context:+Code context for referenced files:
${code_context}}

Return JSON matching this exact schema:
{
  \"threads\": [
    {
      \"id\": \"thread_id from input\",
      \"state\": \"state from input\",
      \"classification\": \"actionable_suggestion|question|approval|conflicting\",
      \"verification\": \"valid|invalid|needs_discussion (only for actionable_suggestion, empty string otherwise)\",
      \"reasoning\": \"brief explanation\",
      \"file\": \"file from input\",
      \"line\": line_from_input,
      \"reviewer\": \"reviewer from input\",
      \"summary\": \"one-line summary\"
    }
  ],
  \"stats\": {
    \"total\": count,
    \"actionable\": count,
    \"questions\": count,
    \"approvals\": count,
    \"conflicting\": count,
    \"valid\": count,
    \"invalid\": count
  }
}

IMPORTANT: Return ONLY the JSON object, no markdown fencing or explanation."

if ! result=$(printf '%s' "$prompt" | claude -p); then
  echo "review-thread-triage: claude -p failed" >&2
  exit 1
fi

if ! printf '%s' "$result" | jq . > /dev/null 2>&1; then
  echo "review-thread-triage: claude returned non-JSON output" >&2
  exit 1
fi

printf '%s\n' "$result"

# Update unified PR state (best-effort)
if [[ -n "$repo_dir" ]]; then
  if _triage_state=$(printf '%s' "$result" | jq -c '{
    total: (.stats.total // 0),
    actionable: (.stats.actionable // 0),
    valid: (.stats.valid // 0),
    questions: (.stats.questions // 0),
    updated_at: (now | todate)
  }' 2>/dev/null); then
    printf '%s' "$_triage_state" \
      | "$(dirname "$_SELF")/pr-state-update" --domain triage --repo-dir "$repo_dir" 2>/dev/null \
      || true
  fi
fi
