#!/usr/bin/env python3
"""Fetch PR review threads, compute lifecycle states, and output status.

Renders a human-readable dashboard to stderr and structured JSON to stdout.
Manages local state in <worktree>/ignore/pr-comments/state.json.

Usage:
  review-threads [--pr NUMBER] [--branch NAME] [--repo-dir PATH]
  review-threads --triage
  review-threads --fix
  review-threads --resolve
"""

import argparse
import json
import re
import subprocess
import sys
from collections.abc import Callable
from dataclasses import dataclass
from pathlib import Path
from string import Template

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

import log
import ai_backend
import pr_comments as pc
import pr_context
import pr_state
import review_common
import review_issue
from review_github import fetch_pr_data
from trail import Trail, add_trail_args

TRIAGE_CONTEXT_LINES = 10
FIX_MIN_TURNS = 20
FIX_MAX_TURNS_CAP = 60
FIX_TURNS_PER_ITEM = 5
FIX_MIN_BUDGET = 2.0
FIX_MAX_BUDGET_CAP = 5.0
FIX_BUDGET_PER_ITEM = 0.5
FIX_MODEL = "sonnet"
DIFF_CONTEXT_MAX_LINES = 100
FIX_RETRY_TURNS_MIN = 30
FIX_RETRY_TURNS_BUMP = 15
TEMPLATE_DIR = Path(__file__).resolve().parent.parent / "lib" / "review-templates"

_FENCE_RE = re.compile(r"```(?:json)?\s*\n(.*?)\n```", re.DOTALL)
_SOURCE_FIX_SUMMARY = "fix_summary"
_DEFERRED_REPLY_PREFIX = "Deferred:"
_FIX_RETRY_HINT = (
    "This is a RETRY of a prior fix pass. Some items were already fixed in the "
    "previous pass — focus only on unchecked items below. Work efficiently.\n\n"
)


def _extract_json(text: str) -> str:
    """Strip markdown code fences or preamble from AI output before JSON parsing."""
    m = _FENCE_RE.search(text)
    if m:
        return m.group(1).strip()
    stripped = text.strip()
    start = stripped.find("{")
    if start > 0:
        end = stripped.rfind("}")
        if end > start:
            return stripped[start:end + 1]
    return stripped


def _resolve_verified_threads(threads_raw: list, threads: dict) -> int:
    """Resolve all verified threads on GitHub. Returns count resolved."""
    resolved = 0
    for thread_data in threads_raw:
        tid = thread_data["id"]
        if threads.get(tid, {}).get("state") != pc.STATE_VERIFIED:
            continue
        if not pc.resolve_thread(tid):
            continue
        threads[tid]["state"] = pc.STATE_RESOLVED
        resolved += 1
    return resolved


def _gather_code_context(threads: list, repo_dir: Path) -> str:
    """Read surrounding source lines for each thread's file location."""
    snippets = []
    for t in threads:
        file_path = t.get("file")
        line = int(t.get("line") or 0)
        if not file_path or line == 0:
            continue
        full_path = repo_dir / file_path
        if not full_path.is_file():
            continue
        try:
            lines = full_path.read_text().splitlines()
        except OSError:
            continue
        start = max(0, line - 1 - TRIAGE_CONTEXT_LINES)
        end = min(len(lines), line + TRIAGE_CONTEXT_LINES)
        snippet = "\n".join(lines[start:end])
        if snippet:
            snippets.append(f"--- {file_path}:{start + 1}-{end} ---\n{snippet}\n---")
    return "\n".join(snippets)


def _build_triage_prompt(
    non_resolved: list, code_context: str,
    unseen_comments: list[dict] | None = None,
) -> str:
    """Build the AI classification prompt for thread triage."""
    thread_json = json.dumps(non_resolved, indent=2)
    context_block = ""
    if code_context:
        context_block = f"\nCode context for referenced files:\n{code_context}\n"

    comments_block = ""
    comment_items_schema = ""
    if unseen_comments:
        comments_json = json.dumps(unseen_comments, indent=2)
        comments_block = f"""

Additionally, analyze these top-level PR comments. Each comment may contain multiple
actionable points — decompose them into individual items and classify each one separately.
Non-actionable preamble (greetings, praise, general observations) should be skipped.

Top-level comments:
{comments_json}
"""
        comment_items_schema = """
  "comment_items": [
    {{
      "source_id": "id from input comment",
      "source_type": "issue_comment or review_body (from input)",
      "index": 0,
      "reviewer": "user from input comment",
      "classification": "actionable_suggestion|question|approval|conflicting",
      "verification": "valid|invalid|needs_discussion (only for actionable_suggestion, empty string otherwise)",
      "complexity": "low|medium|high (only for actionable_suggestion with verification=valid, empty string otherwise)",
      "reasoning": "brief explanation",
      "summary": "one-line summary of this specific item",
      "file": "file path if referenced in the item (empty string if not)",
      "line": 0,
      "body": "relevant excerpt from the comment for this item"
    }}
  ],"""

    return f"""You are a code review triage assistant. Analyze these PR review threads and classify each one.

For each thread, provide:
1. classification: one of 'actionable_suggestion', 'question', 'approval', 'conflicting'
2. verification (only for actionable_suggestion): one of 'valid', 'invalid', 'needs_discussion'
3. complexity (only for actionable_suggestion with verification=valid): one of 'low', 'medium', 'high'
   - low: rename, remove, import fix, guard/nil check, use existing helper
   - medium: logic change within a single function or file
   - high: cross-file refactor, design decision, or architectural change
4. reasoning: one sentence explaining your classification/verification
5. summary: one-line summary of the thread

Thread data:
{thread_json}
{context_block}{comments_block}
Return JSON matching this exact schema:
{{
  "threads": [
    {{
      "id": "thread_id from input",
      "state": "state from input",
      "classification": "actionable_suggestion|question|approval|conflicting",
      "verification": "valid|invalid|needs_discussion (only for actionable_suggestion, empty string otherwise)",
      "complexity": "low|medium|high (only for actionable_suggestion with verification=valid, empty string otherwise)",
      "reasoning": "brief explanation",
      "file": "file from input",
      "line": "line_from_input",
      "reviewer": "reviewer from input",
      "summary": "one-line summary"
    }}
  ],{comment_items_schema}
  "stats": {{
    "total": "count of threads",
    "actionable": "count of actionable threads",
    "questions": "count of question threads",
    "approvals": "count of approval threads",
    "conflicting": "count of conflicting threads",
    "valid": "count of valid threads",
    "invalid": "count of invalid threads",
    "comment_items_total": "count of decomposed comment items (0 if none)",
    "comment_items_actionable": "count of actionable comment items (0 if none)"
  }}
}}

IMPORTANT: Return ONLY the JSON object, no markdown fencing or explanation."""


def _collect_unseen_comments(report: dict) -> list[dict]:
    """Collect unseen issue and review body comments for triage decomposition."""
    unseen = []
    for c in report.get("issue_comments", []):
        if not c.get("seen"):
            unseen.append({
                "id": c["id"],
                "source_type": "issue_comment",
                "user": c.get("user", ""),
                "body": c.get("body", ""),
            })
    for c in report.get("review_body_comments", []):
        if not c.get("seen"):
            unseen.append({
                "id": c["id"],
                "source_type": "review_body",
                "user": c.get("user", ""),
                "body": c.get("body", ""),
            })
    return unseen


def _assign_item_ids(comment_items: list[dict]) -> None:
    """Assign synthetic IDs to decomposed comment items in place."""
    for item in comment_items:
        source_type = item.get("source_type", "ic")
        prefix = "ic" if source_type == "issue_comment" else "rb"
        source_id = item.get("source_id", "0")
        index = item.get("index", 0)
        item["id"] = f"{prefix}-{source_id}-{index}"


def _run_triage(report: dict, repo_dir: Path, ctx_args: dict,
                trail: Trail | None = None) -> tuple[dict | None, int]:
    """Classify non-resolved threads and decompose top-level comments via AI.

    Returns (triage_result, exit_code). Caller handles stdout output.
    """
    non_resolved = [t for t in report["threads"] if t.get("state") != "resolved"]
    unseen_comments = _collect_unseen_comments(report)

    if not non_resolved and not unseen_comments:
        empty = {"threads": [], "comment_items": [], "stats": {
            "total": 0, "actionable": 0, "questions": 0,
            "approvals": 0, "conflicting": 0, "valid": 0, "invalid": 0,
            "comment_items_total": 0, "comment_items_actionable": 0,
        }}
        return empty, 0

    code_context = _gather_code_context(non_resolved, repo_dir)
    prompt = _build_triage_prompt(
        non_resolved, code_context,
        unseen_comments=unseen_comments or None,
    )

    stdout, rc = ai_backend.prompt(prompt)
    if rc != 0:
        if trail:
            trail.error("triage", "AI prompt failed", data={"exit_code": rc})
        log.error("ai prompt failed")
        return None, 1

    try:
        triage_result = json.loads(_extract_json(stdout))
    except (json.JSONDecodeError, TypeError):
        preview = (stdout or "")[:200]
        if trail:
            trail.error("triage", "AI returned non-JSON output",
                        data={"output_len": len(stdout or ""),
                              "output_preview": (stdout or "")[:500]})
        log.error(f"ai returned non-JSON output ({len(stdout or '')} chars): {preview}")
        return None, 1

    # Assign synthetic IDs to comment items
    comment_items = triage_result.get("comment_items", [])
    _assign_item_ids(comment_items)
    triage_result["comment_items"] = comment_items

    # Update triage state
    try:
        stats = triage_result.get("stats", {})
        st = pr_state.load_or_init(**ctx_args)
        pr_state.update_triage(st, pr_state.TriageSummary(
            total=stats.get("total", 0),
            actionable=stats.get("actionable", 0),
            valid=stats.get("valid", 0),
            questions=stats.get("questions", 0),
            comment_items_total=stats.get("comment_items_total", 0),
            comment_items_actionable=stats.get("comment_items_actionable", 0),
            updated_at=pr_state.now_iso(),
        ))
        pr_state.save_state(ctx_args["worktree_root"], st)
    except Exception as exc:
        if trail:
            trail.error("triage", f"state update failed: {exc}")
        log.error(f"triage state update failed: {exc}")

    return triage_result, 0


def _thread_comment_text(comments: list) -> str:
    """Format a thread's comments as quoted conversation."""
    parts = []
    for c in comments:
        author = c.get("author", {}).get("login", "unknown")
        body = c.get("body", "").strip()
        if body:
            quoted = "\n".join(f"> {line}" for line in body.splitlines())
            parts.append(f"**@{author}:**\n{quoted}")
    return "\n\n".join(parts)


def _code_context_for_thread(file_path: str, line: int | str, repo_dir: Path) -> str:
    """Read surrounding source lines for a single thread's file location."""
    line = int(line) if line else 0
    if not file_path or line == 0:
        return ""
    full_path = repo_dir / file_path
    if not full_path.is_file():
        return ""
    try:
        lines = full_path.read_text().splitlines()
    except OSError:
        return ""
    start = max(0, line - 1 - TRIAGE_CONTEXT_LINES)
    end = min(len(lines), line + TRIAGE_CONTEXT_LINES)
    snippet = "\n".join(lines[start:end])
    return f"```\n{snippet}\n```" if snippet else ""


def _diff_context_for_file(file_path: str, wt_path: Path) -> str:
    """Get the PR diff for a file, truncated to DIFF_CONTEXT_MAX_LINES."""
    if not file_path:
        return ""
    result = subprocess.run(
        ["git", "-C", str(wt_path), "diff", "origin/main", "--", file_path],
        capture_output=True, text=True,
    )
    if result.returncode != 0 or not result.stdout.strip():
        return ""
    lines = result.stdout.splitlines()
    total = len(lines)
    if total > DIFF_CONTEXT_MAX_LINES:
        lines = lines[:DIFF_CONTEXT_MAX_LINES]
        lines.append(f"... ({total - DIFF_CONTEXT_MAX_LINES} more lines)")
    return "```diff\n" + "\n".join(lines) + "\n```"


def _build_tracking_file(
    tracking_path: Path,
    fixable: list[dict],
    threads_by_id: dict,
    repo_dir: Path,
    pr_number: int,
    fixable_items: list[dict] | None = None,
) -> None:
    """Build the tracking markdown file for the fix agent."""
    diff_cache: dict[str, str] = {}
    sections = []
    for thread in fixable:
        tid = thread["id"]
        report_thread = threads_by_id.get(tid, {})
        file_path = thread.get("file", "")
        line = thread.get("line", 0)
        reviewer = thread.get("reviewer", "")
        summary = thread.get("summary", "")

        comments = report_thread.get("comments", [])
        conversation = _thread_comment_text(comments)
        code_ctx = _code_context_for_thread(file_path, line, repo_dir)
        if file_path not in diff_cache:
            diff_cache[file_path] = _diff_context_for_file(file_path, repo_dir)
        diff_ctx = diff_cache[file_path]

        section = f"## <!-- thread:{tid} --> {file_path}:{line} — @{reviewer}\n\n"
        if summary:
            section += f"**Summary:** {summary}\n\n"
        if conversation:
            section += f"**Conversation:**\n{conversation}\n\n"
        if code_ctx:
            section += f"**Code context:**\n{code_ctx}\n\n"
        if diff_ctx:
            section += f"**PR diff for this file:**\n{diff_ctx}\n\n"
        section += "- [ ] Apply fix\n"
        sections.append(section)

    for item in (fixable_items or []):
        item_id = item.get("id", "")
        file_path = item.get("file", "")
        line = int(item.get("line") or 0)
        reviewer = item.get("reviewer", "")
        summary = item.get("summary", "")
        body = item.get("body", "")

        location = f"{file_path}:{line}" if file_path and line else (file_path or "general")
        code_ctx = _code_context_for_thread(file_path, line, repo_dir) if file_path and line else ""
        if file_path and file_path not in diff_cache:
            diff_cache[file_path] = _diff_context_for_file(file_path, repo_dir)
        diff_ctx = diff_cache.get(file_path, "")

        section = f"## <!-- item:{item_id} --> {location} — @{reviewer}\n\n"
        if summary:
            section += f"**Summary:** {summary}\n\n"
        if body:
            quoted = "\n".join(f"> {ln}" for ln in body.splitlines())
            section += f"**From comment by @{reviewer}:**\n{quoted}\n\n"
        if code_ctx:
            section += f"**Code context:**\n{code_ctx}\n\n"
        if diff_ctx:
            section += f"**PR diff for this file:**\n{diff_ctx}\n\n"
        section += "- [ ] Apply fix\n"
        sections.append(section)

    content = f"# Comment Fix Tracking — PR #{pr_number}\n\n"
    content += "\n".join(sections)
    tracking_path.parent.mkdir(parents=True, exist_ok=True)
    tracking_path.write_text(content)


def _render_fix_template(
    branch: str, repo: str, threads_content: str,
    tracking_file: str, wt_path: str, max_turns: int,
    main_wt_path: str = "",
) -> str:
    """Render the fix-comments.md template."""
    tmpl = Template((TEMPLATE_DIR / review_common.TEMPLATE_FIX_COMMENTS).read_text())
    result = tmpl.safe_substitute(
        branch_name=branch,
        repo=repo,
        threads_content=threads_content,
        tracking_file=tracking_file,
        wt_path=wt_path,
        max_turns=str(max_turns),
    )
    if main_wt_path:
        result += (
            "\n## Main branch (read-only reference)\n"
            f"Checked out at: {main_wt_path}\n\n"
            "When a reviewer comment references code outside the PR diff — imports, "
            "callers, existing patterns, or shared utilities — read from this path "
            "to understand the baseline. Do not modify files in this worktree.\n"
        )
    return result


def _find_and_update_main_worktree(wt_path: Path) -> Path | None:
    """Find the default-branch worktree and update it to match origin."""
    default_branch = "main"
    try:
        r = subprocess.run(
            ["git", "-C", str(wt_path), "symbolic-ref", "refs/remotes/origin/HEAD"],
            capture_output=True, text=True,
        )
        ref = r.stdout.strip()
        if ref:
            default_branch = ref.replace("refs/remotes/origin/", "")
    except Exception:
        pass

    main_wt = pr_context.find_worktree_for_branch(default_branch, str(wt_path))
    if not main_wt:
        return None

    pr_context.fetch_and_reset(str(main_wt), default_branch)
    return main_wt


def _fix_turn_budget(item_count: int) -> int:
    return min(max(FIX_MIN_TURNS, item_count * FIX_TURNS_PER_ITEM), FIX_MAX_TURNS_CAP)


def _fix_budget_usd(item_count: int) -> float:
    return min(max(FIX_MIN_BUDGET, item_count * FIX_BUDGET_PER_ITEM), FIX_MAX_BUDGET_CAP)


def _fix_retry_budget(original: int) -> int:
    return min(max(FIX_RETRY_TURNS_MIN, original + FIX_RETRY_TURNS_BUMP), FIX_MAX_TURNS_CAP)


def _invoke_fix_agent(
    prompt: str, wt_path: Path, main_wt_path: Path | None = None,
    max_turns: int | None = None, max_budget: float | None = None,
) -> int:
    """Run AI agent to apply fixes. Returns exit code."""
    dirs = [str(wt_path)]
    if main_wt_path:
        dirs.append(str(main_wt_path))
    return ai_backend.invoke_fix(
        prompt,
        add_dirs=dirs,
        max_turns=max_turns or FIX_MIN_TURNS,
        max_budget=max_budget or FIX_MIN_BUDGET,
        model=FIX_MODEL,
    )


def _count_unchecked(path: Path) -> int:
    """Count unchecked checkboxes in a tracking file."""
    if not path.exists():
        return 0
    return sum(
        1 for line in path.read_text().splitlines()
        if re.match(r"^- \[ \] ", line)
    )


def _parse_tracking_results(
    tracking_path: Path, fixable: list[dict],
    fixable_items: list[dict] | None = None,
) -> tuple[list[dict], list[dict], list[dict], list[dict]]:
    """Parse tracking file to determine which threads/items were fixed vs deferred.

    Returns (fixed_threads, deferred_threads, fixed_items, deferred_items).
    """
    content = tracking_path.read_text()
    sections = re.split(r"^## <!-- (?:thread|item):", content, flags=re.MULTILINE)

    fixable_by_id = {t["id"]: t for t in fixable}
    items_by_id = {it["id"]: it for it in (fixable_items or [])}
    fixed = []
    deferred = []
    fixed_items = []
    deferred_items = []

    for section in sections[1:]:
        tid_match = re.match(r"(\S+) -->", section)
        if not tid_match:
            continue
        tid = tid_match.group(1)
        is_checked = bool(re.search(r"^- \[[xX]\] ", section, re.MULTILINE))
        source = fixable_by_id.get(tid) or items_by_id.get(tid)
        if not source:
            continue
        entry = {
            "thread_id": tid,
            "file": source.get("file", ""),
            "line": int(source.get("line") or 0),
            "reviewer": source.get("reviewer", ""),
            "summary": source.get("summary", ""),
        }
        is_item = tid in items_by_id
        target_fixed = fixed_items if is_item else fixed
        target_deferred = deferred_items if is_item else deferred
        if is_checked:
            target_fixed.append(entry)
        else:
            entry["reason"] = "agent could not auto-fix"
            target_deferred.append(entry)

    return fixed, deferred, fixed_items, deferred_items


def _changed_source_files(wt_path: Path, head_before: str) -> set[str]:
    """Return set of files changed between head_before and current HEAD."""
    result = subprocess.run(
        ["git", "-C", str(wt_path), "diff", "--name-only", f"{head_before}..HEAD"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return set()
    return {line.strip() for line in result.stdout.splitlines() if line.strip()}


def _reconcile_fix_results(
    fixed: list[dict],
    deferred: list[dict],
    wt_path: Path,
    head_before: str,
) -> tuple[list[dict], list[dict]]:
    """Move deferred entries to fixed if their file was modified by the agent."""
    changed = _changed_source_files(wt_path, head_before)
    if not changed:
        return fixed, deferred
    reconciled = list(fixed)
    still_deferred = []
    for entry in deferred:
        if entry.get("file") and entry["file"] in changed:
            reconciled.append(entry)
        else:
            still_deferred.append(entry)
    return reconciled, still_deferred


@dataclass
class CommitPushResult:
    sha: str | None
    status: str  # "pushed", "no_changes", "commit_failed", "push_failed"
    error: str


def _commit_regen_and_retry_push(
    wt_path: Path, trail: Trail | None,
) -> CommitPushResult | None:
    """If pre-push hooks left regenerated files uncommitted, commit and retry.

    Returns a successful CommitPushResult on retry success, None otherwise.
    """
    status = subprocess.run(
        ["git", "-C", str(wt_path), "status", "--porcelain", "--untracked-files=no"],
        capture_output=True, text=True,
    )
    modified = [
        line[3:] for line in status.stdout.splitlines()
        if line.startswith(" M ")
    ]
    if not modified:
        return None

    log.info("Committing regenerated files...")
    if trail:
        trail.info("push", "committing regenerated files before retry",
                    data={"files": modified})
    ar = subprocess.run(
        ["git", "-C", str(wt_path), "add", "-u"],
        capture_output=True,
    )
    if ar.returncode != 0:
        log.error("Failed to stage regenerated files.")
        return None
    rc = subprocess.run(
        ["git", "-C", str(wt_path), "commit", "-m",
         "chore: regenerate after review comment fixes"],
        capture_output=True, text=True,
    )
    if rc.returncode != 0:
        return None

    sha = _get_head_sha(wt_path)
    retry = subprocess.run(
        ["git", "-C", str(wt_path), "push"],
        capture_output=True, text=True,
    )
    if retry.returncode != 0:
        return None

    log.info("Pushed fixes (with regenerated files)")
    return CommitPushResult(sha, "pushed", "")


def _commit_and_push(
    wt_path: Path, fixed: int, deferred: int, trail: Trail | None = None,
) -> CommitPushResult:
    """Commit and push fixes. Returns structured result with status."""
    result = subprocess.run(
        ["git", "-C", str(wt_path), "diff", "--quiet"],
        capture_output=True,
    )
    if result.returncode == 0:
        return CommitPushResult(None, "no_changes", "")

    subprocess.run(
        ["git", "-C", str(wt_path), "add", "-A"],
        capture_output=True, check=True,
    )

    msg = "fix: address review comments"
    if fixed:
        msg += f"\n\n{fixed} fixed, {deferred} deferred"

    result = subprocess.run(
        ["git", "-C", str(wt_path), "commit", "-m", msg],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        err = result.stderr.strip()
        log.error(f"commit failed: {err}")
        if trail:
            trail.error("commit", "commit failed", data={"error": err[:500]})
        return CommitPushResult(None, "commit_failed", err)

    sha = _get_head_sha(wt_path)

    log.info(f"Committed fixes ({fixed} fixed, {deferred} deferred)")

    push = subprocess.run(
        ["git", "-C", str(wt_path), "push"],
        capture_output=True, text=True,
    )
    if push.returncode == 0:
        log.info("Pushed fixes")
        return CommitPushResult(sha, "pushed", "")

    # Pre-push hooks may regenerate files (e.g. proto → .pb.go, OpenAPI specs),
    # leaving uncommitted changes that cause the push to fail. Commit and retry.
    retried = _commit_regen_and_retry_push(wt_path, trail)
    if retried:
        return retried

    err = push.stderr.strip()
    log.error(
        f"push failed — branch has diverged. Run:\n"
        f"  git -C '{wt_path}' push --force-with-lease"
    )
    if trail:
        trail.error("push", "push failed", data={"sha": sha, "error": err[:500]})
    return CommitPushResult(sha, "push_failed", err)


def _post_thread_replies(
    entries: list[dict],
    threads_by_id: dict,
    repo: str,
    pr_number: int,
    body_fn: Callable[[dict], str],
) -> int:
    """Post a reply to each thread entry using body_fn to build the message body."""
    posted = 0
    for entry in entries:
        tid = entry.get("thread_id", "")
        thread = threads_by_id.get(tid, {})
        comments = thread.get("comments", [])
        if not comments:
            continue
        database_id = comments[0].get("databaseId")
        if not database_id:
            continue
        if pc.post_thread_reply(repo, pr_number, database_id, body_fn(entry)):
            posted += 1
    return posted


def _post_fix_replies(
    fixed: list[dict],
    threads_by_id: dict,
    repo: str,
    pr_number: int,
    commit_sha: str,
) -> int:
    """Post replies to each fixed thread. Returns count of replies posted."""
    commit_url = f"https://github.com/{repo}/commit/{commit_sha}"

    def body_fn(entry: dict) -> str:
        summary = entry.get("summary", "")
        return f"Applied: {summary}\n\nFixed in [`{commit_sha}`]({commit_url})."

    posted = _post_thread_replies(fixed, threads_by_id, repo, pr_number, body_fn)
    if posted:
        log.info(f"Posted {posted} thread replies")
    return posted


def _find_addressing_commit(wt_path: Path, filepath: str) -> str | None:
    """Find the most recent branch commit that modified a file."""
    result = subprocess.run(
        ["git", "-C", str(wt_path), "log", "-1", "--format=%H",
         "origin/main..HEAD", "--", filepath],
        capture_output=True, text=True,
    )
    sha = result.stdout.strip()
    return sha if sha else None


def _post_already_addressed_replies(
    fixed: list[dict],
    threads_by_id: dict,
    repo: str,
    pr_number: int,
    wt_path: Path,
) -> int:
    """Post replies to threads already addressed in the current code. Returns count posted."""
    commit_cache: dict[str, str | None] = {}

    def body_fn(entry: dict) -> str:
        summary = entry.get("summary", "")
        filepath = entry.get("file", "")
        if filepath not in commit_cache:
            commit_cache[filepath] = _find_addressing_commit(wt_path, filepath)
        sha = commit_cache[filepath]
        if sha:
            commit_url = f"https://github.com/{repo}/commit/{sha}"
            return (
                f"Already addressed: {summary}\n\n"
                f"Addressed in [`{sha[:7]}`]({commit_url})."
            )
        return f"Already addressed in the current implementation: {summary}"

    posted = _post_thread_replies(fixed, threads_by_id, repo, pr_number, body_fn)
    if posted:
        log.info(f"Posted {posted} already-addressed replies")
    return posted


def _post_dismissed_replies(
    dismissed: list[dict],
    threads_by_id: dict,
    repo: str,
    pr_number: int,
) -> int:
    """Post replies to invalid suggestion threads. Returns count posted."""
    def body_fn(entry: dict) -> str:
        reasoning = entry.get("reasoning", "")
        if reasoning:
            return f"Suggestion reviewed and determined to be inapplicable: {reasoning}"
        return "Suggestion reviewed and determined to be inapplicable."

    posted = _post_thread_replies(dismissed, threads_by_id, repo, pr_number, body_fn)
    if posted:
        log.info(f"Dismissed {posted} invalid suggestion(s)")
    return posted


def _has_deferred_reply(thread: dict) -> bool:
    """Check if a thread already has a deferred reply posted."""
    for comment in thread.get("comments", []):
        if comment.get("body", "").startswith(_DEFERRED_REPLY_PREFIX):
            return True
    return False


def _post_deferred_replies(
    deferred: list[dict],
    threads_by_id: dict,
    repo: str,
    pr_number: int,
    issue_id: str,
    issue_url: str,
) -> int:
    """Post replies to deferred threads linking the tracking issue."""
    new_deferred = [
        e for e in deferred
        if not _has_deferred_reply(threads_by_id.get(e.get("thread_id", ""), {}))
    ]
    if not new_deferred:
        return 0

    issue_ref = f"[{issue_id}]({issue_url})" if issue_url else issue_id

    def body_fn(entry: dict) -> str:
        summary = entry.get("summary", "")
        return f"{_DEFERRED_REPLY_PREFIX} {summary}\n\nTracked in {issue_ref}."

    posted = _post_thread_replies(new_deferred, threads_by_id, repo, pr_number, body_fn)
    if posted:
        log.info(f"Posted {posted} deferred thread replies")
    return posted


def _finalize_deferred(
    ctx: pr_context.ResolvedContext,
    threads_by_id: dict,
    trail: Trail | None = None,
) -> None:
    """Create tracking issue and post deferred replies for items held from fix pass."""
    wt_path = ctx.worktree_root
    if not wt_path:
        return
    state = pr_state.load_state(wt_path)
    if not state or not state.fix.threads:
        return

    FA = pr_state.ThreadAction
    deferred = [
        {"thread_id": t.thread_id, "file": t.file, "line": t.line,
         "reviewer": t.reviewer, "summary": t.summary}
        for t in state.fix.threads if t.action == FA.DEFERRED.value
    ]
    if not deferred:
        return

    pr_number = ctx.pr_number
    if not pr_number:
        return

    deferred_issue_id, deferred_issue_url = _create_or_update_deferred_issue(
        deferred, ctx.repo, pr_number, threads_by_id,
        ctx, state.fix.deferred_issue_id, trail,
        state.fix.deferred_issue_url,
    )

    if deferred_issue_id:
        _post_deferred_replies(
            deferred, threads_by_id, ctx.repo, pr_number,
            deferred_issue_id, deferred_issue_url,
        )

    state.fix.deferred_issue_id = deferred_issue_id
    state.fix.deferred_issue_url = deferred_issue_url
    pr_state.save_state(wt_path, state)


def _resolve_fixed_threads(
    fixed: list[dict],
    threads_by_id: dict,
) -> int:
    """Resolve fixed threads on GitHub. Returns count resolved."""
    resolved = 0
    for entry in fixed:
        tid = entry.get("thread_id", "")
        thread = threads_by_id.get(tid, {})
        if thread.get("is_resolved"):
            continue
        if pc.resolve_thread(tid):
            resolved += 1
    if resolved:
        log.info(f"Resolved {resolved} fixed thread(s)")
    return resolved


def _build_deferred_issue_body(
    deferred: list[dict],
    repo: str,
    pr_number: int,
    threads_by_id: dict,
) -> str:
    """Build markdown description for the deferred threads tracking issue."""
    pr_url = f"https://github.com/{repo}/pull/{pr_number}"
    parts = [
        f"## Deferred Review Comments — [PR #{pr_number}]({pr_url})",
        "",
        "| Thread | File | Reason |",
        "|--------|------|--------|",
    ]
    for entry in deferred:
        summary = entry.get("summary", "—")
        permalink = _thread_permalink(entry, threads_by_id, repo, pr_number)
        thread_cell = f"[{summary}]({permalink})" if permalink else summary
        file_path = entry.get("file", "")
        line = entry.get("line", 0)
        file_cell = f"`{file_path}:{line}`" if file_path else "—"
        reason = entry.get("reason", "")
        parts.append(f"| {thread_cell} | {file_cell} | {reason} |")
    parts.append("")
    return "\n".join(parts)


def _update_deferred_issue(
    provider: str, issue_id: str, body: str, repo: str, opts: dict | None,
) -> tuple[str, str]:
    ok = review_issue.update_issue(provider, issue_id, body, repo=repo, opts=opts)
    if not ok:
        log.error(f"Failed to update deferred issue {issue_id}")
        return issue_id, ""
    url = review_issue.get_issue_url(provider, issue_id)
    return issue_id, url


def _create_deferred_issue(
    provider: str,
    body: str,
    ctx: pr_context.ResolvedContext,
    repo: str,
    pr_number: int,
    opts: dict | None,
    trail: Trail | None,
) -> tuple[str, str]:
    parent_id = review_issue.extract_issue_id(provider, ctx.branch)
    team = parent_id.split("-", 1)[0] if parent_id and "-" in parent_id else ""
    if not team:
        log.dim("Cannot determine team key for issue creation — skipping")
        if trail:
            trail.info("deferred_issue", "skipped — no team key")
        return "", ""

    title = f"fix(review): deferred review comments — PR #{pr_number}"
    created = review_issue.create_issue(
        provider, team, title, body, parent_id=parent_id, repo=repo, opts=opts,
    )
    if not created:
        log.error("Failed to create deferred tracking issue")
        if trail:
            trail.error("deferred_issue", "creation failed")
        return "", ""

    if trail:
        trail.info("deferred_issue", f"created {created.id}", data={"url": created.url})
    return created.id, created.url


def _create_or_update_deferred_issue(
    deferred: list[dict],
    repo: str,
    pr_number: int,
    threads_by_id: dict,
    ctx: pr_context.ResolvedContext,
    existing_issue_id: str,
    trail: Trail | None,
    existing_issue_url: str = "",
) -> tuple[str, str]:
    """Create or update the deferred threads tracking issue.

    Returns (issue_id, issue_url). Empty strings on failure or skip.
    """
    if not deferred:
        return existing_issue_id, ""

    root_path = str(ctx.worktree_root) if ctx.worktree_root else None
    provider_info = review_issue.load_issue_provider(root_path)
    provider = provider_info.name

    body = _build_deferred_issue_body(deferred, repo, pr_number, threads_by_id)

    if existing_issue_id:
        issue_id, url = _update_deferred_issue(
            provider, existing_issue_id, body, repo, provider_info.options,
        )
        return issue_id, url or existing_issue_url

    return _create_deferred_issue(provider, body, ctx, repo, pr_number, provider_info.options, trail)


def _fixed_status_text(cp: CommitPushResult, repo: str) -> str:
    """Human-readable status for fixed threads in the summary table."""
    if cp.sha:
        url = f"https://github.com/{repo}/commit/{cp.sha}"
        sha_link = f"[`{cp.sha}`]({url})"
        if cp.status == "pushed":
            return f"Fixed in {sha_link}"
        return f"Fixed in {sha_link} (push failed — run manually)"
    if cp.status == "no_changes":
        return "Fix applied (no commit needed)"
    if cp.status == "commit_failed":
        return "Fix applied (commit failed — pre-commit hook?)"
    return "Fix pending"


def _thread_permalink(
    entry: dict, threads_by_id: dict, repo: str, pr_number: int,
) -> str | None:
    """Build a GitHub permalink for a review thread, or None if unavailable."""
    tid = entry.get("thread_id", "")
    thread = threads_by_id.get(tid, {})
    comments = thread.get("comments", [])
    if not comments:
        return None
    db_id = comments[0].get("databaseId")
    if not db_id:
        return None
    return f"https://github.com/{repo}/pull/{pr_number}#discussion_r{db_id}"


def _summary_cell(entry: dict, threads_by_id: dict, repo: str, pr_number: int) -> str:
    """Thread summary as a markdown link if a permalink is available, plain text otherwise."""
    summary = entry.get("summary", "—")
    url = _thread_permalink(entry, threads_by_id, repo, pr_number)
    if url:
        return f"[{summary}]({url})"
    return summary


def _build_row(
    entry: dict, status: str, threads_by_id: dict, repo: str, pr_number: int,
) -> str:
    """Build a single summary table row for a thread entry."""
    summary = _summary_cell(entry, threads_by_id, repo, pr_number)
    file_path = entry.get("file", "")
    line = entry.get("line", "")
    if file_path and line:
        file_loc = f"`{file_path}:{line}`"
    elif file_path:
        file_loc = f"`{file_path}`"
    else:
        file_loc = "—"
    return f"| {summary} | {file_loc} | {status} |"


def _summarize_comment_body(body: str, max_len: int = 120) -> str:
    """Extract first meaningful line from a comment body, truncated."""
    in_html_comment = False
    for raw_line in body.splitlines():
        stripped = raw_line.strip()
        if in_html_comment:
            in_html_comment = "-->" not in stripped
            continue
        if stripped.startswith("<!--"):
            in_html_comment = "-->" not in stripped
            continue
        line = stripped.lstrip("#").strip()
        if not line:
            continue
        if len(line) > max_len:
            return line[:max_len - 1] + "…"
        return line
    return "(empty)"


def _build_summary_body(
    fixed: list[dict],
    needs_human: list[dict],
    deferred: list[dict],
    cp: CommitPushResult,
    repo: str,
    pr_number: int,
    threads_by_id: dict,
    dismissed: list[dict] | None = None,
    issue_comments: list[dict] | None = None,
    review_body_comments: list[dict] | None = None,
    deferred_issue_id: str = "",
    deferred_issue_url: str = "",
    has_comment_items: bool = False,
) -> str:
    """Build the markdown body for the fix summary comment."""
    dismissed = dismissed or []
    issue_comments = issue_comments or []
    review_body_comments = review_body_comments or []
    fixed_count = len(fixed)
    deferred_count = len(deferred)
    human_count = len(needs_human)
    dismissed_count = len(dismissed)

    parts = ["## Review Comments Addressed", ""]
    counts = []
    if fixed_count:
        counts.append(f"**{fixed_count} fixed**")
    if dismissed_count:
        counts.append(f"{dismissed_count} dismissed")
    if deferred_count:
        counts.append(f"{deferred_count} deferred")
    if human_count:
        counts.append(f"{human_count} need discussion")
    parts.append(" · ".join(counts))
    parts.append("")

    rows = []
    fixed_status = _fixed_status_text(cp, repo)
    for entry in fixed:
        rows.append(_build_row(entry, fixed_status, threads_by_id, repo, pr_number))
    for entry in dismissed:
        rows.append(_build_row(entry, "Dismissed (invalid)", threads_by_id, repo, pr_number))
    for entry in needs_human:
        reason = entry.get("reason", "needs discussion")
        rows.append(_build_row(entry, reason, threads_by_id, repo, pr_number))
    if deferred_issue_id and deferred_issue_url:
        deferred_status = f"Deferred → [{deferred_issue_id}]({deferred_issue_url})"
    elif deferred_issue_id:
        deferred_status = f"Deferred → {deferred_issue_id}"
    else:
        deferred_status = "Deferred"
    for entry in deferred:
        rows.append(_build_row(entry, deferred_status, threads_by_id, repo, pr_number))

    if rows:
        parts.append("| Thread | File | Action |")
        parts.append("|--------|------|--------|")
        parts.extend(rows)
        parts.append("")

    if not has_comment_items:
        parts.extend(_render_raw_comment_sections(review_body_comments, issue_comments))

    return "\n".join(parts)


def _render_raw_comment_sections(
    review_body_comments: list[dict],
    issue_comments: list[dict],
) -> list[str]:
    """Render unseen comments as summary sections (fallback when items weren't decomposed)."""
    parts: list[str] = []
    unseen_reviews = [c for c in review_body_comments if not c.get("seen")]
    if unseen_reviews:
        parts.extend(["### Review-Level Comments", ""])
        parts.extend(_format_review_body_items(unseen_reviews))
        parts.append("")

    unseen_issue = [c for c in issue_comments if not c.get("seen")]
    if unseen_issue:
        parts.extend(["### Discussion Comments", ""])
        parts.extend(_format_issue_comment_items(unseen_issue))
        parts.append("")

    return parts


def _format_review_body_items(comments: list[dict]) -> list[str]:
    lines = []
    for c in comments:
        user = c.get("user", "unknown")
        state = c.get("state", "")
        summary = _summarize_comment_body(c.get("body", ""))
        state_badge = f" ({state})" if state else ""
        lines.append(f"- **@{user}**{state_badge}: {summary}")
    return lines


def _format_issue_comment_items(comments: list[dict]) -> list[str]:
    lines = []
    for c in comments:
        user = c.get("user", "unknown")
        summary = _summarize_comment_body(c.get("body", ""))
        lines.append(f"- **@{user}**: {summary}")
    return lines


def _post_fix_summary(
    fixed: list[dict],
    needs_human: list[dict],
    deferred: list[dict],
    cp: CommitPushResult,
    repo: str,
    pr_number: int,
    threads_by_id: dict,
    dismissed: list[dict] | None = None,
    issue_comments: list[dict] | None = None,
    review_body_comments: list[dict] | None = None,
    deferred_issue_id: str = "",
    deferred_issue_url: str = "",
    has_comment_items: bool = False,
) -> str | None:
    """Post summary issue comment to the PR. Returns the comment URL or None."""
    dismissed = dismissed or []
    issue_comments = issue_comments or []
    review_body_comments = review_body_comments or []
    has_unseen = (
        any(not c.get("seen") for c in issue_comments)
        or any(not c.get("seen") for c in review_body_comments)
    )
    if not fixed and not needs_human and not deferred and not dismissed and not has_unseen:
        return None
    body = _build_summary_body(
        fixed, needs_human, deferred, cp, repo, pr_number, threads_by_id,
        dismissed=dismissed,
        issue_comments=issue_comments,
        review_body_comments=review_body_comments,
        deferred_issue_id=deferred_issue_id,
        deferred_issue_url=deferred_issue_url,
        has_comment_items=has_comment_items,
    )
    url = pc.post_issue_comment(repo, pr_number, body)
    if url:
        log.info(f"Posted fix summary: {url}")
    else:
        log.error("failed to post fix summary")
    return url


def _post_pending_comments(
    state: pr_state.PRState, repo: str, pr_number: int,
) -> None:
    """Post any pending comments saved from a prior fix pass."""
    pending = pr_state.pop_pending_comments(state, source=_SOURCE_FIX_SUMMARY)
    for comment in pending:
        url = pc.post_issue_comment(repo, pr_number, comment.body)
        if url:
            log.info(f"Posted deferred fix summary: {url}")
        else:
            log.error("failed to post deferred fix summary")
            pr_state.add_pending_comment(state, comment)


def _post_or_defer_summary(
    fixed: list[dict],
    needs_human: list[dict],
    deferred: list[dict],
    cp: CommitPushResult,
    repo: str,
    pr_number: int,
    threads_by_id: dict,
    wt_path: Path,
    ctx: pr_context.ResolvedContext,
    dismissed: list[dict] | None = None,
    issue_comments: list[dict] | None = None,
    review_body_comments: list[dict] | None = None,
    deferred_issue_id: str = "",
    deferred_issue_url: str = "",
    has_comment_items: bool = False,
) -> str | None:
    """Post summary immediately or defer to state when discussion is pending.

    Returns the comment URL if posted, None if deferred or nothing to post.
    """
    dismissed = dismissed or []
    issue_comments = issue_comments or []
    review_body_comments = review_body_comments or []
    if not needs_human and not deferred:
        return _post_fix_summary(
            fixed, needs_human, deferred, cp, repo, pr_number,
            threads_by_id, dismissed=dismissed,
            issue_comments=issue_comments,
            review_body_comments=review_body_comments,
            deferred_issue_id=deferred_issue_id,
            deferred_issue_url=deferred_issue_url,
            has_comment_items=has_comment_items,
        )

    # Defer: build body without needs_human/deferred entries and save to state
    has_unseen = (
        any(not c.get("seen") for c in issue_comments)
        or any(not c.get("seen") for c in review_body_comments)
    )
    if not fixed and not deferred and not dismissed and not has_unseen:
        return None
    body = _build_summary_body(
        fixed, [], deferred, cp, repo, pr_number, threads_by_id,
        dismissed=dismissed,
        issue_comments=issue_comments,
        review_body_comments=review_body_comments,
        deferred_issue_id=deferred_issue_id,
        deferred_issue_url=deferred_issue_url,
        has_comment_items=has_comment_items,
    )
    try:
        st = pr_state.load_or_init(
            worktree_root=wt_path, repo=ctx.repo, branch=ctx.branch,
            pr_number=ctx.pr_number, head_sha=ctx.head_sha,
        )
        pr_state.add_pending_comment(st, pr_state.PendingComment(
            body=body, source=_SOURCE_FIX_SUMMARY, updated_at=pr_state.now_iso(),
        ))
        pr_state.save_state(wt_path, st)
        log.info("Deferred fix summary — will post on resolve")
    except Exception as exc:
        log.error(f"failed to defer summary: {exc}")
    return None


def _get_head_sha(wt_path: Path) -> str:
    return subprocess.run(
        ["git", "-C", str(wt_path), "rev-parse", "--short", "HEAD"],
        capture_output=True, text=True,
    ).stdout.strip()


def _is_pushed(wt_path: Path, sha: str) -> bool:
    """Check if a commit has been pushed to the remote tracking branch."""
    result = subprocess.run(
        ["git", "-C", str(wt_path), "branch", "-r", "--contains", sha],
        capture_output=True, text=True,
    )
    return result.returncode == 0 and result.stdout.strip() != ""


def _recover_agent_commit(
    wt_path: Path, head_before: str, trail: Trail | None = None,
) -> CommitPushResult:
    """Detect and push commits made directly by the fix agent."""
    head_after = _get_head_sha(wt_path)
    if head_after == head_before:
        return CommitPushResult(None, "no_changes", "")

    if _is_pushed(wt_path, head_after):
        return CommitPushResult(head_after, "pushed", "")

    push = subprocess.run(
        ["git", "-C", str(wt_path), "push"],
        capture_output=True, text=True,
    )
    if push.returncode == 0:
        log.info("Pushed agent-committed fixes")
        return CommitPushResult(head_after, "pushed", "")

    err = push.stderr.strip()
    log.error("push failed after agent commit")
    if trail:
        trail.error("push", "push failed after agent commit",
                    data={"sha": head_after, "error": err[:500]})
    return CommitPushResult(head_after, "push_failed", err)


def _build_thread_outcomes(
    fixed: list[dict],
    deferred: list[dict],
    needs_human: list[dict],
    dismissed: list[dict],
) -> list[pr_state.ThreadOutcome]:
    """Build ThreadOutcome list from categorized entry dicts."""
    FA = pr_state.ThreadAction
    batches = [
        (fixed, FA.FIXED, "reason"),
        (deferred, FA.DEFERRED, "reason"),
        (needs_human, FA.NEEDS_HUMAN, "reason"),
        (dismissed, FA.DISMISSED, "reasoning"),
    ]
    return [
        pr_state.ThreadOutcome.from_entry(entry, action, reason_key)
        for entries, action, reason_key in batches
        for entry in entries
    ]


def _persist_fix_state(
    fix_summary: pr_state.FixSummary,
    wt_path: Path,
    ctx: pr_context.ResolvedContext,
    trail: Trail | None,
) -> None:
    """Save fix pass results to PR state."""
    try:
        st = pr_state.load_or_init(
            worktree_root=wt_path, repo=ctx.repo, branch=ctx.branch,
            pr_number=ctx.pr_number, head_sha=ctx.head_sha,
        )
        pr_state.update_fix(st, fix_summary)
        pr_state.save_state(wt_path, st)
    except Exception as exc:
        if trail:
            trail.error("fix_state", f"fix state update failed: {exc}")
        log.error(f"fix state update failed: {exc}")


def _classify_triage_entries(
    triage_entries: list[dict], id_key: str = "id",
) -> tuple[list[dict], list[dict], list[dict]]:
    """Classify triage entries into fixable/needs_human/dismissed.

    Works for both threads and comment items. Returns (fixable, needs_human, dismissed).
    """
    fixable = []
    needs_human = []
    dismissed = []

    for tt in triage_entries:
        entry = {
            "thread_id": tt.get(id_key, ""),
            "file": tt.get("file", ""),
            "line": int(tt.get("line") or 0),
            "reviewer": tt.get("reviewer", ""),
            "summary": tt.get("summary", ""),
        }
        classification = tt.get("classification", "")
        verification = tt.get("verification", "")
        state = tt.get("state", "")

        if state == "contested":
            needs_human.append({**entry, "reason": "contested"})
            continue

        if classification == "conflicting":
            needs_human.append({**entry, "reason": "conflicting"})
            continue

        if classification == "question":
            needs_human.append({**entry, "reason": "question"})
            continue

        if classification != "actionable_suggestion":
            continue

        if verification == "valid" and tt.get("complexity") == "high":
            needs_human.append({**entry, "reason": "complex"})
            continue

        if verification == "valid":
            fixable.append(tt)
        elif verification == "needs_discussion":
            needs_human.append({**entry, "reason": "needs_discussion"})
        elif verification == "invalid":
            dismissed.append({**entry, "reasoning": tt.get("reasoning", "")})

    return fixable, needs_human, dismissed


def _retry_fix_pass(
    deferred_threads: list[dict],
    deferred_items: list[dict],
    original_fixable: list[dict],
    original_fixable_items: list[dict],
    threads_by_id: dict,
    wt_path: Path,
    pr_number: int,
    ctx: pr_context.ResolvedContext,
    main_wt: Path | None,
    original_turns: int,
    trail: Trail | None = None,
) -> tuple[list[dict], list[dict], list[dict], list[dict]]:
    """Retry fix pass with only deferred items and increased budget."""
    fixable_by_id = {t["id"]: t for t in original_fixable}
    items_by_id = {it["id"]: it for it in original_fixable_items}

    retry_fixable = [fixable_by_id[e["thread_id"]] for e in deferred_threads
                     if e["thread_id"] in fixable_by_id]
    retry_items = [items_by_id[e["thread_id"]] for e in deferred_items
                   if e["thread_id"] in items_by_id]

    if not retry_fixable and not retry_items:
        return [], deferred_threads, [], deferred_items

    tracking_dir = wt_path / "ignore" / "pr-comments"
    tracking_file = tracking_dir / "fix-tracking.md"

    _build_tracking_file(
        tracking_file, retry_fixable, threads_by_id,
        wt_path, pr_number,
        fixable_items=retry_items,
    )

    retry_count = len(retry_fixable) + len(retry_items)
    retry_turns = _fix_retry_budget(original_turns)

    prompt = _FIX_RETRY_HINT + _render_fix_template(
        branch=ctx.branch,
        repo=ctx.repo,
        threads_content=tracking_file.read_text(),
        tracking_file=str(tracking_file),
        wt_path=str(wt_path),
        max_turns=retry_turns,
        main_wt_path=str(main_wt) if main_wt else "",
    )

    log.info(f"Retry pass — {retry_count} deferred items (max_turns={retry_turns})...")
    head_before = _get_head_sha(wt_path)
    _invoke_fix_agent(prompt, wt_path, main_wt,
                      max_turns=retry_turns, max_budget=_fix_budget_usd(retry_count))
    log.blank()

    fixed, still_deferred, fixed_items, still_deferred_items = _parse_tracking_results(
        tracking_file, retry_fixable, fixable_items=retry_items,
    )

    fixed, still_deferred = _reconcile_fix_results(
        fixed, still_deferred, wt_path, head_before,
    )
    fixed_items, still_deferred_items = _reconcile_fix_results(
        fixed_items, still_deferred_items, wt_path, head_before,
    )

    if trail:
        trail.info("fix_retry", "retry pass complete",
                    data={"fixed": len(fixed), "fixed_items": len(fixed_items),
                          "still_deferred": len(still_deferred) + len(still_deferred_items)})

    return fixed, still_deferred, fixed_items, still_deferred_items


def _run_comment_fix(
    triage_result: dict,
    report: dict,
    wt_path: Path,
    ctx: pr_context.ResolvedContext,
    trail: Trail | None = None,
) -> dict:
    """Apply mechanical fixes for valid actionable comment threads and items.

    Returns a fix_pass dict with fixed/needs_human/deferred/commit_sha
    plus comment_items breakdown.
    """
    threads_by_id = {t["id"]: t for t in report["threads"]}

    # Classify threads
    fixable, needs_human, dismissed = _classify_triage_entries(
        triage_result.get("threads", []),
    )

    # Classify comment items
    fixable_items, items_needs_human, items_dismissed = _classify_triage_entries(
        triage_result.get("comment_items", []),
    )

    all_needs_human = needs_human + items_needs_human
    all_dismissed = dismissed + items_dismissed

    no_commit = CommitPushResult(None, "no_changes", "")

    dismissed_replies = 0
    if dismissed:
        dismissed_replies = _post_dismissed_replies(
            dismissed, threads_by_id, ctx.repo, report["pr_number"],
        )

    all_fixable = bool(fixable) or bool(fixable_items)
    has_items = bool(fixable_items) or bool(items_needs_human) or bool(items_dismissed)

    empty_result = {
        "fixed": [], "needs_human": all_needs_human, "dismissed": all_dismissed,
        "deferred": [], "commit_sha": None,
        "commit_status": "no_changes",
        "replies_posted": dismissed_replies, "summary_url": None,
        "comment_items": {
            "fixed": [], "needs_human": items_needs_human,
            "dismissed": items_dismissed, "deferred": [],
        },
    }

    if not all_fixable:
        if all_dismissed or all_needs_human:
            summary_url = _post_or_defer_summary(
                [], all_needs_human, [], no_commit, ctx.repo, report["pr_number"],
                threads_by_id, wt_path, ctx, dismissed=all_dismissed,
                issue_comments=report.get("issue_comments"),
                review_body_comments=report.get("review_body_comments"),
                has_comment_items=has_items,
            )
        else:
            summary_url = None
        empty_result["summary_url"] = summary_url
        empty_result["summary_deferred"] = summary_url is None and bool(all_needs_human)
        _persist_fix_state(pr_state.FixSummary(
            threads=_build_thread_outcomes([], [], all_needs_human, all_dismissed),
            commit_status=no_commit.status,
            replies_posted=dismissed_replies,
            summary_url=summary_url or "",
            summary_deferred=summary_url is None and bool(all_needs_human),
            updated_at=pr_state.now_iso(),
        ), wt_path, ctx, trail)
        return empty_result

    tracking_dir = wt_path / "ignore" / "pr-comments"
    tracking_file = tracking_dir / "fix-tracking.md"

    _build_tracking_file(
        tracking_file, fixable, threads_by_id,
        wt_path, report["pr_number"],
        fixable_items=fixable_items,
    )

    total_items = len(fixable) + len(fixable_items or [])
    max_turns = _fix_turn_budget(total_items)
    max_budget = _fix_budget_usd(total_items)

    head_before = _get_head_sha(wt_path)

    main_wt = _find_and_update_main_worktree(wt_path)

    prompt = _render_fix_template(
        branch=ctx.branch,
        repo=ctx.repo,
        threads_content=tracking_file.read_text(),
        tracking_file=str(tracking_file),
        wt_path=str(wt_path),
        max_turns=max_turns,
        main_wt_path=str(main_wt) if main_wt else "",
    )

    log.info("Fix pass — applying review comment suggestions...")
    _invoke_fix_agent(prompt, wt_path, main_wt,
                      max_turns=max_turns, max_budget=max_budget)
    log.blank()

    fixed, deferred, fixed_items, deferred_items = _parse_tracking_results(
        tracking_file, fixable, fixable_items=fixable_items,
    )

    fixed, deferred = _reconcile_fix_results(
        fixed, deferred, wt_path, head_before,
    )
    fixed_items, deferred_items = _reconcile_fix_results(
        fixed_items, deferred_items, wt_path, head_before,
    )

    all_deferred_pre_retry = deferred + deferred_items
    if all_deferred_pre_retry:
        retry_fixed, retry_deferred, retry_fixed_items, retry_deferred_items = (
            _retry_fix_pass(
                deferred, deferred_items, fixable, fixable_items or [],
                threads_by_id, wt_path, report["pr_number"],
                ctx, main_wt, max_turns, trail,
            )
        )
        fixed = fixed + retry_fixed
        deferred = retry_deferred
        fixed_items = fixed_items + retry_fixed_items
        deferred_items = retry_deferred_items

    fixed_count = len(fixed) + len(fixed_items)
    deferred_count = len(deferred) + len(deferred_items)

    cp = _commit_and_push(wt_path, fixed_count, deferred_count, trail=trail)

    if cp.status in ("no_changes", "commit_failed"):
        cp = _recover_agent_commit(wt_path, head_before, trail)

    replies_posted = dismissed_replies
    if fixed:
        if cp.sha:
            replies_posted += _post_fix_replies(
                fixed, threads_by_id, ctx.repo, report["pr_number"], cp.sha,
            )
        else:
            replies_posted += _post_already_addressed_replies(
                fixed, threads_by_id, ctx.repo, report["pr_number"], wt_path,
            )
        _resolve_fixed_threads(fixed, threads_by_id)

    # Merge item results into the overall lists for summary/state
    all_fixed = fixed + fixed_items
    all_deferred = deferred + deferred_items

    pending_deferred = bool(all_deferred) or bool(all_needs_human)

    summary_url = _post_or_defer_summary(
        all_fixed, all_needs_human, all_deferred, cp,
        ctx.repo, report["pr_number"],
        threads_by_id, wt_path, ctx, dismissed=all_dismissed,
        issue_comments=report.get("issue_comments"),
        review_body_comments=report.get("review_body_comments"),
        has_comment_items=has_items,
    )

    _persist_fix_state(pr_state.FixSummary(
        threads=_build_thread_outcomes(
            all_fixed, all_deferred, all_needs_human, all_dismissed,
        ),
        commit_sha=cp.sha or "",
        commit_status=cp.status,
        replies_posted=replies_posted,
        summary_url=summary_url or "",
        summary_deferred=summary_url is None and pending_deferred,
        reconciled_count=0,
        updated_at=pr_state.now_iso(),
    ), wt_path, ctx, trail)

    return {
        "fixed": all_fixed,
        "needs_human": all_needs_human,
        "dismissed": all_dismissed,
        "deferred": all_deferred,
        "commit_sha": cp.sha,
        "commit_status": cp.status,
        "replies_posted": replies_posted,
        "summary_url": summary_url,
        "summary_deferred": summary_url is None and pending_deferred,
        "comment_items": {
            "fixed": fixed_items, "needs_human": items_needs_human,
            "dismissed": items_dismissed, "deferred": deferred_items,
        },
    }


def _run_threads(trail, args, ctx) -> None:
    repo = ctx.repo
    pr_number = ctx.pr_number
    branch = ctx.branch
    toplevel = ctx.worktree_root
    head_sha = ctx.head_sha

    owner, repo_name = repo.split("/", 1)

    pr_data = fetch_pr_data(repo, str(pr_number))
    my_login = pr_data.viewer_login

    state_path = toplevel / "ignore" / "pr-comments" / "state.json"

    # Load prior state
    prior_state = pc.load_state(state_path)
    prior_threads = prior_state.get("threads", {}) if prior_state else {}

    # Fetch from GitHub (served from pr_data, no extra API calls)
    threads_raw = pc.fetch_threads(owner, repo_name, pr_number, pr_data)
    verdicts = pc.fetch_reviewer_verdicts(repo, pr_number, pr_data)
    issue_comments = pc.fetch_issue_comments(repo, pr_number, my_login, pr_data)
    review_body_comments = pc.fetch_review_body_comments(
        repo, pr_number, my_login, pr_data,
    )
    trail.info("fetch_threads", f"fetched {len(threads_raw)} threads",
               data={"count": len(threads_raw)})

    # Sync
    threads = pc.sync_threads(threads_raw, prior_threads, my_login)
    synced_resolved = sum(1 for t in threads.values() if t.get("state") == "resolved")
    synced_open = len(threads) - synced_resolved
    trail.info("sync_threads", f"{synced_resolved} resolved, {synced_open} open",
               data={"resolved": synced_resolved, "open": synced_open, "total": len(threads)})

    # Resolve verified threads if requested (or as part of triage)
    if args.resolve or args.triage:
        resolved_count = _resolve_verified_threads(threads_raw, threads)
        if resolved_count:
            log.info(f"Resolved {resolved_count} verified threads")

    # Save state
    state = pc.empty_state(repo, pr_number, my_login)
    state["threads"] = threads
    pc.save_state(state_path, state)

    # Dashboard to stderr
    dashboard = pc.render_dashboard(
        pr_number, threads, verdicts, issue_comments,
        review_body_comments=review_body_comments,
    )
    print(dashboard, file=sys.stderr)

    # JSON report to stdout
    report = {
        "repo": repo,
        "pr_number": pr_number,
        "my_login": my_login,
        "threads": [],
        "issue_comments": issue_comments,
        "review_body_comments": review_body_comments,
        "verdicts": verdicts,
    }
    for thread_data in threads_raw:
        tid = thread_data["id"]
        t = threads.get(tid, {})
        comments = thread_data.get("comments", {}).get("nodes", [])
        report["threads"].append({
            "id": tid,
            "state": t.get("state", "new"),
            "classification": t.get("classification"),
            "reviewer": t.get("reviewer", ""),
            "comments": comments,
            "is_resolved": thread_data.get("isResolved", False),
            "file": thread_data.get("path"),
            "line": thread_data.get("line"),
        })

    # Update unified PR state (best-effort)
    ctx_args = dict(
        worktree_root=toplevel, repo=repo, branch=branch,
        pr_number=pr_number, head_sha=head_sha,
    )
    try:
        thread_states: dict[str, int] = {}
        for t in report["threads"]:
            s = t.get("state", "new")
            thread_states[s] = thread_states.get(s, 0) + 1
        blocking = [
            v.get("user", "unknown")
            for v in report.get("verdicts", [])
            if v.get("state") == "CHANGES_REQUESTED"
        ]
        has_approvals = any(
            v.get("state") == "APPROVED" for v in report.get("verdicts", [])
        )
        st = pr_state.load_or_init(**ctx_args)
        prior_seen_ids = set(st.comments.seen_issue_comment_ids)
        current_ids = [c["id"] for c in issue_comments]
        for c in issue_comments:
            c["seen"] = c["id"] in prior_seen_ids
        prior_seen_review_ids = set(st.comments.seen_review_body_comment_ids)
        current_review_ids = [c["id"] for c in review_body_comments]
        for c in review_body_comments:
            c["seen"] = c["id"] in prior_seen_review_ids
        pr_state.update_comments(st, pr_state.CommentsSummary(
            total_threads=len(report["threads"]),
            by_state=thread_states,
            blocking_reviewers=blocking,
            has_approvals=has_approvals,
            seen_issue_comment_ids=current_ids,
            seen_review_body_comment_ids=current_review_ids,
            updated_at=pr_state.now_iso(),
        ))
        if args.resolve:
            _post_pending_comments(st, repo, pr_number)
            threads_by_id = {t["id"]: t for t in report["threads"]}
            _finalize_deferred(ctx, threads_by_id, trail=trail)
        pr_state.save_state(toplevel, st)
    except Exception as exc:
        trail.error("state_update", f"state update failed: {exc}")
        log.error(f"state update failed: {exc}")

    # Triage and/or fix mode
    if args.triage:
        triage_mode = "fix" if args.fix else "triage"
        trail.decision("triage_mode", f"running {triage_mode}",
                       reason="--fix flag" if args.fix else "--triage flag",
                       data={"fix": args.fix, "triage": args.triage})
        triage_result, rc = _run_triage(report, toplevel, ctx_args, trail=trail)
        if rc != 0:
            sys.exit(rc)

        if args.fix and triage_result:
            triage_threads = triage_result.get("threads", [])
            triage_items = triage_result.get("comment_items", [])
            fixable_count = sum(
                1 for t in triage_threads
                if t.get("classification") == "actionable_suggestion"
                and t.get("verification") == "valid"
            )
            fixable_items_count = sum(
                1 for it in triage_items
                if it.get("classification") == "actionable_suggestion"
                and it.get("verification") == "valid"
            )
            trail.decision(
                "fix_classification",
                f"{fixable_count} fixable threads, {fixable_items_count} fixable items identified",
                reason="classification=actionable_suggestion and verification=valid",
                data={"fixable": fixable_count, "fixable_items": fixable_items_count,
                      "total": len(triage_threads), "total_items": len(triage_items)},
            )
            fix_pass = _run_comment_fix(triage_result, report, toplevel, ctx, trail=trail)
            deferred_count = len(fix_pass.get("deferred", []))
            dismissed_count = len(fix_pass.get("dismissed", []))
            trail.info("fix_result", "fix pass complete",
                       data={"fixable": fixable_count, "deferred": deferred_count,
                             "dismissed": dismissed_count,
                             "commit_sha": fix_pass.get("commit_sha"),
                             "commit_status": fix_pass.get("commit_status")})
            output = {**triage_result, "fix_pass": fix_pass,
                      "issue_comments": report.get("issue_comments", []),
                      "review_body_comments": report.get("review_body_comments", [])}
        else:
            output = {**triage_result,
                      "issue_comments": report.get("issue_comments", []),
                      "review_body_comments": report.get("review_body_comments", [])}

        json.dump(output, sys.stdout, indent=2)
        print()
        sys.exit(0)

    json.dump(report, sys.stdout, indent=2)
    print()


def main():
    parser = argparse.ArgumentParser(description="PR review thread status")
    parser.add_argument("--pr", help="PR number")
    parser.add_argument("--branch", help="Branch name (resolved via resolve-branch)")
    parser.add_argument("--triage", action="store_true",
                        help="Classify threads via AI and auto-resolve verified")
    parser.add_argument("--fix", action="store_true",
                        help="Triage threads and apply mechanical fixes via Claude agent")
    parser.add_argument("--resolve", "--resolve-verified", action="store_true",
                        dest="resolve",
                        help="Resolve all verified threads on GitHub")
    parser.add_argument("--repo-dir", "--worktree",
                        help="Git worktree directory (skips git toplevel detection)")
    add_trail_args(parser)
    args = parser.parse_args()

    if args.fix:
        args.triage = True

    ctx = pr_context.resolve(
        pr=args.pr, branch=args.branch, repo_dir=args.repo_dir,
    )
    repo = ctx.repo
    pr_number = ctx.pr_number
    if pr_number is None:
        log.error("No PR found for current branch")
        sys.exit(1)
    branch = ctx.branch
    toplevel = ctx.worktree_root
    head_sha = ctx.head_sha

    trail = Trail.start(
        script="review-threads",
        artifact_dir=str(toplevel / pr_state.STATE_DIR),
        context={"repo": repo, "pr": pr_number, "branch": branch},
        debug=args.debug,
    )

    try:
        _run_threads(trail, args, ctx)
    except Exception as exc:
        trail.error("unexpected_error", str(exc))
        raise
    finally:
        trail.finish()


if __name__ == "__main__":
    main()
