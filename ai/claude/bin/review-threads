#!/usr/bin/env python3
"""Fetch PR review threads, compute lifecycle states, and output status.

Renders a human-readable dashboard to stderr and structured JSON to stdout.
Manages local state in <worktree>/ignore/pr-comments/state.json.

Usage:
  review-threads [--pr NUMBER] [--branch NAME] [--repo-dir PATH]
  review-threads --triage
  review-threads --fix
  review-threads --resolve
"""

import argparse
import json
import re
import subprocess
import sys
from pathlib import Path
from string import Template

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

import ai_backend
import pr_comments as pc
import pr_context
import pr_state
import review_common
from review_github import fetch_pr_data
from trail import Trail, add_trail_args

TRIAGE_CONTEXT_LINES = 10
FIX_MAX_TURNS = 15
FIX_MODEL = "sonnet"
TEMPLATE_DIR = Path(__file__).resolve().parent.parent / "lib" / "review-templates"


def _resolve_verified_threads(threads_raw: list, threads: dict) -> int:
    """Resolve all verified threads on GitHub. Returns count resolved."""
    resolved = 0
    for thread_data in threads_raw:
        tid = thread_data["id"]
        if threads.get(tid, {}).get("state") != pc.STATE_VERIFIED:
            continue
        if not pc.resolve_thread(tid):
            continue
        threads[tid]["state"] = pc.STATE_RESOLVED
        resolved += 1
    return resolved


def _gather_code_context(threads: list, repo_dir: Path) -> str:
    """Read surrounding source lines for each thread's file location."""
    snippets = []
    for t in threads:
        file_path = t.get("file")
        line = int(t.get("line") or 0)
        if not file_path or line == 0:
            continue
        full_path = repo_dir / file_path
        if not full_path.is_file():
            continue
        try:
            lines = full_path.read_text().splitlines()
        except OSError:
            continue
        start = max(0, line - 1 - TRIAGE_CONTEXT_LINES)
        end = min(len(lines), line + TRIAGE_CONTEXT_LINES)
        snippet = "\n".join(lines[start:end])
        if snippet:
            snippets.append(f"--- {file_path}:{start + 1}-{end} ---\n{snippet}\n---")
    return "\n".join(snippets)


def _build_triage_prompt(non_resolved: list, code_context: str) -> str:
    """Build the AI classification prompt for thread triage."""
    thread_json = json.dumps(non_resolved, indent=2)
    context_block = ""
    if code_context:
        context_block = f"\nCode context for referenced files:\n{code_context}\n"

    return f"""You are a code review triage assistant. Analyze these PR review threads and classify each one.

For each thread, provide:
1. classification: one of 'actionable_suggestion', 'question', 'approval', 'conflicting'
2. verification (only for actionable_suggestion): one of 'valid', 'invalid', 'needs_discussion'
3. reasoning: one sentence explaining your classification/verification
4. summary: one-line summary of the thread

Thread data:
{thread_json}
{context_block}
Return JSON matching this exact schema:
{{
  "threads": [
    {{
      "id": "thread_id from input",
      "state": "state from input",
      "classification": "actionable_suggestion|question|approval|conflicting",
      "verification": "valid|invalid|needs_discussion (only for actionable_suggestion, empty string otherwise)",
      "reasoning": "brief explanation",
      "file": "file from input",
      "line": "line_from_input",
      "reviewer": "reviewer from input",
      "summary": "one-line summary"
    }}
  ],
  "stats": {{
    "total": "count",
    "actionable": "count",
    "questions": "count",
    "approvals": "count",
    "conflicting": "count",
    "valid": "count",
    "invalid": "count"
  }}
}}

IMPORTANT: Return ONLY the JSON object, no markdown fencing or explanation."""


def _run_triage(report: dict, repo_dir: Path, ctx_args: dict) -> tuple[dict | None, int]:
    """Classify non-resolved threads via AI and update triage state.

    Returns (triage_result, exit_code). Caller handles stdout output.
    """
    non_resolved = [t for t in report["threads"] if t.get("state") != "resolved"]
    if not non_resolved:
        empty = {"threads": [], "stats": {
            "total": 0, "actionable": 0, "questions": 0,
            "approvals": 0, "conflicting": 0, "valid": 0, "invalid": 0,
        }}
        return empty, 0

    code_context = _gather_code_context(non_resolved, repo_dir)
    prompt = _build_triage_prompt(non_resolved, code_context)

    stdout, rc = ai_backend.prompt(prompt)
    if rc != 0:
        print("review-threads: ai prompt failed", file=sys.stderr)
        return None, 1

    try:
        triage_result = json.loads(stdout)
    except (json.JSONDecodeError, TypeError):
        print("review-threads: ai returned non-JSON output", file=sys.stderr)
        return None, 1

    # Update triage state
    try:
        stats = triage_result.get("stats", {})
        st = pr_state.load_or_init(**ctx_args)
        pr_state.update_triage(st, pr_state.TriageSummary(
            total=stats.get("total", 0),
            actionable=stats.get("actionable", 0),
            valid=stats.get("valid", 0),
            questions=stats.get("questions", 0),
            updated_at=pr_state.now_iso(),
        ))
        pr_state.save_state(ctx_args["worktree_root"], st)
    except Exception as exc:
        print(f"review-threads: triage state update failed: {exc}", file=sys.stderr)

    return triage_result, 0


def _thread_comment_text(comments: list) -> str:
    """Format a thread's comments as quoted conversation."""
    parts = []
    for c in comments:
        author = c.get("author", {}).get("login", "unknown")
        body = c.get("body", "").strip()
        if body:
            quoted = "\n".join(f"> {line}" for line in body.splitlines())
            parts.append(f"**@{author}:**\n{quoted}")
    return "\n\n".join(parts)


def _code_context_for_thread(file_path: str, line: int | str, repo_dir: Path) -> str:
    """Read surrounding source lines for a single thread's file location."""
    line = int(line) if line else 0
    if not file_path or line == 0:
        return ""
    full_path = repo_dir / file_path
    if not full_path.is_file():
        return ""
    try:
        lines = full_path.read_text().splitlines()
    except OSError:
        return ""
    start = max(0, line - 1 - TRIAGE_CONTEXT_LINES)
    end = min(len(lines), line + TRIAGE_CONTEXT_LINES)
    snippet = "\n".join(lines[start:end])
    return f"```\n{snippet}\n```" if snippet else ""


def _build_tracking_file(
    tracking_path: Path,
    fixable: list[dict],
    threads_by_id: dict,
    repo_dir: Path,
    pr_number: int,
) -> None:
    """Build the tracking markdown file for the fix agent."""
    sections = []
    for thread in fixable:
        tid = thread["id"]
        report_thread = threads_by_id.get(tid, {})
        file_path = thread.get("file", "")
        line = thread.get("line", 0)
        reviewer = thread.get("reviewer", "")
        summary = thread.get("summary", "")

        comments = report_thread.get("comments", [])
        conversation = _thread_comment_text(comments)
        code_ctx = _code_context_for_thread(file_path, line, repo_dir)

        section = f"## <!-- thread:{tid} --> {file_path}:{line} — @{reviewer}\n\n"
        if summary:
            section += f"**Summary:** {summary}\n\n"
        if conversation:
            section += f"**Conversation:**\n{conversation}\n\n"
        if code_ctx:
            section += f"**Code context:**\n{code_ctx}\n\n"
        section += "- [ ] Apply fix\n"
        sections.append(section)

    content = f"# Comment Fix Tracking — PR #{pr_number}\n\n"
    content += "\n".join(sections)
    tracking_path.parent.mkdir(parents=True, exist_ok=True)
    tracking_path.write_text(content)


def _render_fix_template(
    branch: str, repo: str, threads_content: str,
    tracking_file: str, wt_path: str, max_turns: int,
) -> str:
    """Render the fix-comments.md template."""
    tmpl = Template((TEMPLATE_DIR / review_common.TEMPLATE_FIX_COMMENTS).read_text())
    return tmpl.safe_substitute(
        branch_name=branch,
        repo=repo,
        threads_content=threads_content,
        tracking_file=tracking_file,
        wt_path=wt_path,
        max_turns=str(max_turns),
    )


def _invoke_fix_agent(prompt: str, wt_path: Path) -> int:
    """Run AI agent to apply fixes. Returns exit code."""
    return ai_backend.invoke_fix(
        prompt,
        add_dirs=[str(wt_path)],
        max_turns=FIX_MAX_TURNS,
        model=FIX_MODEL,
    )


def _count_unchecked(path: Path) -> int:
    """Count unchecked checkboxes in a tracking file."""
    if not path.exists():
        return 0
    return sum(
        1 for line in path.read_text().splitlines()
        if re.match(r"^- \[ \] ", line)
    )


def _parse_tracking_results(
    tracking_path: Path, fixable: list[dict],
) -> tuple[list[dict], list[dict]]:
    """Parse tracking file to determine which threads were fixed vs skipped."""
    content = tracking_path.read_text()
    sections = re.split(r"^## <!-- thread:", content, flags=re.MULTILINE)

    fixable_by_id = {t["id"]: t for t in fixable}
    fixed = []
    skipped = []

    for section in sections[1:]:
        tid_match = re.match(r"(\S+) -->", section)
        if not tid_match:
            continue
        tid = tid_match.group(1)
        thread = fixable_by_id.get(tid)
        if not thread:
            continue
        entry = {
            "thread_id": tid,
            "file": thread.get("file", ""),
            "line": thread.get("line", 0),
            "reviewer": thread.get("reviewer", ""),
            "summary": thread.get("summary", ""),
        }
        if re.search(r"^- \[[xX]\] ", section, re.MULTILINE):
            fixed.append(entry)
        else:
            entry["reason"] = "agent could not auto-fix"
            skipped.append(entry)

    return fixed, skipped


def _commit_and_push(wt_path: Path, fixed: int, skipped: int) -> str | None:
    """Commit and push fixes if there are changes. Returns commit SHA or None."""
    result = subprocess.run(
        ["git", "-C", str(wt_path), "diff", "--quiet"],
        capture_output=True,
    )
    if result.returncode == 0:
        return None

    subprocess.run(
        ["git", "-C", str(wt_path), "add", "-A"],
        capture_output=True, check=True,
    )

    msg = "fix: address review comments"
    if fixed:
        msg += f"\n\n{fixed} fixed, {skipped} skipped"

    result = subprocess.run(
        ["git", "-C", str(wt_path), "commit", "-m", msg],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        print(f"review-threads: commit failed: {result.stderr.strip()}", file=sys.stderr)
        return None

    sha = subprocess.run(
        ["git", "-C", str(wt_path), "rev-parse", "--short", "HEAD"],
        capture_output=True, text=True,
    ).stdout.strip()

    print(f"Committed fixes ({fixed} fixed, {skipped} skipped)", file=sys.stderr)

    push = subprocess.run(
        ["git", "-C", str(wt_path), "push"],
        capture_output=True, text=True,
    )
    if push.returncode == 0:
        print("Pushed fixes", file=sys.stderr)
    else:
        print(
            f"review-threads: push failed — branch has diverged. Run:\n"
            f"  git -C '{wt_path}' push --force-with-lease",
            file=sys.stderr,
        )
        return None

    return sha


def _post_fix_replies(
    fixed: list[dict],
    threads_by_id: dict,
    repo: str,
    pr_number: int,
    commit_sha: str,
) -> int:
    """Post replies to each fixed thread. Returns count of replies posted."""
    posted = 0
    commit_url = f"https://github.com/{repo}/commit/{commit_sha}"
    for entry in fixed:
        tid = entry.get("thread_id", "")
        thread = threads_by_id.get(tid, {})
        comments = thread.get("comments", [])
        if not comments:
            continue
        database_id = comments[0].get("databaseId")
        if not database_id:
            continue
        summary = entry.get("summary", "")
        body = f"Applied: {summary}\n\nFixed in [`{commit_sha}`]({commit_url})."
        if pc.post_thread_reply(repo, pr_number, database_id, body):
            posted += 1
    if posted:
        print(f"Posted {posted} thread replies", file=sys.stderr)
    return posted


def _build_summary_body(
    fixed: list[dict],
    needs_human: list[dict],
    skipped: list[dict],
    commit_sha: str | None,
    repo: str,
) -> str:
    """Build the markdown body for the fix summary comment."""
    fixed_count = len(fixed)
    skipped_count = len(skipped)
    human_count = len(needs_human)

    parts = ["## Review Comments Addressed", ""]
    counts = []
    if fixed_count:
        counts.append(f"**{fixed_count} fixed**")
    if skipped_count:
        counts.append(f"{skipped_count} skipped")
    if human_count:
        counts.append(f"{human_count} need discussion")
    parts.append(" · ".join(counts))
    parts.append("")

    rows = []
    commit_url = f"https://github.com/{repo}/commit/{commit_sha}" if commit_sha else ""
    sha_link = f"[`{commit_sha}`]({commit_url})" if commit_sha else ""
    for entry in fixed:
        summary = entry.get("summary", "—")
        file_loc = f"`{entry.get('file', '')}:{entry.get('line', '')}`"
        status = f"Fixed in {sha_link}" if sha_link else "Fix pending (push failed)"
        rows.append(f"| {summary} | {file_loc} | {status} |")
    for entry in needs_human:
        summary = entry.get("summary", "—")
        file_loc = f"`{entry.get('file', '')}:{entry.get('line', '')}`"
        reason = entry.get("reason", "needs discussion")
        rows.append(f"| {summary} | {file_loc} | {reason} |")
    for entry in skipped:
        summary = entry.get("summary", "—")
        file_loc = f"`{entry.get('file', '')}:{entry.get('line', '')}`"
        rows.append(f"| {summary} | {file_loc} | Skipped |")

    if rows:
        parts.append("| Thread | File | Action |")
        parts.append("|--------|------|--------|")
        parts.extend(rows)
        parts.append("")

    return "\n".join(parts)


def _post_fix_summary(
    fixed: list[dict],
    needs_human: list[dict],
    skipped: list[dict],
    commit_sha: str | None,
    repo: str,
    pr_number: int,
) -> str | None:
    """Post summary issue comment to the PR. Returns the comment URL or None."""
    if not fixed and not needs_human and not skipped:
        return None
    body = _build_summary_body(fixed, needs_human, skipped, commit_sha, repo)
    url = pc.post_issue_comment(repo, pr_number, body)
    if url:
        print(f"Posted fix summary: {url}", file=sys.stderr)
    else:
        print("review-threads: failed to post fix summary", file=sys.stderr)
    return url


def _run_comment_fix(
    triage_result: dict,
    report: dict,
    wt_path: Path,
    ctx: pr_context.ResolvedContext,
) -> dict:
    """Apply mechanical fixes for valid actionable comment threads.

    Returns a fix_pass dict with fixed/needs_human/skipped/commit_sha.
    """
    threads_by_id = {t["id"]: t for t in report["threads"]}
    triage_threads = triage_result.get("threads", [])

    fixable = []
    needs_human = []

    for tt in triage_threads:
        entry = {
            "thread_id": tt.get("id", ""),
            "file": tt.get("file", ""),
            "line": tt.get("line", 0),
            "reviewer": tt.get("reviewer", ""),
            "summary": tt.get("summary", ""),
        }
        classification = tt.get("classification", "")
        verification = tt.get("verification", "")
        state = tt.get("state", "")

        if state == "contested":
            needs_human.append({**entry, "reason": "contested"})
            continue

        if classification == "conflicting":
            needs_human.append({**entry, "reason": "conflicting"})
            continue

        if classification == "question":
            needs_human.append({**entry, "reason": "question"})
            continue

        if classification != "actionable_suggestion":
            continue

        if verification == "valid":
            fixable.append(tt)
        elif verification == "needs_discussion":
            needs_human.append({**entry, "reason": "needs_discussion"})

    empty_result = {
        "fixed": [], "needs_human": needs_human,
        "skipped": [], "commit_sha": None,
        "replies_posted": 0, "summary_url": None,
    }

    if not fixable:
        if needs_human:
            summary_url = _post_fix_summary(
                [], needs_human, [], None, ctx.repo, report["pr_number"],
            )
            empty_result["summary_url"] = summary_url
        return empty_result

    tracking_dir = wt_path / "ignore" / "pr-comments"
    tracking_file = tracking_dir / "fix-tracking.md"

    _build_tracking_file(
        tracking_file, fixable, threads_by_id,
        wt_path, report["pr_number"],
    )

    before = _count_unchecked(tracking_file)

    prompt = _render_fix_template(
        branch=ctx.branch,
        repo=ctx.repo,
        threads_content=tracking_file.read_text(),
        tracking_file=str(tracking_file),
        wt_path=str(wt_path),
        max_turns=FIX_MAX_TURNS,
    )

    print("Fix pass — applying review comment suggestions...", file=sys.stderr)
    _invoke_fix_agent(prompt, wt_path)
    print(file=sys.stderr)

    after = _count_unchecked(tracking_file)
    fixed_count = before - after

    fixed, skipped = _parse_tracking_results(tracking_file, fixable)

    commit_sha = _commit_and_push(wt_path, fixed_count, after)

    replies_posted = 0
    if commit_sha and fixed:
        replies_posted = _post_fix_replies(
            fixed, threads_by_id, ctx.repo, report["pr_number"], commit_sha,
        )

    summary_url = _post_fix_summary(
        fixed, needs_human, skipped, commit_sha, ctx.repo, report["pr_number"],
    )

    return {
        "fixed": fixed,
        "needs_human": needs_human,
        "skipped": skipped,
        "commit_sha": commit_sha,
        "replies_posted": replies_posted,
        "summary_url": summary_url,
    }


def _run_threads(trail, args, ctx) -> None:
    repo = ctx.repo
    pr_number = ctx.pr_number
    branch = ctx.branch
    toplevel = ctx.worktree_root
    head_sha = ctx.head_sha

    owner, repo_name = repo.split("/", 1)

    pr_data = fetch_pr_data(repo, str(pr_number))
    my_login = pr_data.viewer_login

    state_path = toplevel / "ignore" / "pr-comments" / "state.json"

    # Load prior state
    prior_state = pc.load_state(state_path)
    prior_threads = prior_state.get("threads", {}) if prior_state else {}

    # Fetch from GitHub (served from pr_data, no extra API calls)
    threads_raw = pc.fetch_threads(owner, repo_name, pr_number, pr_data)
    verdicts = pc.fetch_reviewer_verdicts(repo, pr_number, pr_data)
    issue_comments = pc.fetch_issue_comments(repo, pr_number, my_login, pr_data)
    trail.info("fetch_threads", f"fetched {len(threads_raw)} threads",
               data={"count": len(threads_raw)})

    # Sync
    threads = pc.sync_threads(threads_raw, prior_threads, my_login)
    synced_resolved = sum(1 for t in threads.values() if t.get("state") == "resolved")
    synced_open = len(threads) - synced_resolved
    trail.info("sync_threads", f"{synced_resolved} resolved, {synced_open} open",
               data={"resolved": synced_resolved, "open": synced_open, "total": len(threads)})

    # Resolve verified threads if requested (or as part of triage)
    if args.resolve or args.triage:
        resolved_count = _resolve_verified_threads(threads_raw, threads)
        if resolved_count:
            print(f"Resolved {resolved_count} verified threads", file=sys.stderr)

    # Save state
    state = pc.empty_state(repo, pr_number, my_login)
    state["threads"] = threads
    pc.save_state(state_path, state)

    # Dashboard to stderr
    dashboard = pc.render_dashboard(pr_number, threads, verdicts, issue_comments)
    print(dashboard, file=sys.stderr)

    # JSON report to stdout
    report = {
        "repo": repo,
        "pr_number": pr_number,
        "my_login": my_login,
        "threads": [],
        "issue_comments": issue_comments,
        "verdicts": verdicts,
    }
    for thread_data in threads_raw:
        tid = thread_data["id"]
        t = threads.get(tid, {})
        comments = thread_data.get("comments", {}).get("nodes", [])
        report["threads"].append({
            "id": tid,
            "state": t.get("state", "new"),
            "classification": t.get("classification"),
            "reviewer": t.get("reviewer", ""),
            "comments": comments,
            "is_resolved": thread_data.get("isResolved", False),
            "file": thread_data.get("path"),
            "line": thread_data.get("line"),
        })

    # Update unified PR state (best-effort)
    ctx_args = dict(
        worktree_root=toplevel, repo=repo, branch=branch,
        pr_number=pr_number, head_sha=head_sha,
    )
    try:
        thread_states: dict[str, int] = {}
        for t in report["threads"]:
            s = t.get("state", "new")
            thread_states[s] = thread_states.get(s, 0) + 1
        blocking = [
            v.get("author", {}).get("login", "unknown")
            for v in report.get("verdicts", [])
            if v.get("state") == "CHANGES_REQUESTED"
        ]
        has_approvals = any(
            v.get("state") == "APPROVED" for v in report.get("verdicts", [])
        )
        st = pr_state.load_or_init(**ctx_args)
        pr_state.update_comments(st, pr_state.CommentsSummary(
            total_threads=len(report["threads"]),
            by_state=thread_states,
            blocking_reviewers=blocking,
            has_approvals=has_approvals,
            updated_at=pr_state.now_iso(),
        ))
        pr_state.save_state(toplevel, st)
    except Exception as exc:
        print(f"review-threads: state update failed: {exc}", file=sys.stderr)

    # Triage and/or fix mode
    if args.triage:
        triage_mode = "fix" if args.fix else "triage"
        trail.decision("triage_mode", f"running {triage_mode}",
                       reason="--fix flag" if args.fix else "--triage flag",
                       data={"fix": args.fix, "triage": args.triage})
        triage_result, rc = _run_triage(report, toplevel, ctx_args)
        if rc != 0:
            sys.exit(rc)

        if args.fix and triage_result:
            triage_threads = triage_result.get("threads", [])
            fixable_count = sum(
                1 for t in triage_threads
                if t.get("classification") == "actionable_suggestion"
                and t.get("verification") == "valid"
            )
            trail.decision(
                "fix_classification",
                f"{fixable_count} fixable threads identified",
                reason="classification=actionable_suggestion and verification=valid",
                data={"fixable": fixable_count, "total": len(triage_threads)},
            )
            fix_pass = _run_comment_fix(triage_result, report, toplevel, ctx)
            skipped_count = len(fix_pass.get("skipped", []))
            trail.info("fix_result", "fix pass complete",
                       data={"fixable": fixable_count, "skipped": skipped_count,
                             "commit_sha": fix_pass.get("commit_sha")})
            output = {**triage_result, "fix_pass": fix_pass}
        else:
            output = triage_result

        json.dump(output, sys.stdout, indent=2)
        print()
        sys.exit(0)

    json.dump(report, sys.stdout, indent=2)
    print()


def main():
    parser = argparse.ArgumentParser(description="PR review thread status")
    parser.add_argument("--pr", help="PR number")
    parser.add_argument("--branch", help="Branch name (resolved via resolve-branch)")
    parser.add_argument("--triage", action="store_true",
                        help="Classify threads via AI and auto-resolve verified")
    parser.add_argument("--fix", action="store_true",
                        help="Triage threads and apply mechanical fixes via Claude agent")
    parser.add_argument("--resolve", "--resolve-verified", action="store_true",
                        dest="resolve",
                        help="Resolve all verified threads on GitHub")
    parser.add_argument("--repo-dir", "--worktree",
                        help="Git worktree directory (skips git toplevel detection)")
    add_trail_args(parser)
    args = parser.parse_args()

    if args.fix:
        args.triage = True

    ctx = pr_context.resolve(
        pr=args.pr, branch=args.branch, repo_dir=args.repo_dir,
    )
    repo = ctx.repo
    pr_number = ctx.pr_number
    if pr_number is None:
        print("No PR found for current branch", file=sys.stderr)
        sys.exit(1)
    branch = ctx.branch
    toplevel = ctx.worktree_root
    head_sha = ctx.head_sha

    trail = Trail.start(
        script="review-threads",
        artifact_dir=str(toplevel / pr_state.STATE_DIR),
        context={"repo": repo, "pr": pr_number, "branch": branch},
        debug=args.debug,
    )

    try:
        _run_threads(trail, args, ctx)
    except Exception as exc:
        trail.error("unexpected_error", str(exc))
        raise
    finally:
        trail.finish()


if __name__ == "__main__":
    main()
