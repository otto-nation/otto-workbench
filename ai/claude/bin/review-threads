#!/usr/bin/env python3
"""Fetch PR review threads, compute lifecycle states, and output status.

Renders a human-readable dashboard to stderr and structured JSON to stdout.
Manages local state in <worktree>/ignore/pr-comments/state.json.

Usage:
  review-threads [--pr NUMBER] [--branch NAME] [--repo-dir PATH]
  review-threads --resolve-verified
"""

import argparse
import json
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

import pr_comments as pc
import pr_context
import pr_state


def _my_login() -> str:
    """Get the current GitHub user login."""
    result = subprocess.run(
        ["gh", "api", "user", "--jq", ".login"],
        capture_output=True, text=True,
    )
    return result.stdout.strip()


def _resolve_verified_threads(threads_raw: list, threads: dict) -> int:
    """Resolve all verified threads on GitHub. Returns count resolved."""
    resolved = 0
    for thread_data in threads_raw:
        tid = thread_data["id"]
        if threads.get(tid, {}).get("state") != pc.STATE_VERIFIED:
            continue
        if not pc.resolve_thread(tid):
            continue
        threads[tid]["state"] = pc.STATE_RESOLVED
        resolved += 1
    return resolved


def main():
    parser = argparse.ArgumentParser(description="PR review thread status")
    parser.add_argument("--pr", help="PR number")
    parser.add_argument("--branch", help="Branch name (resolved via resolve-branch)")
    parser.add_argument("--resolve-verified", action="store_true",
                        help="Resolve all verified threads on GitHub")
    parser.add_argument("--repo-dir", "--repo", "--worktree",
                        help="Git worktree directory (skips git toplevel detection)")
    args = parser.parse_args()

    ctx = pr_context.resolve(
        pr=args.pr, branch=args.branch, repo_dir=args.repo_dir,
    )
    repo = ctx.repo
    pr_number = ctx.pr_number
    if pr_number is None:
        print("No PR found for current branch", file=sys.stderr)
        sys.exit(1)
    branch = ctx.branch
    toplevel = ctx.worktree_root
    head_sha = ctx.head_sha

    owner, repo_name = repo.split("/", 1)
    my_login = _my_login()

    state_path = toplevel / "ignore" / "pr-comments" / "state.json"

    # Load prior state
    prior_state = pc.load_state(state_path)
    prior_threads = prior_state.get("threads", {}) if prior_state else {}

    # Fetch from GitHub
    threads_raw = pc.fetch_threads(owner, repo_name, pr_number)
    verdicts = pc.fetch_reviewer_verdicts(repo, pr_number)
    issue_comments = pc.fetch_issue_comments(repo, pr_number, my_login)

    # Sync
    threads = pc.sync_threads(threads_raw, prior_threads, my_login)

    # Resolve verified threads if requested
    if args.resolve_verified:
        resolved_count = _resolve_verified_threads(threads_raw, threads)
        if resolved_count:
            print(f"Resolved {resolved_count} verified threads", file=sys.stderr)

    # Save state
    state = pc.empty_state(repo, pr_number, my_login)
    state["threads"] = threads
    pc.save_state(state_path, state)

    # Dashboard to stderr
    dashboard = pc.render_dashboard(pr_number, threads, verdicts, issue_comments)
    print(dashboard, file=sys.stderr)

    # JSON report to stdout
    report = {
        "repo": repo,
        "pr_number": pr_number,
        "my_login": my_login,
        "threads": [],
        "issue_comments": issue_comments,
        "verdicts": verdicts,
    }
    for thread_data in threads_raw:
        tid = thread_data["id"]
        t = threads.get(tid, {})
        comments = thread_data.get("comments", {}).get("nodes", [])
        report["threads"].append({
            "id": tid,
            "state": t.get("state", "new"),
            "classification": t.get("classification"),
            "reviewer": t.get("reviewer", ""),
            "comments": comments,
            "is_resolved": thread_data.get("isResolved", False),
            "file": thread_data.get("path"),
            "line": thread_data.get("line"),
        })

    # Update unified PR state (best-effort)
    try:
        thread_states: dict[str, int] = {}
        for t in report["threads"]:
            s = t.get("state", "new")
            thread_states[s] = thread_states.get(s, 0) + 1
        blocking = [
            v.get("author", {}).get("login", "unknown")
            for v in report.get("verdicts", [])
            if v.get("state") == "CHANGES_REQUESTED"
        ]
        has_approvals = any(
            v.get("state") == "APPROVED" for v in report.get("verdicts", [])
        )
        st = pr_state.load_or_init(
            worktree_root=toplevel, repo=repo, branch=branch,
            pr_number=pr_number, head_sha=head_sha,
        )
        pr_state.update_comments(st, pr_state.CommentsSummary(
            total_threads=len(report["threads"]),
            by_state=thread_states,
            blocking_reviewers=blocking,
            has_approvals=has_approvals,
            updated_at=pr_state.now_iso(),
        ))
        pr_state.save_state(toplevel, st)
    except Exception as exc:
        print(f"review-threads: state update failed: {exc}", file=sys.stderr)

    json.dump(report, sys.stdout, indent=2)
    print()


if __name__ == "__main__":
    main()
