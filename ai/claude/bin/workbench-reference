#!/usr/bin/env python3
"""Print a reference card of all workbench skills, agents, and modes.

Discovers from SKILL.md frontmatter and agent .md files.

Usage: workbench-reference
  Prints a markdown reference card of all available workbench skills,
  agents, and reuse modes. Auto-discovers from installed files.
"""

from __future__ import annotations

import os
import re
import sys
from pathlib import Path

if "--help" in sys.argv or "-h" in sys.argv:
    for line in (__doc__ or "").strip().splitlines():
        print(line)
    sys.exit(0)

CLAUDE_DIR = Path(os.environ.get("CLAUDE_DIR", os.path.expanduser("~/.claude")))
SKILLS_DIR = CLAUDE_DIR / "skills"
AGENTS_DIR = CLAUDE_DIR / "agents"

FRONTMATTER_RE = re.compile(r"^(\w+):\s*(.*)$")
DESC_TRIM_RE = re.compile(r"\.\s*(?:TRIGGER|SKIP|Use when).*", re.DOTALL)


def _parse_frontmatter(path: Path) -> dict[str, str]:
    fields: dict[str, str] = {}
    in_frontmatter = False
    for line in path.read_text().splitlines():
        if line.strip() == "---":
            if in_frontmatter:
                break
            in_frontmatter = True
            continue
        if not in_frontmatter:
            continue
        m = FRONTMATTER_RE.match(line)
        if m:
            val = m.group(2).strip().strip('"')
            fields[m.group(1)] = val
    return fields


def _trim_description(desc: str) -> str:
    m = DESC_TRIM_RE.search(desc)
    if m:
        return desc[:m.start() + 1]
    return desc


def _print_skills() -> None:
    print("## Skills\n")
    print("| Command | Description |")
    print("|---------|-------------|")

    for skill_file in sorted(SKILLS_DIR.glob("*/SKILL.md")):
        fields = _parse_frontmatter(skill_file)
        name = fields.get("name")
        if not name:
            continue
        invocation = fields.get("invocation", f"/{name}")
        desc = _trim_description(fields.get("description", ""))
        print(f"| `{invocation}` | {desc} |")


def _print_agents() -> None:
    print("\n## Agents\n")
    print("| Agent | Description |")
    print("|-------|-------------|")

    for agent_file in sorted(AGENTS_DIR.glob("*.md")):
        fields = _parse_frontmatter(agent_file)
        name = fields.get("name", agent_file.stem)
        desc = fields.get("description", "")
        print(f"| {name} | {desc} |")


def _print_reuse_modes() -> None:
    print("\n## Reuse Modes\n")
    print("| Level | Behavior |")
    print("|-------|----------|")
    print("| lite | Build what's asked, name the lazier alternative in one line |")
    print("| **full** | Enforce the reuse ladder. Stdlib and native first (default) |")
    print("| ultra | Challenge the requirement. Deletion before addition |")
    print("\nSwitch: `/reuse lite|full|ultra`  ·  Persist: `/reuse default <level>`")


def main() -> None:
    _print_skills()
    _print_agents()
    _print_reuse_modes()


if __name__ == "__main__":
    main()
