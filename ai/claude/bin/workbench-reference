#!/usr/bin/env bash
# Print a reference card of all workbench skills, agents, and modes.
# Discovers from SKILL.md frontmatter and agent .md files.
set -e

CLAUDE_DIR="${CLAUDE_DIR:-$HOME/.claude}"
SKILLS_DIR="$CLAUDE_DIR/skills"
AGENTS_DIR="$CLAUDE_DIR/agents"

# ── Skills ────────────────────────────────────────────────────────────────────

printf "## Skills\n\n"
printf "| Command | Description |\n"
printf "|---------|-------------|\n"

if [[ -d "$SKILLS_DIR" ]]; then
    for skill_file in "$SKILLS_DIR"/*/SKILL.md; do
        [[ -f "$skill_file" ]] || continue
        name=""
        invocation=""
        desc=""
        in_frontmatter=false

        while IFS= read -r line; do
            if [[ "$line" == "---" ]]; then
                if $in_frontmatter; then
                    break
                fi
                in_frontmatter=true
                continue
            fi
            if $in_frontmatter; then
                case "$line" in
                    name:*)      name=$(echo "$line" | sed 's/^name: *//; s/^"//; s/"$//') ;;
                    invocation:*) invocation=$(echo "$line" | sed 's/^invocation: *//; s/^"//; s/"$//') ;;
                esac
            fi
        done < "$skill_file"

        # Extract first sentence of description field
        desc=$(grep '^description:' "$skill_file" | head -1 | sed 's/^description: *"//; s/".*//')
        # Truncate at first period followed by space or TRIGGER
        desc=$(echo "$desc" | sed 's/\. TRIGGER.*/./; s/\. SKIP.*/./; s/\. Use when.*/\./')

        invocation="${invocation:-/$name}"
        [[ -n "$name" ]] && printf "| \`%s\` | %s |\n" "$invocation" "$desc"
    done
fi

# ── Agents ────────────────────────────────────────────────────────────────────

printf "\n## Agents\n\n"
printf "| Agent | Description |\n"
printf "|-------|-------------|\n"

if [[ -d "$AGENTS_DIR" ]]; then
    for agent_file in "$AGENTS_DIR"/*.md; do
        [[ -f "$agent_file" ]] || continue
        name=""
        desc=""
        in_frontmatter=false

        while IFS= read -r line; do
            if [[ "$line" == "---" ]]; then
                if $in_frontmatter; then
                    break
                fi
                in_frontmatter=true
                continue
            fi
            if $in_frontmatter; then
                case "$line" in
                    name:*)        name=$(echo "$line" | sed 's/^name: *//; s/^"//; s/"$//') ;;
                    description:*) desc=$(echo "$line" | sed 's/^description: *//; s/^"//; s/"$//') ;;
                esac
            fi
        done < "$agent_file"

        [[ -z "$name" ]] && name=$(basename "$agent_file" .md)
        [[ -n "$name" ]] && printf "| %s | %s |\n" "$name" "$desc"
    done
fi

# ── Reuse Modes ───────────────────────────────────────────────────────────────

printf "\n## Reuse Modes\n\n"
printf "| Level | Behavior |\n"
printf "|-------|----------|\n"
printf "| lite | Build what's asked, name the lazier alternative in one line |\n"
printf "| **full** | Enforce the reuse ladder. Stdlib and native first (default) |\n"
printf "| ultra | Challenge the requirement. Deletion before addition |\n"
printf "\nSwitch: \`/reuse lite|full|ultra\`  ·  Persist: \`/reuse default <level>\`\n"
