#!/usr/bin/env bash
# Print a reference card of all workbench skills, agents, and modes.
# Discovers from SKILL.md frontmatter and agent .md files.
#
# Usage: workbench-reference
#   Prints a markdown reference card of all available workbench skills,
#   agents, and reuse modes. Auto-discovers from installed files.
set -e

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  # ceiling: duplicated help pattern, extract to shared helper if a third script needs it
  sed -n '/^# Usage:/,/^[^#]/{ /^#/s/^# *//p; }' "$0"
  exit 0
fi

CLAUDE_DIR="${CLAUDE_DIR:-$HOME/.claude}"
SKILLS_DIR="$CLAUDE_DIR/skills"
AGENTS_DIR="$CLAUDE_DIR/agents"

parse_frontmatter_field() {
  local file="$1" field="$2"
  grep "^${field}:" "$file" | head -1 | sed "s/^${field}: *//; s/^\"//; s/\"$//"
}

print_skill_row() {
  local skill_file="$1"
  local name invocation desc

  name=$(parse_frontmatter_field "$skill_file" "name")
  [[ -z "$name" ]] && return 0
  invocation=$(parse_frontmatter_field "$skill_file" "invocation")
  invocation="${invocation:-/$name}"
  desc=$(parse_frontmatter_field "$skill_file" "description")
  desc=$(echo "$desc" | sed 's/\. TRIGGER.*/./; s/\. SKIP.*/./; s/\. Use when.*/\./')
  printf "| \`%s\` | %s |\n" "$invocation" "$desc"
}

print_agent_row() {
  local agent_file="$1"
  local name desc

  name=$(parse_frontmatter_field "$agent_file" "name")
  [[ -z "$name" ]] && name=$(basename "$agent_file" .md)
  desc=$(parse_frontmatter_field "$agent_file" "description")
  printf "| %s | %s |\n" "$name" "$desc"
}

# ── Skills ────────────────────────────────────────────────────────────────────

printf "## Skills\n\n"
printf "| Command | Description |\n"
printf "|---------|-------------|\n"

for skill_file in "$SKILLS_DIR"/*/SKILL.md; do
  [[ -f "$skill_file" ]] || continue
  print_skill_row "$skill_file"
done

# ── Agents ────────────────────────────────────────────────────────────────────

printf "\n## Agents\n\n"
printf "| Agent | Description |\n"
printf "|-------|-------------|\n"

for agent_file in "$AGENTS_DIR"/*.md; do
  [[ -f "$agent_file" ]] || continue
  print_agent_row "$agent_file"
done

# ── Reuse Modes ───────────────────────────────────────────────────────────────

printf "\n## Reuse Modes\n\n"
printf "| Level | Behavior |\n"
printf "|-------|----------|\n"
printf "| lite | Build what's asked, name the lazier alternative in one line |\n"
printf "| **full** | Enforce the reuse ladder. Stdlib and native first (default) |\n"
printf "| ultra | Challenge the requirement. Deletion before addition |\n"
printf "\nSwitch: \`/reuse lite|full|ultra\`  ·  Persist: \`/reuse default <level>\`\n"
