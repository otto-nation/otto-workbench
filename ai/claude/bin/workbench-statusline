#!/usr/bin/env python3
"""Workbench status line — reuse level + PR state.

Called by Claude Code statusline; receives session JSON on stdin.

Usage: workbench-statusline
  Reads session JSON on stdin (from Claude Code statusline hook).
  Outputs compact status: reuse level (if non-default) and PR state.
"""

from __future__ import annotations

import json
import subprocess
import sys
from pathlib import Path

if "--help" in sys.argv or "-h" in sys.argv:
    for line in (__doc__ or "").strip().splitlines():
        print(line)
    sys.exit(0)

sys.path.insert(0, str(Path(__file__).resolve().parent))
from _reuse_levels import read_default, read_level


def _reuse_piece() -> str:
    level = read_level()
    default = read_default()
    if level != default:
        return f"reuse:{level}"
    return ""


def _pr_piece() -> str:
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True,
        )
        if result.returncode != 0:
            return ""
        repo_root = result.stdout.strip()
    except Exception:
        return ""

    state_file = Path(repo_root) / ".workbench" / "state.json"
    if not state_file.is_file():
        return ""

    try:
        state = json.loads(state_file.read_text())
    except (json.JSONDecodeError, OSError):
        return ""

    pr_number = (state.get("identity") or {}).get("pr_number")
    if not pr_number:
        return ""

    label = f"PR#{pr_number}"
    details = _pr_details(state)
    if details:
        label = f"{label} {details}"
    return label


def _pr_details(state: dict) -> str:
    parts: list[str] = []

    ci = state.get("ci") or {}
    ci_conclusion = ci.get("conclusion") or ""
    ci_failures = ci.get("failure_count") or 0
    if ci_conclusion == "failure" and ci_failures > 0:
        parts.append(f"CI:{ci_failures}F")
    elif ci_conclusion == "success":
        parts.append("CI:ok")
    elif ci_conclusion:
        parts.append(f"CI:{ci_conclusion}")

    verdict = (state.get("review") or {}).get("verdict") or ""
    if verdict:
        parts.append(f"review:{verdict}")

    open_threads = (state.get("comments") or {}).get("by_state", {}).get("open") or 0
    if open_threads > 0:
        parts.append(f"{open_threads}open")

    return " ".join(parts)


def main() -> None:
    pieces: list[str] = []
    reuse = _reuse_piece()
    if reuse:
        pieces.append(reuse)
    pr = _pr_piece()
    if pr:
        pieces.append(pr)
    if pieces:
        print(" ".join(pieces), end="")


if __name__ == "__main__":
    main()
