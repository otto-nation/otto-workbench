{
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "command=$(jq -r '.tool_input.command // empty'); if [[ \"$command\" == *\"gh pr create\"* ]]; then echo 'BLOCKED: Use task pr:create instead of gh pr create — it auto-loads the repo PR template.' >&2; exit 2; fi"
          },
          {
            "type": "command",
            "command": "command=$(jq -r '.tool_input.command // empty'); if [[ \"$command\" =~ ^[A-Z_][A-Z0-9_]*= ]]; then echo 'BLOCKED: VAR=value prefix triggers permission prompts. Use tool-native flags instead (task --global REPO_DIR=..., mise -C ..., go env -w ...). See bash-tool.md.' >&2; exit 2; fi"
          },
          {
            "type": "command",
            "command": "command=$(jq -r '.tool_input.command // empty'); if [[ \"$command\" =~ ^cd[[:space:]] ]] && [[ \"$command\" == *'&&'* || \"$command\" == *';'* ]]; then echo 'BLOCKED: Compound cd commands (cd path && ...) trigger unsuppressible permission prompts. Use absolute paths, git -C <path>, or gh --repo instead. See bash-tool.md.' >&2; exit 2; fi"
          },
          {
            "type": "command",
            "command": "command=$(jq -r '.tool_input.command // empty'); stripped=$(printf '%s' \"$command\" | sed \"s/'[^']*'//g\"); if [[ \"$stripped\" =~ \\{[^{}]*[a-zA-Z_][^{}]*,[^{}]*\\} ]]; then echo 'BLOCKED: Brace expansion ({a,b,...}) triggers a permission prompt. List files individually or use a glob (*.go) instead. See bash-tool.md.' >&2; exit 2; fi"
          },
          {
            "type": "command",
            "command": "command=$(jq -r '.tool_input.command // empty'); if [[ \"$command\" =~ ^/[^[:space:]]*/((git/)?bin/local/[^[:space:]]*) ]]; then rel=\"${BASH_REMATCH[1]}\"; echo \"BLOCKED: Use relative path '$rel' instead of absolute path. Absolute paths to bin/local/ scripts trigger a new permission prompt in every worktree.\" >&2; exit 2; fi"
          },
          {
            "type": "command",
            "command": "command=$(jq -r '.tool_input.command // empty'); if [[ \"$command\" == *\"-exec \"* || \"$command\" == *\"-exec\\\"\"* ]]; then echo 'BLOCKED: find -exec triggers an unsuppressible permission prompt. Use find ... -print0 | xargs -0 <command> instead.' >&2; exit 2; fi"
          },
          {
            "type": "command",
            "command": "command=$(jq -r '.tool_input.command // empty'); if [[ \"$command\" == *'$('* ]]; then echo 'BLOCKED: Command substitution $(...) triggers an unsuppressible permission prompt. Run the inner command first, then use the result in the next call. See bash-tool.md.' >&2; exit 2; fi"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file_path=$(jq -r '.tool_input.file_path // empty'); [[ -z \"$file_path\" ]] && exit 0; repo_dir=$(cd \"$(dirname \"$file_path\")\" 2>/dev/null && git rev-parse --show-toplevel 2>/dev/null) || exit 0; branch=$(git -C \"$repo_dir\" branch --show-current 2>/dev/null); [[ -z \"$branch\" ]] && exit 0; if [[ \"$branch\" == \"main\" || \"$branch\" == \"master\" ]]; then echo \"BLOCKED: Cannot edit files on $branch. Create a worktree first: wt switch -c <branch>\" >&2; exit 2; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file_path=$(jq -r '.tool_input.file_path // empty'); if [[ \"$file_path\" == *.sh ]]; then shellcheck \"$file_path\" 2>&1 | head -20 || true; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/dream/should-dream.sh && run-auto-task dream || true"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/promote/should-promote.sh && run-auto-task promote || true"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/retro/should-retro.sh && run-auto-task retro || true"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/anatomy/generate-anatomy.sh || true"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/machine/generate-machine-profile.sh || true"
          },
          {
            "type": "command",
            "command": "find $HOME/.claude/logs -name '*.log' -mtime +7 -delete 2>/dev/null || true"
          }
        ]
      }
    ]
  },
