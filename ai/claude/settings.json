{
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/dream/should-dream.sh && touch $HOME/.claude/.dream-pending || true"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/anatomy/generate-anatomy.sh || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [

      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(echo:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(bat:*)",
      "Bash(tr:*)",
      "Bash(cut:*)",
      "Bash(command:*)",
      "Bash(task:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh run:*)",
      "Bash(gh workflow:*)",
      "Bash(gh release:*)",
      "Bash(gh search:*)",
      "Bash(gh repo view:*)",
      "Bash(gh repo list:*)",
      "Bash(gh repo clone:*)",
      "Bash(gh repo fork:*)",
      "Bash(gh repo sync:*)",
      "Bash(gh auth status:*)",
      "Bash(gh gist:*)",
      "Bash(gh label:*)",
      "Bash(gh milestone:*)",
      "Bash(go:*)",
      "Bash(golangci-lint:*)",
      "Bash(shellcheck:*)",
      "Bash(tree:*)",
      "Bash(gradle:*)",
      "Bash(./gradlew:*)",
      "Bash(brew:*)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:gist.github.com)"
    ],
    "deny": [
      "Bash(git reset:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)"
    ]
  }
}
