{
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "mcp__serena__*",
      "mcp__sequential-thinking__*",
      "mcp__context7__*",
      "mcp__datadog__*",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(echo:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(bat:*)",
      "Bash(tr:*)",
      "Bash(cut:*)",
      "Bash(command:*)",
      "Bash(task:*)",
      "Bash(gh:*)",
      "Bash(gradle:*)",
      "Bash(./gradlew:*)",
      "Bash(brew:*)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:gist.github.com)"
    ],
    "deny": [
      "Bash(git reset:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)"
    ]
  }
}
