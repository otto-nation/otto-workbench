{
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "command=$(jq -r '.tool_input.command // empty'); if [[ \"$command\" == *\"gh pr create\"* ]]; then echo 'BLOCKED: Use task pr:create instead of gh pr create — it auto-loads the repo PR template.' >&2; exit 2; fi"
          },
          {
            "type": "command",
            "command": "command=$(jq -r '.tool_input.command // empty'); if [[ \"$command\" =~ ^[A-Z_][A-Z0-9_]*= ]]; then echo 'BLOCKED: VAR=value prefix triggers permission prompts. Use tool-native flags instead (task --global REPO_DIR=..., mise -C ..., go env -w ...). See git-operations.md.' >&2; exit 2; fi"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file_path=$(jq -r '.tool_input.file_path // empty'); [[ -z \"$file_path\" ]] && exit 0; repo_dir=$(cd \"$(dirname \"$file_path\")\" 2>/dev/null && git rev-parse --show-toplevel 2>/dev/null) || exit 0; branch=$(git -C \"$repo_dir\" branch --show-current 2>/dev/null); [[ -z \"$branch\" ]] && exit 0; if [[ \"$branch\" == \"main\" || \"$branch\" == \"master\" ]]; then echo \"BLOCKED: Cannot edit files on $branch. Create a worktree first: wt switch -c <branch>\" >&2; exit 2; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file_path=$(jq -r '.tool_input.file_path // empty'); if [[ \"$file_path\" == *.sh ]]; then shellcheck \"$file_path\" 2>&1 | head -20 || true; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/dream/should-dream.sh && run-auto-task dream || true"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/promote/should-promote.sh && run-auto-task promote || true"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/retro/should-retro.sh && run-auto-task retro || true"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/anatomy/generate-anatomy.sh || true"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/machine/generate-machine-profile.sh || true"
          },
          {
            "type": "command",
            "command": "wt-cleanup --quiet || true"
          },
          {
            "type": "command",
            "command": "find $HOME/.claude/logs -name '*.log' -mtime +7 -delete 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(echo:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(bat:*)",
      "Bash(tr:*)",
      "Bash(cut:*)",
      "Bash(command:*)",
      "Bash(brew:*)",
      "Bash(ln:*)",
      "Bash(env)",
      "Bash(xargs:*)",
      "Bash(pytest:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(for:*)",
      "Bash(while:*)",
      "Bash(if:*)",
      "Bash([:*)",
      "Bash([[:*)",
      "Bash(test:*)",
      "Bash(true:*)",
      "Bash(false:*)",
      "Bash(set:*)",
      "Bash(cd:*)",
      "Bash(mkdir:*)",
      "Bash(rm:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(realpath:*)",
      "Bash(readlink:*)",
      "Bash(date:*)",
      "Bash(printf:*)",
      "Bash(read:*)",
      "Bash(export:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(curl:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(shasum:*)",
      "Bash(bash:*)",
      "Bash(pip3:*)",
      "Bash(gofmt:*)",
      "Bash(bin/local/*:*)",
      "Bash(git/bin/local/*:*)",
      "Bash(* --help)",
      "Bash(* --help *)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:github.com)",
      "WebSearch",
      "Edit",
      "Write",
      "Read(//tmp/**)",
      "Write(//tmp/**)",
      "Edit(//tmp/**)",
      "Read(//private/tmp/**)",
      "Write(//private/tmp/**)",
      "Edit(//private/tmp/**)",
      "Read(//opt/homebrew/**)"
    ],
    "deny": [
      "Bash(git reset:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)"
    ]
  }
}
