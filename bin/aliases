#!/usr/bin/env zsh
# Auto-discover and display custom aliases and functions from config files

# Resolve the real path: whence -p finds the command in PATH (giving an absolute
# path even when $0 is just the bare name), then readlink follows one symlink level
# to get the actual file in the workbench repo.
_CMD="${$(whence -p "${0:t}" 2>/dev/null):-$0}"
_SELF="$(readlink "$_CMD" 2>/dev/null || echo "$_CMD")"
. "$(dirname "$_SELF")/../lib/ui.sh"

ALIASES_DIR="$HOME/.config/zsh/config.d"
FILTER="${1:-}"

# Display layout
DIVIDER_WIDTH=80
ITEM_NAME_WIDTH=25
ITEM_VALUE_MAX_WIDTH=60

# Skip these files (deprecated/internal)
# aliases-git.zsh is excluded from the normal loop and merged with gitconfig into one section below
# git.zsh is excluded from the main loop and merged with gitconfig aliases into one section below
SKIP_FILES=("git.zsh")

print_header() {
  local title=$1 filter_key=${2:-}
  # Show filter hint only when not already filtering — redundant otherwise
  if [[ -n "$filter_key" && -z "$FILTER" ]]; then
    echo -e "\n${BOLD}${BLUE}${title}${NC}  ${DIM}aliases ${filter_key}${NC}"
  else
    echo -e "\n${BOLD}${BLUE}${title}${NC}"
  fi
  echo -e "${DIM}$(printf '─%.0s' {1..$DIVIDER_WIDTH})${NC}"
}

print_item() {
  local type=$1 name=$2 value=$3
  local color=$GREEN
  [[ "$type" == "function" ]] && color=$CYAN

  value=$(echo "$value" | sed "s/^['\"]//;s/['\"]$//" | cut -c1-$ITEM_VALUE_MAX_WIDTH)
  printf "  ${color}%-${ITEM_NAME_WIDTH}s${NC} ${DIM}→${NC} %s\n" "$name" "$value"
}

should_skip_file() {
  # Space-padding both sides prevents partial matches — e.g., "aws" matching "aws-sso-set.zsh"
  [[ " ${SKIP_FILES[@]} " =~ " $1 " ]]
}

matches_filter() {
  [[ -z "$FILTER" ]] || [[ "$1" =~ "$FILTER" ]]
}

# Process each config file
for config_file in "$ALIASES_DIR"/*.zsh; do
  [[ ! -f "$config_file" ]] && continue

  filename=$(basename "$config_file")
  should_skip_file "$filename" && continue

  # Two-phase filter: first check filename, then search file contents — allows matching
  # by alias/function name even when the config file name doesn't contain the filter term
  if [[ -n "$FILTER" ]] && [[ ! "$filename" =~ "$FILTER" ]]; then
    grep -qiE "^(alias|function) .*$FILTER" "$config_file" 2>/dev/null || continue
  fi

  header=$(grep -m1 "^# .*Configuration" "$config_file" 2>/dev/null | sed 's/^# //' || echo "${filename%.zsh}")
  # Derive filter key: strip "aliases-" prefix and ".zsh" suffix (e.g. aliases-docker.zsh → docker)
  local section_key="${filename#aliases-}"
  section_key="${section_key%.zsh}"

  typeset -a items=()

  # Extract aliases
  while IFS= read -r line; do
    if [[ "$line" =~ ^alias\ +([^=]+)=(.+)$ ]]; then
      name="${match[1]}"
      name="${name## }"; name="${name%% }"
      value="${match[2]}"
      value="${value#\'}"; value="${value%\'}"; value="${value#\"}"; value="${value%\"}"

      # Skip internal/legacy aliases (whitelist specific aws- aliases)
      [[ "$name" =~ ^(aws-|_) ]] && [[ ! "$name" =~ ^(aws-whoami|aws-logout|aws-docker|aws-k8s-qa)$ ]] && continue

      matches_filter "$name" || matches_filter "$value" || continue
      items+=("alias|$name|$value")
    fi
  done < <(grep "^alias " "$config_file" 2>/dev/null)

  # Extract functions
  # prev_line captures the comment directly above a function definition to use as its description;
  # it resets on any non-comment, non-function line so unrelated comments are not carried over
  local prev_line=""
  while IFS= read -r line; do
    if [[ "$line" =~ ^#\ *(.+)$ ]]; then
      prev_line="${match[1]}"
    elif [[ "$line" =~ "^(function +)?([a-zA-Z0-9_-]+) *[(][)] *[{]" ]]; then
      local fname="${match[2]}"
      [[ "$fname" =~ ^_ ]] && continue
      matches_filter "$fname" || continue

      local desc="Function"
      [[ -n "$prev_line" && ! "$prev_line" =~ ^=+ ]] && desc="$prev_line"

      items+=("function|$fname|$desc")
      prev_line=""
    else
      prev_line=""
    fi
  done < "$config_file"

  # Print section if we have items
  if [[ ${#items[@]} -gt 0 ]]; then
    print_header "$header" "$section_key"
    for item in "${items[@]}"; do
      IFS='|' read -r type name value <<< "$item"
      print_item "$type" "$name" "$value"
    done
  fi
done

# Combined git section: ZSH short forms/functions (aliases-git.zsh) + gitconfig aliases
typeset -a git_items=()

GIT_ZSH_FILE="$ALIASES_DIR/git.zsh"
if [[ -f "$GIT_ZSH_FILE" ]]; then
  while IFS= read -r line; do
    if [[ "$line" =~ ^alias\ +([^=]+)=(.+)$ ]]; then
      name="${match[1]}"
      name="${name## }"; name="${name%% }"
      value="${match[2]}"
      value="${value#\'}"; value="${value%\'}"; value="${value#\"}"; value="${value%\"}"
      matches_filter "$name" || matches_filter "$value" || continue
      git_items+=("alias|$name|$value")
    fi
  done < <(grep "^alias " "$GIT_ZSH_FILE")

  local prev_line=""
  while IFS= read -r line; do
    if [[ "$line" =~ ^#\ *(.+)$ ]]; then
      prev_line="${match[1]}"
    elif [[ "$line" =~ "^(function +)?([a-zA-Z0-9_-]+) *[(][)] *[{]" ]]; then
      local fname="${match[2]}"
      [[ "$fname" =~ ^_ ]] && continue
      matches_filter "$fname" || continue
      local desc="Function"
      [[ -n "$prev_line" && ! "$prev_line" =~ ^=+ ]] && desc="$prev_line"
      git_items+=("function|$fname|$desc")
      prev_line=""
    else
      prev_line=""
    fi
  done < "$GIT_ZSH_FILE"
fi

# Double-pipe pattern: the first while runs in a subshell and cannot modify git_items directly;
# piping its output to a second while lets us populate the array in the current shell
git config --get-regexp '^alias\.' 2>/dev/null | while IFS= read -r line; do
  line="${line#alias.}"
  name="${line%% *}"
  value="${line#* }"
  matches_filter "$name" || matches_filter "$value" || continue
  echo "alias|$name|$value"
done | while IFS='|' read -r type name value; do
  git_items+=("$type|$name|$value")
done

if [[ ${#git_items[@]} -gt 0 ]]; then
  print_header "Git" "git"
  for item in "${git_items[@]}"; do
    IFS='|' read -r type name value <<< "$item"
    print_item "$type" "$name" "$value"
  done
fi

# List custom scripts from this workbench's bin/ directory.
# Using the resolved script path (via _SELF) makes this work both when run directly
# from the repo and when run through the ~/.local/bin symlink.
SCRIPT_DIR="$(dirname "$_SELF")"
typeset -a script_items=()

for script in "$SCRIPT_DIR"/*; do
  [[ ! -f "$script" ]] && continue
  [[ ! -x "$script" ]] && continue

  script_name=$(basename "$script")

  # Skip self and the task wrapper
  [[ "$script_name" == "$(basename "$_SELF")" ]] && continue
  [[ "$script_name" == "task" ]] && continue

  matches_filter "$script_name" || continue

  # Extract description from second line if it starts with "# " and a capital letter
  desc="Custom script"
  second_line=$(sed -n '2p' "$script" 2>/dev/null)
  if [[ "$second_line" =~ ^#\ ([A-Z].*) ]]; then
    desc="${match[1]}"
  fi

  script_items+=("script|$script_name|$desc")
done

if [[ ${#script_items[@]} -gt 0 ]]; then
  print_header "Custom Scripts"
  for item in "${script_items[@]}"; do
    IFS='|' read -r type name value <<< "$item"
    print_item "$type" "$name" "$value"
  done
fi

# Usage hint
if [[ -z "$FILTER" ]]; then
  echo -e "\n${DIM}Usage: aliases [filter]${NC}"
  echo -e "${DIM}Example: aliases aws, aliases git, aliases docker${NC}"
  echo -e "${DIM}Add new aliases to: $ALIASES_DIR/*.zsh${NC}"
else
  echo -e "\n${DIM}Showing results for: ${YELLOW}$FILTER${NC}"
fi

echo ""
