#!/usr/bin/env bash
# Manage local Claude Code rule additions.
#
# Usage: claude-rules <command> [args]
#
# Commands:
#   sync                  Re-symlink workbench rules and regenerate workbench.md
#   add <domain> "rule"   Append a rule to ~/.claude/rules/<domain>.local.md
#   list                  List all local rule files with line counts
#   status                Show local rules not tracked in workbench
#   open [domain]         Open a local rule file in $EDITOR
#   project add "rule"    Append a rule to the current repo's CLAUDE.md
#   project show          Display the current repo's CLAUDE.md
#
# Local rule files (*.local.md) are never touched by workbench setup or sync.
# They complement workbench-managed symlinks for machine-specific additions.
# Run 'claude-rules status' to review before contributing back to the workbench.

set -e

_SELF="$(readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
# shellcheck source=/dev/null
. "$(dirname "$_SELF")/../lib/ui.sh"

RULES_DIR="$CLAUDE_RULES_DIR"

# ─── Frontmatter ──────────────────────────────────────────────────────────────

# _normalize_domain DOMAIN — echoes the canonical domain name for aliases.
_normalize_domain() {
  case "$1" in
    ts|js)    echo "typescript" ;;
    py)       echo "python" ;;
    sh|shell) echo "bash" ;;
    yml)      echo "yaml" ;;
    *)        echo "$1" ;;
  esac
}

# _write_frontmatter FILE DOMAIN — creates FILE with YAML path-scope frontmatter
# extracted from the workbench source rule. No-op if FILE already exists.
_write_frontmatter() {
  local file="$1" domain
  domain=$(_normalize_domain "$2")
  [[ -f "$file" ]] && return

  local source="$GUIDELINES_RULES_SRC_DIR/${domain}.md"
  if [[ ! -f "$source" ]]; then
    touch "$file"
    return
  fi

  # Extract YAML frontmatter (between first two --- lines)
  local in_fm=false fm=""
  while IFS= read -r line; do
    if [[ "$line" == "---" ]]; then
      if [[ "$in_fm" == false ]]; then
        in_fm=true; fm="---"$'\n'; continue
      else
        fm+="---"$'\n'; break
      fi
    fi
    [[ "$in_fm" == true ]] && fm+="$line"$'\n'
  done < "$source"

  if [[ -n "$fm" ]]; then
    printf '%s\n' "$fm" > "$file"
  else
    touch "$file"
  fi
}

# ─── Commands ─────────────────────────────────────────────────────────────────

# _install_workbench_rule — writes the workbench.md rule file with current paths baked in.
_install_workbench_rule() {
  local target="$RULES_DIR/workbench.md"

  cat > "$target" <<EOF
# Workbench

Your developer environment is managed at: $WORKBENCH_DIR

What it owns: Claude config (\`ai/claude/\`), coding rules (\`ai/guidelines/rules/\`),
bin scripts (\`bin/\`), zsh config (\`zsh/\`), git config (\`git/\`),
Docker setup (\`docker/\`), Brew packages (\`brew/\`).

When modifying Claude config (MCPs, agents, skills, settings), bin scripts, zsh config,
git config, or developer tooling — make the change in the workbench repo and re-run
the relevant setup script. Do not edit \`~/\` directly.

Re-run AI setup:   bash $AI_SRC_DIR/setup.sh
Add a local rule:  claude-rules add <domain> "rule text"
Edit local rules:  claude-rules open [domain]
Review untracked:  claude-rules status
EOF
  success "workbench.md"
}

# _check_local_rules — warns about any *.local.md files not tracked in the workbench.
_check_local_rules() {
  local found=false file lines
  for file in "$RULES_DIR"/*.local.md; do
    [[ -e "$file" ]] || continue
    lines=$(wc -l < "$file" | tr -d ' ')
    if [[ "$found" == false ]]; then
      echo
      warn "Local rule additions not tracked in workbench:"
    fi
    echo -e "  ${DIM}  • $(basename "$file") ($lines lines)${NC}"
    found=true
  done
  if [[ "$found" == true ]]; then
    echo -e "  ${DIM}  Run 'claude-rules status' to review, or edit $GUIDELINES_RULES_SRC_DIR/ to formalize${NC}"
  fi
}

cmd_sync() {
  local rules_src="$GUIDELINES_RULES_SRC_DIR"
  [[ -d "$rules_src" ]] || { err "Rules not found at $rules_src"; exit 1; }

  mkdir -p "$RULES_DIR"

  info "Syncing workbench rules → $RULES_DIR"
  symlink_dir "$rules_src" "$RULES_DIR" "$RULES_GLOB" --strip-ext --replace-copies --prune

  echo
  info "Generating workbench.md"
  _install_workbench_rule

  _check_local_rules
}

cmd_add() {
  local domain="${1:-}" rule="${2:-}"
  if [[ -z "$domain" || -z "$rule" ]]; then
    err "Usage: claude-rules add <domain> \"rule text\""
    echo "Domains: general, kotlin, java, go, typescript, python, bash, docker, yaml, sql" >&2
    exit 1
  fi

  mkdir -p "$RULES_DIR"
  local file="$RULES_DIR/${domain}.local.md"
  _write_frontmatter "$file" "$domain"
  printf -- '- %s\n' "$rule" >> "$file"
  success "Added to ${domain}.local.md"
  echo -e "  ${DIM}$file${NC}"
}

cmd_list() {
  local found=false file lines
  if [[ ! -d "$RULES_DIR" ]]; then
    echo -e "  ${DIM}No rules directory found at $RULES_DIR${NC}"
    return
  fi

  for file in "$RULES_DIR"/*.local.md; do
    [[ -e "$file" ]] || continue
    lines=$(wc -l < "$file" | tr -d ' ')
    echo -e "  ${CYAN}$(basename "$file")${NC}  ${DIM}$lines lines${NC}"
    found=true
  done
  if [[ "$found" == false ]]; then
    echo -e "  ${DIM}No local rule files in $RULES_DIR${NC}"
  fi
}

cmd_status() {
  local found=false file lines
  echo
  info "Local rule additions (not tracked in workbench)"

  if [[ ! -d "$RULES_DIR" ]]; then
    echo -e "\n  ${DIM}No rules directory found at $RULES_DIR${NC}"
    return
  fi

  for file in "$RULES_DIR"/*.local.md; do
    [[ -e "$file" ]] || continue
    lines=$(wc -l < "$file" | tr -d ' ')
    echo
    echo -e "  ${CYAN}$(basename "$file")${NC}  ${DIM}$lines lines${NC}"
    local in_frontmatter=false frontmatter_done=false
    while IFS= read -r line; do
      # Skip the opening --- frontmatter block
      if [[ "$frontmatter_done" == false && "$line" == "---" ]]; then
        if [[ "$in_frontmatter" == false ]]; then
          in_frontmatter=true; continue
        else
          in_frontmatter=false; frontmatter_done=true; continue
        fi
      fi
      [[ "$in_frontmatter" == true ]] && continue
      [[ -z "$line" ]] && continue
      echo -e "  ${DIM}  $line${NC}"
    done < "$file"
    found=true
  done

  if [[ "$found" == false ]]; then
    echo -e "\n  ${DIM}No untracked local rules${NC}"
    return
  fi

  echo
  echo -e "  ${DIM}To formalize: edit $GUIDELINES_RULES_SRC_DIR/<domain>.md${NC}"
}

cmd_open() {
  local domain="${1:-}"
  local file

  mkdir -p "$RULES_DIR"

  if [[ -n "$domain" ]]; then
    file="$RULES_DIR/${domain}.local.md"
    _write_frontmatter "$file" "$domain"
  else
    file="$RULES_DIR"
  fi

  ${EDITOR:-nano} "$file"
}

# ─── Project commands ────────────────────────────────────────────────────────

# _find_repo_root — walk up from cwd to find a git repo root with CLAUDE.md
_find_repo_root() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    if [[ -d "$dir/.git" ]]; then
      echo "$dir"
      return
    fi
    dir="$(dirname "$dir")"
  done
  err "Not inside a git repository"
  exit 1
}

cmd_project() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    add)
      local rule="${1:-}"
      if [[ -z "$rule" ]]; then
        err "Usage: claude-rules project add \"rule text\""
        exit 1
      fi

      local root
      root="$(_find_repo_root)"
      local claude_md="$root/CLAUDE.md"

      if [[ ! -f "$claude_md" ]]; then
        err "No CLAUDE.md found at $root"
        echo "  Create one first, then use this command to append rules." >&2
        exit 1
      fi

      # Append under ## Conventions if it exists, otherwise append at end
      if grep -q '^## Conventions' "$claude_md"; then
        printf -- '- %s\n' "$rule" >> "$claude_md"
      else
        printf '\n## Conventions\n\n- %s\n' "$rule" >> "$claude_md"
      fi
      success "Added to $claude_md"
      ;;

    show)
      local root
      root="$(_find_repo_root)"
      local claude_md="$root/CLAUDE.md"

      if [[ ! -f "$claude_md" ]]; then
        echo -e "  ${DIM}No CLAUDE.md at $root${NC}"
        return
      fi
      cat "$claude_md"
      ;;

    *)
      err "Usage: claude-rules project <add|show>"
      echo "  add \"rule\"   Append a convention to CLAUDE.md" >&2
      echo "  show         Display CLAUDE.md" >&2
      exit 1
      ;;
  esac
}

# ─── Main ─────────────────────────────────────────────────────────────────────

case "${1:-}" in
  sync)    cmd_sync ;;
  add)     shift; cmd_add "$@" ;;
  list)    cmd_list ;;
  status)  cmd_status ;;
  open)    shift; cmd_open "$@" ;;
  project) shift; cmd_project "$@" ;;
  *)
    echo "Usage: claude-rules <command>"
    echo
    echo "Commands:"
    echo "  sync                   Re-symlink workbench rules and regenerate workbench.md"
    echo "  add <domain> \"rule\"   Append a rule to ~/.claude/rules/<domain>.local.md"
    echo "  list                   List all local rule files with line counts"
    echo "  status                 Show local rules not tracked in workbench"
    echo "  open [domain]          Open a local rule file in \$EDITOR"
    echo "  project add \"rule\"   Append a convention to the current repo's CLAUDE.md"
    echo "  project show           Display the current repo's CLAUDE.md"
    echo
    echo "Domains: general, kotlin, java, go, typescript, python, bash, docker, yaml, sql"
    exit 1
    ;;
esac
