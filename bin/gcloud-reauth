#!/usr/bin/env bash
set -e

_SELF="$(readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
WORKBENCH_DIR="$(cd "$(dirname "$_SELF")/.." && pwd)"
# shellcheck source=/dev/null
. "$WORKBENCH_DIR/lib/ui.sh"

# shellcheck disable=SC2034  # used by commands_usage() via nameref
COMMANDS=(
  "install"    "Install launchd agent (runs every 12h)"
  "uninstall"  "Remove launchd agent"
  "status"     "Show agent status"
)

usage() {
  cat <<EOF
Check GCP application-default credentials and re-login if expired.

Usage: $(basename "$0") [command]

Commands:
  (none)      Check credentials, launch login if expired
$(commands_usage)
EOF
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }

LABEL="com.otto-workbench.gcloud-reauth"
PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"
LOG_DIR="$HOME/Library/Logs/otto-workbench"
INTERVAL=43200  # 12 hours
SCRIPT_PATH="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
MISE="$LOCAL_BIN_DIR/mise"

_resolve_gcloud() {
  local gcloud_dir
  gcloud_dir="$("$MISE" where gcloud 2>/dev/null)" || true
  if [[ -x "${gcloud_dir}/bin/gcloud" ]]; then
    echo "${gcloud_dir}/bin/gcloud"
  elif command -v gcloud &>/dev/null; then
    command -v gcloud
  else
    echo "ERROR: gcloud not found" >&2
    return 1
  fi
}

_check() {
  local gcloud
  gcloud="$(_resolve_gcloud)" || exit 1

  if "$gcloud" auth application-default print-access-token &>/dev/null; then
    echo "GCP application-default credentials are valid."
    exit 0
  fi

  echo "Credentials expired or missing — launching login..."
  "$gcloud" auth application-default login
}

cmd_install() {
  mkdir -p "$(dirname "$PLIST")" "$LOG_DIR"

  # Unload if already running
  launchctl list "$LABEL" &>/dev/null && launchctl unload "$PLIST" 2>/dev/null || true

  cat > "$PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>${LABEL}</string>
	<key>Program</key>
	<string>${SCRIPT_PATH}</string>
	<key>StartInterval</key>
	<integer>${INTERVAL}</integer>
	<key>RunAtLoad</key>
	<true/>
	<key>StandardOutPath</key>
	<string>${LOG_DIR}/gcloud-reauth.log</string>
	<key>StandardErrorPath</key>
	<string>${LOG_DIR}/gcloud-reauth.log</string>
</dict>
</plist>
EOF

  launchctl load "$PLIST"
  echo "Installed — running every $(( INTERVAL / 3600 ))h"
}

cmd_uninstall() {
  if launchctl list "$LABEL" &>/dev/null; then
    launchctl unload "$PLIST" 2>/dev/null || true
  fi
  rm -f "$PLIST"
  echo "Uninstalled"
}

cmd_status() {
  if ! launchctl list "$LABEL" &>/dev/null; then
    echo "Not running"
    echo "  Install with: gcloud-reauth install"
    return
  fi

  local interval
  interval=$(/usr/libexec/PlistBuddy -c "Print :StartInterval" "$PLIST" 2>/dev/null || echo "unknown")
  echo "Running every $(( interval / 3600 ))h"

  local logfile="$LOG_DIR/gcloud-reauth.log"
  if [[ -f "$logfile" && -s "$logfile" ]]; then
    echo "Last log:"
    tail -3 "$logfile"
  fi
}

case "${1:-}" in
  install)    cmd_install ;;
  uninstall)  cmd_uninstall ;;
  status)     cmd_status ;;
  -h|--help)  usage ;;
  *)          _check ;;
esac
