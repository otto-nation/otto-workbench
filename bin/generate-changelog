#!/usr/bin/env bash
# Generate a changelog from conventional commits on the current branch.
#
# Usage: bin/generate-changelog [--since DATE] [--until DATE]
#
# Defaults: --since "30 days ago", --until HEAD
# Output: grouped markdown to stdout
#
# Groups commits by conventional commit type using the authoritative COMMIT_TYPES
# list from lib/conventions.sh. Non-conforming commits appear under "Other".

set -e

_SELF="$(readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
# shellcheck source=/dev/null
. "$(dirname "$_SELF")/../lib/ui.sh"
# shellcheck source=../lib/conventions.sh
. "$WORKBENCH_DIR/lib/conventions.sh"

# ─── Args ─────────────────────────────────────────────────────────────────────

SINCE="30 days ago"
UNTIL="HEAD"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --since) SINCE="$2"; shift 2 ;;
    --until) UNTIL="$2"; shift 2 ;;
    -h|--help)
      echo "Usage: generate-changelog [--since DATE] [--until DATE]"
      echo
      echo "Defaults: --since \"30 days ago\" --until HEAD"
      exit 0
      ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

# ─── Type → section mapping ──────────────────────────────────────────────────

declare -A TYPE_SECTION
TYPE_SECTION=(
  [feat]="Features"
  [fix]="Fixes"
  [perf]="Performance"
  [refactor]="Refactoring"
  [docs]="Documentation"
  [style]="Style"
  [test]="Tests"
  [build]="Build & CI"
  [ci]="Build & CI"
  [chore]="Chores"
  [deps]="Chores"
  [revert]="Chores"
)

# Section display order
SECTION_ORDER=(
  "Features"
  "Fixes"
  "Performance"
  "Refactoring"
  "Documentation"
  "Style"
  "Tests"
  "Build & CI"
  "Chores"
  "Other"
)

# ─── Parse commits ───────────────────────────────────────────────────────────

# Associative array: section → newline-separated entries
declare -A SECTIONS

git_log_output="$(git log --format="%h %s" --since="$SINCE" "$UNTIL" 2>/dev/null)" || true

if [[ -z "$git_log_output" ]]; then
  echo "No commits found in the given range."
  exit 0
fi

# Conventional commit pattern: type(scope)?: subject
CC_PATTERN='^([a-z]+)(\(([^)]+)\))?!?: (.+)$'

while IFS= read -r line; do
  [[ -z "$line" ]] && continue
  hash="${line%% *}"
  subject="${line#* }"

  if [[ "$subject" =~ $CC_PATTERN ]]; then
    type="${BASH_REMATCH[1]}"
    scope="${BASH_REMATCH[3]}"
    desc="${BASH_REMATCH[4]}"

    section="${TYPE_SECTION[$type]:-Other}"
    if [[ -n "$scope" ]]; then
      entry="- **${scope}**: ${desc} (${hash})"
    else
      entry="- ${desc} (${hash})"
    fi
  else
    section="Other"
    entry="- ${subject} (${hash})"
  fi

  SECTIONS["$section"]+="${entry}"$'\n'
done <<< "$git_log_output"

# ─── Render ───────────────────────────────────────────────────────────────────

# Date range header
since_date="$(git log --format="%ai" --since="$SINCE" "$UNTIL" --reverse 2>/dev/null | head -1 | cut -d' ' -f1)"
until_date="$(git log --format="%ai" "$UNTIL" -1 2>/dev/null | cut -d' ' -f1)"
echo "# Changelog"
echo
if [[ -n "$since_date" && -n "$until_date" ]]; then
  echo "## ${since_date} — ${until_date}"
else
  echo "## Recent changes"
fi

for section in "${SECTION_ORDER[@]}"; do
  entries="${SECTIONS[$section]:-}"
  [[ -z "$entries" ]] && continue
  echo
  echo "### ${section}"
  printf '%s' "$entries"
done
