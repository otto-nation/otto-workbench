#!/usr/bin/env bash
# Generate ai/guidelines/rules/tools.generated.md from domain registries.
#
# Reads:     brew/registry.yml  bin/registry.yml  zsh/registry.yml
# Writes:    ai/guidelines/rules/tools.generated.md
#
# Run automatically via pre-push hook and workbench sync.
# Never edit tools.generated.md directly — edit the source registries instead.
#
# Environment overrides (used in tests):
#   BREW_REGISTRY          path to brew registry YAML  (default: brew/registry.yml)
#   BIN_REGISTRY           path to bin registry YAML   (default: bin/registry.yml)
#   ZSH_REGISTRY           path to zsh registry YAML   (default: zsh/registry.yml)
#   TOOL_CONTEXT_OUTPUT    output file path             (default: ai/guidelines/rules/tools.generated.md)
#   README_PATH            path to README.md            (default: README.md)
#   TASKFILE_PATH          path to Taskfile.global.yml  (default: Taskfile.global.yml)
#   AI_DIR                 path to ai/                  (default: ai/)

set -euo pipefail

_SELF="$(readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
REPO_ROOT="$(cd "$(dirname "$_SELF")/.." && pwd)"

# shellcheck source=../lib/ui.sh
. "$REPO_ROOT/lib/ui.sh"

BREW_REGISTRY="${BREW_REGISTRY:-"$REPO_ROOT/brew/registry.yml"}"
BIN_REGISTRY="${BIN_REGISTRY:-"$REPO_ROOT/bin/registry.yml"}"
ZSH_REGISTRY="${ZSH_REGISTRY:-"$REPO_ROOT/zsh/registry.yml"}"
OUTPUT="${TOOL_CONTEXT_OUTPUT:-"$REPO_ROOT/$TOOLS_GENERATED_RELPATH"}"
README_PATH="${README_PATH:-"$REPO_ROOT/README.md"}"
TASKFILE_PATH="${TASKFILE_PATH:-"$REPO_ROOT/Taskfile.global.yml"}"
AI_DIR="${AI_DIR:-"$REPO_ROOT/ai"}"

if ! command -v yq >/dev/null 2>&1; then
  err "yq not found — run: brew install yq"
  exit 1
fi

# _render_registry FILE TITLE
# Emits a markdown section for every tool entry in FILE.
# Silently skips if FILE is empty, missing, or has no tools.
_render_registry() {
  local file="$1"
  local title="$2"

  [[ -f "$file" ]] || return 0

  local count
  count=$(yq '.tools | length' "$file")
  [[ "$count" -gt 0 ]] || return 0

  printf '\n## %s\n' "$title"

  local i=0 name description when_to_use usage docs
  while [[ "$i" -lt "$count" ]]; do
    name=$(yq ".tools[$i].name" "$file")
    description=$(yq ".tools[$i].description" "$file")
    when_to_use=$(yq ".tools[$i].when_to_use" "$file")
    usage=$(yq ".tools[$i].usage // \"\"" "$file")
    docs=$(yq ".tools[$i].docs // \"\"" "$file")

    printf '\n### %s\n' "$name"
    printf '%s\n' "$description"
    printf -- '- **When to use**: %s\n' "$when_to_use"
    # shellcheck disable=SC2016  # backticks are markdown literals, not shell substitution
    [[ -n "$usage" && "$usage" != "null" ]] && printf -- '- **Usage**: `%s`\n' "$usage"
    [[ -n "$docs"  && "$docs"  != "null" ]] && printf -- '- **Docs**: %s\n'   "$docs"
    i=$(( i + 1 ))
  done
}

{
  printf '# Environment Tools\n'
  printf '<!-- AUTO-GENERATED — do not edit directly -->\n'
  printf '<!-- Sources: brew/registry.yml  bin/registry.yml  zsh/registry.yml -->\n'
  printf '<!-- Regenerate: bin/generate-tool-context -->\n'
  _render_registry "$BREW_REGISTRY" "Brew Tools"
  _render_registry "$BIN_REGISTRY"  "Workbench Scripts"
  _render_registry "$ZSH_REGISTRY"  "Shell Aliases"
} > "$OUTPUT"

success "Generated $(basename "$OUTPUT")"

# _update_readme_scripts README REGISTRY
# Regenerates the scripts table in README between <!-- SCRIPTS-TABLE-START --> and
# <!-- SCRIPTS-TABLE-END --> markers from REGISTRY. No-ops if markers are absent.
_update_readme_scripts() {
  local readme="$1" registry="$2"
  [[ -f "$readme" ]]   || return 0
  [[ -f "$registry" ]] || return 0

  local tmp_table tmp_out
  tmp_table=$(mktemp)
  tmp_out=$(mktemp)

  {
    printf '| Script | Description |\n'
    printf '|--------|-------------|\n'
    local count i name description
    count=$(yq '.tools | length' "$registry")
    for (( i=0; i<count; i++ )); do
      name=$(yq ".tools[$i].name" "$registry")
      description=$(yq ".tools[$i].description" "$registry")
      printf '| `%s` | %s |\n' "$name" "$description"
    done
  } > "$tmp_table"

  awk -v tf="$tmp_table" '
    /<!-- SCRIPTS-TABLE-START -->/ { print; while ((getline line < tf) > 0) print line; skip=1; next }
    /<!-- SCRIPTS-TABLE-END -->/   { skip=0 }
    !skip                          { print }
  ' "$readme" > "$tmp_out" && mv "$tmp_out" "$readme"

  rm -f "$tmp_table"
  success "Updated README scripts table"
}

_update_readme_scripts "$README_PATH" "$BIN_REGISTRY"

# _update_readme_tasks README TASKFILE
# Regenerates the tasks code block in README between <!-- TASKS-BLOCK-START --> and
# <!-- TASKS-BLOCK-END --> markers from TASKFILE. Excludes brew:* and help tasks.
# No-ops if markers are absent.
_update_readme_tasks() {
  local readme="$1" taskfile="$2"
  [[ -f "$readme" ]]   || return 0
  [[ -f "$taskfile" ]] || return 0

  local tmp_block tmp_out
  tmp_block=$(mktemp)
  tmp_out=$(mktemp)

  {
    printf '```bash\n'
    local count i key desc
    count=$(yq '.tasks | to_entries | length' "$taskfile")
    for (( i=0; i<count; i++ )); do
      key=$(yq ".tasks | to_entries[$i].key" "$taskfile")
      desc=$(yq ".tasks | to_entries[$i].value.desc // \"\"" "$taskfile")
      [[ "$key" == brew:* ]] && continue
      [[ "$key" == "help"  ]] && continue
      [[ -z "$desc" || "$desc" == "null" ]] && continue
      printf 'task --global %-20s # %s\n' "$key" "$desc"
    done
    printf '```\n'
  } > "$tmp_block"

  awk -v tf="$tmp_block" '
    /<!-- TASKS-BLOCK-START -->/ { print; while ((getline line < tf) > 0) print line; skip=1; next }
    /<!-- TASKS-BLOCK-END -->/   { skip=0 }
    !skip                        { print }
  ' "$readme" > "$tmp_out" && mv "$tmp_out" "$readme"

  rm -f "$tmp_block"
  success "Updated README tasks block"
}

_update_readme_tasks "$README_PATH" "$TASKFILE_PATH"

# _join_array SEP ARRAY... — joins array elements with SEP
_join_array() {
  local sep=$1; shift
  local result="" item
  for item in "$@"; do
    [[ -n "$result" ]] && result+="$sep"
    result+="$item"
  done
  printf '%s' "$result"
}

# _update_readme_ai README AI_DIR
# Regenerates the "What gets installed" block between <!-- AI-INSTALLS-START --> and
# <!-- AI-INSTALLS-END --> markers from the ai/ directory structure. No-ops if absent.
_update_readme_ai() {
  local readme="$1" ai_dir="$2"
  [[ -f "$readme" ]] || return 0
  [[ -d "$ai_dir"  ]] || return 0

  local tmp_block tmp_out
  tmp_block=$(mktemp)
  tmp_out=$(mktemp)

  {
    printf '**Claude Code:**\n'
    printf -- '- `~/.claude/settings.json` — permissions and deny rules (merged, not overwritten)\n'
    printf -- '- `~/.claude/CLAUDE.md` — coding guidelines\n'
    printf -- '- `~/.claude/rules/` — language and tool-specific rules (symlinked)\n'

    local skills=()
    for d in "$ai_dir/claude/skills"/*/; do
      [[ -d "$d" ]] && skills+=("$(basename "$d")")
    done
    [[ ${#skills[@]} -gt 0 ]] && printf -- '- Skills: %s\n' "$(_join_array ', ' "${skills[@]}")"

    local agents=()
    for f in "$ai_dir/claude/agents"/*.md; do
      [[ -f "$f" ]] && agents+=("$(basename "${f%.md}")")
    done
    [[ ${#agents[@]} -gt 0 ]] && printf -- '- Agents: %s\n' "$(_join_array ', ' "${agents[@]}")"

    local mcps=() label
    for f in "$ai_dir/claude/mcps"/*.json; do
      [[ -f "$f" ]] || continue
      label=$(yq '.label // ""' "$f" | tr -d '"')
      label="${label#MCP: }"
      [[ -n "$label" ]] && mcps+=("$label")
    done
    [[ ${#mcps[@]} -gt 0 ]] && printf -- '- MCPs: %s\n' "$(_join_array ', ' "${mcps[@]}")"

    printf '\n'
    printf '**Kiro:**\n'
    printf -- '- `~/.kiro/steering/` — language, tool, and git rules (symlinked from `ai/guidelines/rules/`)\n'

    local kiro_agents=()
    for f in "$ai_dir/kiro/agents"/*.json; do
      [[ -f "$f" ]] && kiro_agents+=("$(basename "${f%.json}")")
    done
    [[ ${#kiro_agents[@]} -gt 0 ]] && printf -- '- Agents: %s\n' "$(_join_array ', ' "${kiro_agents[@]}")"
  } > "$tmp_block"

  awk -v tf="$tmp_block" '
    /<!-- AI-INSTALLS-START -->/ { print; while ((getline line < tf) > 0) print line; skip=1; next }
    /<!-- AI-INSTALLS-END -->/   { skip=0 }
    !skip                        { print }
  ' "$readme" > "$tmp_out" && mv "$tmp_out" "$readme"

  rm -f "$tmp_block"
  success "Updated README AI installs section"
}

_update_readme_ai "$README_PATH" "$AI_DIR"
