#!/usr/bin/env bash
# Regenerates generated files and README sections from source registries and config.
#
# Writes:
#   ai/guidelines/rules/tools.generated.md  — tool context for AI sessions
#   README.md sections                      — scripts table, tasks block, AI installs
#
# Run automatically via pre-push hook and otto-workbench sync.
# Never edit generated content directly — edit the source files instead.
#
# Registry discovery:
#   Top-level:  brew/registry.yml  bin/registry.yml  zsh/registry.yml
#   Optional stacks: brew/lang/*.registry.yml  brew/infra/*.registry.yml  brew/tools/*.registry.yml
#                    (rendered only for installed tools — install_check: true)
#   Adding a new stack: create brew/<category>/<name>.registry.yml with a meta block.
#   Adding a new top-level registry: add one _render_registry call in the output block.
#
# Each registry file must contain a `meta` block:
#   meta:
#     section:       "Section Title"   # H2 heading in generated output
#     install_check: false             # if true, omit tools not found in PATH
#     validation:    brewfile          # brewfile | bindir | zsh-comments | none
#     source:        brew/Brewfile     # relative path used by validate-registries
#
# Environment overrides (for tests):
#   BREW_REGISTRY        brew/registry.yml
#   BIN_REGISTRY         bin/registry.yml
#   ZSH_REGISTRY         zsh/registry.yml
#   BREW_STACKS_DIR      brew/ directory (scanned recursively for *.registry.yml)
#   TOOL_CONTEXT_OUTPUT  tools.generated.md path
#   README_PATH          README.md path
#   TASKFILE_PATH        Taskfile.global.yml path
#   AI_DIR               ai/ directory

set -euo pipefail

_SELF="$(readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
REPO_ROOT="$(cd "$(dirname "$_SELF")/.." && pwd)"

# shellcheck source=../lib/ui.sh
. "$REPO_ROOT/lib/ui.sh"

BREW_REGISTRY="${BREW_REGISTRY:-"$REPO_ROOT/brew/registry.yml"}"
BIN_REGISTRY="${BIN_REGISTRY:-"$REPO_ROOT/bin/registry.yml"}"
ZSH_REGISTRY="${ZSH_REGISTRY:-"$REPO_ROOT/zsh/registry.yml"}"
BREW_STACKS_DIR="${BREW_STACKS_DIR:-"$REPO_ROOT/brew"}"
OUTPUT="${TOOL_CONTEXT_OUTPUT:-"$REPO_ROOT/$TOOLS_GENERATED_RELPATH"}"
README_PATH="${README_PATH:-"$REPO_ROOT/README.md"}"
TASKFILE_PATH="${TASKFILE_PATH:-"$REPO_ROOT/Taskfile.global.yml"}"
AI_DIR="${AI_DIR:-"$REPO_ROOT/ai"}"

if ! command -v yq >/dev/null 2>&1; then
  err "yq not found — run: brew install yq"
  exit 1
fi

# ── Helpers ───────────────────────────────────────────────────────────────────

# _join SEP ITEMS... — joins items with SEP
_join() {
  local sep=$1; shift
  local result="" item
  for item in "$@"; do
    [[ -n "$result" ]] && result+="$sep"
    result+="$item"
  done
  printf '%s' "$result"
}

# _splice_readme README MARKER
# Reads new section content from stdin and replaces the region between
# <!-- MARKER-START --> and <!-- MARKER-END --> in README. No-ops if absent.
_splice_readme() {
  local readme="$1" marker="$2"
  if [[ ! -f "$readme" ]]; then cat > /dev/null; return 0; fi
  local tmp_content tmp_out
  tmp_content=$(mktemp)
  tmp_out=$(mktemp)
  cat > "$tmp_content"
  awk -v tf="$tmp_content" \
      -v s="<!-- ${marker}-START -->" \
      -v e="<!-- ${marker}-END -->" '
    $0 == s { print; while ((getline line < tf) > 0) print line; skip=1; next }
    $0 == e { skip=0 }
    !skip   { print }
  ' "$readme" > "$tmp_out" && mv "$tmp_out" "$readme"
  rm -f "$tmp_content"
}

# _is_installed NAME — returns 0 if NAME is found in PATH
_is_installed() { command -v "$1" >/dev/null 2>&1; }

# _iter_tools FILE CALLBACK [FILTER]
# Calls CALLBACK name description when_to_use usage docs for each tool in FILE.
# If FILTER is provided (a function name), skips tools for which FILTER NAME fails.
_iter_tools() {
  local file="$1" cb="$2" filter="${3:-}"
  [[ -f "$file" ]] || return 0
  local count i
  count=$(yq '.tools | length' "$file")
  for (( i=0; i<count; i++ )); do
    local name
    name=$(yq ".tools[$i].name" "$file")
    if [[ -n "$filter" ]] && ! "$filter" "$name"; then continue; fi
    "$cb" \
      "$name" \
      "$(yq ".tools[$i].description"   "$file")" \
      "$(yq ".tools[$i].when_to_use"   "$file")" \
      "$(yq ".tools[$i].usage // \"\""  "$file")" \
      "$(yq ".tools[$i].docs  // \"\""  "$file")"
  done
}

# ── tools.generated.md ────────────────────────────────────────────────────────

_tool_md_entry() {
  local name="$1" description="$2" when_to_use="$3" usage="$4" docs="$5"
  printf '\n### %s\n' "$name"
  printf '%s\n' "$description"
  printf -- '- **When to use**: %s\n' "$when_to_use"
  # shellcheck disable=SC2016  # backticks are markdown literals, not shell substitution
  if [[ -n "$usage" && "$usage" != "null" ]]; then printf -- '- **Usage**: `%s`\n' "$usage"; fi
  if [[ -n "$docs"  && "$docs"  != "null" ]]; then printf -- '- **Docs**: %s\n'   "$docs";  fi
}

# _render_registry FILE
# Reads meta.section and meta.install_check from FILE, then renders all matching
# tools as a markdown section. Skips the section entirely if no tools pass the filter.
_render_registry() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  local count
  count=$(yq '.tools | length' "$file")
  [[ "$count" -gt 0 ]] || return 0

  local section install_check filter=""
  section=$(yq '.meta.section // "Tools"' "$file")
  install_check=$(yq '.meta.install_check // false' "$file")
  [[ "$install_check" == "true" ]] && filter="_is_installed"

  # Accumulate tool entries first; skip the section header if nothing renders
  local content
  content=$( _iter_tools "$file" _tool_md_entry "$filter" )
  [[ -n "$content" ]] || return 0

  printf '\n## %s\n' "$section"
  printf '%s\n' "$content"
}

{
  printf '# Environment Tools\n'
  printf '<!-- AUTO-GENERATED — do not edit directly -->\n'
  printf '<!-- Sources: brew/registry.yml  brew/{lang,infra,tools}/*.registry.yml  bin/registry.yml  zsh/registry.yml -->\n'
  printf '<!-- Regenerate: bin/generate-tool-context -->\n'
  _render_registry "$BREW_REGISTRY"
  while IFS= read -r -d '' registry; do
    _render_registry "$registry"
  done < <(find "$BREW_STACKS_DIR" -mindepth 2 -maxdepth 2 -name '*.registry.yml' -print0 | sort -z)
  _render_registry "$BIN_REGISTRY"
  _render_registry "$ZSH_REGISTRY"
} > "$OUTPUT"
success "Generated $(basename "$OUTPUT")"

# ── README sections ───────────────────────────────────────────────────────────

_tool_readme_row() { printf '| `%s` | %s |\n' "$1" "$2"; }

_readme_scripts() {
  printf '| Script | Description |\n'
  printf '|--------|-------------|\n'
  _iter_tools "$BIN_REGISTRY" _tool_readme_row
}

_readme_tasks() {
  local count i key desc
  printf '```bash\n'
  count=$(yq '.tasks | to_entries | length' "$TASKFILE_PATH")
  for (( i=0; i<count; i++ )); do
    key=$(yq ".tasks | to_entries[$i].key" "$TASKFILE_PATH")
    desc=$(yq ".tasks | to_entries[$i].value.desc // \"\"" "$TASKFILE_PATH")
    # Exclude utility/infrastructure tasks; only surface user-facing AI tasks
    [[ "$key" == brew:* || "$key" == "help" ]] && continue
    [[ -z "$desc" || "$desc" == "null" ]] && continue
    printf 'task --global %-20s # %s\n' "$key" "$desc"
  done
  printf '```\n'
}

_readme_ai_installs() {
  # Derive display paths from constants, replacing $HOME prefix with ~
  local claude_home="~${CLAUDE_DIR#"$HOME"}"
  local claude_rules="~${CLAUDE_RULES_DIR#"$HOME"}"
  local kiro_steering="~${KIRO_STEERING_DIR#"$HOME"}"

  # Source dirs within the repo
  local claude_skills_src="$AI_DIR/claude/skills"
  local claude_agents_src="$AI_DIR/claude/agents"
  local claude_mcps_src="$AI_DIR/claude/mcps"
  local kiro_agents_src="$AI_DIR/kiro/agents"

  printf '**Claude Code:**\n'
  printf -- '- `%s/settings.json` — permissions and deny rules (merged, not overwritten)\n' "$claude_home"
  printf -- '- `%s/CLAUDE.md` — coding guidelines\n' "$claude_home"
  printf -- '- `%s/` — language and tool-specific rules (symlinked)\n' "$claude_rules"

  local skills=()
  for d in "$claude_skills_src"/*/; do
    [[ -d "$d" ]] && skills+=("$(basename "$d")")
  done
  [[ ${#skills[@]} -gt 0 ]] && printf -- '- Skills: %s\n' "$(_join ', ' "${skills[@]}")"

  local agents=()
  for f in "$claude_agents_src"/*.md; do
    [[ -f "$f" ]] && agents+=("$(basename "${f%.md}")")
  done
  [[ ${#agents[@]} -gt 0 ]] && printf -- '- Agents: %s\n' "$(_join ', ' "${agents[@]}")"

  local mcps=()
  for f in "$claude_mcps_src"/*.json; do
    [[ -f "$f" ]] && mcps+=("$(jq -r '.name // ""' "$f")")
  done
  [[ ${#mcps[@]} -gt 0 ]] && printf -- '- MCPs: %s\n' "$(_join ', ' "${mcps[@]}")"

  printf '\n'
  printf '**Kiro:**\n'
  printf -- '- `%s/` — language, tool, and git rules (symlinked from `ai/guidelines/rules/`)\n' "$kiro_steering"

  local kiro_agents=()
  for f in "$kiro_agents_src"/*.json; do
    [[ -f "$f" ]] && kiro_agents+=("$(basename "${f%.json}")")
  done
  [[ ${#kiro_agents[@]} -gt 0 ]] && printf -- '- Agents: %s\n' "$(_join ', ' "${kiro_agents[@]}")"
}

# _brew_pkgs_from FILE — comma-separated short package names from a Brewfile
_brew_pkgs_from() {
  [[ -f "$1" ]] || return 0
  grep -E '^(brew|cask) ' "$1" \
    | grep -oE '"[^"]+"' | tr -d '"' | awk -F'/' '{print $NF}' \
    | paste -sd ',' - | sed 's/,/, /g'
}

_readme_brew_stacks() {
  local brew_dir="$BREW_STACKS_DIR"

  # Core Brewfile
  local core_pkgs
  core_pkgs=$(_brew_pkgs_from "$brew_dir/Brewfile")
  printf -- '- `brew/Brewfile` — core: %s\n' "$core_pkgs"

  # Optional stacks grouped by category dir
  for cat_dir in "$brew_dir"/*/; do
    [[ -d "$cat_dir" ]] || continue
    local cat_name
    cat_name="$(basename "$cat_dir")"
    local stack_files=()
    for f in "$cat_dir"*.Brewfile; do
      [[ -f "$f" ]] && stack_files+=("$f")
    done
    [[ ${#stack_files[@]} -eq 0 ]] && continue

    if [[ ${#stack_files[@]} -eq 1 ]]; then
      # Single stack — show packages inline
      local pkgs
      pkgs=$(_brew_pkgs_from "${stack_files[0]}")
      printf -- '- `brew/%s/` — %s\n' "$cat_name" "$pkgs"
    else
      # Multiple stacks — list stack names only
      local names=()
      for f in "${stack_files[@]}"; do names+=("$(basename "$f" .Brewfile)"); done
      printf -- '- `brew/%s/` — %s\n' "$cat_name" "$(_join ' · ' "${names[@]}")"
    fi
  done
}

if [[ -f "$BIN_REGISTRY" ]];  then _readme_scripts    | _splice_readme "$README_PATH" "SCRIPTS-TABLE"; success "Updated README scripts table"; fi
if [[ -f "$TASKFILE_PATH" ]]; then _readme_tasks       | _splice_readme "$README_PATH" "TASKS-BLOCK";   success "Updated README tasks block";   fi
if [[ -d "$AI_DIR" ]];        then _readme_ai_installs | _splice_readme "$README_PATH" "AI-INSTALLS";   success "Updated README AI installs";   fi
if [[ -d "$BREW_STACKS_DIR" ]]; then _readme_brew_stacks | _splice_readme "$README_PATH" "BREW-STACKS"; success "Updated README brew stacks";   fi
