#!/usr/bin/env bash
# Validate the component framework contracts for all workbench components.
#
# Usage: bin/local/validate-components
#
# Checks:
#   Tier 1 (Core — steps.sh only):
#     - Every steps.sh at workbench root level defines sync_<name>()
#
#   Tier 2 (Optional — setup.conf + setup.sh):
#     - Every entry in install.components has a matching directory
#     - Every entry in install.components has setup.conf and setup.sh
#     - Every setup.conf has non-empty label and description fields
#     - No orphan: directory has setup.conf but is not registered
#
#   Cross-tier:
#     - No duplicate sync_<name>() definitions across all steps.sh files
#     - Every optional component's steps.sh (if present) defines sync_<name>()
#     - Every declared `depends` entry exists in install.components
#     - Every declared `depends` entry appears before its dependent in install.components
#
# Exit code: 0 if all checks pass, 1 if any fail.

set -e

_SELF="$(readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
# shellcheck source=/dev/null
. "$(dirname "$_SELF")/../../lib/ui.sh"
# shellcheck source=/dev/null
. "$(dirname "$_SELF")/../../lib/components.sh"

usage() {
  cat <<EOF
Usage: $(basename "$0") [--quiet]

Validate the component framework contracts for all workbench components.

Options:
  --quiet     Suppress per-check output; show only the final summary
  -h, --help  Show this help
EOF
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }
QUIET=false
[[ "${1:-}" == "--quiet" ]] && QUIET=true

ERRORS=0
CHECKS=0

_pass() { CHECKS=$(( CHECKS + 1 )); $QUIET || echo -e "  ${GREEN}✓${NC} $*"; }
_fail() { CHECKS=$(( CHECKS + 1 )); ERRORS=$(( ERRORS + 1 )); err "$*"; }

# ─── Cross-tier: no duplicate sync_<name>() definitions across steps.sh files ─

if ! $QUIET; then echo; info "Cross-tier — no duplicate sync_<name>() definitions"; fi

_step_files=()
discover_step_files _step_files

_sync_fns_all=""
for _sf in "${_step_files[@]}"; do
  _sync_fns_all+=$(grep -oE "^sync_[a-z_]+[[:space:]]*\(\)" "$_sf" | sed 's/[[:space:]]*()//')$'\n'
done
_sync_dupes=$(printf '%s' "$_sync_fns_all" | sort | uniq -d)
if [[ -n "$_sync_dupes" ]]; then
  while IFS= read -r _fn; do
    [[ -z "$_fn" ]] && continue
    _fail "duplicate ${_fn}() defined in multiple steps.sh files"
  done <<< "$_sync_dupes"
else
  _pass "no duplicate sync_<name>() definitions"
fi
unset _sync_fns_all _sync_dupes _sf _fn

# ─── Tier 1: steps.sh files define sync_<name>() ─────────────────────────────

if ! $QUIET; then echo; info "Tier 1 — Core components (steps.sh → sync_<name>)"; fi

for steps_file in "$WORKBENCH_DIR"/*/steps.sh; do
  [[ -f "$steps_file" ]] || continue
  name=$(basename "$(dirname "$steps_file")")
  if grep -qE "^sync_${name}[[:space:]]*\(\)" "$steps_file"; then
    _pass "$name/steps.sh defines sync_${name}()"
  else
    _fail "$name/steps.sh is missing sync_${name}()"
  fi
done

# ─── Tier 2: install.components registry ─────────────────────────────────────

if ! $QUIET; then echo; info "Tier 2 — Optional components (install.components registry)"; fi

REGISTRY="$WORKBENCH_DIR/install.components"
if [[ ! -f "$REGISTRY" ]]; then
  _fail "install.components not found at $REGISTRY"
else
  while IFS= read -r component; do
    [[ -z "$component" || "$component" =~ ^# ]] && continue

    # Directory exists
    if [[ ! -d "$WORKBENCH_DIR/$component" ]]; then
      _fail "$component: directory not found"
      continue
    fi

    # setup.conf exists with required fields
    conf="$WORKBENCH_DIR/$component/setup.conf"
    if [[ ! -f "$conf" ]]; then
      _fail "$component: missing setup.conf"
    else
      label=$(conf_get "$conf" label)
      desc=$(conf_get "$conf" description)
      if [[ -n "$label" ]]; then _pass "$component/setup.conf: label present"
      else                       _fail "$component/setup.conf: missing label"; fi
      if [[ -n "$desc" ]];  then _pass "$component/setup.conf: description present"
      else                       _fail "$component/setup.conf: missing description"; fi
    fi

    # setup.sh exists
    if [[ ! -f "$WORKBENCH_DIR/$component/setup.sh" ]]; then
      _fail "$component: missing setup.sh"
    else
      _pass "$component/setup.sh: present"
    fi

    # If steps.sh exists, it must define sync_<name>()
    optional_steps="$WORKBENCH_DIR/$component/steps.sh"
    if [[ -f "$optional_steps" ]]; then
      if grep -qE "^sync_${component}[[:space:]]*\(\)" "$optional_steps"; then
        _pass "$component/steps.sh defines sync_${component}()"
      else
        _fail "$component/steps.sh is missing sync_${component}()"
      fi
    fi
  done < "$REGISTRY"

  # Reverse check: no orphaned setup.conf
  if ! $QUIET; then echo; info "Reverse check — no orphaned setup.conf"; fi
  for conf in "$WORKBENCH_DIR"/*/setup.conf; do
    [[ -f "$conf" ]] || continue
    dir=$(basename "$(dirname "$conf")")
    if grep -qx "$dir" "$REGISTRY" 2>/dev/null; then
      _pass "$dir: registered in install.components"
    else
      _fail "$dir: has setup.conf but is not registered in install.components"
    fi
  done
fi

# ─── Dependency ordering ──────────────────────────────────────────────────────
# For each component with a `depends` field, verify:
#   1. The declared dep exists in install.components
#   2. The dep appears before the component in install.components

if [[ -f "$REGISTRY" ]]; then
  if ! $QUIET; then echo; info "Dependency ordering"; fi

  # Build ordered list from registry
  _reg_order=()
  while IFS= read -r _rc; do
    [[ -z "$_rc" || "$_rc" =~ ^# ]] && continue
    _reg_order+=("$_rc")
  done < "$REGISTRY"

  for _ri in "${!_reg_order[@]}"; do
    _rcomp="${_reg_order[$_ri]}"
    _rconf="$WORKBENCH_DIR/$_rcomp/setup.conf"
    [[ -f "$_rconf" ]] || continue
    _rdeps=$(conf_get "$_rconf" depends)
    [[ -z "$_rdeps" ]] && continue
    for _rdep in $_rdeps; do
      _rdep_idx=-1
      for _rj in "${!_reg_order[@]}"; do
        [[ "${_reg_order[$_rj]}" == "$_rdep" ]] && { _rdep_idx=$_rj; break; }
      done
      if [[ $_rdep_idx -eq -1 ]]; then
        _fail "$_rcomp: depends on '$_rdep' which is not in install.components"
      elif [[ $_rdep_idx -gt $_ri ]]; then
        _fail "$_rcomp: dependency '$_rdep' appears after '$_rcomp' in install.components (must come first)"
      else
        _pass "$_rcomp: dependency '$_rdep' correctly precedes '$_rcomp'"
      fi
    done
  done
  unset _reg_order _rc _ri _rcomp _rconf _rdeps _rdep _rdep_idx _rj
fi

# ─── Summary ──────────────────────────────────────────────────────────────────

echo
if (( ERRORS == 0 )); then
  success "$CHECKS checks passed"
  exit 0
else
  err "$ERRORS of $CHECKS checks failed"
  exit 1
fi
