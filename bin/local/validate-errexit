#!/usr/bin/env python3
"""Validate that bash scripts do not use && as the last statement before a
scope closer (}, fi, done, esac, ;;) — this pattern silently exits under set -e.

Usage: bin/local/validate-errexit [--quiet] [file...]

Under set -e (errexit), a command like `[[ test ]] && action` returns exit
code 1 when the test is false.  When this is the last statement in a function
body or if/else branch, the non-zero exit propagates and kills the script.
The fix is to use `if/then/fi` or append `|| true`.

When no files are given, discovers all bash scripts in the repo by shebang.

Exit code: 0 if all files pass, 1 if any have violations.
"""

import argparse
import os
import re
import sys

_WORKBENCH_DIR = os.path.dirname(os.path.dirname(os.path.dirname(os.path.realpath(__file__))))
sys.path.insert(0, os.path.join(_WORKBENCH_DIR, 'lib'))
from ansi import RED, GREEN, DIM, NC  # noqa: E402

FUNC_DEF = re.compile(r'^\s*([a-zA-Z_][a-zA-Z0-9_]*)\s*\(\)\s*\{')
FUNC_END = re.compile(r'^\}\s*$')
HEREDOC_START = re.compile(r"<<-?\s*'?([A-Za-z_]\w*)'?")
CMD_SUB_OPEN = re.compile(r'\$\(')
SCOPE_CLOSER = re.compile(r'^\s*(fi|done|esac|\})\s*(#.*)?$')
CONDITION_LEADER = re.compile(r'^\s*(if|elif|while|until)\b')
CASE_TERMINATOR = re.compile(r';;\s*(#.*)?$')

def strip_strings_and_comments(line: str) -> str:
    line = re.sub(r"'[^']*'", '', line)
    line = re.sub(r'"[^"]*"', '', line)
    line = re.sub(r'#.*', '', line)
    return line


def join_continuations(lines: list[str]) -> list[tuple[int, str]]:
    """Join backslash-continued lines, returning (original_lineno, joined_line) pairs."""
    result = []
    buf = ''
    start_lineno = 1

    for lineno, line in enumerate(lines, 1):
        stripped = line.rstrip('\n')
        if buf:
            buf += ' ' + stripped.lstrip()
        else:
            buf = stripped
            start_lineno = lineno

        if not stripped.endswith('\\'):
            result.append((start_lineno, buf))
            buf = ''
        else:
            buf = buf[:-1].rstrip()

    if buf:
        result.append((start_lineno, buf))

    return result


def has_unguarded_and(stripped: str) -> bool:
    """Check if line has && as command separator without || fallback."""
    if '&&' not in stripped:
        return False
    if '||' in stripped:
        return False
    if CONDITION_LEADER.match(stripped):
        return False
    return True


# ── Checker ─────────────────────────────────────────────────────────────────

class _ErreachitState:
    __slots__ = ('sub_depth', 'heredoc_end', 'func_name', 'prev_dangerous')

    def __init__(self):
        self.sub_depth = 0
        self.heredoc_end = None
        self.func_name = '(top-level)'
        self.prev_dangerous = None  # (lineno, line, func_name) if previous line had unguarded &&


def _preprocess_errexit_line(state: _ErreachitState, raw_line: str) -> str | None:
    """Strip noise (heredocs, command substitutions). Returns cleaned line or None to skip."""
    line = raw_line.rstrip()

    if state.heredoc_end is not None:
        if line.strip() == state.heredoc_end:
            state.heredoc_end = None
        return None

    m = HEREDOC_START.search(line)
    if m:
        state.heredoc_end = m.group(1)

    stripped = strip_strings_and_comments(line)

    opens = len(CMD_SUB_OPEN.findall(stripped))
    state.sub_depth += opens
    if state.sub_depth <= 0:
        return stripped

    net_close = stripped.count(')') - (stripped.count('(') - opens)
    if net_close > 0:
        state.sub_depth = max(0, state.sub_depth - net_close)
    return None


def _handle_errexit_function(state: _ErreachitState, stripped: str, violations: list) -> bool:
    """Handle function definition/end boundaries. Returns True if line was consumed."""
    fm = FUNC_DEF.match(stripped)
    if fm:
        if stripped.rstrip().endswith('}'):
            return True
        state.func_name = fm.group(1)
        state.prev_dangerous = None
        return True

    if FUNC_END.match(stripped):
        if state.prev_dangerous:
            violations.append(state.prev_dangerous)
        state.func_name = '(top-level)'
        state.prev_dangerous = None
        return True

    return False


def _classify_errexit_line(state: _ErreachitState, stripped: str, lineno: int, line: str, violations: list) -> None:
    """Handle && detection and prev_dangerous tracking."""
    trimmed = stripped.strip()
    if not trimmed:
        return

    is_closer = bool(SCOPE_CLOSER.match(stripped))

    if state.prev_dangerous and is_closer:
        violations.append(state.prev_dangerous)
        state.prev_dangerous = None
        return

    if not has_unguarded_and(stripped):
        state.prev_dangerous = None
        return

    if CASE_TERMINATOR.search(stripped):
        violations.append((lineno, line.strip(), state.func_name))
        state.prev_dangerous = None
    else:
        state.prev_dangerous = (lineno, line.strip(), state.func_name)


def check_file(filepath: str) -> list[tuple[int, str, str]]:
    """Return list of (line_number, line_content, function_name) violations."""
    violations = []
    state = _ErreachitState()

    with open(filepath) as f:
        lines = f.readlines()

    joined = join_continuations(lines)

    for lineno, raw_line in joined:
        stripped = _preprocess_errexit_line(state, raw_line)
        if stripped is None or _handle_errexit_function(state, stripped, violations):
            continue

        _classify_errexit_line(state, stripped, lineno, raw_line, violations)

    if state.prev_dangerous:
        violations.append(state.prev_dangerous)

    return violations


# ── Discovery ───────────────────────────────────────────────────────────────

def _read_shebang(path: str) -> bytes | None:
    try:
        with open(path, 'rb') as f:
            return f.readline()
    except (OSError, UnicodeDecodeError):
        return None


def _has_bash_shebang(path: str, shebang_re: re.Pattern) -> bool:
    shebang = _read_shebang(path)
    return shebang is not None and shebang_re.search(shebang) is not None


def _discover_by_extension(repo_root: str, shebang_re: re.Pattern) -> set[str]:
    """Find .sh/.bash scripts with a bash shebang."""
    scripts: set[str] = set()

    for dirpath, dirnames, filenames in os.walk(repo_root):
        dirnames[:] = [d for d in dirnames if d != '.git']
        paths = [os.path.join(dirpath, f) for f in filenames if f.endswith(('.sh', '.bash'))]
        scripts.update(p for p in paths if _has_bash_shebang(p, shebang_re))

    return scripts


def _extensionless_paths(search_dir: str) -> list[str]:
    """Collect extensionless file paths in search_dir (max depth 2)."""
    paths = []
    for dirpath, _, filenames in os.walk(search_dir):
        rel = os.path.relpath(dirpath, search_dir)
        if rel != '.' and rel.count(os.sep) >= 2:
            continue
        candidates = [f for f in filenames if '.' not in f]
        for fname in candidates:
            paths.append(os.path.join(dirpath, fname))
    return paths


def _discover_extensionless(repo_root: str, shebang_re: re.Pattern) -> set[str]:
    """Find extensionless bash scripts in known directories by shebang."""
    scripts: set[str] = set()

    for subdir in ('bin', 'ai/claude/bin', 'git/hooks', 'git/bin'):
        search_dir = os.path.join(repo_root, subdir)
        if not os.path.isdir(search_dir):
            continue
        paths = _extensionless_paths(search_dir)
        scripts.update(p for p in paths if _has_bash_shebang(p, shebang_re))

    return scripts


def discover_scripts(repo_root: str) -> list[str]:
    """Find all bash scripts in the repo by shebang."""
    shebang_re = re.compile(rb'^#!.*(/(ba)?sh|/env (ba)?sh)')
    scripts = _discover_by_extension(repo_root, shebang_re) | _discover_extensionless(repo_root, shebang_re)
    return sorted(scripts)


# ── Reporting ───────────────────────────────────────────────────────────────

def _report_violations(relpath: str, violations: list[tuple[int, str, str]]) -> None:
    print(f'{RED}✗{NC} {relpath}: unsafe && before scope closer', file=sys.stderr)
    prev_func = None
    for lineno, line, func in violations:
        if func != prev_func:
            print(f'    {DIM}in {func}():{NC}', file=sys.stderr)
            prev_func = func
        print(f'      line {lineno}: {line}', file=sys.stderr)


def _print_summary(files_checked: int, errors: int) -> None:
    print()
    if errors == 0:
        print(f'{GREEN}✓{NC} {files_checked} files checked, no unsafe && patterns')
    else:
        print(f'{RED}✗{NC} {errors} of {files_checked} files have unsafe && before scope closers', file=sys.stderr)


# ── CLI ─────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(description='Validate bash scripts for unsafe && before scope closers.')
    parser.add_argument('--quiet', action='store_true', help='Only show failures and summary')
    parser.add_argument('files', nargs='*', help='Files to check (auto-discovers if omitted)')
    args = parser.parse_args()

    repo_root = os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

    files = args.files if args.files else discover_scripts(repo_root)

    errors = 0

    for filepath in files:
        violations = check_file(filepath)
        relpath = os.path.relpath(filepath, repo_root)

        if violations:
            errors += 1
            _report_violations(relpath, violations)
        elif not args.quiet:
            print(f'  {GREEN}✓{NC} {relpath}')

    _print_summary(len(files), errors)
    if errors:
        sys.exit(1)


if __name__ == '__main__':
    main()
