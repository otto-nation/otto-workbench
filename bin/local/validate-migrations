#!/usr/bin/env bash
# Validate migration file conventions across all workbench components.
#
# Usage: bin/local/validate-migrations
#
# Checks:
#   - Filenames match YYYYMMDD-slug.sh (slug: lowercase alphanumeric + dashes)
#   - Each file has a #!/usr/bin/env bash shebang
#   - Each file defines a function matching migration_YYYYMMDD_slug (derived from filename)
#   - No duplicate filenames across components
#
# Exit code: 0 if all checks pass (or no migrations found), 1 if any fail.

set -e

_SELF="$(readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
# shellcheck source=/dev/null
. "$(dirname "$_SELF")/../../lib/ui.sh"
# shellcheck source=/dev/null
. "$(dirname "$_SELF")/../../lib/components.sh"

usage() {
  cat <<EOF
Usage: $(basename "$0") [--quiet]

Validate migration file conventions across all workbench components.

Options:
  --quiet     Suppress per-check output; show only the final summary
  -h, --help  Show this help
EOF
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }
QUIET=false
[[ "${1:-}" == "--quiet" ]] && QUIET=true

ERRORS=0
CHECKS=0
FOUND=0

_pass() { CHECKS=$(( CHECKS + 1 )); $QUIET || echo -e "  ${GREEN}✓${NC} $*"; }
_fail() { CHECKS=$(( CHECKS + 1 )); ERRORS=$(( ERRORS + 1 )); err "$*"; }

# Collect all migration files
ALL_BASENAMES=()

_migration_dirs=()
discover_migration_dirs _migration_dirs

for migrations_dir in "${_migration_dirs[@]}"; do
  for migration in "$migrations_dir"/*.sh; do
    [[ -f "$migration" ]] || continue
    FOUND=$(( FOUND + 1 ))

    basename_m="$(basename "$migration")"
    component_rel="$(dirname "$migrations_dir")"
    component_rel="${component_rel#"$WORKBENCH_DIR/"}"
    display="$component_rel/$basename_m"

    ALL_BASENAMES+=("$basename_m")

    # Filename format: YYYYMMDD-slug.sh
    [[ "$basename_m" =~ ^[0-9]{8}-[a-z0-9-]+\.sh$ ]] \
      && _pass "$display: filename format valid" \
      || _fail "$display: filename must match YYYYMMDD-slug.sh (lowercase alphanumeric + dashes)"

    # Shebang check
    first_line="$(head -1 "$migration")"
    [[ "$first_line" == "#!/usr/bin/env bash" ]] \
      && _pass "$display: shebang present" \
      || _fail "$display: missing #!/usr/bin/env bash shebang"

    # Function name: migration_YYYYMMDD_slug (dashes to underscores, .sh stripped)
    expected_fn="migration_${basename_m%.sh}"
    expected_fn="${expected_fn//-/_}"
    grep -qE "^${expected_fn}[[:space:]]*\(\)" "$migration" \
      && _pass "$display: defines ${expected_fn}()" \
      || _fail "$display: expected function ${expected_fn}() not found"
  done
done

# Duplicate filename check across components
if (( FOUND > 0 )); then
  if ! $QUIET; then echo; info "Cross-component — no duplicate migration filenames"; fi
  dupes="$(printf '%s\n' "${ALL_BASENAMES[@]}" | sort | uniq -d)"
  [[ -z "$dupes" ]] && _pass "no duplicate migration filenames"
  while IFS= read -r dup; do
    [[ -z "$dup" ]] && continue
    _fail "duplicate migration filename: $dup"
  done <<< "${dupes:-}"
fi

# Summary
echo
if (( FOUND == 0 )); then
  echo -e "  ${DIM}no migration files found${NC}"
  exit 0
elif (( ERRORS == 0 )); then
  success "$CHECKS checks passed ($FOUND migrations)"
  exit 0
else
  err "$ERRORS of $CHECKS checks failed"
  exit 1
fi
