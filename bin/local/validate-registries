#!/usr/bin/env bash
# Validate tool registries against schema and cross-check with their source files.
#
# Checks performed per registry:
#   - Required fields present: name, description, permission, visibility
#     (when_to_use + usage required when visibility: full; forbidden otherwise)
#   - No unknown fields (see KNOWN_TOOL_FIELDS in lib/registries.sh)
#   - No duplicate tool names
#   - Cross-file check based on meta.validation:
#       brewfile      — every tool name (or brew_name override) exists in meta.source Brewfile
#       bindir        — every tool name exists as a file in meta.source directory
#                       + every executable in meta.source is registered (reverse check)
#       zsh-comments  — every tool name has a matching header comment under meta.source
#       none          — schema-only, no cross-check
#
# Registry discovery:
#   Top-level:       <repo>/*/registry.yml
#   Nested:          <repo>/*/*/registry.yml  (e.g. ai/claude/registry.yml)
#   Optional stacks: <repo>/brew/{lang,infra,tools}/*.registry.yml
#
# Usage: bin/local/validate-registries
# Exit code: 0 if all checks pass, 1 if any fail.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
WORKBENCH_DIR="${WORKBENCH_DIR:-$REPO_ROOT}"

# shellcheck source=/dev/null
. "$REPO_ROOT/lib/ui.sh"
# shellcheck source=/dev/null
. "$REPO_ROOT/lib/registries.sh"

usage() {
  cat <<EOF
Usage: $(basename "$0") [--quiet]

Validate tool registries against schema and cross-check with their source files.

Options:
  --quiet     Suppress per-registry output; show only the final summary
  -h, --help  Show this help
EOF
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }
QUIET=false
[[ "${1:-}" == "--quiet" ]] && QUIET=true

ERRORS=0
REGISTRIES_CHECKED=0
declare -a ALL_ENV_VARS=()   # "VAR_NAME:source_file" pairs for cross-registry dupe check

# _fail MSG — records an error and prints it; does not exit immediately so all
# errors in a registry are reported before aborting.
_fail() {
  echo -e "  ${RED}✗${NC} $*" >&2
  ERRORS=$(( ERRORS + 1 ))
}

# _check_required_fields FILE INDEX
_check_required_fields() {
  local file="$1" i="$2"
  local name description visibility
  name=$(yq ".tools[$i].name // \"\"" "$file")
  description=$(yq ".tools[$i].description // \"\"" "$file")
  visibility=$(yq ".tools[$i].visibility // \"\"" "$file")

  [[ -n "$name" && "$name" != "null" ]]               || _fail "$(basename "$file") [$i]: missing required field: name"
  [[ -n "$description" && "$description" != "null" ]]  || _fail "$(basename "$file") entry '$name': missing required field: description"
  if [[ -z "$visibility" || "$visibility" == "null" ]]; then
    _fail "$(basename "$file") entry '$name': missing required field: visibility (use full, brief, or hidden)"
  elif [[ "$visibility" != "full" && "$visibility" != "brief" && "$visibility" != "hidden" ]]; then
    _fail "$(basename "$file") entry '$name': invalid visibility value '$visibility' (must be full|brief|hidden)"
  fi

  local when_to_use usage
  when_to_use=$(yq ".tools[$i].when_to_use // \"\"" "$file")
  usage=$(yq ".tools[$i].usage // \"\"" "$file")
  local has_wtu has_usage
  has_wtu=$(yq ".tools[$i] | has(\"when_to_use\")" "$file")
  has_usage=$(yq ".tools[$i] | has(\"usage\")" "$file")

  if [[ "$visibility" == "full" ]]; then
    [[ -n "$when_to_use" && "$when_to_use" != "null" ]] || _fail "$(basename "$file") entry '$name': missing required field: when_to_use (required when visibility: full)"
    [[ -n "$usage" && "$usage" != "null" ]]             || _fail "$(basename "$file") entry '$name': missing required field: usage (required when visibility: full)"
  else
    [[ "$has_wtu" != "true" ]]   || _fail "$(basename "$file") entry '$name': field 'when_to_use' is not allowed when visibility: $visibility"
    [[ "$has_usage" != "true" ]] || _fail "$(basename "$file") entry '$name': field 'usage' is not allowed when visibility: $visibility"
  fi
}

# _check_no_duplicates FILE
_check_no_duplicates() {
  local file="$1"
  local dupes
  dupes=$(yq '.tools[].name' "$file" | sort | uniq -d)
  if [[ -n "$dupes" ]]; then
    while IFS= read -r name; do
      _fail "$(basename "$file"): duplicate tool name: $name"
    done <<< "$dupes"
  fi
}

# _check_permission_seq FILE INDEX NAME
_check_permission_seq() {
  local file="$1" i="$2" name="$3"
  local j arr_len entry
  arr_len=$(yq ".tools[$i].permission | length" "$file")
  [[ "$arr_len" -gt 0 ]] || _fail "$(basename "$file") entry '$name': permission array must not be empty"
  for (( j=0; j<arr_len; j++ )); do
    entry=$(yq ".tools[$i].permission[$j]" "$file")
    [[ "$entry" =~ ^Bash\(.+\)$ ]] || _fail "$(basename "$file") entry '$name': permission array entry '$entry' must match Bash(...) pattern"
  done
}

# _check_unknown_fields FILE INDEX
_check_unknown_fields() {
  local file="$1" i="$2"
  local name
  name=$(yq ".tools[$i].name // \"[$i]\"" "$file")
  local key
  while IFS= read -r key; do
    local known=false field
    for field in $KNOWN_TOOL_FIELDS; do
      if [[ "$key" == "$field" ]]; then known=true; break; fi
    done
    if ! $known; then
      _fail "$(basename "$file") entry '$name': unknown field '$key'"
    fi
  done < <(yq ".tools[$i] | keys | .[]" "$file")
}

# _check_permission_field FILE INDEX
_check_permission_field() {
  local file="$1" i="$2"
  local has_perm
  has_perm=$(yq ".tools[$i] | has(\"permission\")" "$file")
  if [[ "$has_perm" != "true" ]]; then
    local name
    name=$(yq ".tools[$i].name // \"[$i]\"" "$file")
    _fail "$(basename "$file") entry '$name': missing required field: permission (use false for internal tools)"
    return 0
  fi

  local name perm_tag
  name=$(yq ".tools[$i].name" "$file")
  perm_tag=$(yq ".tools[$i].permission | tag" "$file")

  case "$perm_tag" in
    '!!bool') ;;
    '!!str')
      local perm_str
      perm_str=$(yq ".tools[$i].permission" "$file")
      [[ -n "$perm_str" ]] || _fail "$(basename "$file") entry '$name': permission string must be non-empty"
      ;;
    '!!seq')
      _check_permission_seq "$file" "$i" "$name"
      ;;
    *)
      _fail "$(basename "$file") entry '$name': permission must be boolean, string, or array of strings (got $perm_tag)"
      ;;
  esac
}


# _check_known_command_field KEY FILE TOOL_NAME CMD_NAME
_check_known_command_field() {
  local key="$1" file="$2" name="$3" cmd_name="$4"
  local field
  for field in $KNOWN_COMMAND_FIELDS; do
    if [[ "$key" == "$field" ]]; then return 0; fi
  done
  _fail "$(basename "$file") entry '$name' command '$cmd_name': unknown field '$key'"
}

# _check_single_command FILE TOOL_INDEX CMD_INDEX TOOL_NAME
_check_single_command() {
  local file="$1" i="$2" j="$3" name="$4"
  local cmd_name cmd_desc
  cmd_name=$(yq ".tools[$i].commands[$j].name // \"\"" "$file")
  cmd_desc=$(yq ".tools[$i].commands[$j].description // \"\"" "$file")

  [[ -n "$cmd_name" && "$cmd_name" != "null" ]] || _fail "$(basename "$file") entry '$name' commands[$j]: missing required field: name"
  [[ -n "$cmd_desc" && "$cmd_desc" != "null" ]] || _fail "$(basename "$file") entry '$name' command '$cmd_name': missing required field: description"

  local key
  while IFS= read -r key; do
    _check_known_command_field "$key" "$file" "$name" "$cmd_name"
  done < <(yq ".tools[$i].commands[$j] | keys | .[]" "$file")
}

# _check_commands_field FILE INDEX
_check_commands_field() {
  local file="$1" i="$2"
  local has_commands
  has_commands=$(yq ".tools[$i] | has(\"commands\")" "$file")
  [[ "$has_commands" == "true" ]] || return 0

  local name visibility
  name=$(yq ".tools[$i].name // \"[$i]\"" "$file")
  visibility=$(yq ".tools[$i].visibility // \"\"" "$file")

  if [[ "$visibility" != "full" ]]; then
    _fail "$(basename "$file") entry '$name': field 'commands' is not allowed when visibility: $visibility"
    return 0
  fi

  local cmd_count j
  cmd_count=$(yq ".tools[$i].commands | length" "$file")

  for (( j=0; j<cmd_count; j++ )); do
    _check_single_command "$file" "$i" "$j" "$name"
  done

  local dupes
  dupes=$(yq ".tools[$i].commands[].name" "$file" | sort | uniq -d)
  if [[ -n "$dupes" ]]; then
    while IFS= read -r dup; do
      _fail "$(basename "$file") entry '$name': duplicate command name: $dup"
    done <<< "$dupes"
  fi
}

# _validate_schema FILE
# Runs required-field, allow-field, and duplicate checks for every entry in FILE.
_validate_schema() {
  local file="$1"
  [[ -f "$file" ]] || { warn "$(basename "$file") not found — skipping"; return; }
  local count i=0
  count=$(yq '.tools | length' "$file")
  while [[ "$i" -lt "$count" ]]; do
    _check_required_fields "$file" "$i"
    _check_permission_field "$file" "$i"
    _check_unknown_fields "$file" "$i"
    _check_commands_field "$file" "$i"
    i=$(( i + 1 ))
  done
  _check_no_duplicates "$file"
}

# _validate_against_brewfile REGISTRY BREWFILE
# Every tool name (or brew_name override) must appear in BREWFILE.
_validate_against_brewfile() {
  local file="$1" brewfile="$2"
  [[ -f "$brewfile" ]] || { warn "$(basename "$brewfile") not found — skipping cross-check"; return; }
  local count i=0 name brew_name check_name
  count=$(yq '.tools | length' "$file")
  while [[ "$i" -lt "$count" ]]; do
    name=$(yq ".tools[$i].name" "$file")
    brew_name=$(yq ".tools[$i].brew_name // \"\"" "$file")
    check_name="${brew_name:-$name}"
    if ! grep -qE "^(brew|cask) [\"']?${check_name}[\"']?" "$brewfile"; then
      _fail "$(basename "$file"): '$name' not found in ${brewfile#"$REPO_ROOT/"}"
    fi
    i=$(( i + 1 ))
  done
}

# _validate_against_bindir REGISTRY DIR
# Every tool name must exist as a file in DIR.
_validate_against_bindir() {
  local file="$1" dir="$2"
  local count i=0 name
  count=$(yq '.tools | length' "$file")
  while [[ "$i" -lt "$count" ]]; do
    name=$(yq ".tools[$i].name" "$file")
    if [[ ! -f "$dir/$name" ]]; then
      _fail "$(basename "$file"): '$name' not found in ${dir#"$REPO_ROOT/"}/"
    fi
    i=$(( i + 1 ))
  done
}

# _validate_bindir_reverse REGISTRY DIR
# Every executable file in DIR must be registered in REGISTRY.
_validate_bindir_reverse() {
  local file="$1" dir="$2"
  local -A registered=()
  local name
  while IFS= read -r name; do
    registered[$name]=1
  done < <(yq '.tools[].name' "$file")

  local item basename
  for item in "$dir"/*; do
    [[ -f "$item" ]] || continue
    [[ -x "$item" ]] || continue
    basename=$(basename "$item")
    [[ "$basename" == "registry.yml" ]] && continue
    if [[ -z "${registered[$basename]+set}" ]]; then
      _fail "$(basename "$file"): '$basename' exists in ${dir#"$REPO_ROOT/"} but is not registered"
    fi
  done
}

# _validate_against_zsh REGISTRY DIR
# Every tool name must have a matching header comment somewhere under DIR.
_validate_against_zsh() {
  local file="$1" dir="$2"
  local count i=0 name keyword
  count=$(yq '.tools | length' "$file")
  while [[ "$i" -lt "$count" ]]; do
    name=$(yq ".tools[$i].name" "$file")
    keyword=$(echo "$name" | cut -d' ' -f1)
    if ! grep -rqi "# ${keyword}" "$dir" 2>/dev/null; then
      _fail "$(basename "$file"): '$name' — no matching comment found in ${dir#"$REPO_ROOT/"}/ for keyword '${keyword}'"
    fi
    i=$(( i + 1 ))
  done
}

# _validate_env_fields FILE
# Validates the optional top-level env[] array: var is present, valid format, no dupes.
_validate_env_fields() {
  local file="$1"
  local has_env
  has_env=$(yq '. | has("env")' "$file")
  [[ "$has_env" == "true" ]] || return 0

  local count i=0
  count=$(yq '.env | length' "$file")
  local -a seen_vars=()
  while [[ "$i" -lt "$count" ]]; do
    local var
    var=$(yq ".env[$i].var // \"\"" "$file")
    if [[ -z "$var" || "$var" == "null" ]]; then
      _fail "$(basename "$file") env[$i]: missing required field: var"
      i=$(( i + 1 ))
      continue
    fi
    if [[ ! "$var" =~ ^[A-Z][A-Z0-9_]*$ ]]; then
      _fail "$(basename "$file") env '$var': invalid var name (must match ^[A-Z][A-Z0-9_]*$)"
    fi
    local v
    for v in "${seen_vars[@]}"; do
      [[ "$v" != "$var" ]] && continue
      _fail "$(basename "$file"): duplicate env var: $var"
      break
    done
    seen_vars+=("$var")
    # Track for cross-registry duplicate check (use relative path for readability)
    ALL_ENV_VARS+=("$var:${file#"$REPO_ROOT/"}")
    i=$(( i + 1 ))
  done
}

# _validate_install_check_command FILE
# When install_check: true and install_check_command is set, validates it is non-empty.
# When tools is empty and install_check: true, requires install_check_command.
_validate_install_check_command() {
  local file="$1"
  local install_check install_check_command tools_count
  install_check=$(yq '.meta.install_check // false' "$file")
  [[ "$install_check" == "true" ]] || return 0

  install_check_command=$(yq '.meta.install_check_command // ""' "$file")
  tools_count=$(yq '.tools | length' "$file")

  local install_check_symlink
  install_check_symlink=$(yq '.meta.install_check_symlink // ""' "$file")

  if [[ "$tools_count" -eq 0 ]] \
     && [[ -z "$install_check_command" || "$install_check_command" == "null" ]] \
     && [[ -z "$install_check_symlink" || "$install_check_symlink" == "null" ]]; then
    _fail "$(basename "$file"): install_check: true with empty tools[] requires install_check_command or install_check_symlink"
  fi
}

# _validate_meta_scope FILE
# If meta.scope is present, validates it contains only lowercase alphanumeric characters and hyphens.
_validate_meta_scope() {
  local file="$1"
  local scope
  scope=$(yq '.meta.scope // ""' "$file")
  [[ -z "$scope" || "$scope" == "null" ]] && return 0
  if [[ "$scope" =~ [^a-z0-9-] ]]; then
    _fail "$(basename "$file"): meta.scope '$scope' must be lowercase alphanumeric with hyphens"
  fi
}

# _validate_auth_fields FILE
# If auth block is present, env_var must be non-empty. Warns if setup_url is missing.
_validate_auth_fields() {
  local file="$1"
  local count i=0
  count=$(yq '.tools | length' "$file")
  while [[ "$i" -lt "$count" ]]; do
    local has_auth
    has_auth=$(yq ".tools[$i] | has(\"auth\")" "$file")
    if [[ "$has_auth" != "true" ]]; then
      i=$(( i + 1 ))
      continue
    fi
    local name env_var setup_url
    name=$(yq ".tools[$i].name" "$file")
    env_var=$(yq ".tools[$i].auth.env_var // \"\"" "$file")
    setup_url=$(yq ".tools[$i].auth.setup_url // \"\"" "$file")
    if [[ -z "$env_var" || "$env_var" == "null" ]]; then
      _fail "$(basename "$file") entry '$name': auth block missing required field: env_var"
    else
      ALL_ENV_VARS+=("$env_var:${file#"$REPO_ROOT/"}")
    fi
    if [[ -z "$setup_url" || "$setup_url" == "null" ]]; then
      warn "$(basename "$file") entry '$name': auth block missing setup_url"
    fi
    i=$(( i + 1 ))
  done
}

# _validate_registry FILE
# Dispatches cross-validation based on meta.validation and meta.source in FILE.
_validate_registry() {
  local file="$1"
  local validation source
  validation=$(yq '.meta.validation // "none"' "$file")
  source=$(yq '.meta.source // ""' "$file")

  case "$validation" in
    brewfile)
      [[ -n "$source" ]] && _validate_against_brewfile "$file" "$REPO_ROOT/$source"
      ;;
    bindir)
      [[ -n "$source" ]] && _validate_against_bindir "$file" "$REPO_ROOT/$source"
      [[ -n "$source" ]] && _validate_bindir_reverse "$file" "$REPO_ROOT/$source"
      ;;
    zsh-comments)
      [[ -n "$source" ]] && _validate_against_zsh "$file" "$REPO_ROOT/$source"
      ;;
    none|install-check) ;;
    *)
      warn "$(basename "$file"): unknown validation type '$validation' — skipping cross-check"
      ;;
  esac
}

# ── Main ──────────────────────────────────────────────────────────────────────

if ! command -v yq >/dev/null 2>&1; then
  err "yq not found — run: brew install yq"
  exit 1
fi

# Collect all registries: top-level + nested (e.g. ai/claude/) + optional brew stacks
declare -a all_registries=()
collect_registries all_registries "$REPO_ROOT"

if [[ "${#all_registries[@]}" -eq 0 ]]; then
  warn "No registry files found — skipping"
  exit 0
fi

$QUIET || echo "→ Validating registries..."

for registry in "${all_registries[@]}"; do
  REGISTRIES_CHECKED=$(( REGISTRIES_CHECKED + 1 ))
  if ! $QUIET; then
    echo
    info "Schema: ${registry#"$REPO_ROOT/"}"
  fi
  _validate_schema "$registry"
  _validate_env_fields "$registry"
  _validate_auth_fields "$registry"
  _validate_install_check_command "$registry"
  _validate_meta_scope "$registry"
  _validate_registry "$registry"
done

# Cross-registry duplicate check: no env var name should appear in multiple registries.
_check_cross_registry_dupes() {
  local -A var_sources=()
  local entry var source
  for entry in "${ALL_ENV_VARS[@]}"; do
    var="${entry%%:*}"
    source="${entry#*:}"
    if [[ -n "${var_sources[$var]:-}" && "${var_sources[$var]}" != "$source" ]]; then
      _fail "env var '$var' defined in multiple registries: ${var_sources[$var]} and $source"
    fi
    var_sources[$var]="$source"
  done
}
if [[ "${#ALL_ENV_VARS[@]}" -gt 0 ]]; then
  _check_cross_registry_dupes
fi

echo
if [[ "$ERRORS" -gt 0 ]]; then
  err "$ERRORS error(s) found"
  exit 1
fi

success "All registries valid ($REGISTRIES_CHECKED files)"
