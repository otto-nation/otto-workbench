#!/usr/bin/env bash
# Manage your workbench developer environment.
#
# Usage: otto-workbench [--workbench-dir <path>] <command>
#
# Global flags:
#   --workbench-dir <path>  Override workbench root (e.g. a worktree checkout)
#
# Commands:
#   install [--all] [COMPONENT ...]  Bootstrap the workbench (first-time setup)
#   sync                  Re-apply all workbench configuration to ~/
#   ai <subcmd>           Manage AI tools — scaffold projects, sync config, manage overrides
#   maintenance <subcmd>  Scheduled pull, sync, and cleanup via launchd
#   state [regenerate]    Show or re-detect installed component state
#   changelog             Show recent changes from conventional commits
#
# What install does:
#   Runs first-time setup: installs Homebrew (if missing), syncs core
#   components (bin, git, task, zsh), presents a menu of optional
#   components (brew packages, docker, terminals, editors, ai, mise),
#   and runs pending migrations. Safe to re-run — idempotent.
#   Use --all to skip menus, or name specific components.
#
# What ai does:
#   ai init — scaffolds a .claude/ directory in the current git repo (if one
#   doesn't exist) with stack-detected rules and a project anatomy file.
#   Use --force to re-scaffold, --analyze to run /analyze-project after.
#   ai sync — syncs machine-level AI config (settings, rules, skills, agents, MCPs).
#   ai override <type> [name] [--add|--disable|--enable|--status] — manage user overrides.
#
# What sync does (pure config reconciliation):
#   - Re-symlinks scripts, zsh/, git/.gitconfig, Taskfile, lib/
#   - Syncs Claude settings.json, CLAUDE.md, rules/, skills/, agents/, MCPs
#   - Merges Zed/Sublime editor settings
#   - Reconciles Ghostty theme key
#   - Checks for install-needed changes (missing brew packages, unconfigured
#     components) and prints actionable "install.sh <component>" commands
#
# What sync does NOT do (one-time setup via otto-workbench install):
#   - Install Homebrew packages or casks
#   - Configure Docker runtime
#   - Import iTerm themes
#   - Create Ghostty config from template
#   - Regenerate tool context (now runs during sync via sync_zsh)
#
# To run first-time setup or those components: otto-workbench install [COMPONENT ...]

set -e

# Require modern bash (4.3+ for namerefs used in lib/registries.sh).
if [[ "${BASH_VERSINFO[0]}" -lt 4 || ( "${BASH_VERSINFO[0]}" -eq 4 && "${BASH_VERSINFO[1]}" -lt 3 ) ]]; then
  echo "✗ bash 4.3+ required (found ${BASH_VERSION}). Install: brew install bash" >&2
  exit 1
fi

# Parse global flags before sourcing libs (constants.sh respects WORKBENCH_DIR if set).
while [[ $# -gt 0 ]]; do
  case "$1" in
    --workbench-dir) export WORKBENCH_DIR="$2"; shift 2 ;;
    *) break ;;
  esac
done

_SELF="$(readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
WORKBENCH_DIR="${WORKBENCH_DIR:-$(git -C "$(dirname "$_SELF")" rev-parse --show-toplevel)}"
# shellcheck source=/dev/null
. "$WORKBENCH_DIR/lib/ui.sh"
# shellcheck source=/dev/null
. "$WORKBENCH_DIR/lib/migrations.sh"
# shellcheck source=/dev/null
. "$WORKBENCH_DIR/lib/install.sh"

# Auto-discover and source all steps.sh files.
# Each steps.sh self-derives its own paths; no external variables need to be injected.
# Adding a new component with a steps.sh automatically makes its functions available here.
_step_files=()
discover_step_files _step_files
for _f in "${_step_files[@]}"; do
  # shellcheck source=/dev/null
  . "$_f"
done
unset _f _step_files

# shellcheck disable=SC2034  # used by commands_usage() via nameref
COMMANDS=(
  "install [--all] [COMPONENT ...]"  "Bootstrap the workbench (first-time setup)"
  "sync"                              "Re-apply all workbench configuration to ~/"
  "ai <subcmd>"                       "Manage AI tools — scaffold projects, sync config, manage overrides"
  "discover [regenerate]"             "Show installed components, scripts, and launchd agents"
  "maintenance <subcmd>"              "Scheduled pull, sync, and cleanup via launchd"
  "changelog"                         "Show recent changes from conventional commits"
)

# shellcheck disable=SC2034  # used by commands_usage() via nameref
COMMANDS_AI=(
  "init [--force] [--analyze]"        "Scaffold .claude/ in the current git repo"
  "sync"                              "Sync machine-level AI config (settings, rules, MCPs, skills, agents)"
  "override <type> [name] [flags]"    "Manage user overrides (agents, skills, rules)"
)

# shellcheck disable=SC2034  # used by commands_usage() via nameref
COMMANDS_MAINTENANCE=(
  "start [SECONDS]"  "Start maintenance (default: every 12h)"
  "stop"             "Stop maintenance"
  "status"           "Show maintenance status"
  "run"              "Run maintenance now"
  "logs"             "Show recent log entries"
)

# ─── Install-needed detection ─────────────────────────────────────────────────

# _check_install_needed — detects components that need a full install.sh run.
# Checks: core Brewfile missing packages, optional component check commands.
# Prints actionable output with the exact install.sh command to run.
_check_install_needed() {
  local -a needs_install=()
  local -a install_reasons=()

  # 1. Check core Brewfile for missing packages
  local brewfile="$BREWFILE"
  if [[ -f "$brewfile" ]] && command -v brew >/dev/null 2>&1; then
    local missing_output
    if ! missing_output=$(brew bundle check --file="$brewfile" --no-upgrade 2>&1); then
      local missing_count
      missing_count=$(echo "$missing_output" | grep -c 'needs to be installed') || missing_count=0
      if (( missing_count > 0 )); then
        needs_install+=("brew")
        install_reasons+=("$missing_count missing package(s)")
      else
        needs_install+=("brew")
        install_reasons+=("missing packages")
      fi
    fi
  fi

  # 2. Check optional components with check commands in setup.conf
  local registry="$INSTALL_COMPONENTS_FILE"
  if [[ -f "$registry" ]]; then
    local component check_cmd
    while IFS= read -r component; do
      [[ -z "$component" || "$component" =~ ^# ]] && continue
      local conf="$WORKBENCH_DIR/$component/setup.conf"
      [[ -f "$conf" ]] || continue
      check_cmd=$(grep -m1 '^check[[:space:]]*=' "$conf" 2>/dev/null \
        | sed 's/^check[[:space:]]*=[[:space:]]*//')
      [[ -z "$check_cmd" ]] && continue
      # shellcheck disable=SC2086
      bash -c "$check_cmd" >/dev/null 2>&1 && continue
      needs_install+=("$component")
      install_reasons+=("not configured")
    done < "$registry"
  fi

  # Print results
  if [[ ${#needs_install[@]} -gt 0 ]]; then
    echo
    echo -e "  ${CYAN}Install needed${NC}"
    local i
    for i in "${!needs_install[@]}"; do
      printf "    ${YELLOW}%-18s${NC} %s\n" "${needs_install[$i]}" "${install_reasons[$i]}"
    done
    echo
    echo -e "  Run: ${BOLD}otto-workbench install ${needs_install[*]}${NC}"
  fi
}

# ─── Commands ─────────────────────────────────────────────────────────────────

# _clone_workbench_repo — clones the workbench repo for Cellar-based installs.
# After cloning, the caller should re-exec from the cloned copy.
WORKBENCH_REPO_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/otto-workbench"

_clone_workbench_repo() {
  local repo_url="https://github.com/otto-nation/otto-workbench.git"

  if [[ -d "$WORKBENCH_REPO_DIR" ]]; then
    info "Workbench repo already exists at $WORKBENCH_REPO_DIR"
    return
  fi

  info "Cloning workbench repo to $WORKBENCH_REPO_DIR"
  git clone "$repo_url" "$WORKBENCH_REPO_DIR"
}

_check_linux_prerequisites() {
  local -a missing=() apt_pkgs=()
  local cmd
  for cmd in git zsh curl jq; do
    command -v "$cmd" >/dev/null 2>&1 || { missing+=("$cmd"); apt_pkgs+=("$cmd"); }
  done
  # yq (mikefarah/yq) is not in standard apt repos — track separately for a tailored hint
  command -v yq >/dev/null 2>&1 || missing+=("yq")

  if [[ ${#missing[@]} -gt 0 ]]; then
    warn "Missing prerequisites: ${missing[*]}"
    if [[ ${#apt_pkgs[@]} -gt 0 ]]; then
      echo -e "  ${DIM}Install with: sudo apt install ${apt_pkgs[*]}${NC}"
    fi
    if [[ " ${missing[*]} " == *" yq "* ]]; then
      echo -e "  ${DIM}Install yq: snap install yq  (or see https://github.com/mikefarah/yq/releases)${NC}"
    fi
  else
    success "Linux prerequisites satisfied"
  fi
}

cmd_install() {
  # If running from Homebrew Cellar, clone the full repo and re-exec from there.
  if [[ "$WORKBENCH_DIR" == */Cellar/* ]]; then
    _clone_workbench_repo
    exec "$WORKBENCH_REPO_DIR/bin/otto-workbench" install "$@"
  fi

  # Parse flags: --all, component targets
  parse_install_flags "$@"

  # Collect warnings/errors for final summary replay.
  WORKBENCH_INSTALL_LOG="$(mktemp "${TMPDIR:-/tmp}/workbench-install.XXXXXX")"
  export WORKBENCH_INSTALL_LOG
  trap 'rm -f "$WORKBENCH_INSTALL_LOG"' EXIT
  export WORKBENCH_DIR

  # Interactive mode: install_symlink prompts before overwriting real files.
  # shellcheck disable=SC2034  # read by install_symlink in lib/ui.sh
  SYMLINK_MODE=""

  echo -e "${BOLD}${BLUE}Installing dotfiles...${NC}"
  echo -e "  ${DIM}✓${NC} installed  ${DIM}✓ up to date  ⊘ skipped  ⚠ attention needed${NC}"
  echo

  # ─── Bootstrap ──────────────────────────────────────────────────────────
  if [[ "$OSTYPE" == "darwin"* ]]; then
    step_brew_install
  else
    _check_linux_prerequisites
  fi
  echo

  # Resolve known components and validate targets (if any).
  resolve_known_components
  if [[ "$INSTALL_TARGETED" == true ]]; then
    validate_install_targets "${INSTALL_TARGETS[@]}"
  fi

  # ─── Core components ───────────────────────────────────────────────────
  local -a _core_dirs=() _core_descs=()
  discover_core_components _core_dirs _core_descs

  if [[ ${#_core_dirs[@]} -gt 0 ]]; then
    local -a _core_selected=()
    select_core_components _core_selected _core_dirs _core_descs
    local _c
    for _c in "${_core_selected[@]}"; do
      run_core_component "$_c"
    done
  fi

  update_path_in_shell_rc

  # Run pending migrations after core sync, before optional components.
  echo
  info "Migrations"
  run_all_migrations

  echo -e "\n${BOLD}${GREEN}✓ Dotfiles installed!${NC}"

  # ─── Optional components ────────────────────────────────────────────────
  local registry="$INSTALL_COMPONENTS_FILE"
  validate_components "$registry"
  discover_components  "$registry"
  select_components
  run_components

  print_install_summary
}

cmd_sync() {
  # Non-interactive mode: install_symlink warns and skips real files.
  # shellcheck disable=SC2034  # read by install_symlink in lib/ui.sh
  SYMLINK_MODE=no-prompt

  # Quiet mode: suppresses per-file dim checkmarks, section headers, and
  # summary noise. Only changes, warnings, and errors surface.
  WORKBENCH_SYNC=true
  export WORKBENCH_SYNC

  # Collect warnings/errors for final summary replay.
  WORKBENCH_INSTALL_LOG="$(mktemp "${TMPDIR:-/tmp}/workbench-sync.XXXXXX")"
  export WORKBENCH_INSTALL_LOG
  trap 'rm -f "$WORKBENCH_INSTALL_LOG"' EXIT

  run_all_migrations

  # Sync components — respects installation state when a state file exists.
  # Without a state file (pre-existing installs), syncs everything (backward compat).
  # Infrastructure components (bin, task, git, zsh) always sync regardless of state.
  #
  # Before syncing, prune any orphaned state entries (renamed/removed components).
  state_prune_orphans

  local -a _step_files=()
  discover_step_files _step_files
  local _f _c _path
  local _always_sync="$CORE_COMPONENTS"
  for _f in "${_step_files[@]}"; do
    _c=$(basename "$(dirname "$_f")")
    # Derive component path relative to WORKBENCH_DIR (e.g. ai/claude from ai/claude/steps.sh)
    _path="${_f#"$WORKBENCH_DIR/"}"
    _path="${_path%/steps.sh}"

    # Gate on state: skip uninstalled components (unless no state file = backward compat)
    if state_file_exists && [[ " $_always_sync " != *" $_path "* ]] && ! state_is_installed "$_path"; then
      continue
    fi

    # Skip sub-components whose parent has a sync function — the parent
    # is responsible for dispatching to its children.
    local _parent_dir="${_path%/*}"
    local _parent_name
    _parent_name=$(basename "$_parent_dir")
    if [[ "$_parent_dir" != "$_path" ]] \
       && declare -f "sync_${_parent_name}" > /dev/null; then
      continue
    fi

    export WORKBENCH_CURRENT_COMPONENT="$_c"
    if declare -f "sync_${_c}" > /dev/null; then
      "sync_${_c}"
    fi
  done
  unset WORKBENCH_CURRENT_COMPONENT

  # shellcheck source=/dev/null
  . "$WORKBENCH_DIR/lib/summary.sh"

  # Auto-discover and call per-component summaries (brew, docker, ai, etc.)
  # Only warnings/errors surface during sync (summary_ok/summary_info are suppressed).
  run_component_summaries

  echo
  success "Workbench synced"

  print_warnings_summary
}

# _stream_progress SESSION_LOG — reads stream-json from stdin, shows tool-use progress, saves raw log.
_stream_progress() {
  local session_log="$1"
  : > "$session_log"
  local prev_label=""
  while IFS= read -r line; do
    echo "$line" >> "$session_log"
    local msg_type
    msg_type=$(echo "$line" | jq -r '.type // empty' 2>/dev/null) || continue
    [[ "$msg_type" == "assistant" ]] || continue

    local labels
    labels=$(echo "$line" | jq -r '
      .message.content[]? | select(.type == "tool_use") |
      if .input.description then
        .input.description
      elif .name == "Read" then
        "Read " + (.input.file_path | split("/") | last)
      elif .name == "Grep" then
        "Grep " + (.input.pattern // "")
      elif .name == "Glob" then
        "Glob " + (.input.pattern // "")
      elif .name == "Write" then
        "Write " + (.input.file_path | split("/") | last)
      else
        .name
      end
    ' 2>/dev/null)
    [[ -z "$labels" ]] && continue

    while IFS= read -r label; do
      [[ -z "$label" ]] && continue
      [[ "$label" == "$prev_label" ]] && continue
      echo -e "  ${DIM}▸ ${label}${NC}"
      prev_label="$label"
    done <<< "$labels"
  done
}

# ─── AI command ──────────────────────────────────────────────────────────────

_ai_usage() {
  cat <<EOF
Usage: otto-workbench ai <command>

Manage AI coding tool configuration (Claude Code, etc.).

Commands:
$(commands_usage COMMANDS_AI)

Run 'otto-workbench ai <command> -h' for command-specific help.
Run 'otto-workbench sync' to apply changes after editing overrides.
EOF
}

cmd_ai_init() {
  local force_flag="" analyze=false

  local arg
  for arg in "$@"; do
    case "$arg" in
      --force)    force_flag="--force" ;;
      --analyze)  analyze=true ;;
      -h|--help)
        cat <<EOF
Usage: otto-workbench ai init [--force] [--analyze]

Scaffold a .claude/ directory in the current git repo with stack-detected
rules, conventions, and a project anatomy file.

Options:
  --force     Re-scaffold an existing .claude/ directory
  --analyze   Run /analyze-project after scaffolding to populate files
EOF
        return 0
        ;;
    esac
  done

  title "AI init"
  echo

  local project_root
  project_root="$(git rev-parse --show-toplevel 2>/dev/null)" || true
  if [[ -z "$project_root" ]]; then
    echo
    warn "Not in a git repo — skipping project scaffold and anatomy"
    return
  fi

  cd "$project_root"

  local did_scaffold=false
  if [[ -d ".claude" ]] && [[ -z "$force_flag" ]]; then
    info "Project .claude/ exists — skipping scaffold (use --force to re-scaffold)"
  else
    info "Scaffolding project"
    scaffold_project_claude $force_flag
    did_scaffold=true
  fi

  local anatomy_gen="$CLAUDE_SKILLS_DIR/anatomy/generate-anatomy.sh"
  if [[ -f "$anatomy_gen" ]]; then
    echo
    info "Generating project anatomy"
    if bash "$anatomy_gen"; then
      success "anatomy.md"
    else
      skip "anatomy.md (generator failed)"
    fi
  fi

  local skill_file="$CLAUDE_SKILLS_DIR/analyze-project/SKILL.md"
  if [[ "$did_scaffold" == true ]] && command -v claude >/dev/null 2>&1 && [[ -f "$skill_file" ]]; then
    echo
    local run_analyze=false
    if [[ "$analyze" == true ]] || confirm "Run /analyze-project now to populate the scaffolded files?"; then
      run_analyze=true
    fi

    if [[ "$run_analyze" == true ]]; then
      local session_log=".claude/analyze-project.session.jsonl"
      info "Running /analyze-project"
      echo
      local skill_content
      skill_content=$(awk 'NR==1 && /^---$/{f=1;next} f && /^---$/{f=0;next} !f{print}' "$skill_file")
      claude -p --verbose --output-format stream-json \
        --permission-mode acceptEdits \
        "$skill_content" \
        | _stream_progress "$session_log"
      echo
    fi
  fi

  echo
  success "AI init complete!"
}

cmd_ai_sync() {
  case "${1:-}" in
    -h|--help)
      cat <<EOF
Usage: otto-workbench ai sync

Sync machine-level AI config: settings, rules, MCPs, skills, agents,
machine profile, and memory backup. This is the AI-only subset of
'otto-workbench sync'.
EOF
      return 0
      ;;
  esac

  title "AI sync"
  echo
  sync_ai
  echo
  success "AI sync complete!"
}

cmd_ai() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    init)     cmd_ai_init "$@" ;;
    sync)     cmd_ai_sync "$@" ;;
    override) cmd_ai_override "$@" ;;
    -h|--help) _ai_usage; return 0 ;;
    *)        _ai_usage >&2; return 1 ;;
  esac
}

cmd_changelog() {
  bash "$WORKBENCH_DIR/git/bin/generate-changelog" "$@"
}

# ─── Maintenance ─────────────────────────────────────────────────────────────

_MAINTENANCE_DEFAULT_INTERVAL=43200  # 12 hours

# ── macOS (launchd) ──────────────────────────────────────────────────────────

_MAINTENANCE_LABEL="com.otto-workbench.maintenance"
_MAINTENANCE_PLIST="$HOME/Library/LaunchAgents/${_MAINTENANCE_LABEL}.plist"
_MAINTENANCE_LOG_DIR_MACOS="$HOME/Library/Logs/otto-workbench"

_launchd_is_loaded() {
  launchctl list "$_MAINTENANCE_LABEL" >/dev/null 2>&1
}

_launchd_install() {
  local interval="${1:-$_MAINTENANCE_DEFAULT_INTERVAL}"
  local template="$MAINTENANCE_SRC_DIR/maintenance.plist.template"

  mkdir -p "$(dirname "$_MAINTENANCE_PLIST")" "$_MAINTENANCE_LOG_DIR_MACOS"

  sed \
    -e "s|__WORKBENCH_DIR__|${WORKBENCH_DIR}|g" \
    -e "s|__INTERVAL__|${interval}|g" \
    -e "s|__LOG_DIR__|${_MAINTENANCE_LOG_DIR_MACOS}|g" \
    "$template" > "$_MAINTENANCE_PLIST"
}

_launchd_start() {
  local interval="$1"
  if _launchd_is_loaded; then
    launchctl unload "$_MAINTENANCE_PLIST" 2>/dev/null || true
  fi
  _launchd_install "$interval"
  launchctl load "$_MAINTENANCE_PLIST"
}

_launchd_stop() {
  if _launchd_is_loaded; then
    launchctl unload "$_MAINTENANCE_PLIST" 2>/dev/null || true
    rm -f "$_MAINTENANCE_PLIST"
    return 0
  fi
  return 1
}

_launchd_status() {
  if ! _launchd_is_loaded; then return 1; fi
  local interval
  interval=$(/usr/libexec/PlistBuddy -c "Print :StartInterval" "$_MAINTENANCE_PLIST" 2>/dev/null || echo "unknown")
  echo -e "  ${GREEN}Running${NC}  every $(_format_interval "$interval")"
  return 0
}

# ── Linux (systemd user timer) ───────────────────────────────────────────────

_SYSTEMD_UNIT="otto-workbench-maintenance"
_SYSTEMD_USER_DIR="$HOME/.config/systemd/user"

_systemd_is_active() {
  systemctl --user is-active "${_SYSTEMD_UNIT}.timer" >/dev/null 2>&1
}

_systemd_install() {
  local interval="${1:-$_MAINTENANCE_DEFAULT_INTERVAL}"
  local svc_template="$MAINTENANCE_SRC_DIR/systemd/${_SYSTEMD_UNIT}.service.template"
  local tmr_template="$MAINTENANCE_SRC_DIR/systemd/${_SYSTEMD_UNIT}.timer.template"

  mkdir -p "$_SYSTEMD_USER_DIR"

  sed -e "s|__WORKBENCH_DIR__|${WORKBENCH_DIR}|g" \
    "$svc_template" > "$_SYSTEMD_USER_DIR/${_SYSTEMD_UNIT}.service"

  sed -e "s|__INTERVAL__|${interval}|g" \
    "$tmr_template" > "$_SYSTEMD_USER_DIR/${_SYSTEMD_UNIT}.timer"

  systemctl --user daemon-reload
}

_systemd_start() {
  local interval="$1"
  _systemd_install "$interval"
  systemctl --user enable --now "${_SYSTEMD_UNIT}.timer"
}

_systemd_stop() {
  if _systemd_is_active; then
    systemctl --user disable --now "${_SYSTEMD_UNIT}.timer"
    rm -f "$_SYSTEMD_USER_DIR/${_SYSTEMD_UNIT}".{service,timer}
    systemctl --user daemon-reload
    return 0
  fi
  return 1
}

_systemd_status() {
  if ! _systemd_is_active; then return 1; fi
  local interval
  interval=$(systemctl --user show -p TriggerUSec "${_SYSTEMD_UNIT}.timer" 2>/dev/null \
    | grep -oP '\d+' | head -1)
  if [[ -n "$interval" ]]; then
    echo -e "  ${GREEN}Running${NC}  (systemd timer active)"
  else
    echo -e "  ${GREEN}Running${NC}"
  fi
  return 0
}

# ── Platform-dispatching commands ────────────────────────────────────────────

_format_interval() {
  local seconds=$1
  if (( seconds >= 3600 )); then
    echo "$(( seconds / 3600 ))h"
  elif (( seconds >= 60 )); then
    echo "$(( seconds / 60 ))m"
  else
    echo "${seconds}s"
  fi
}

cmd_maintenance_start() {
  local interval="${1:-$_MAINTENANCE_DEFAULT_INTERVAL}"
  if [[ "$OSTYPE" == "darwin"* ]]; then
    _launchd_start "$interval"
  else
    _systemd_start "$interval"
  fi
  success "Maintenance started (every $(_format_interval "$interval"))"
}

cmd_maintenance_stop() {
  if [[ "$OSTYPE" == "darwin"* ]]; then
    if _launchd_stop; then success "Maintenance stopped"; else info "Maintenance is not running"; fi
  else
    if _systemd_stop; then success "Maintenance stopped"; else info "Maintenance is not running"; fi
  fi
}

cmd_maintenance_status() {
  local running=false
  if [[ "$OSTYPE" == "darwin"* ]]; then
    if _launchd_status; then running=true; fi
  else
    if _systemd_status; then running=true; fi
  fi

  if [[ "$running" == false ]]; then
    echo -e "  ${DIM}Not running${NC}"
    echo -e "  ${DIM}Start with: otto-workbench maintenance start${NC}"
    return
  fi

  local last_run_file="${XDG_CONFIG_HOME:-$HOME/.config}/workbench/maintenance.last"
  [[ -f "$last_run_file" ]] || return 0
  local ts last_date
  ts=$(cat "$last_run_file")
  if [[ "$OSTYPE" == "darwin"* ]]; then
    last_date=$(date -r "$ts" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "unknown")
  else
    last_date=$(date -d "@$ts" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "unknown")
  fi
  echo -e "  ${DIM}Last run: $last_date${NC}"
}

cmd_maintenance_run() {
  info "Running maintenance now"
  "$MAINTENANCE_SRC_DIR/bin/otto-workbench-maintenance"
}

cmd_maintenance_logs() {
  if [[ "$OSTYPE" == "darwin"* ]]; then
    local logfile="$_MAINTENANCE_LOG_DIR_MACOS/maintenance.log"
    if [[ -f "$logfile" ]]; then
      tail -50 "$logfile"
    else
      info "No log file yet"
    fi
  else
    journalctl --user -u "$_SYSTEMD_UNIT" --no-pager -n 50 2>/dev/null \
      || info "No journal entries yet"
  fi
}

_maintenance_usage() {
  cat <<EOF
Usage: otto-workbench maintenance <command>

Scheduled maintenance via $(if [[ "$OSTYPE" == "darwin"* ]]; then echo "launchd"; else echo "systemd"; fi). Pulls changes, runs sync, and cleans stale worktrees.

Commands:
$(commands_usage COMMANDS_MAINTENANCE)
EOF
}

cmd_maintenance() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    start)  cmd_maintenance_start "$@" ;;
    stop)   cmd_maintenance_stop ;;
    status) cmd_maintenance_status ;;
    run)    cmd_maintenance_run ;;
    logs)   cmd_maintenance_logs ;;
    -h|--help) _maintenance_usage; exit 0 ;;
    *)
      _maintenance_usage >&2
      exit 1
      ;;
  esac
}

# ─── Override management ─────────────────────────────────────────────────────

_override_type_dirs() {
  local -n __default=$2 __user=$3
  case "$1" in
    agent|agents)   __default="$CLAUDE_AGENTS_SRC_DIR"; __user="$USER_AGENTS_DIR" ;;
    skill|skills)   __default="$CLAUDE_SKILLS_SRC_DIR"; __user="$USER_SKILLS_DIR" ;;
    rule|rules)     __default="$GUIDELINES_RULES_SRC_DIR"; __user="$USER_RULES_DIR" ;;
    *)              err "Unknown type: $1 (expected: agent, skill, rule)"; return 1 ;;
  esac
}

_is_override_type() {
  case "$1" in
    agent|agents|skill|skills|rule|rules) return 0 ;;
    *) return 1 ;;
  esac
}

_show_override_status() {
  local dir="$1" type="$2" found=false item name
  for item in "$dir"/*; do
    [[ -e "$item" ]] || continue
    name=$(basename "$item")
    [[ "$found" == false ]] && { echo -e "  ${CYAN}$type${NC}"; found=true; }
    [[ "$name" == *.disabled ]] \
      && echo -e "    ${RED}✗${NC} ${name%.disabled} ${DIM}(disabled)${NC}" \
      || echo -e "    ${GREEN}↻${NC} ${name%.md} ${DIM}(override)${NC}"
  done
}

_list_override_dir() {
  local dir="$1" label="$2" _found=false
  for item in "$dir"/*; do
    [[ -e "$item" ]] || continue
    _found=true
    local name suffix=""
    name=$(basename "$item")
    [[ "$name" == *.disabled ]] && suffix=" (disabled)"
    echo -e "  ${CYAN}$label/${name}${NC}${DIM}${suffix}${NC}"
  done
  [[ "$_found" == true ]]
}

_show_item_status() {
  local type="$1" name="$2"
  local default_dir user_dir
  _override_type_dirs "$type" default_dir user_dir

  local has_default=false has_override=false is_disabled=false
  case "$type" in
    skill|skills) if [[ -d "$default_dir/$name" ]]; then has_default=true; fi ;;
    *)            if [[ -f "$default_dir/${name}.md" ]]; then has_default=true; fi ;;
  esac
  case "$type" in
    skill|skills) if [[ -d "$user_dir/$name" ]]; then has_override=true; fi ;;
    *)            if [[ -f "$user_dir/${name}.md" ]]; then has_override=true; fi ;;
  esac
  [[ -f "$user_dir/${name}.disabled" ]] && is_disabled=true

  if [[ "$is_disabled" == true ]]; then
    echo -e "  ${RED}✗${NC} ${name} ${DIM}(disabled)${NC}"
  elif [[ "$has_override" == true ]]; then
    echo -e "  ${GREEN}↻${NC} ${name} ${DIM}(override)${NC}"
  elif [[ "$has_default" == true ]]; then
    echo -e "  ${DIM}${name} (default)${NC}"
  else
    err "No $type named '$name'"
    return 1
  fi
}

_list_defaults() {
  local type="$1"
  local default_dir user_dir
  _override_type_dirs "$type" default_dir user_dir

  local item name
  for item in "$default_dir"/*; do
    [[ -e "$item" ]] || continue
    name=$(basename "$item")
    case "$type" in
      agent|agents|rule|rules) name="${name%.md}" ;;
    esac
    if [[ -f "$user_dir/${name}.disabled" ]]; then
      echo -e "  ${RED}✗${NC} ${name} ${DIM}(disabled)${NC}"
    elif { [[ "$type" == skill* ]] && [[ -d "$user_dir/$name" ]]; } \
      || { [[ "$type" != skill* ]] && [[ -f "$user_dir/${name}.md" ]]; }; then
      echo -e "  ${GREEN}↻${NC} ${name} ${DIM}(override)${NC}"
    else
      echo -e "  ${DIM}${name}${NC}"
    fi
  done
}

_ai_override_usage() {
  cat <<EOF
Usage: otto-workbench ai override <agent|skill|rule> [name] [--add|--disable|--enable|--status]

Manage user overrides for AI config (agents, skills, rules).
Override files live in ~/.config/workbench/overrides/ai/.

Examples:
  otto-workbench ai override agent                   List agents and their status
  otto-workbench ai override agent debugger           Show debugger override status
  otto-workbench ai override agent debugger --add     Copy default for editing
  otto-workbench ai override agent debugger --disable Suppress a default
  otto-workbench ai override agent debugger --enable  Re-enable a disabled default

Flags:
  --status    Show detailed override status (overrides vs defaults)
  --help      Show this help
EOF
}

_ai_override_list() {
  local display_dir="${USER_AI_DIR/#$HOME/\~}"
  _ai_override_usage
  echo
  info "Active user overrides"
  local found=false item
  for item in "$USER_GUIDELINES_SRC" "$USER_GUIDELINES_LOCAL" "$USER_SETTINGS_SRC"; do
    [[ -f "$item" ]] || continue
    found=true
    echo -e "  ${CYAN}$(basename "$item")${NC}"
  done
  local dir label
  for dir in "$USER_AGENTS_DIR:agents" "$USER_SKILLS_DIR:skills" "$USER_RULES_DIR:rules"; do
    label="${dir##*:}"
    dir="${dir%%:*}"
    [[ -d "$dir" ]] || continue
    if _list_override_dir "$dir" "$label"; then
      found=true
    fi
  done
  [[ "$found" == false ]] && echo -e "  ${DIM}No overrides in ${display_dir}/${NC}"
  return 0
}

_ai_override_add() {
  local type="$1" name="$2" display_dir="${USER_AI_DIR/#$HOME/\~}"
  local default_dir user_dir
  _override_type_dirs "$type" default_dir user_dir

  local src=""
  case "$type" in
    agent|agents) src="$default_dir/${name}.md" ;;
    rule|rules)   src="$default_dir/${name}.md" ;;
    skill|skills) src="$default_dir/${name}" ;;
  esac

  if [[ ! -e "$src" ]]; then
    err "No default $type named '$name' found at $src"
    return 1
  fi

  mkdir -p "$user_dir"
  if [[ "$type" == skill* ]]; then
    cp -R "$src" "$user_dir/"
    success "Copied $type '$name' to ${display_dir}/ for editing"
    echo -e "  ${DIM}$user_dir/$name/${NC}"
  else
    local dest="$user_dir/${name}.md"
    cp "$src" "$dest"
    success "Copied $type '$name' to ${display_dir}/ for editing"
    echo -e "  ${DIM}$dest${NC}"
  fi
  echo -e "  ${DIM}Run 'otto-workbench sync' after editing to apply${NC}"
}

_ai_override_disable() {
  local type="$1" name="$2"
  local default_dir user_dir
  _override_type_dirs "$type" default_dir user_dir
  mkdir -p "$user_dir"
  touch "$user_dir/${name}.disabled"
  success "Disabled $type '$name'"
  echo -e "  ${DIM}Run 'otto-workbench sync' to apply${NC}"
}

_ai_override_enable() {
  local type="$1" name="$2"
  local default_dir user_dir
  _override_type_dirs "$type" default_dir user_dir
  local sentinel="$user_dir/${name}.disabled"
  if [[ -f "$sentinel" ]]; then
    rm "$sentinel"
    success "Re-enabled $type '$name'"
    echo -e "  ${DIM}Run 'otto-workbench sync' to apply${NC}"
  else
    warn "No disable sentinel found for $type '$name'"
  fi
}

_ai_override_set_positional() {
  local -n __t=$1 __n=$2
  local val="$3"
  if [[ -z "$__t" ]]; then __t="$val"
  elif [[ -z "$__n" ]]; then __n="$val"
  else err "Unexpected argument: $val"; _ai_override_usage >&2; return 1
  fi
}

_ai_override_parse_args() {
  local -n __type=$1 __name=$2 __action=$3
  shift 3
  __type="" __name="" __action=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --add|--disable|--enable|--status)
        [[ -n "$__action" ]] && { err "Only one action flag allowed (got $__action and $1)"; return 1; }
        __action="$1"
        ;;
      -h|--help)    __action="--help" ;;
      -*)           err "Unknown flag: $1"; _ai_override_usage >&2; return 1 ;;
      *)            _ai_override_set_positional __type __name "$1" || return 1 ;;
    esac
    shift
  done
}

_ai_override_status() {
  info "Override status (${USER_AI_DIR/#$HOME/\~}/ vs defaults)"
  echo
  local _type default_dir user_dir
  for _type in agents skills rules; do
    _override_type_dirs "$_type" default_dir user_dir
    [[ -d "$user_dir" ]] || continue
    _show_override_status "$user_dir" "$_type"
  done
}

cmd_ai_override() {
  local type name action
  _ai_override_parse_args type name action "$@" || return 1

  # No type: top-level
  if [[ -z "$type" ]]; then
    [[ "$action" == "--status" ]] && { _ai_override_status; return 0; }
    _ai_override_list
    return 0
  fi

  if ! _is_override_type "$type"; then
    err "Unknown type: $type (expected: agent, skill, rule)"
    return 1
  fi

  # Type only, no name
  if [[ -z "$name" ]]; then
    info "$type overrides"
    _list_defaults "$type"
    return 0
  fi

  # Type + name + action
  case "$action" in
    --add)     _ai_override_add "$type" "$name" ;;
    --disable) _ai_override_disable "$type" "$name" ;;
    --enable)  _ai_override_enable "$type" "$name" ;;
    --help)    _ai_override_usage ;;
    --status|"") _show_item_status "$type" "$name" ;;
  esac
}

# ─── Discover ────────────────────────────────────────────────────────────────

_discover_components() {
  if ! state_file_exists; then
    echo -e "    ${DIM}(no state file — run 'otto-workbench discover regenerate' to detect)${NC}"
    return
  fi
  if [[ ! -f "$INSTALL_YML_FILE" ]]; then
    echo -e "    ${DIM}(legacy state file — run 'otto-workbench sync' to migrate)${NC}"
    return
  fi
  local comp val
  while IFS= read -r comp; do
    [[ -z "$comp" ]] && continue
    echo "    $comp"
    val=$(c="$comp" yq -r '.components[env(c)]' "$INSTALL_YML_FILE" 2>/dev/null)
    [[ "$val" == "true" ]] && continue
    c="$comp" yq -r '.components[env(c)] | to_entries[] | "      " + .key + ": " + (.value | tostring)' "$INSTALL_YML_FILE" 2>/dev/null
  done < <(yq '.components | keys | .[]' "$INSTALL_YML_FILE" 2>/dev/null)
}

_discover_scripts() {
  local registry="$BIN_REGISTRY_FILE"
  if [[ ! -f "$registry" ]] || ! command -v yq &>/dev/null; then
    echo -e "    ${DIM}(registry not found or yq not installed)${NC}"
    return
  fi
  local count name desc
  count=$(yq '.tools | length' "$registry")
  for (( i = 0; i < count; i++ )); do
    name=$(yq ".tools[$i].name" "$registry")
    desc=$(yq ".tools[$i].description" "$registry")
    printf "    ${GREEN}%-18s${NC} %s\n" "$name" "$desc"
  done
}

_discover_launchd_agents() {
  local found=false plist label short interval
  for plist in "$HOME"/Library/LaunchAgents/com.otto-workbench.*.plist; do
    [[ -f "$plist" ]] || continue
    found=true
    label=$(/usr/libexec/PlistBuddy -c "Print :Label" "$plist" 2>/dev/null)
    short="${label#com.otto-workbench.}"
    if launchctl list "$label" &>/dev/null; then
      interval=$(/usr/libexec/PlistBuddy -c "Print :StartInterval" "$plist" 2>/dev/null || echo "")
      [[ -n "$interval" ]] \
        && printf "    ${GREEN}%-18s${NC} Running (every %s)\n" "$short" "$(_format_interval "$interval")" \
        || printf "    ${GREEN}%-18s${NC} Running\n" "$short"
    else
      printf "    ${DIM}%-18s Stopped${NC}\n" "$short"
    fi
  done
  [[ "$found" == true ]]
}

_discover_systemd_timers() {
  local found=false unit short
  for unit in "$_SYSTEMD_USER_DIR"/otto-workbench-*.timer; do
    [[ -f "$unit" ]] || continue
    found=true
    short=$(basename "$unit" .timer)
    if systemctl --user is-active "$short.timer" &>/dev/null; then
      printf "    ${GREEN}%-18s${NC} Running (systemd timer)\n" "${short#otto-workbench-}"
    else
      printf "    ${DIM}%-18s Stopped${NC}\n" "${short#otto-workbench-}"
    fi
  done
  [[ "$found" == true ]]
}

_discover_agents() {
  local found=false
  if [[ "$OSTYPE" == "darwin"* ]]; then
    if _discover_launchd_agents; then found=true; fi
  else
    if _discover_systemd_timers; then found=true; fi
  fi
  [[ "$found" == false ]] && echo -e "    ${DIM}(none installed)${NC}"
  return 0
}

cmd_discover() {
  local subcmd="${1:-}"
  case "$subcmd" in
    regenerate)
      info "Regenerating installation state"
      rm -f "$INSTALL_YML_FILE" "$INSTALLED_STATE_FILE"
      state_detect_installed
      echo
      success "Installation state regenerated"
      ;;
    "")
      ;;
    *)
      echo "Usage: otto-workbench discover [regenerate]" >&2
      exit 1
      ;;
  esac

  echo -e "\n  ${BOLD}Components${NC}"
  _discover_components
  echo -e "\n  ${BOLD}Scripts${NC}"
  _discover_scripts
  echo -e "\n  ${BOLD}Agents${NC}"
  _discover_agents
  echo
}

# ─── Main ─────────────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
Usage: otto-workbench [--workbench-dir <path>] <command>

Global flags:
  --workbench-dir <path>  Override workbench root (e.g. a worktree checkout)

Commands:
$(commands_usage)

Run 'otto-workbench install --help' for install options.
Run 'otto-workbench ai' or 'otto-workbench maintenance' for subcommands.
EOF
}

case "${1:-}" in
  install)    shift; cmd_install "$@" ;;
  sync)       cmd_sync ;;
  ai)         shift; cmd_ai "$@" ;;
  discover)   shift; cmd_discover "$@" ;;
  maintenance) shift; cmd_maintenance "$@" ;;
  changelog)  shift; cmd_changelog "$@" ;;
  -h|--help) usage; exit 0 ;;
  *)
    usage >&2
    exit 1
    ;;
esac
