#!/bin/bash
# Manage your workbench developer environment.
#
# Usage: otto-workbench <command>
#
# Commands:
#   sync   Re-apply all workbench configuration to ~/
#
# What sync does:
#   - Re-symlinks bin/, zsh/, git/.gitconfig, Taskfile, lib/
#   - Syncs Claude settings.json, CLAUDE.md, rules/, skills/, agents/, MCPs
#
# What sync does NOT do (one-time setup operations):
#   - Install Homebrew packages
#   - Configure Docker runtime
#   - Install iTerm themes
#
# To run first-time setup or those components: bash <workbench>/install.sh

set -e

_SELF="$(readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
# shellcheck source=/dev/null
. "$(dirname "$_SELF")/../lib/ui.sh"

WORKBENCH_DIR="$(cd "$(dirname "$_SELF")/.." && pwd)"

# SCRIPT_DIR is expected by ai/claude/steps.sh functions (they look for
# $SCRIPT_DIR/claude/, $SCRIPT_DIR/guidelines/, etc.)
# shellcheck disable=SC2034
SCRIPT_DIR="$WORKBENCH_DIR/ai"

# Non-interactive mode: all install_symlink calls warn and skip real files rather
# than prompting. Users who need interactive overwrite should run install.sh instead.
# shellcheck disable=SC2034  # read by install_symlink in lib/ui.sh
SYMLINK_MODE=no-prompt

# Source step functions for git and Claude
# shellcheck source=/dev/null
. "$WORKBENCH_DIR/git/setup.sh"
# shellcheck source=/dev/null
. "$WORKBENCH_DIR/ai/claude/steps.sh"

# ─── Commands ─────────────────────────────────────────────────────────────────

cmd_sync() {
  echo -e "${BOLD}${BLUE}Workbench sync${NC}"
  echo

  # ─── Core ──────────────────────────────────────────────────────────────────

  info "bin scripts → $LOCAL_BIN_DIR/"
  mkdir -p "$LOCAL_BIN_DIR"
  symlink_dir "$WORKBENCH_DIR/bin" "$LOCAL_BIN_DIR" --prune

  echo
  info "zsh configs → $ZSH_CONFIG_DIR/"
  mkdir -p "$ZSH_CONFIG_DIR"
  symlink_dir "$WORKBENCH_DIR/zsh" "$ZSH_CONFIG_DIR" "*.zsh" --prune

  echo
  info "git, taskfile, lib, starship"
  mkdir -p "$TASK_CONFIG_DIR"
  step_gitconfig
  install_symlink "$WORKBENCH_DIR/Taskfile.global.yml"       "$TASK_CONFIG_DIR/Taskfile.yml"
  install_symlink "$WORKBENCH_DIR/lib"                       "$TASK_CONFIG_DIR/lib"
  install_symlink "$WORKBENCH_DIR/zsh/starship.toml"         "$STARSHIP_CONFIG_FILE"

  echo
  info "global git hooks → $GIT_HOOKS_DIR"
  step_global_hooks

  # ─── Claude ────────────────────────────────────────────────────────────────

  echo
  if ! command -v claude >/dev/null 2>&1; then
    warn "claude not found in PATH — skipping Claude steps"
  else
    info "Claude settings"
    step_claude_settings

    echo
    info "Tool context"
    step_generate_tools

    echo
    info "Claude guidelines + rules"
    step_claude_guidelines
    step_claude_rules

    echo
    info "Claude MCPs"
    step_claude_mcps

    echo
    info "Claude skills + agents"
    step_claude_skills
    step_claude_agents
  fi

  echo
  echo -e "${BOLD}${GREEN}✓ Workbench synced!${NC}"
  echo -e "  ${DIM}Reload your shell: exec $(basename "$SHELL")${NC}"
}

# ─── Main ─────────────────────────────────────────────────────────────────────

case "${1:-}" in
  sync) cmd_sync ;;
  *)
    echo "Usage: otto-workbench <command>"
    echo
    echo "Commands:"
    echo "  sync   Re-apply all workbench configuration to ~/"
    exit 1
    ;;
esac
