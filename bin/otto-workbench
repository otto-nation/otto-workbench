#!/usr/bin/env bash
# Manage your workbench developer environment.
#
# Usage: otto-workbench <command>
#
# Commands:
#   sync              Re-apply all workbench configuration to ~/
#   claude [--force]  Sync Claude config + scaffold project .claude/ (see below)
#   changelog         Show recent changes from conventional commits
#
# What claude does:
#   Syncs machine-level Claude config (settings, rules, skills, agents, MCPs),
#   then scaffolds a .claude/ directory in the current git repo (if one doesn't
#   exist) with stack-detected rules and a project anatomy file.
#   Anatomy is a file index (.claude/anatomy.md) with per-file descriptions and
#   token estimates — helps Claude decide what to read before exploring.
#   Use --force to re-scaffold an existing .claude/ directory.
#
# What sync does (pure config reconciliation):
#   - Re-symlinks scripts, zsh/, git/.gitconfig, Taskfile, lib/
#   - Syncs Claude settings.json, CLAUDE.md, rules/, skills/, agents/, MCPs
#   - Merges Zed/Sublime editor settings
#   - Reconciles Ghostty theme key
#
# What sync does NOT do (one-time setup via install.sh):
#   - Install Homebrew packages or casks
#   - Configure Docker runtime
#   - Import iTerm themes
#   - Create Ghostty config from template
#   - Regenerate tool context (now runs during sync via sync_zsh)
#
# To run first-time setup or those components: bash <workbench>/install.sh

set -e

# Require modern bash (4.3+ for namerefs used in lib/registries.sh).
if [[ "${BASH_VERSINFO[0]}" -lt 4 || ( "${BASH_VERSINFO[0]}" -eq 4 && "${BASH_VERSINFO[1]}" -lt 3 ) ]]; then
  echo "✗ bash 4.3+ required (found ${BASH_VERSION}). Install: brew install bash" >&2
  exit 1
fi

_SELF="$(readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
# shellcheck source=/dev/null
. "$(dirname "$_SELF")/../lib/ui.sh"
# shellcheck source=/dev/null
. "$(dirname "$_SELF")/../lib/migrations.sh"

WORKBENCH_DIR="$(cd "$(dirname "$_SELF")/.." && pwd)"

# Non-interactive mode: all install_symlink calls warn and skip real files rather
# than prompting. Users who need interactive overwrite should run install.sh instead.
# shellcheck disable=SC2034  # read by install_symlink in lib/ui.sh
SYMLINK_MODE=no-prompt

# Auto-discover and source all steps.sh files.
# Each steps.sh self-derives its own paths; no external variables need to be injected.
# Adding a new component with a steps.sh automatically makes its functions available here.
_step_files=()
discover_step_files _step_files
for _f in "${_step_files[@]}"; do
  # shellcheck source=/dev/null
  . "$_f"
done
unset _f _step_files

# ─── Commands ─────────────────────────────────────────────────────────────────

cmd_sync() {
  # Collect warnings/errors for final summary replay.
  WORKBENCH_INSTALL_LOG="$(mktemp "${TMPDIR:-/tmp}/workbench-sync.XXXXXX")"
  export WORKBENCH_INSTALL_LOG
  trap 'rm -f "$WORKBENCH_INSTALL_LOG"' EXIT

  title "Workbench sync"
  echo

  # Run pending migrations before syncing components.
  # Migrations clean up state (stale symlinks, old config) that sync functions depend on.
  info "Migrations"
  run_all_migrations
  echo

  # Auto-discovers sync_<component>() from all steps.sh files.
  # Glob order is alphabetical: bin → docker → git → task → terminals → zsh →
  #                              ai/claude → editors/… → …
  # Adding any component with a sync_<name>() function includes it automatically.
  local -a _step_files=()
  discover_step_files _step_files
  local _f _c
  for _f in "${_step_files[@]}"; do
    _c=$(basename "$(dirname "$_f")")
    export WORKBENCH_CURRENT_COMPONENT="$_c"
    declare -f "sync_${_c}" > /dev/null && "sync_${_c}"
  done
  unset WORKBENCH_CURRENT_COMPONENT

  # shellcheck source=/dev/null
  . "$(dirname "$_SELF")/../lib/summary.sh"

  echo
  success "Workbench synced!"
  print_workbench_summary

  # Auto-discover and call per-component summaries (brew, docker, ai, etc.)
  run_component_summaries

  print_warnings_summary
}

cmd_claude() {
  local force_flag=""
  [[ "${2:-}" == "--force" ]] && force_flag="--force"

  title "Claude setup"
  echo

  # 1. Sync machine-level Claude config (settings, rules, skills, agents, MCPs)
  sync_claude

  # 2. Scaffold project .claude/ if not already done (or if --force)
  local project_root
  project_root="$(git rev-parse --show-toplevel 2>/dev/null)" || true

  if [[ -n "$project_root" ]]; then
    cd "$project_root"
    echo
    if [[ -d ".claude" ]] && [[ -z "$force_flag" ]]; then
      info "Project .claude/ exists — skipping scaffold (use --force to re-scaffold)"
    else
      info "Scaffolding project"
      scaffold_project_claude $force_flag
    fi

    # 3. Generate project anatomy
    local anatomy_gen="$CLAUDE_SKILLS_DIR/anatomy/generate-anatomy.sh"
    if [[ -f "$anatomy_gen" ]]; then
      echo
      info "Generating project anatomy"
      if bash "$anatomy_gen"; then
        success "anatomy.md"
      else
        skip "anatomy.md (generator failed)"
      fi
    fi
  else
    echo
    warn "Not in a git repo — skipping project scaffold and anatomy"
  fi

  echo
  success "Claude setup complete!"
}

cmd_changelog() {
  shift  # remove "changelog" from args
  bash "$WORKBENCH_DIR/git/bin/generate-changelog" "$@"
}

# ─── Main ─────────────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
Usage: otto-workbench <command>

Commands:
  sync              Re-apply all workbench configuration to ~/
  claude [--force]  Sync Claude config + scaffold .claude/ in current repo
  changelog         Show recent changes from conventional commits
EOF
}

case "${1:-}" in
  sync)      cmd_sync ;;
  claude)    cmd_claude "$@" ;;
  changelog) cmd_changelog "$@" ;;
  -h|--help) usage; exit 0 ;;
  *)
    usage >&2
    exit 1
    ;;
esac
