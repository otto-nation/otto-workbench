#!/usr/bin/env python3
"""Validate that scripts do not exceed a maximum nesting depth per function.

Usage: validate-nesting [--quiet] [--max-depth N] [file...]

Checks nesting depth in bash, Python, and Go scripts. Each language has
its own default max depth (bash/python: 2, go: 3) overridable with
--max-depth.

When no files are given, discovers all scripts in the repo by extension
and shebang.

Exit code: 0 if all files pass, 1 if any exceed max depth.
"""

import argparse
import os
import subprocess
import sys

_WORKBENCH_DIR = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
sys.path.insert(0, os.path.join(_WORKBENCH_DIR, 'lib'))
from ansi import RED, GREEN, DIM, NC  # noqa: E402
from nesting import get_checker_for_extension, get_checker_for_shebang, get_all_extensions  # noqa: E402

# ── Discovery ────────────────────────────────────────────────────────────────

SKIP_DIRS = {
    '.git', 'node_modules', 'vendor', '__pycache__', '.venv', 'venv',
    '.tox', '.mypy_cache', 'dist', 'build', '.eggs', '.cache',
}


def _read_shebang(path: str) -> bytes | None:
    try:
        with open(path, 'rb') as f:
            return f.readline()
    except (OSError, UnicodeDecodeError):
        return None


def _get_checker_by_ext(filepath: str, ext: str):
    checker = get_checker_for_extension(ext)
    if not checker:
        return None
    if ext == '.bats':
        return checker
    shebang = _read_shebang(filepath)
    return checker if shebang is not None else None


def _get_checker(filepath: str):
    _, ext = os.path.splitext(filepath)
    if ext:
        return _get_checker_by_ext(filepath, ext)
    shebang = _read_shebang(filepath)
    if shebang:
        return get_checker_for_shebang(shebang)
    return None


def _discover_in_dir(dirpath, filenames, scripts):
    all_exts = get_all_extensions()
    for fname in filenames:
        _, ext = os.path.splitext(fname)
        if ext not in all_exts and '.' in fname:
            continue
        path = os.path.join(dirpath, fname)
        checker = _get_checker(path)
        if checker:
            scripts.add((path, checker))


def discover_scripts(repo_root):
    scripts = set()
    for dirpath, dirnames, filenames in os.walk(repo_root):
        dirnames[:] = [d for d in dirnames if d not in SKIP_DIRS]
        _discover_in_dir(dirpath, filenames, scripts)
    return sorted(scripts, key=lambda t: t[0])


# ── Reporting ────────────────────────────────────────────────────────────────

def _report_violations(relpath, violations, max_depth):
    print(f'{RED}✗{NC} {relpath}: nesting exceeds {max_depth} levels', file=sys.stderr)
    prev_func = None
    for v in violations:
        if v.function_name != prev_func:
            print(f'    {DIM}in {v.function_name}():{NC}', file=sys.stderr)
            prev_func = v.function_name
        print(f'      line {v.line_number}: depth {v.depth}', file=sys.stderr)


def _print_summary(files_checked, errors):
    print()
    if errors == 0:
        print(f'{GREEN}✓{NC} {files_checked} files checked, no excessive nesting')
    else:
        print(f'{RED}✗{NC} {errors} of {files_checked} files exceed max nesting depth', file=sys.stderr)


# ── CLI ──────────────────────────────────────────────────────────────────────

def _resolve_files(args, repo_root):
    if not args.files:
        return discover_scripts(repo_root)
    return [(f, c) for f in args.files if (c := _get_checker(f))]


def main():
    parser = argparse.ArgumentParser(description='Validate script nesting depth.')
    parser.add_argument('--quiet', action='store_true', help='Only show failures and summary')
    parser.add_argument('--max-depth', type=int, default=None,
                        help='Maximum nesting depth (overrides per-language defaults)')
    parser.add_argument('files', nargs='*', help='Files to check (auto-discovers if omitted)')
    args = parser.parse_args()

    try:
        repo_root = subprocess.check_output(
            ['git', 'rev-parse', '--show-toplevel'], stderr=subprocess.DEVNULL,
        ).decode().strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        repo_root = os.getcwd()

    file_checkers = _resolve_files(args, repo_root)

    errors = 0
    for filepath, checker in file_checkers:
        max_depth = args.max_depth if args.max_depth is not None else checker.DEFAULT_MAX_DEPTH
        with open(filepath) as f:
            lines = f.readlines()
        violations = checker.check_nesting(lines, max_depth)
        relpath = os.path.relpath(filepath, repo_root)

        if violations:
            errors += 1
            _report_violations(relpath, violations, max_depth)
        elif not args.quiet:
            print(f'  {GREEN}✓{NC} {relpath}')

    _print_summary(len(file_checkers), errors)
    if errors:
        sys.exit(1)


if __name__ == '__main__':
    main()
