#!/usr/bin/env bash
# Validate tool registries against schema and cross-check with their source files.
#
# Checks performed per registry:
#   - Required fields present: name, description, when_to_use
#   - No duplicate tool names
#   - Cross-file check based on meta.validation:
#       brewfile      — every tool name (or brew_name override) exists in meta.source Brewfile
#       bindir        — every tool name exists as a file in meta.source directory
#       zsh-comments  — every tool name has a matching header comment under meta.source
#       none          — schema-only, no cross-check
#
# Registry discovery:
#   Top-level:    <repo>/*/registry.yml
#   Optional stacks: <repo>/brew/{lang,infra,tools}/*.registry.yml
#
# Usage: bin/validate-registries
# Exit code: 0 if all checks pass, 1 if any fail.

set -euo pipefail

_SELF="$(readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
REPO_ROOT="$(cd "$(dirname "$_SELF")/.." && pwd)"

# shellcheck source=../lib/ui.sh
. "$REPO_ROOT/lib/ui.sh"

ERRORS=0

# _fail MSG — records an error and prints it; does not exit immediately so all
# errors in a registry are reported before aborting.
_fail() {
  echo -e "  ${RED}✗${NC} $*" >&2
  ERRORS=$(( ERRORS + 1 ))
}

# _check_required_fields FILE INDEX
_check_required_fields() {
  local file="$1" i="$2"
  local name description when_to_use
  name=$(yq ".tools[$i].name // \"\"" "$file")
  description=$(yq ".tools[$i].description // \"\"" "$file")
  when_to_use=$(yq ".tools[$i].when_to_use // \"\"" "$file")

  [[ -n "$name" && "$name" != "null" ]]             || _fail "$(basename "$file") [$i]: missing required field: name"
  [[ -n "$description" && "$description" != "null" ]] || _fail "$(basename "$file") entry '$name': missing required field: description"
  [[ -n "$when_to_use" && "$when_to_use" != "null" ]] || _fail "$(basename "$file") entry '$name': missing required field: when_to_use"
}

# _check_no_duplicates FILE
_check_no_duplicates() {
  local file="$1"
  local dupes
  dupes=$(yq '.tools[].name' "$file" | sort | uniq -d)
  if [[ -n "$dupes" ]]; then
    while IFS= read -r name; do
      _fail "$(basename "$file"): duplicate tool name: $name"
    done <<< "$dupes"
  fi
}

# _validate_schema FILE
# Runs required-field and duplicate checks for every entry in FILE.
_validate_schema() {
  local file="$1"
  [[ -f "$file" ]] || { warn "$(basename "$file") not found — skipping"; return; }
  local count i=0
  count=$(yq '.tools | length' "$file")
  while [[ "$i" -lt "$count" ]]; do
    _check_required_fields "$file" "$i"
    i=$(( i + 1 ))
  done
  _check_no_duplicates "$file"
}

# _validate_against_brewfile REGISTRY BREWFILE
# Every tool name (or brew_name override) must appear in BREWFILE.
_validate_against_brewfile() {
  local file="$1" brewfile="$2"
  [[ -f "$brewfile" ]] || { warn "$(basename "$brewfile") not found — skipping cross-check"; return; }
  local count i=0 name brew_name check_name
  count=$(yq '.tools | length' "$file")
  while [[ "$i" -lt "$count" ]]; do
    name=$(yq ".tools[$i].name" "$file")
    brew_name=$(yq ".tools[$i].brew_name // \"\"" "$file")
    check_name="${brew_name:-$name}"
    if ! grep -qE "^(brew|cask) [\"']?${check_name}[\"']?" "$brewfile"; then
      _fail "$(basename "$file"): '$name' not found in ${brewfile#"$REPO_ROOT/"}"
    fi
    i=$(( i + 1 ))
  done
}

# _validate_against_bindir REGISTRY DIR
# Every tool name must exist as a file in DIR.
_validate_against_bindir() {
  local file="$1" dir="$2"
  local count i=0 name
  count=$(yq '.tools | length' "$file")
  while [[ "$i" -lt "$count" ]]; do
    name=$(yq ".tools[$i].name" "$file")
    if [[ ! -f "$dir/$name" ]]; then
      _fail "$(basename "$file"): '$name' not found in ${dir#"$REPO_ROOT/"}/"
    fi
    i=$(( i + 1 ))
  done
}

# _validate_against_zsh REGISTRY DIR
# Every tool name must have a matching header comment somewhere under DIR.
_validate_against_zsh() {
  local file="$1" dir="$2"
  local count i=0 name keyword
  count=$(yq '.tools | length' "$file")
  while [[ "$i" -lt "$count" ]]; do
    name=$(yq ".tools[$i].name" "$file")
    keyword=$(echo "$name" | cut -d' ' -f1)
    if ! grep -rqi "# ${keyword}" "$dir" 2>/dev/null; then
      _fail "$(basename "$file"): '$name' — no matching comment found in ${dir#"$REPO_ROOT/"}/ for keyword '${keyword}'"
    fi
    i=$(( i + 1 ))
  done
}

# _validate_registry FILE
# Dispatches cross-validation based on meta.validation and meta.source in FILE.
_validate_registry() {
  local file="$1"
  local validation source
  validation=$(yq '.meta.validation // "none"' "$file")
  source=$(yq '.meta.source // ""' "$file")

  case "$validation" in
    brewfile)
      [[ -n "$source" ]] && _validate_against_brewfile "$file" "$REPO_ROOT/$source"
      ;;
    bindir)
      [[ -n "$source" ]] && _validate_against_bindir "$file" "$REPO_ROOT/$source"
      ;;
    zsh-comments)
      [[ -n "$source" ]] && _validate_against_zsh "$file" "$REPO_ROOT/$source"
      ;;
    none|install-check) ;;
    *)
      warn "$(basename "$file"): unknown validation type '$validation' — skipping cross-check"
      ;;
  esac
}

# ── Main ──────────────────────────────────────────────────────────────────────

if ! command -v yq >/dev/null 2>&1; then
  err "yq not found — run: brew install yq"
  exit 1
fi

# Collect all registries: top-level (one per domain dir) + optional stacks
declare -a all_registries=()
for f in "$REPO_ROOT"/*/registry.yml; do
  [[ -f "$f" ]] && all_registries+=("$f")
done
while IFS= read -r -d '' f; do
  all_registries+=("$f")
done < <(find "$REPO_ROOT/brew" -mindepth 2 -maxdepth 2 -name '*.registry.yml' -print0 | sort -z)

if [[ "${#all_registries[@]}" -eq 0 ]]; then
  warn "No registry files found — skipping"
  exit 0
fi

echo "→ Validating registries..."

for registry in "${all_registries[@]}"; do
  echo
  info "Schema: ${registry#"$REPO_ROOT/"}"
  _validate_schema "$registry"
  _validate_registry "$registry"
done

echo
if [[ "$ERRORS" -gt 0 ]]; then
  err "$ERRORS error(s) found"
  exit 1
fi

success "All registries valid"
