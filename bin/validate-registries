#!/usr/bin/env bash
# Validate tool registries against schema and cross-check with their source files.
#
# Checks performed per registry:
#   - Required fields present: name, description, when_to_use
#   - No duplicate tool names
#   - Cross-file check based on meta.validation:
#       brewfile      — every tool name (or brew_name override) exists in meta.source Brewfile
#       bindir        — every tool name exists as a file in meta.source directory
#       zsh-comments  — every tool name has a matching header comment under meta.source
#       none          — schema-only, no cross-check
#
# Registry discovery:
#   Top-level:       <repo>/*/registry.yml
#   Nested:          <repo>/*/*/registry.yml  (e.g. ai/claude/registry.yml)
#   Optional stacks: <repo>/brew/{lang,infra,tools}/*.registry.yml
#
# Usage: bin/validate-registries
# Exit code: 0 if all checks pass, 1 if any fail.

set -euo pipefail

_SELF="$(readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
REPO_ROOT="$(cd "$(dirname "$_SELF")/.." && pwd)"

# shellcheck source=../lib/ui.sh
. "$REPO_ROOT/lib/ui.sh"
# shellcheck source=../lib/registries.sh
. "$REPO_ROOT/lib/registries.sh"

usage() {
  cat <<EOF
Usage: $(basename "$0") [--quiet]

Validate tool registries against schema and cross-check with their source files.

Options:
  --quiet     Suppress per-registry output; show only the final summary
  -h, --help  Show this help
EOF
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }
QUIET=false
[[ "${1:-}" == "--quiet" ]] && QUIET=true

ERRORS=0
REGISTRIES_CHECKED=0
declare -a ALL_ENV_VARS=()   # "VAR_NAME:source_file" pairs for cross-registry dupe check

# _fail MSG — records an error and prints it; does not exit immediately so all
# errors in a registry are reported before aborting.
_fail() {
  echo -e "  ${RED}✗${NC} $*" >&2
  ERRORS=$(( ERRORS + 1 ))
}

# _check_required_fields FILE INDEX
_check_required_fields() {
  local file="$1" i="$2"
  local name description when_to_use
  name=$(yq ".tools[$i].name // \"\"" "$file")
  description=$(yq ".tools[$i].description // \"\"" "$file")
  when_to_use=$(yq ".tools[$i].when_to_use // \"\"" "$file")

  [[ -n "$name" && "$name" != "null" ]]             || _fail "$(basename "$file") [$i]: missing required field: name"
  [[ -n "$description" && "$description" != "null" ]] || _fail "$(basename "$file") entry '$name': missing required field: description"
  [[ -n "$when_to_use" && "$when_to_use" != "null" ]] || _fail "$(basename "$file") entry '$name': missing required field: when_to_use"
}

# _check_no_duplicates FILE
_check_no_duplicates() {
  local file="$1"
  local dupes
  dupes=$(yq '.tools[].name' "$file" | sort | uniq -d)
  if [[ -n "$dupes" ]]; then
    while IFS= read -r name; do
      _fail "$(basename "$file"): duplicate tool name: $name"
    done <<< "$dupes"
  fi
}

# _validate_schema FILE
# Runs required-field and duplicate checks for every entry in FILE.
_validate_schema() {
  local file="$1"
  [[ -f "$file" ]] || { warn "$(basename "$file") not found — skipping"; return; }
  local count i=0
  count=$(yq '.tools | length' "$file")
  while [[ "$i" -lt "$count" ]]; do
    _check_required_fields "$file" "$i"
    i=$(( i + 1 ))
  done
  _check_no_duplicates "$file"
}

# _validate_against_brewfile REGISTRY BREWFILE
# Every tool name (or brew_name override) must appear in BREWFILE.
_validate_against_brewfile() {
  local file="$1" brewfile="$2"
  [[ -f "$brewfile" ]] || { warn "$(basename "$brewfile") not found — skipping cross-check"; return; }
  local count i=0 name brew_name check_name
  count=$(yq '.tools | length' "$file")
  while [[ "$i" -lt "$count" ]]; do
    name=$(yq ".tools[$i].name" "$file")
    brew_name=$(yq ".tools[$i].brew_name // \"\"" "$file")
    check_name="${brew_name:-$name}"
    if ! grep -qE "^(brew|cask) [\"']?${check_name}[\"']?" "$brewfile"; then
      _fail "$(basename "$file"): '$name' not found in ${brewfile#"$REPO_ROOT/"}"
    fi
    i=$(( i + 1 ))
  done
}

# _validate_against_bindir REGISTRY DIR
# Every tool name must exist as a file in DIR.
_validate_against_bindir() {
  local file="$1" dir="$2"
  local count i=0 name
  count=$(yq '.tools | length' "$file")
  while [[ "$i" -lt "$count" ]]; do
    name=$(yq ".tools[$i].name" "$file")
    if [[ ! -f "$dir/$name" ]]; then
      _fail "$(basename "$file"): '$name' not found in ${dir#"$REPO_ROOT/"}/"
    fi
    i=$(( i + 1 ))
  done
}

# _validate_against_zsh REGISTRY DIR
# Every tool name must have a matching header comment somewhere under DIR.
_validate_against_zsh() {
  local file="$1" dir="$2"
  local count i=0 name keyword
  count=$(yq '.tools | length' "$file")
  while [[ "$i" -lt "$count" ]]; do
    name=$(yq ".tools[$i].name" "$file")
    keyword=$(echo "$name" | cut -d' ' -f1)
    if ! grep -rqi "# ${keyword}" "$dir" 2>/dev/null; then
      _fail "$(basename "$file"): '$name' — no matching comment found in ${dir#"$REPO_ROOT/"}/ for keyword '${keyword}'"
    fi
    i=$(( i + 1 ))
  done
}

# _validate_env_fields FILE
# Validates the optional top-level env[] array: var is present, valid format, no dupes.
_validate_env_fields() {
  local file="$1"
  local has_env
  has_env=$(yq '. | has("env")' "$file")
  [[ "$has_env" == "true" ]] || return 0

  local count i=0
  count=$(yq '.env | length' "$file")
  local -a seen_vars=()
  while [[ "$i" -lt "$count" ]]; do
    local var
    var=$(yq ".env[$i].var // \"\"" "$file")
    if [[ -z "$var" || "$var" == "null" ]]; then
      _fail "$(basename "$file") env[$i]: missing required field: var"
      i=$(( i + 1 ))
      continue
    fi
    if [[ ! "$var" =~ ^[A-Z][A-Z0-9_]*$ ]]; then
      _fail "$(basename "$file") env '$var': invalid var name (must match ^[A-Z][A-Z0-9_]*$)"
    fi
    local v
    for v in "${seen_vars[@]}"; do
      if [[ "$v" == "$var" ]]; then
        _fail "$(basename "$file"): duplicate env var: $var"
        break
      fi
    done
    seen_vars+=("$var")
    # Track for cross-registry duplicate check (use relative path for readability)
    ALL_ENV_VARS+=("$var:${file#"$REPO_ROOT/"}")
    i=$(( i + 1 ))
  done
}

# _validate_install_check_command FILE
# When install_check: true and install_check_command is set, validates it is non-empty.
# When tools is empty and install_check: true, requires install_check_command.
_validate_install_check_command() {
  local file="$1"
  local install_check install_check_command tools_count
  install_check=$(yq '.meta.install_check // false' "$file")
  [[ "$install_check" == "true" ]] || return 0

  install_check_command=$(yq '.meta.install_check_command // ""' "$file")
  tools_count=$(yq '.tools | length' "$file")

  local install_check_symlink
  install_check_symlink=$(yq '.meta.install_check_symlink // ""' "$file")

  if [[ "$tools_count" -eq 0 ]] \
     && [[ -z "$install_check_command" || "$install_check_command" == "null" ]] \
     && [[ -z "$install_check_symlink" || "$install_check_symlink" == "null" ]]; then
    _fail "$(basename "$file"): install_check: true with empty tools[] requires install_check_command or install_check_symlink"
  fi
}

# _validate_auth_fields FILE
# If auth block is present, env_var must be non-empty. Warns if setup_url is missing.
_validate_auth_fields() {
  local file="$1"
  local count i=0
  count=$(yq '.tools | length' "$file")
  while [[ "$i" -lt "$count" ]]; do
    local has_auth
    has_auth=$(yq ".tools[$i] | has(\"auth\")" "$file")
    if [[ "$has_auth" == "true" ]]; then
      local name env_var setup_url
      name=$(yq ".tools[$i].name" "$file")
      env_var=$(yq ".tools[$i].auth.env_var // \"\"" "$file")
      setup_url=$(yq ".tools[$i].auth.setup_url // \"\"" "$file")
      if [[ -z "$env_var" || "$env_var" == "null" ]]; then
        _fail "$(basename "$file") entry '$name': auth block missing required field: env_var"
      else
        ALL_ENV_VARS+=("$env_var:${file#"$REPO_ROOT/"}")
      fi
      if [[ -z "$setup_url" || "$setup_url" == "null" ]]; then
        warn "$(basename "$file") entry '$name': auth block missing setup_url"
      fi
    fi
    i=$(( i + 1 ))
  done
}

# _validate_registry FILE
# Dispatches cross-validation based on meta.validation and meta.source in FILE.
_validate_registry() {
  local file="$1"
  local validation source
  validation=$(yq '.meta.validation // "none"' "$file")
  source=$(yq '.meta.source // ""' "$file")

  case "$validation" in
    brewfile)
      [[ -n "$source" ]] && _validate_against_brewfile "$file" "$REPO_ROOT/$source"
      ;;
    bindir)
      [[ -n "$source" ]] && _validate_against_bindir "$file" "$REPO_ROOT/$source"
      ;;
    zsh-comments)
      [[ -n "$source" ]] && _validate_against_zsh "$file" "$REPO_ROOT/$source"
      ;;
    none|install-check) ;;
    *)
      warn "$(basename "$file"): unknown validation type '$validation' — skipping cross-check"
      ;;
  esac
}

# ── Main ──────────────────────────────────────────────────────────────────────

if ! command -v yq >/dev/null 2>&1; then
  err "yq not found — run: brew install yq"
  exit 1
fi

# Collect all registries: top-level + nested (e.g. ai/claude/) + optional brew stacks
declare -a all_registries=()
collect_registries all_registries "$REPO_ROOT"

if [[ "${#all_registries[@]}" -eq 0 ]]; then
  warn "No registry files found — skipping"
  exit 0
fi

$QUIET || echo "→ Validating registries..."

for registry in "${all_registries[@]}"; do
  REGISTRIES_CHECKED=$(( REGISTRIES_CHECKED + 1 ))
  if ! $QUIET; then
    echo
    info "Schema: ${registry#"$REPO_ROOT/"}"
  fi
  _validate_schema "$registry"
  _validate_env_fields "$registry"
  _validate_auth_fields "$registry"
  _validate_install_check_command "$registry"
  _validate_registry "$registry"
done

# Cross-registry duplicate check: no env var name should appear in multiple registries.
_check_cross_registry_dupes() {
  local -A var_sources=()
  local entry var source
  for entry in "${ALL_ENV_VARS[@]}"; do
    var="${entry%%:*}"
    source="${entry#*:}"
    if [[ -n "${var_sources[$var]:-}" && "${var_sources[$var]}" != "$source" ]]; then
      _fail "env var '$var' defined in multiple registries: ${var_sources[$var]} and $source"
    fi
    var_sources[$var]="$source"
  done
}
if [[ "${#ALL_ENV_VARS[@]}" -gt 0 ]]; then
  _check_cross_registry_dupes
fi

echo
if [[ "$ERRORS" -gt 0 ]]; then
  err "$ERRORS error(s) found"
  exit 1
fi

success "All registries valid ($REGISTRIES_CHECKED files)"
