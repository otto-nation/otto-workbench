# Work / project-specific packages — opt-in during bootstrap.
# Install: brew bundle --file=brew/Brewfile.work
# Update:  WORK=1 task --global brew:dump

# ---------------------------------------------------------------------------
# AWS & cloud
# ---------------------------------------------------------------------------
brew "awscli"
brew "aws-sso-util"

# ---------------------------------------------------------------------------
# Work tools
# ---------------------------------------------------------------------------
brew "ankitpokhrel/jira-cli/jira-cli"

# ---------------------------------------------------------------------------
# Java
# ---------------------------------------------------------------------------
brew "gradle"
brew "jenv"
brew "maven"

# ---------------------------------------------------------------------------
# Terraform
# ---------------------------------------------------------------------------
brew "terraform-docs"
brew "tfenv"

# ---------------------------------------------------------------------------
# Kubernetes
# ---------------------------------------------------------------------------
brew "k9s"
brew "kubectx"
brew "kubernetes-cli"
