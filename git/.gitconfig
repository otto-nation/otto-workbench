# Shared git configuration — machine-agnostic settings only.
#
# Architecture:
#   ~/.gitconfig          → minimal file: includes THIS file + ~/.gitconfig.local
#   git/.gitconfig        → this file: shared aliases, colors, and behavior (version-controlled)
#   ~/.gitconfig.local    → machine-specific identity, GPG, and credentials (never committed)
#
# To update shared settings: edit this file and commit.
# To update machine-specific settings: edit ~/.gitconfig.local.
# Run install.sh if ~/.gitconfig ever needs to be recreated.
#
# DO NOT add [include] stanzas here — those belong only in ~/.gitconfig.

[alias]
	hard-delete = branch -D
	delete = branch -d
	ch = checkout
	st = status
	unstage = reset HEAD --
	discard = checkout --
	fetch-all = fetch --all
	graph-log = log --graph --decorate --pretty=oneline --abbrev-commit
	fixup = "!func() { git commit --fixup=$1 && git stash && git rebase -i --autosquash $1^1; }; func"
	wip = !git add . && git commit -m 'wip'
	nah = !git reset --hard && git clean -df
	rebase-off-main = !git fetch --all && git stash && git checkout main && git pull && git checkout - && git rebase main
	deploy-branch = !git checkout main && git pull && git checkout -b your-name/deploy && git rebase main && git commit --allow-empty --no-verify -m 'chore: deploy' && git push --no-verify
	deploy-commit = !git commit -m 'chore: deploy' --allow-empty --no-verify && git push --no-verify

[color]
	ui = true

[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22

[color "diff"]
	meta = yellow
	frag = magenta bold
	commit = yellow bold
	old = red bold
	new = green bold
	whitespace = red reverse

[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f

[init]
	defaultBranch = main

[pull]
	rebase = true

[commit]
	gpgSign = true

[tag]
	forceSignAnnotated = true

[push]
	autoSetupRemote = true

[core]
	fsmonitor = true
	untrackedCache = true

