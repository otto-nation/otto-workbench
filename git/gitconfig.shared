# Shared git configuration — machine-agnostic settings only.
#
# Architecture:
#   ~/.gitconfig           → your machine: identity, GPG, overrides (+ includes this file)
#   git/gitconfig.shared   → this file: shared aliases, colors, and behavior (version-controlled)
#
# To update shared settings: edit this file and commit.
# To update machine-specific settings: edit ~/.gitconfig directly or use git config --global.

[alias]
	hard-delete = branch -D
	delete = branch -d
	ch = checkout
	st = status
	unstage = reset HEAD --
	discard = checkout --
	fetch-all = fetch --all
	graph-log = log --graph --decorate --pretty=oneline --abbrev-commit
	fixup = "!func() { git commit --fixup=$1 && git stash && (git rebase -i --autosquash $1^1 || git stash pop); }; func"
	wip = !git add . && git commit -m 'wip'
	nah = !git reset --hard && git clean -df
	rebase-off-main = "!func() { git fetch --all; DIRTY=false; git diff --quiet && git diff --cached --quiet || DIRTY=true; $DIRTY && git stash; git checkout main && git pull && git checkout -; git rebase main; $DIRTY && git stash pop; }; func"
	deploy-branch = !git checkout main && git pull && git checkout -b "$(id -un)/deploy" && git rebase main && git commit --allow-empty -m 'chore: deploy' && git push
	deploy-commit = !git commit -m 'chore: deploy' --allow-empty && git push
	strip-coauthor = "!f() { if [ -z \"$1\" ]; then echo \"Usage: git strip-coauthor <pattern>\"; echo \"Example: git strip-coauthor Claude\"; exit 1; fi; BRANCH=$(git rev-parse --abbrev-ref HEAD); if [ \"$BRANCH\" = main ] || [ \"$BRANCH\" = master ]; then printf \"You are on %s. Rewrite commits anyway? [y/N] \" \"$BRANCH\"; read -r ANS; case \"$ANS\" in [yY]*) ;; *) echo \"Aborted.\"; exit 1;; esac; fi; BASE=$(git merge-base HEAD origin/main 2>/dev/null || git merge-base HEAD origin/master); COUNT=$(git rev-list --count \"$BASE\"..HEAD); if [ \"$COUNT\" = 0 ]; then echo \"No commits to rewrite (up to date with origin).\"; exit 0; fi; echo \"Rewriting $COUNT commit(s)...\"; FILTER_BRANCH_SQUELCH_WARNING=1 git filter-branch -f --msg-filter \"sed /^Co-Authored-By:.*$1/Id\" \"$BASE\"..HEAD; }; f"

[color]
	ui = true

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	light = false
	side-by-side = false
	line-numbers = true

[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f

[init]
	defaultBranch = main

[pull]
	rebase = true

[gpg]
	format = openpgp

[commit]
	gpgSign = true

[tag]
	forceSignAnnotated = true

[push]
	autoSetupRemote = true

[core]
	excludesFile = ~/.config/git/ignore
	fsmonitor = true
	untrackedCache = true
	pager = delta
