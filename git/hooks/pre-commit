#!/usr/bin/env bash
# Pre-commit hook: scans staged changes for secrets before they enter history.
# Installed globally by git/steps.sh → ~/.git-hooks/pre-commit
#
# For global protection (all repos), the workbench install configures
# a global hooks dir at ~/.git-hooks/ — see git/steps.sh.

set -euo pipefail

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "✗ gitleaks not found — run: brew install gitleaks"
  exit 1
fi

_repo_root="$(git rev-parse --show-toplevel)"
_config_flag=""
[[ -f "$_repo_root/.gitleaks.toml" ]] && _config_flag="--config $_repo_root/.gitleaks.toml"

# shellcheck disable=SC2086  # word splitting intentional for optional flag
gitleaks protect --staged --verbose --no-color --no-banner $_config_flag \
  || { echo "✗ gitleaks found potential secrets — review the output above before committing"; exit 1; }

# Delegate to the repo-local hook if present (bypassed when core.hooksPath is set globally).
_local_hook="$_repo_root/.git/hooks/pre-commit"
if [[ -x "$_local_hook" ]]; then
  exec "$_local_hook" "$@"
fi
