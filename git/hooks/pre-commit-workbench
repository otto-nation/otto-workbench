#!/usr/bin/env bash
# Pre-commit hook for otto-workbench: regenerates gitignored AI context files.
# Dispatched from .git/hooks/pre-commit via `task dev:setup`.
# Called via delegation from the global pre-commit hook (~/.git-hooks/pre-commit).

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
WORKBENCH_DIR="$REPO_ROOT"

# shellcheck source=../../lib/ui.sh
. "$WORKBENCH_DIR/lib/ui.sh"

# Regenerate AI context files (gitignored — no staging needed)
"$REPO_ROOT/bin/local/generate-tool-context" --quiet
"$REPO_ROOT/git/bin/local/generate-git-rules" --quiet
