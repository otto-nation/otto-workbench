#!/usr/bin/env bash
# Pre-push hook: repo-local hook for otto-workbench.
# Runs validation, linting, and tests before push.

set -euo pipefail

# Print the failing command on unexpected exits so errors are never silent.
trap 'echo "✗ pre-push hook failed (exit $?) at line $LINENO" >&2' ERR

REPO_ROOT="$(git rev-parse --show-toplevel)"

# shellcheck source=../../lib/ui.sh
. "$REPO_ROOT/lib/ui.sh"

# ── Output helpers ───────────────────────────────────────────────────────────

# _step LABEL — prints "→ LABEL..." without a newline. Follow with _pass or _fail.
_step() { printf "${BLUE}→${NC} %s... " "$*"; }

# _pass [DETAIL] — completes the current step line with ✓ and optional detail.
_pass() {
  if [[ -n "${1:-}" ]]; then
    printf "${GREEN}✓${NC} ${DIM}(%s)${NC}\n" "$*"
  else
    printf "${GREEN}✓${NC}\n"
  fi
}

# _fail MSG — completes the current step line with ✗, prints captured output, and exits.
_fail() {
  printf "${RED}✗${NC}\n" >&2
  echo "$1" >&2
  exit 1
}

# _run_step LABEL COMMAND [ARGS...] — runs a command silently; prints compact pass/fail.
# On success, extracts a parenthesized detail from stdout (e.g. "(16 files)") for display.
_run_step() {
  local label="$1"; shift
  _step "$label"
  local output
  if output=$("$@" 2>&1); then
    # Extract detail from success output for compact display.
    # Matches "(N files)" or "N checks passed" patterns.
    local detail=""
    local _paren_re='\(([^)]+)\)'
    local _checks_re='([0-9]+ checks)'
    if [[ "$output" =~ $_paren_re ]]; then
      detail="${BASH_REMATCH[1]}"
    elif [[ "$output" =~ $_checks_re ]]; then
      detail="${BASH_REMATCH[1]}"
    fi
    _pass "$detail"
  else
    _fail "$output"
  fi
}

# ── Secret scan ──────────────────────────────────────────────────────────────

if ! command -v gitleaks >/dev/null 2>&1; then
  err "gitleaks not found — run: brew install gitleaks"
  exit 1
fi

_step "Scanning for secrets"
_config_flag=""
[[ -f "$REPO_ROOT/.gitleaks.toml" ]] && _config_flag="--config $REPO_ROOT/.gitleaks.toml"
# shellcheck disable=SC2086  # word splitting intentional for optional flag
if _gitleaks_output=$(gitleaks protect --staged $_config_flag 2>&1); then
  _pass
else
  _fail "$_gitleaks_output"
fi

# ── Validation ───────────────────────────────────────────────────────────────

if ! command -v yq >/dev/null 2>&1; then
  err "yq not found — run: brew install yq"
  exit 1
fi

_run_step "Validating registries"   "$REPO_ROOT/bin/validate-registries" --quiet
_run_step "Validating components"   "$REPO_ROOT/bin/validate-components" --quiet
_run_step "Validating migrations"   "$REPO_ROOT/bin/validate-migrations" --quiet

# ── Generation ───────────────────────────────────────────────────────────────

_step "Regenerating tool context"
"$REPO_ROOT/ai/bin/generate-tool-context" --quiet
if ! git -C "$REPO_ROOT" diff --quiet "$TOOLS_GENERATED_RELPATH"; then
  printf "${RED}✗${NC}\n" >&2
  err "tools.generated.md was updated — commit it before pushing:"
  echo "  git add $TOOLS_GENERATED_RELPATH"
  echo "  git commit -m \"chore: regenerate tool context\""
  exit 1
fi
_pass

_step "Regenerating git rules"
"$REPO_ROOT/git/bin/generate-git-rules" --quiet
if ! git -C "$REPO_ROOT" diff --quiet "$GIT_GENERATED_RELPATH"; then
  printf "${RED}✗${NC}\n" >&2
  err "git.generated.md was updated — commit it before pushing:"
  echo "  git add $GIT_GENERATED_RELPATH"
  echo "  git commit -m \"chore: regenerate git rules\""
  exit 1
fi
_pass

# ── ShellCheck ───────────────────────────────────────────────────────────────

if ! command -v shellcheck >/dev/null 2>&1; then
  err "shellcheck not found — run: brew install shellcheck"
  exit 1
fi

_step "Running ShellCheck"
if _sc_output=$(grep -rlE '^#!.*(/(ba)?sh|/env (ba)?sh)' "$REPO_ROOT" --exclude-dir='.git' \
  | sort \
  | xargs shellcheck --severity=warning 2>&1); then
  _pass
else
  _fail "$_sc_output"
fi

# ── YAML lint ────────────────────────────────────────────────────────────────

if command -v yamllint >/dev/null 2>&1; then
  _step "Linting YAML"
  if _yl_output=$(yamllint "$REPO_ROOT" 2>&1); then
    _yl_count=$(find "$REPO_ROOT" \( -name '*.yml' -o -name '*.yaml' \) -not -path '*/.git/*' | wc -l | tr -d ' ')
    _pass "${_yl_count} files"
  else
    _fail "$_yl_output"
  fi
fi

# ── ZSH syntax ───────────────────────────────────────────────────────────────

_step "Checking ZSH syntax"
_zsh_files=()
while IFS= read -r -d '' f; do
  _zsh_files+=("$f")
done < <(find "$REPO_ROOT" -name '*.zsh' -not -path '*/.git/*' -print0)
if [[ ${#_zsh_files[@]} -gt 0 ]]; then
  if _zsh_output=$(zsh -n "${_zsh_files[@]}" 2>&1); then
    _pass "${#_zsh_files[@]} files"
  else
    _fail "$_zsh_output"
  fi
else
  _pass "0 files"
fi

# ── JSON validation ──────────────────────────────────────────────────────────

_step "Validating JSON"
_json_errors=""
_json_count=0
while IFS= read -r -d '' f; do
  _json_count=$((_json_count + 1))
  if ! jq -e '.' "$f" > /dev/null 2>&1; then
    _json_errors+="  Invalid JSON: $f"$'\n'
  fi
done < <(find "$REPO_ROOT" -name '*.json' -not -path '*/.git/*' -not -path '*/.claude/*' -print0)
if [[ -n "$_json_errors" ]]; then
  _fail "$_json_errors"
else
  _pass "${_json_count} files"
fi

# ── Bats tests ───────────────────────────────────────────────────────────────

if ! command -v bats >/dev/null 2>&1; then
  err "bats not found — run: brew install bats-core"
  exit 1
fi

_step "Running tests"
_bats_start=$SECONDS
_bats_jobs_flag=()
command -v parallel >/dev/null 2>&1 && _bats_jobs_flag=(--jobs 8 --no-parallelize-within-files)
_bats_output=$(bats "$REPO_ROOT/tests/" --recursive --timing "${_bats_jobs_flag[@]}" 2>&1) || {
  printf "${RED}✗${NC}\n" >&2
  echo "$_bats_output" | grep -E '^(not ok |# )'
  err "Tests failed"
  exit 1
}
_bats_elapsed=$(( SECONDS - _bats_start ))

# Extract test count from TAP plan line (1..N)
_test_count=$(echo "$_bats_output" | grep -oE '^1\.\.[0-9]+' | head -1)
_test_count="${_test_count#1..}"
_pass "${_test_count:-?} tests, ${_bats_elapsed}s"

# Warn about slow tests (>2s) — surfaces performance regressions
_slow_threshold_ms=2000
_slow_tests=$(echo "$_bats_output" \
  | grep -E '^ok .+ in [0-9]+ms$' \
  | while IFS= read -r line; do
      _ms="${line##* in }"
      _ms="${_ms%ms}"
      if [[ "$_ms" -gt "$_slow_threshold_ms" ]]; then
        # Strip "ok N " prefix (N can be multi-digit) and " in Nms" suffix
        _name="${line% in *}"
        _name="${_name#ok }"
        _name="${_name#* }"
        printf '  %s (%ss)\n' "$_name" "$(( _ms / 1000 ))"
      fi
    done)
if [[ -n "$_slow_tests" ]]; then
  warn "Slow tests (>${_slow_threshold_ms}ms):"
  echo "$_slow_tests"
fi
